{%- comment -%}css-variables.liquid — KB-v4 · self-hosted fonts via Shopify CDN{%- endcomment -%}
{%- style -%}
  /* ── Lilita One (headings) — self-hosted ─────────────────── */
  @font-face {
    font-family: 'Lilita One';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url({{ 'lilita-one-v17-latin.woff2' | asset_url }}) format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Lilita One';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url({{ 'lilita-one-v17-latin-ext.woff2' | asset_url }}) format('woff2');
    unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
  }
  /* ── Karla (body) — self-hosted variabele font 200–800 ───── */
  @font-face {
    font-family: 'Karla';
    font-style: normal;
    font-weight: 200 800;
    font-display: swap;
    src: url({{ 'karla-v33-latin.woff2' | asset_url }}) format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Karla';
    font-style: normal;
    font-weight: 200 800;
    font-display: swap;
    src: url({{ 'karla-v33-latin-ext.woff2' | asset_url }}) format('woff2');
    unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
  }
  :root {
    --page-width:   {{ settings.max_page_width }};
    --page-margin:  {{ settings.min_page_margin }}px;
    --font-heading: 'Lilita One', cursive;
    --font-body:    'Karla', sans-serif;
    /* Skeleton critical.css verwacht deze var voor de body-font */
    --font-primary--family: var(--font-body);
    --color-pink:   {{ settings.color_brand_pink }};
    --color-green:  {{ settings.color_brand_green }};
    --color-orange: {{ settings.color_brand_orange }};
    --color-yellow: {{ settings.color_brand_yellow }};
    --color-ink:    {{ settings.color_ink }};
    --color-body:   {{ settings.color_body }};
    --color-muted:  {{ settings.color_muted }};
    --color-cream:  {{ settings.color_cream }};
    --color-line:   {{ settings.color_line }};
    --radius-sm:    8px;
    --radius-md:    16px;
    --radius-lg:    24px;
    --radius-pill:  999px;
    /* ── Design-systeem: consistent ritme, type-schaal, schaduwen ── */
    --section-pad:    clamp(52px, 8vw, 96px);   /* verticale sectie-ruimte */
    --section-pad-sm: clamp(40px, 6vw, 64px);
    --fs-eyebrow:     .82rem;                    /* type-schaal */
    --fs-h2:          clamp(2rem, 4.8vw, 3.2rem);
    --fs-h3:          1.2rem;
    --fs-lead:        1.08rem;
    --fs-body:        1.02rem;
    --shadow-card:       0 14px 36px rgba(61, 34, 9, .06);  /* kaart-diepte */
    --shadow-card-hover: 0 22px 50px rgba(61, 34, 9, .10);
    --shadow-pop:        0 12px 30px rgba(61, 34, 9, .14);
    /* Skeleton critical.css verwacht deze vars op de body/inputs/dialogs */
    --color-background:           #fff;
    --color-foreground:           {{ settings.color_body }};
    --style-border-radius-inputs: var(--radius-sm);
  }
{%- endstyle -%}
