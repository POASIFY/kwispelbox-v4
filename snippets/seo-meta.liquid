{%- comment -%}
  snippets/seo-meta.liquid — KB-v4 per-pagina <title>, meta description en robots.
  Bron = de SEO-metavelden (page_title/page_description, bewerkbaar in de admin),
  thema voegt " | Kwispelbox.com" toe. Bepaalt ook welke pagina's op noindex staan.
{%- endcomment -%}

{%- liquid
  assign t = ''
  assign d = ''
  assign noindex = false
  assign sfx = template.suffix

  case request.page_type
    when 'index'
      assign t = 'De leukste verrassingsbox voor je hond'
      assign d = 'Elke maand een verrassingsbox vol stevige speeltjes, gezonde snacks en knuffels voor je hond. Met zorg samengesteld en gratis verzonden vanaf €75.'

    when 'page'
      # dunne/dubbele pagina's niet indexeren (canonieke varianten staan elders)
      if sfx == 'verzendbeleid' or sfx == 'retourbeleid' or sfx == 'verzending-retour'
        assign noindex = true
      endif
      if page.handle == 'vergelijk-de-boxen' or page.handle == 'data-sharing-opt-out'
        assign noindex = true
      endif

    when 'collection'
      # utility-collecties niet indexeren
      if collection.handle == 'frontpage' or collection.handle == 'maak-er-een-echt-cadeautje-van'
        assign noindex = true
      endif
      # cannibalisatie: de curated /pages/alle-boxen + /pages/special-editions zijn de indexeerbare versies,
      # dus de rauwe collecties noindexen (follow blijft voor link-equity)
      if collection.handle == 'boxen' or collection.handle == 'special-editions'
        assign noindex = true
      endif

    when 'search'
      assign noindex = true
      assign t = 'Zoekresultaten'

    when '404'
      assign noindex = true
      assign t = 'Pagina niet gevonden'
  endcase

  if t == blank
    assign t = page_title | default: shop.name
  endif
  if d == blank
    assign d = page_description | default: shop.description | default: shop.name
  endif
-%}

<title>{{ t | strip_html }} | Kwispelbox.com</title>
<meta name="description" content="{{ d | strip_html | escape }}">
{%- if noindex -%}
<meta name="robots" content="noindex,follow">
{%- endif -%}
