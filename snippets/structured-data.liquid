{%- comment -%}
  snippets/structured-data.liquid — KB-v4 JSON-LD structured data.
  Organization + WebSite(SearchAction) sitewide; BreadcrumbList + Product per pagina.
  Gevoed door de globale "SEO & Bedrijf" theme-instellingen.
{%- endcomment -%}

{%- liquid
  assign org_name = settings.seo_legal_name | default: shop.name
  assign base = shop.url
  assign org_desc = settings.seo_description | default: shop.description | default: shop.name

  assign socials = ''
  if settings.social_instagram != blank
    assign socials = socials | append: settings.social_instagram | append: '|'
  endif
  if settings.social_facebook != blank
    assign socials = socials | append: settings.social_facebook | append: '|'
  endif
  if settings.social_tiktok != blank
    assign socials = socials | append: settings.social_tiktok | append: '|'
  endif
  if settings.social_pinterest != blank
    assign socials = socials | append: settings.social_pinterest | append: '|'
  endif
  if settings.social_youtube != blank
    assign socials = socials | append: settings.social_youtube | append: '|'
  endif
  assign social_arr = socials | split: '|'
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ org_name | json }},
  "url": {{ base | json }},
  "description": {{ org_desc | strip_html | truncate: 280 | json }}
  {%- if settings.seo_logo != blank -%},
  "logo": {{ settings.seo_logo | image_url: width: 400 | prepend: "https:" | json }}
  {%- endif -%}
  {%- if social_arr.size > 0 -%},
  "sameAs": [{% for s in social_arr %}{{ s | json }}{% unless forloop.last %},{% endunless %}{% endfor %}]
  {%- endif -%}
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ base | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ base }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{%- comment -%} ── BreadcrumbList ── {%- endcomment -%}
{%- liquid
  assign crumb_name = ''
  assign crumb_url = ''
  case request.page_type
    when 'product'
      assign crumb_name = product.title
      assign crumb_url = product.url
    when 'collection'
      assign crumb_name = collection.title
      assign crumb_url = collection.url
    when 'page'
      assign crumb_name = page.title
      assign crumb_url = page.url
    when 'article'
      assign crumb_name = article.title
      assign crumb_url = article.url
    when 'blog'
      assign crumb_name = blog.title
      assign crumb_url = blog.url
  endcase
-%}
{%- if crumb_name != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ base | json }} },
    { "@type": "ListItem", "position": 2, "name": {{ crumb_name | json }}, "item": {{ crumb_url | prepend: base | json }} }
  ]
}
</script>
{%- endif -%}

{%- comment -%} ── Product ── {%- endcomment -%}
{%- if request.page_type == 'product' -%}
  {%- assign v = product.selected_or_first_available_variant -%}
  {%- if product.available -%}{%- assign avail = 'https://schema.org/InStock' -%}{%- else -%}{%- assign avail = 'https://schema.org/OutOfStock' -%}{%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 300 | json }},
  "url": {{ product.url | prepend: base | json }},
  {%- if product.featured_image -%}"image": [{{ product.featured_image | image_url: width: 1200 | prepend: "https:" | json }}],{%- endif -%}
  "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
  {%- if v.sku != blank -%}"sku": {{ v.sku | json }},{%- endif -%}
  "offers": {
    "@type": "Offer",
    "url": {{ product.url | prepend: base | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ v.price | divided_by: 100.0 }},
    "availability": {{ avail | json }},
    "itemCondition": "https://schema.org/NewCondition"
  }
}
{%- comment -%} aggregateRating/review wordt geleverd door Judge.me (eigen structured data) — niet hier, om dubbele rating te voorkomen. {%- endcomment -%}
</script>
{%- endif -%}
