<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {{ 'karla-v33-latin.woff2' | asset_url | preload_tag: as: 'font' }}
    {{ 'lilita-one-v17-latin.woff2' | asset_url | preload_tag: as: 'font' }}
    {%- render 'css-variables' -%}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {%- render 'meta-tags' -%}
    {{ content_for_header }}
  </head>
  <body>
    <a class="skip-to-content" href="#main-content">Naar inhoud</a>
    {% sections 'header-group' %}
    <main id="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {% sections 'footer-group' %}
    {%- render 'mobile-tabbar' -%}
  </body>
</html>
