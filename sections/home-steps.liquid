{%- comment -%}
  sections/home-steps.liquid — Kwispelbox KB-v4
  "Hoe werkt het" — 3 stappen met genummerde badges + verbindingslijn.
  Witte achtergrond als ritmebreuk t.o.v. de crème buren.
{%- endcomment -%}

{%- assign steps = section.blocks | where: 'type', 'step' -%}

<div class="hiw full-width">
  <div class="hiw__inner">

    <div class="hiw__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hiw__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hiw__title">{{ section.settings.heading }}
          {%- if section.settings.heading_highlight != blank %} <span class="hiw__title-em">{{ section.settings.heading_highlight }}</span>{%- endif -%}
        </h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="hiw__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- if steps.size > 0 -%}
      <ol class="hiw__steps" style="--step-count: {{ steps.size }};">
        {%- for block in steps -%}
          {%- assign accent = block.settings.color | default: 'green' -%}
          <li class="hiw__step hiw__step--{{ accent }}" {{ block.shopify_attributes }}>
            <div class="hiw__badge">
              <span class="hiw__num">{{ forloop.index }}</span>
              <span class="hiw__icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
            </div>
            <h3 class="hiw__step-title">{{ block.settings.title }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="hiw__step-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}

    {%- if section.settings.note != blank -%}
      <p class="hiw__note">
        <span class="hiw__note-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>
        {{ section.settings.note }}
      </p>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.hiw { background: transparent; padding: var(--section-pad) 0; }
.hiw__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }
.hiw__head { text-align: center; margin-bottom: 44px; }
.hiw__eyebrow { font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: var(--color-green); margin: 0 0 8px; }
.hiw__title { font-family: var(--font-heading); font-size: var(--fs-h2); color: var(--color-ink); margin: 0; }
.hiw__title-em { color: var(--color-pink); }
.hiw__intro { font-family: var(--font-body); font-size: var(--fs-lead); color: var(--color-body); line-height: 1.6; margin: 12px auto 0; max-width: 52ch; }

.hiw__steps {
  list-style: none; margin: 0; padding: 0;
  display: grid; grid-template-columns: repeat(var(--step-count, 3), 1fr); gap: 28px;
  position: relative;
}
/* Verbindingslijn achter de badges (desktop) */
.hiw__steps::before {
  content: ""; position: absolute; top: 38px; left: 12%; right: 12%; height: 0;
  border-top: 2px dashed var(--color-line); z-index: 0;
}
.hiw__step { position: relative; z-index: 1; text-align: center; --c: var(--color-green); --c-soft: #e8f5e2; }
.hiw__step--pink { --c: var(--color-pink); --c-soft: #ffe0ee; }
.hiw__step--orange { --c: var(--color-orange); --c-soft: #fff0e4; }
.hiw__step--green { --c: var(--color-green); --c-soft: #e8f5e2; }

.hiw__badge { position: relative; width: 76px; height: 76px; margin: 0 auto 18px; }
.hiw__num {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: var(--c-soft); color: var(--c); border-radius: 50%;
  font-family: var(--font-heading); font-size: 1.9rem; border: 3px solid #fff; box-shadow: var(--shadow-card);
}
.hiw__icon {
  position: absolute; bottom: -6px; right: -6px; width: 34px; height: 34px;
  display: flex; align-items: center; justify-content: center;
  background: var(--c); color: #fff; border-radius: 50%; border: 3px solid #fff;
}
.hiw__icon svg { width: 16px; height: 16px; }
.hiw__step-title { font-family: var(--font-heading); font-size: var(--fs-h3); color: var(--color-ink); margin: 0 0 8px; }
.hiw__step-text { font-family: var(--font-body); font-size: var(--fs-body); line-height: 1.6; color: var(--color-body); margin: 0 auto; max-width: 32ch; }

.hiw__note {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  margin: 44px auto 0; max-width: 560px; padding: 16px 22px;
  background: #fff; border: 1.5px solid var(--color-line); border-radius: var(--radius-pill); box-shadow: var(--shadow-card);
  font-family: var(--font-body); font-size: .98rem; font-weight: 600; color: var(--color-body); text-align: center;
}
.hiw__note-icon { color: var(--color-pink); flex-shrink: 0; display: inline-flex; }
.hiw__note-icon svg { width: 18px; height: 18px; fill: currentColor; }

@media (max-width: 749px) {
  .hiw__head { margin-bottom: 32px; }
  .hiw__steps { grid-template-columns: 1fr; gap: 14px; }
  .hiw__steps::before { display: none; }
  /* Compacte horizontale stap-kaart op mobiel */
  .hiw__step {
    display: grid;
    grid-template-columns: 76px 1fr;
    grid-template-areas: "badge title" "badge text";
    column-gap: 16px; row-gap: 4px; align-items: center;
    text-align: left;
    background: #fff; border-radius: var(--radius-md); padding: 16px 18px; box-shadow: var(--shadow-card);
  }
  .hiw__badge { grid-area: badge; margin: 0; align-self: center; }
  .hiw__step-title { grid-area: title; align-self: end; margin: 0; }
  .hiw__step-text { grid-area: text; align-self: start; margin: 0; max-width: none; }
  .hiw__note { margin-top: 28px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Hoe werkt het",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Zo simpel werkt het" },
    { "type": "text", "id": "heading", "label": "Titel", "default": "In 3 stappen naar een" },
    { "type": "text", "id": "heading_highlight", "label": "Titel accent (roze)", "default": "blije hond" },
    { "type": "textarea", "id": "intro", "label": "Introtekst", "default": "Geen gedoe — jij kiest, wij verrassen, je hond geniet." },
    { "type": "text", "id": "note", "label": "Afsluitende notitie (optioneel)", "default": "Wij zorgen voor de verrassing, jij voor de blije kwispel." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Stap",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "Kies jouw box" },
        { "type": "textarea", "id": "text", "label": "Tekst", "default": "Mini, Happy of Mega — jij kiest wat past bij jouw hond." },
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "gift",
          "options": [
            { "value": "gift", "label": "Cadeau" }, { "value": "paw", "label": "Poot" },
            { "value": "heart", "label": "Hart" }, { "value": "package", "label": "Doos" },
            { "value": "sparkles", "label": "Sterretjes" }, { "value": "bone", "label": "Bot" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Kleur", "default": "green",
          "options": [ { "value": "green", "label": "Groen" }, { "value": "pink", "label": "Roze" }, { "value": "orange", "label": "Oranje" } ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hoe werkt het",
      "blocks": [
        { "type": "step", "settings": { "title": "Kies jouw box", "text": "Mini, Happy of Mega — jij kiest wat past bij jouw hond.", "icon": "gift", "color": "green" } },
        { "type": "step", "settings": { "title": "Wij stellen 'm samen", "text": "Met de leukste speeltjes, snacks en knuffels, met liefde uitgezocht.", "icon": "sparkles", "color": "pink" } },
        { "type": "step", "settings": { "title": "Uitpakken & genieten", "text": "De verrassing valt op de mat. Tijd voor een feestje!", "icon": "heart", "color": "orange" } }
      ]
    }
  ]
}
{% endschema %}
