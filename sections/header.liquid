.dd-se__corner--br{bottom:80px;left:18px;width:26px;height:26px;color:var(--color-pink);opacity:.12;transform:rotate(14deg);}

.dd-se__body{display:grid;grid-template-columns:1fr 384px;gap:30px;align-items:stretch;}
.dd-se__left{display:flex;flex-direction:column;min-width:0;}
