{%- comment -%}
  sections/header.liquid — Kwispelbox KB-v3
  5 rijke dropdown layouts per menu-item:
  - standard:    2-koloms links + banner (Special Editions)
  - featured:    featured products + links (Verrassingsboxen)
  - categories:  sub-categorie kolommen met foto (Shop)
  - club:        Kwispelclub layout
  - about:       Over ons brand layout
{%- endcomment -%}

{%- assign dd_blocks       = section.blocks | where: 'type', 'dropdown_config' -%}
{%- assign col_blocks      = section.blocks | where: 'type', 'dropdown_col' -%}
{%- assign prod_blocks     = section.blocks | where: 'type', 'dropdown_product' -%}
{%- assign se_blocks       = section.blocks | where: 'type', 'se_item' -%}
{%- assign se_usp_blocks   = section.blocks | where: 'type', 'se_usp' -%}
{%- assign shop_blocks     = section.blocks | where: 'type', 'shop_cat' -%}
{%- assign club_item_blocks = section.blocks | where: 'type', 'club_item' -%}
{%- assign club_reward_blocks = section.blocks | where: 'type', 'club_reward' -%}
{%- assign club_benefit_blocks = section.blocks | where: 'type', 'club_benefit' -%}

<div class="site-header__wrapper full-width">

  <!-- ══ TRUSTBAR (Lucide iconen + voordelen) ═══════════ -->
  {%- assign trust_blocks = section.blocks | where: 'type', 'trust_item' -%}
  {%- if trust_blocks.size > 0 -%}
    <div class="site-header__trust" role="complementary" aria-label="Voordelen van Kwispelbox">
      <div class="site-header__trust-inner">
        <ul class="site-header__trust-list" role="list">
          {%- for block in trust_blocks -%}
            <li class="site-header__trust-item" {{ block.shopify_attributes }}>
              <span class="site-header__trust-icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'icon-truck.svg' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 18.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
                  {%- when 'icon-paw.svg' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg>
                  {%- when 'icon-gift.svg' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
                  {%- when 'icon-star.svg' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>
                  {%- when 'icon-heart.svg' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                  {%- when 'icon-shield.svg' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
                  {%- when 'icon-refresh.svg' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                  {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
                {%- endcase -%}
              </span>
              <span class="site-header__trust-text">{{ block.settings.title }}{%- if block.settings.subtitle != blank -%} {{ block.settings.subtitle }}{%- endif -%}</span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endif -%}

  <!-- ══ RIJ 1: LOGO + ZOEK + ACTIES ══════════════════ -->
  <div class="site-header__top">
    <div class="site-header__top-inner">

      <!-- Logo -->
      <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            srcset="{{ section.settings.logo | image_url: width: 200 }} 200w,
                    {{ section.settings.logo | image_url: width: 400 }} 400w"
            sizes="{{ section.settings.logo_width }}px"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
            loading="eager" fetchpriority="high" class="site-header__logo-img">
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <!-- Zoekbalk (desktop) -->
      <form action="{{ routes.search_url }}" method="get" role="search" class="site-header__search-bar" data-search-form>
        <input type="hidden" name="type" value="product">
        <label for="header-search-main" class="site-header__sr-only">Zoeken</label>
        <div class="site-header__search-bar-field">
          <span class="site-header__search-bar-icon" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
          <input type="search" id="header-search-main" name="q"
            class="site-header__search-bar-input"
            placeholder="{{ section.settings.search_placeholder }}"
            autocomplete="off" autocorrect="off" spellcheck="false"
            data-search-input aria-autocomplete="list" aria-controls="search-results">
          <button type="button" class="site-header__search-clear" aria-label="Wissen" hidden data-search-clear>
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
          <button type="submit" class="site-header__search-bar-btn" aria-label="Zoeken">
            {{- 'icon-search.svg' | inline_asset_content -}}
          </button>
        </div>
        <div class="site-header__search-results" id="search-results" role="listbox" hidden data-search-results></div>
      </form>

      <!-- Acties rechts (Lucide icon buttons) -->
      <div class="site-header__actions">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="site-header__icon-btn" aria-label="Mijn account">
            <span class="site-header__sr-only">Mijn account</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="site-header__icon-btn site-header__icon-btn--cart"
           aria-label="Winkelwagen, {{ cart.item_count }} items">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="site-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
        <!-- Hamburger (mobiel) -->
        <button class="site-header__burger"
                aria-expanded="false"
                aria-controls="header-drawer"
                aria-label="Menu openen">
          {{- 'icon-menu.svg' | inline_asset_content -}}
        </button>
      </div>

    </div>
  </div>

  <!-- ══ RIJ 2: NAVIGATIE ═══════════════════════════════ -->
  {%- if section.settings.menu != blank -%}
    <header class="site-header" role="banner">
      <div class="site-header__nav-row">

        <div class="site-header__nav-deco" aria-hidden="true">
          <span class="site-header__nav-deco-1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
          <span class="site-header__nav-deco-2"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
          <span class="site-header__nav-deco-3"><svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg></span>
          <span class="site-header__nav-deco-4"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M2 12c3-4 5 4 8 0s5 4 8 0"/></svg></span>
        </div>

        <nav class="site-header__nav" aria-label="Hoofdnavigatie">
          <ul class="site-header__chips" role="list">
            {%- for link in section.settings.menu.links -%}
              {%- assign lx = forloop.index -%}
              {%- assign dd = nil -%}
              {%- for b in dd_blocks -%}
                {%- if b.settings.menu_item_index == lx -%}{%- assign dd = b -%}{%- endif -%}
              {%- endfor -%}
              {%- assign has_dd = false -%}
              {%- if dd != nil or link.links.size > 0 -%}{%- assign has_dd = true -%}{%- endif -%}

              <li class="site-header__chip-item{% if has_dd %} site-header__chip-item--has-dd{% endif %}" data-nav-item>

                <a href="{{ link.url }}"
                   class="site-header__chip{% if dd %} site-header__chip--{{ dd.settings.accent_color }}{% endif %}"
                   {% if link.active %}aria-current="page"{% endif %}
                   {% if has_dd %}aria-haspopup="true" aria-expanded="false" data-nav-trigger{% endif %}>
                  {%- if lx == 1 -%}<span class="site-header__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg></span>
                  {%- elsif lx == 2 -%}<span class="site-header__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg></span>
                  {%- elsif lx == 3 -%}<span class="site-header__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 10c.7-.7 1.69 0 2.5 0a2.5 2.5 0 1 0 0-5 .5.5 0 0 1-.5-.5 2.5 2.5 0 1 0-5 0c0 .81.7 1.8 0 2.5l-7 7c-.7.7-1.69 0-2.5 0a2.5 2.5 0 0 0 0 5c.28 0 .5.22.5.5a2.5 2.5 0 1 0 5 0c0-.81-.7-1.8 0-2.5Z"/></svg></span>
                  {%- elsif lx == 4 -%}<span class="site-header__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
                  {%- elsif lx == 5 -%}<span class="site-header__chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                  {%- endif -%}
                  {{ link.title }}
                  {%- if has_dd -%}
                    <span class="site-header__chip-chevron" aria-hidden="true">
                      {{- 'icon-chevron-down.svg' | inline_asset_content -}}
                    </span>
                  {%- endif -%}
                </a>

                {%- if has_dd -%}
                  <div class="site-header__dropdown" data-nav-dropdown>
                    <div class="site-header__dropdown-card">
                      {%- assign layout = dd.settings.layout_type | default: 'standard' -%}

                      {%- comment -%} ══ LAYOUT: FEATURED / MEGA (Verrassingsboxen) ══ {%- endcomment -%}
                      {%- if layout == 'featured' -%}
                        <div class="dd-verr">
                          <span class="dd-se__pointer" aria-hidden="true"></span>
                          <span class="dd-se__corner dd-se__corner--tl" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
                          <span class="dd-se__corner dd-se__corner--br" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>

                          <div class="dd-verr__head">
                            <span class="dd-verr__head-icon dd-verr__head-icon--{{ dd.settings.accent_color }}" aria-hidden="true">{%- render 'lucide', icon: 'gift' -%}</span>
                            <div>
                              <a href="{{ link.url }}" class="dd-verr__title dd-verr__title--{{ dd.settings.accent_color }}">{{ link.title }}</a>
                              {%- if dd.settings.col1_desc != blank -%}<p class="dd-verr__subtitle">{{ dd.settings.col1_desc }}</p>{%- endif -%}
                            </div>
                          </div>

                          <div class="dd-verr__body">
                            <div class="dd-verr__boxes">
                              {%- assign box_count = 0 -%}
                              {%- for pb in prod_blocks -%}{%- if pb.settings.menu_item_index == lx and pb.settings.product != blank -%}{%- assign box_count = box_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
                              {%- for pb in prod_blocks -%}
                                {%- if pb.settings.menu_item_index == lx -%}
                                  {%- assign p = pb.settings.product -%}
                                  {%- if p != blank -%}
                                    <a href="{{ p.url }}" class="dd-verr__box" {{ pb.shopify_attributes }}>
                                      {%- if p.featured_image -%}
                                        <img src="{{ p.featured_image | image_url: width: 160 }}" alt="{{ p.featured_image.alt | default: p.title | escape }}" width="72" height="72" loading="lazy" class="dd-verr__box-img">
                                      {%- else -%}
                                        <span class="dd-verr__box-img dd-verr__box-img--ph">{%- render 'lucide', icon: 'gift' -%}</span>
                                      {%- endif -%}
                                      <span class="dd-verr__box-info">
                                        <span class="dd-verr__box-name">{{ p.title }}{%- if pb.settings.badge != blank -%}<span class="dd-verr__box-badge">{{ pb.settings.badge }}</span>{%- endif -%}</span>
                                        {%- if pb.settings.description != blank -%}<span class="dd-verr__box-desc">{{ pb.settings.description }}</span>{%- endif -%}
                                      </span>
                                      <span class="dd-verr__box-price">{{ p.price | money }}</span>
                                    </a>
                                  {%- endif -%}
                                {%- endif -%}
                              {%- endfor -%}
                              {%- if box_count == 0 -%}
                                <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-verr__empty">Bekijk alle boxen<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
                              {%- endif -%}
                              {%- if dd.settings.view_all_label != blank -%}
                                <a href="{{ dd.settings.view_all_url | default: link.url }}" class="dd-verr__viewall">{{ dd.settings.view_all_label }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
                              {%- endif -%}
                            </div>

                            {%- if dd.settings.link_list != blank and dd.settings.link_list.links.size > 0 -%}
                              <div class="dd-verr__links">
                                {%- if dd.settings.links_heading != blank -%}<span class="dd-verr__links-head">{{ dd.settings.links_heading }}</span>{%- endif -%}
                                <ul role="list">
                                  {%- for child in dd.settings.link_list.links -%}
                                    <li>
                                      <a href="{{ child.url }}" class="dd-verr__link">
                                        <span class="dd-verr__link-icon dd-verr__link-icon--{{ dd.settings.accent_color }}" aria-hidden="true">{%- render 'lucide', icon: 'paw' -%}</span>
                                        <span>{{ child.title }}</span>
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                                      </a>
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              </div>
                            {%- endif -%}

                            {%- if dd.settings.banner_title != blank or dd.settings.banner_image != blank -%}
                              <div class="dd-se__promo dd-verr__promo">
                                <div class="dd-se__promo-media">
                                  {%- if dd.settings.banner_image != blank -%}
                                    <img src="{{ dd.settings.banner_image | image_url: width: 760 }}" srcset="{{ dd.settings.banner_image | image_url: width: 500 }} 500w, {{ dd.settings.banner_image | image_url: width: 760 }} 760w" sizes="380px" alt="{{ dd.settings.banner_image.alt | default: dd.settings.banner_title | escape }}" width="380" height="240" loading="lazy" class="dd-se__promo-img">
                                  {%- else -%}
                                    <div class="dd-se__promo-img dd-se__promo-img--ph">{%- render 'lucide', icon: 'gift' -%}</div>
                                  {%- endif -%}
                                  {%- if dd.settings.banner_badge != blank -%}<span class="dd-se__promo-badge">{{ dd.settings.banner_badge }}</span>{%- endif -%}
                                  <span class="dd-se__promo-deco dd-se__promo-deco--heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                                </div>
                                <div class="dd-se__promo-body">
                                  <strong class="dd-se__promo-title">{{ dd.settings.banner_title }}</strong>
                                  {%- if dd.settings.banner_text != blank -%}<p class="dd-se__promo-text">{{ dd.settings.banner_text }}</p>{%- endif -%}
                                  {%- if dd.settings.banner_cta_label != blank -%}
                                    <div class="dd-se__promo-cta-row">
                                      <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-se__promo-cta">{{ dd.settings.banner_cta_label }}{{- 'icon-paw.svg' | inline_asset_content -}}</a>
                                    </div>
                                  {%- endif -%}
                                </div>
                              </div>
                            {%- endif -%}
                          </div>
                        </div>

                      {%- comment -%} ══ LAYOUT: CATEGORIES (Shop) ══ {%- endcomment -%}
                      {%- elsif layout == 'categories' -%}
                        <div class="dd-categories">
                          {%- for cb in col_blocks -%}
