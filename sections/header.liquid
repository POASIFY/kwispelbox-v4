.dd-se__edition:hover .dd-se__edition-arrow{opacity:1;transform:translateX(0);}

.dd-se__viewall{display:inline-flex;align-items:center;gap:7px;margin-top:14px;padding:2px 4px;font-family:var(--font-body);font-size:.9rem;font-weight:800;color:var(--color-pink);text-decoration:none;transition:gap 160ms;width:fit-content;}
