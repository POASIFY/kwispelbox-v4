.dd-se__cols{display:grid;grid-template-columns:1fr 1fr;gap:6px 18px;flex:1;}
.dd-se__col{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px;}
.dd-se__edition{--ec:var(--color-green);--ec-soft:#e8f5e2;display:grid;grid-template-columns:40px 1fr 14px;align-items:center;gap:12px;padding:9px 12px;border-radius:14px;text-decoration:none;transition:background 160ms;}
.dd-se__edition--pink{--ec:var(--color-pink);--ec-soft:#ffe0ee;}
.dd-se__edition--orange{--ec:var(--color-orange);--ec-soft:#fff0e4;}
.dd-se__edition--yellow{--ec:#d99100;--ec-soft:#fffae0;}
.dd-se__edition--green{--ec:var(--color-green);--ec-soft:#e8f5e2;}
.dd-se__edition:hover{background:#fff;}
.dd-se__edition-icon{display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;background:var(--ec-soft);color:var(--ec);}
