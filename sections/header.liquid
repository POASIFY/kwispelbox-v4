/* ══ SPECIAL EDITIONS MEGA MENU ══════════════════════ */
.site-header__dropdown-card:has(.dd-se){overflow:visible;background:var(--color-cream);border-color:rgba(61,34,9,.08);box-shadow:0 28px 70px rgba(61,34,9,.16);border-radius:28px;}
.dd-se{position:relative;padding:28px 30px;}
.dd-se__pointer{position:absolute;top:-9px;left:16%;width:18px;height:18px;background:var(--color-cream);border-top:1.5px solid rgba(61,34,9,.08);border-left:1.5px solid rgba(61,34,9,.08);border-radius:5px 0 0 0;transform:rotate(45deg);}
