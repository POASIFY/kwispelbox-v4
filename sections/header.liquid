                            {%- endif -%}
                            {%- if dd.settings.banner_cta_label != blank -%}
                              <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--{{ dd.settings.accent_color }}">
                                {{ dd.settings.banner_cta_label }}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                              </a>
                            {%- endif -%}
                            {%- if dd.settings.banner_image != blank -%}
                              <img src="{{ dd.settings.banner_image | image_url: width: 400 }}"
                                   alt="{{ dd.settings.banner_image.alt | escape }}"
                                   width="400" height="260" loading="lazy" class="dd-about__content-img">
                            {%- endif -%}
                          </div>
                          {%- if dd.settings.about_team_image != blank or dd.settings.about_team_title != blank -%}
                            <div class="dd-about__team">
                              <strong class="dd-about__team-title">{{ dd.settings.about_team_title }}</strong>
                              {%- if dd.settings.about_team_image != blank -%}
                                <div class="dd-polaroid">
                                  <img src="{{ dd.settings.about_team_image | image_url: width: 280 }}"
                                       alt="{{ dd.settings.about_team_title | default: 'Het team' | escape }}"
                                       width="280" height="200" loading="lazy" class="dd-polaroid__img">
                                </div>
                              {%- endif -%}
                              {%- if dd.settings.about_team_tagline != blank -%}
                                <span class="dd-about__team-tagline">{{ dd.settings.about_team_tagline }}</span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>

                      {%- comment -%} ══ LAYOUT: STANDARD (Special Editions, default) ══ {%- endcomment -%}
                      {%- else -%}
                        <div class="dd-standard">
                          <div class="dd-standard__links-wrap">
                            {%- if dd.settings.link_list != blank -%}
                              <div class="dd-standard__grid">
                                {%- for child in dd.settings.link_list.links -%}
                                  <a href="{{ child.url }}" class="dd-standard__item"
                                     {% if child.active %}aria-current="page"{% endif %}>
                                    <span class="dd-standard__item-icon dd-link-icon--{{ dd.settings.accent_color }}" aria-hidden="true">
                                      {{- 'icon-paw.svg' | inline_asset_content -}}
                                    </span>
                                    <span class="dd-standard__item-text">
                                      <strong>{{ child.title }}</strong>
                                    </span>
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endfor -%}
                              </div>
                            {%- endif -%}
                            {%- if dd.settings.view_all_label != blank -%}
                              <a href="{{ dd.settings.view_all_url | default: link.url }}" class="dd-view-all dd-view-all--{{ dd.settings.accent_color }}">
                                {{ dd.settings.view_all_label }}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                              </a>
                            {%- endif -%}
                          </div>
                          {%- if dd.settings.banner_title != blank -%}
                            <div class="dd-banner">
                              {%- if dd.settings.banner_image != blank -%}
                                <div class="dd-banner__img-wrap">
                                  <img src="{{ dd.settings.banner_image | image_url: width: 600 }}"
                                       alt="{{ dd.settings.banner_image.alt | default: dd.settings.banner_title | escape }}"
                                       width="600" height="400" loading="lazy" class="dd-banner__img">
                                  {%- if dd.settings.banner_badge != blank -%}
                                    <span class="dd-banner__badge dd-banner__badge--{{ dd.settings.accent_color }}">{{ dd.settings.banner_badge }}</span>
                                  {%- endif -%}
                                </div>
                              {%- endif -%}
                              <div class="dd-banner__body">
                                <strong class="dd-banner__title">{{ dd.settings.banner_title }}</strong>
                                {%- if dd.settings.banner_text != blank -%}<span class="dd-banner__text">{{ dd.settings.banner_text }}</span>{%- endif -%}
                                {%- if dd.settings.banner_cta_label != blank -%}
                                  <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--{{ dd.settings.accent_color }}">
                                    {{ dd.settings.banner_cta_label }}
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endif -%}
                              </div>
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                    </div>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>
        </nav>
        <span class="site-header__nav-deco site-header__nav-deco--right" aria-hidden="true">
          <svg width="40" height="32" viewBox="0 0 40 32" fill="none"><path d="M38 28 C32 20, 26 8, 16 12 S4 28, 2 20" stroke="#66AA44" stroke-width="2.5" stroke-linecap="round" fill="none"/><path d="M10 6 C8 2, 4 4, 6 8" stroke="#66AA44" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
        </span>
      </div>
    </header>
  {%- endif -%}

  <!-- ══ TRUST BAR ════════════════════════════════════ -->
  {%- if trust_blocks.size > 0 -%}
    <div class="site-header__trust-bar">
      <div class="site-header__trust-inner">
        {%- for block in trust_blocks -%}
          <div class="site-header__trust-item" {{ block.shopify_attributes }}>
            {%- if block.settings.url != blank -%}<a href="{{ block.settings.url }}" class="site-header__trust-link">{%- else -%}<span class="site-header__trust-link">{%- endif -%}
              <span class="site-header__trust-icon" aria-hidden="true">{{- block.settings.icon | inline_asset_content -}}</span>
              <span class="site-header__trust-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}<span>{{ block.settings.subtitle }}</span>{%- endif -%}
              </span>
            {%- if block.settings.url != blank -%}</a>{%- else -%}</span>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

<!-- ══ OVERLAY ══════════════════════════════════════════ -->
<div class="site-header__overlay" id="nav-overlay" aria-hidden="true" data-nav-overlay></div>

<!-- ══ MOBIEL DRAWER ════════════════════════════════════ -->
<div class="header-drawer" id="header-drawer" role="dialog" aria-modal="true" aria-label="Navigatiemenu" aria-hidden="true">

  <!-- Header -->
  <div class="header-drawer__header">
    <a href="{{ routes.root_url }}" class="header-drawer__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}"
             alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
             width="120" height="auto" loading="lazy" class="header-drawer__logo-img">
      {%- else -%}
        <span class="header-drawer__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <div class="header-drawer__header-actions">
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header-drawer__icon-btn" aria-label="Account">
          {{- 'icon-account.svg' | inline_asset_content -}}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="header-drawer__icon-btn header-drawer__cart-btn" aria-label="Winkelwagen">
        {{- 'icon-cart.svg' | inline_asset_content -}}
        {%- if cart.item_count > 0 -%}
          <span class="header-drawer__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button class="header-drawer__close" aria-label="Sluiten" data-drawer-close>
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </div>
  </div>

  <!-- Trust bar -->
  {%- assign trust_blocks_drawer = section.blocks | where: 'type', 'trust_item' -%}
  {%- if trust_blocks_drawer.size > 0 -%}
    <div class="header-drawer__trust">
      {%- for block in trust_blocks_drawer limit: 3 -%}
        <div class="header-drawer__trust-item">
          <span class="header-drawer__trust-icon" aria-hidden="true">{{- block.settings.icon | inline_asset_content -}}</span>
          <span class="header-drawer__trust-text">{{ block.settings.title }}{%- if block.settings.subtitle != blank -%} {{ block.settings.subtitle }}{%- endif -%}</span>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Navigatie -->
  <nav aria-label="Mobiel menu" class="header-drawer__nav-wrap">
    <ul class="header-drawer__nav" role="list">
      {%- for link in section.settings.menu.links -%}
        {%- assign nav_lx = forloop.index -%}
        <li class="header-drawer__nav-item{% if link.links.size > 0 %} header-drawer__nav-item--has-sub{% endif %}">
          <div class="header-drawer__nav-row">
            <span class="header-drawer__nav-icon header-drawer__nav-icon--{% if nav_lx == 1 %}green{% elsif nav_lx == 2 %}pink{% elsif nav_lx == 3 %}green{% elsif nav_lx == 4 %}orange{% else %}orange{% endif %}" aria-hidden="true">
              {%- if nav_lx == 1 -%}{{- 'icon-gift.svg' | inline_asset_content -}}
              {%- elsif nav_lx == 2 -%}{{- 'icon-gift.svg' | inline_asset_content -}}
              {%- elsif nav_lx == 3 -%}{{- 'icon-bone.svg' | inline_asset_content -}}
              {%- elsif nav_lx == 4 -%}{{- 'icon-paw.svg' | inline_asset_content -}}
              {%- else -%}{{- 'icon-heart.svg' | inline_asset_content -}}
              {%- endif -%}
            </span>
            <a href="{{ link.url }}" class="header-drawer__nav-link" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a>
            {%- if link.links.size > 0 -%}
              <button class="header-drawer__sub-toggle" aria-expanded="false" aria-label="{{ link.title }} submenu">
                {{- 'icon-chevron-down.svg' | inline_asset_content -}}
              </button>
            {%- else -%}
              <svg class="header-drawer__nav-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
            {%- endif -%}
          </div>
          {%- if link.links.size > 0 -%}
            <ul class="header-drawer__sub-nav" role="list" hidden>
              {%- for child in link.links -%}
                <li><a href="{{ child.url }}" class="header-drawer__sub-link" {% if child.active %}aria-current="page"{% endif %}>{{ child.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  <!-- Extra links -->
  <div class="header-drawer__extras">
    <a href="{{ routes.search_url }}" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
      <span>Zoeken</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    {%- if shop.customer_accounts_enabled -%}
      <a href="{{ routes.account_url }}" class="header-drawer__extra-link">
        <span class="header-drawer__extra-icon" aria-hidden="true">{{- 'icon-account.svg' | inline_asset_content -}}</span>
        <span>{%- if customer -%}Mijn account{%- else -%}{{ section.settings.account_label }}{%- endif -%}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    {%- endif -%}
    <a href="{{ routes.cart_url }}" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">{{- 'icon-cart.svg' | inline_asset_content -}}</span>
      <span>Winkelwagen</span>
      <span class="header-drawer__extra-badge">
        {%- if cart.item_count > 0 -%}<span class="header-drawer__cart-count">{{ cart.item_count }}</span>{%- endif -%}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </span>
    </a>
    <a href="/pages/klantenservice" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
      </span>
      <span>Klantenservice</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    <a href="/pages/veelgestelde-vragen" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </span>
      <span>Veelgestelde vragen</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </a>
  </div>

  <!-- Banner Kwispelclub -->
  {%- if section.settings.drawer_banner_title != blank -%}
    <div class="header-drawer__banner">
      <div class="header-drawer__banner-content">
        <strong class="header-drawer__banner-title">{{ section.settings.drawer_banner_title }}</strong>
        {%- if section.settings.drawer_banner_text != blank -%}
          <p class="header-drawer__banner-text">{{ section.settings.drawer_banner_text }}</p>
        {%- endif -%}
        {%- if section.settings.drawer_banner_cta != blank -%}
          <a href="{{ section.settings.drawer_banner_url | default: routes.root_url }}" class="header-drawer__banner-btn">
            {{ section.settings.drawer_banner_cta }}
            {{- 'icon-paw.svg' | inline_asset_content -}}
          </a>
        {%- endif -%}
      </div>
      {%- if section.settings.drawer_banner_image != blank -%}
        <div class="header-drawer__banner-img-wrap">
          <img src="{{ section.settings.drawer_banner_image | image_url: width: 300 }}"
               alt="{{ section.settings.drawer_banner_image.alt | escape }}"
               width="150" height="150" loading="lazy" class="header-drawer__banner-img">
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- Footer -->
  <div class="header-drawer__footer">
    <span class="header-drawer__footer-text">Woeff, tot snel! ♡</span>
    <div class="header-drawer__footer-wave" aria-hidden="true">
      <svg viewBox="0 0 375 48" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 24C62.5 24 62.5 48 125 48C187.5 48 187.5 24 250 24C312.5 24 312.5 48 375 48V0H0V24Z" fill="var(--color-green)" opacity="0.3"/>
        <path d="M0 32C62.5 32 62.5 48 125 48C187.5 48 187.5 32 250 32C312.5 32 312.5 48 375 48V48H0V32Z" fill="var(--color-green)"/>
      </svg>
    </div>
  </div>

</div>
<div class="header-drawer__overlay" id="header-overlay" aria-hidden="true" data-drawer-overlay></div>

{% stylesheet %}
/* ── Helpers ──────────────────────────────────────────── */
.site-header__sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;}

/* ── Wrapper ──────────────────────────────────────────── */
.site-header__wrapper{position:sticky;top:0;z-index:100;background:#fff;box-shadow:0 1px 0 var(--color-line);}

/* ══ RIJ 1: TOP BAR (Logo + Zoek + Acties) ═══════════ */
.site-header__top{background:#fff;border-bottom:1px solid var(--color-line);}
.site-header__top-inner{
  max-width:var(--page-width);
  margin:0 auto;
  padding:0 var(--page-margin);
  height:80px;
  display:grid;
  grid-template-columns:auto 1fr auto;
  align-items:center;
  gap:24px;
}

/* Logo */
.site-header__logo{display:flex;flex-direction:column;text-decoration:none;flex-shrink:0;}
.site-header__logo-img{height:auto;max-height:56px;width:auto;display:block;}
.site-header__logo-text{font-family:var(--font-heading);font-size:1.5rem;color:var(--color-ink);white-space:nowrap;}

/* Zoekbalk desktop */
.site-header__search-bar{position:relative;display:flex;align-items:center;width:100%;}
.site-header__search-bar-field{
  flex:1;
  display:flex;
  align-items:center;
  gap:8px;
  height:48px;
  background:var(--color-cream);
  border:1.5px solid var(--color-line);
  border-radius:var(--radius-pill);
  padding:0 16px;
  transition:border-color 160ms;
}
.site-header__search-bar-field:focus-within{border-color:var(--color-orange);background:#fff;}
.site-header__search-bar-icon{display:flex;align-items:center;color:var(--color-muted);flex-shrink:0;}
.site-header__search-bar-icon svg{width:18px;height:18px;}
.site-header__search-bar-input{
  flex:1;
  background:none;
  border:none;
  outline:none;
  font-family:var(--font-body);
  font-size:.95rem;
  color:var(--color-ink);
  min-width:0;
  height:100%;
}
.site-header__search-bar-input::placeholder{color:var(--color-muted);}
.site-header__search-clear{display:flex;align-items:center;background:none;border:none;cursor:pointer;color:var(--color-muted);padding:4px;}
.site-header__search-clear svg{width:16px;height:16px;}
.site-header__search-bar-btn{
  height:48px;
  width:48px;
  background:none;
  border:none;
  border-radius:0 var(--radius-pill) var(--radius-pill) 0;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  flex-shrink:0;
  color:var(--color-muted);
  transition:color 160ms;
}
.site-header__search-bar-btn:hover{color:var(--color-ink);}
.site-header__search-bar-btn svg{width:20px;height:20px;}
.site-header__search-results{
  position:absolute;
  top:calc(100% + 4px);
  left:0;
  right:52px;
  background:#fff;
  border:1.5px solid var(--color-line);
  border-radius:var(--radius-md);
  box-shadow:0 8px 24px rgba(0,0,0,.08);
  overflow:hidden;
  z-index:200;
}

/* Acties rechts */
.site-header__actions{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.site-header__action-btn{
  display:flex;
  align-items:center;
  gap:8px;
  padding:8px 12px;
  border-radius:var(--radius-md);
  text-decoration:none;
  color:var(--color-ink);
  font-family:var(--font-body);
  font-size:.85rem;
  font-weight:700;
  transition:background 160ms;
  white-space:nowrap;
  position:relative;
}
.site-header__action-btn:hover{background:var(--color-cream);}
.site-header__action-icon{display:flex;align-items:center;position:relative;width:22px;height:22px;flex-shrink:0;}
.site-header__action-icon svg,.site-header__action-icon img{width:22px!important;height:22px!important;max-width:22px!important;display:block;}
.site-header__action-icon svg{width:22px;height:22px;}
.site-header__action-label{display:block;}
.site-header__account{display:flex;}
.site-header__cart-count{
  position:absolute;
  top:-6px;right:-6px;
  background:var(--color-pink);
  color:#fff;
  font-family:var(--font-body);
  font-size:.58rem;
  font-weight:800;
  min-width:18px;
  height:18px;
  padding:0 4px;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  border:2px solid #fff;
}

/* Hamburger (mobiel) */
.site-header__burger{display:none;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:8px;color:var(--color-ink);}
.site-header__burger svg{width:24px;height:24px;display:block;}

/* ══ RIJ 2: NAVIGATIE ════════════════════════════════ */
.site-header{background:#fff;}
.site-header__nav-row{
  max-width:var(--page-width);
  margin:0 auto;
  padding:0 var(--page-margin);
  height:56px;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
}
.site-header__nav-deco{display:flex;align-items:center;opacity:.7;}
.site-header__nav{display:flex;align-items:center;}
.site-header__chips{display:flex;align-items:center;gap:2px;list-style:none;margin:0;padding:0;}
.site-header__chip-item{position:static;}
.site-header__chip{
  display:inline-flex;align-items:center;gap:6px;
  padding:7px 14px;
  border-radius:var(--radius-pill);
  font-family:var(--font-body);
  font-size:.88rem;
  font-weight:700;
  text-decoration:none;
  white-space:nowrap;
  color:var(--color-ink);
  background:none;
  border:2px solid transparent;
  cursor:pointer;
  transition:background 160ms,color 160ms,border-color 160ms;
}
.site-header__chip:hover,.site-header__chip[aria-current="page"]{background:var(--color-cream);}
.site-header__chip[aria-expanded="true"]{background:var(--color-cream);}
.site-header__chip--green{color:var(--color-green);border-color:var(--color-green);}
.site-header__chip--green:hover,.site-header__chip--green[aria-expanded="true"]{background:#e8f5e2;}
.site-header__chip--pink{color:var(--color-pink);}.site-header__chip--pink:hover,.site-header__chip--pink[aria-expanded="true"]{background:#ffe0ee;}
.site-header__chip--orange{color:var(--color-orange);}.site-header__chip--orange:hover,.site-header__chip--orange[aria-expanded="true"]{background:#fff0e4;}
.site-header__chip--yellow{color:var(--color-yellow);}.site-header__chip--yellow:hover,.site-header__chip--yellow[aria-expanded="true"]{background:#fffae0;}
.site-header__chip-icon{display:inline-flex;align-items:center;flex-shrink:0;}
.site-header__chip-icon svg{width:15px;height:15px;}
.site-header__chip-chevron{display:inline-flex;align-items:center;margin-left:2px;transition:transform 200ms ease;}
.site-header__chip-chevron svg{width:13px;height:13px;}
.site-header__chip[aria-expanded="true"] .site-header__chip-chevron{transform:rotate(180deg);}

/* ══ DROPDOWN ════════════════════════════════════════ */
.site-header__dropdown{
  position:fixed;
  left:0;right:0;
  top:var(--header-bottom,136px);
  background:transparent;
  z-index:99;
  opacity:0;visibility:hidden;
  transform:translateY(-6px);
  transition:opacity 200ms ease,visibility 200ms ease,transform 200ms ease;
  pointer-events:none;
  padding:8px 0 0;
}
.site-header__dropdown[data-open]{opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto;}
.site-header__dropdown-card{
  background:#fff;
  border-radius:20px;
  box-shadow:0 20px 60px rgba(61,34,9,.12);
  border:1.5px solid var(--color-line);
  overflow:hidden;
  max-width:var(--page-width);
  margin:0 auto;
}

/* ══ TRUST BAR ═══════════════════════════════════════ */
.site-header__trust-bar{background:#fff;border-top:1.5px solid var(--color-line);}
.site-header__trust-inner{max-width:var(--page-width);margin:0 auto;padding:0 var(--page-margin);height:52px;display:flex;align-items:center;justify-content:center;gap:0;}
.site-header__trust-item{display:flex;}
.site-header__trust-link{
  display:inline-flex;align-items:center;gap:8px;
  padding:6px 20px;
  font-family:var(--font-body);font-size:.78rem;font-weight:700;
  color:var(--color-body);text-decoration:none;
  border-right:1px solid var(--color-line);
  transition:color 160ms;white-space:nowrap;
}
.site-header__trust-item:last-child .site-header__trust-link{border-right:none;}
.site-header__trust-link:hover{color:var(--color-ink);}
.site-header__trust-icon{display:flex;align-items:center;flex-shrink:0;color:var(--color-muted);}
.site-header__trust-icon svg{width:16px;height:16px;}
.site-header__trust-text strong{font-family:var(--font-body);font-size:.78rem;font-weight:800;color:var(--color-ink);}
.site-header__trust-text span{font-family:var(--font-body);font-size:.72rem;color:var(--color-muted);margin-left:3px;}

/* ══ OVERLAY ═════════════════════════════════════════ */
.site-header__overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:98;opacity:0;visibility:hidden;transition:opacity 200ms,visibility 200ms;}
.site-header__overlay[aria-hidden="false"]{opacity:1;visibility:visible;}

/* ══ ZOEKRESULTATEN ══════════════════════════════════ */
.search-result-item{display:flex;align-items:center;gap:12px;padding:10px 16px;text-decoration:none;color:var(--color-ink);border-bottom:1px solid var(--color-line);transition:background 120ms;}
.search-result-item:last-child{border-bottom:none;}
.search-result-item:hover,.search-result-item[aria-selected="true"]{background:var(--color-cream);}
.search-result-item__img{width:44px;height:44px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0;background:var(--color-cream);}
.search-result-item__title{font-family:var(--font-body);font-size:.88rem;font-weight:700;color:var(--color-ink);}
.search-result-item__price{font-family:var(--font-body);font-size:.82rem;color:var(--color-muted);margin-top:2px;}
.search-result-item__all{display:block;padding:10px 16px;font-family:var(--font-body);font-size:.85rem;font-weight:700;color:var(--color-ink);text-decoration:none;text-align:center;border-top:1px solid var(--color-line);}
.search-result-item__all:hover{background:var(--color-cream);}

/* ══ MOBIEL ══════════════════════════════════════════ */
@media(max-width:989px){
  .site-header__top-inner{
    grid-template-columns:1fr auto;
    height:64px;
    gap:12px;
  }
  .site-header__search-bar{display:none;}
  .site-header__action-label{display:none;}
  .site-header__action-btn{padding:8px;}
  .site-header__burger{display:flex;}
  .site-header{display:none;}
  .site-header__trust-bar{display:none;}
  .site-header__nav-deco{display:none;}
}

/* ══ FEATURED layout (Verrassingsboxen) ════════════════ */
.dd-verr{display:flex;gap:0;align-items:stretch;min-height:360px;}
.dd-verr__col{flex:1;min-width:0;padding:20px 18px;border-right:1.5px solid var(--color-line);display:flex;flex-direction:column;gap:10px;}
.dd-verr__col:last-of-type{border-right:none;}
.dd-verr__col--products{flex:1.4;}
.dd-verr__col-head{display:flex;align-items:flex-start;gap:10px;margin-bottom:2px;}
.dd-verr__col-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.dd-verr__col-icon svg{width:18px;height:18px;}
.dd-verr__col-icon--green{background:#e8f5e2;color:var(--color-green);}
.dd-verr__col-icon--pink{background:#ffe0ee;color:var(--color-pink);}
.dd-verr__col-icon--orange{background:#fff0e4;color:var(--color-orange);}
.dd-verr__col-icon--yellow{background:#fffae0;color:var(--color-yellow);}
.dd-verr__col-icon--ink{background:var(--color-cream);color:var(--color-ink);}
.dd-verr__col-title{font-family:var(--font-heading);font-size:1.05rem;text-decoration:none;display:block;line-height:1.2;}
.dd-verr__col-title--green{color:var(--color-green);}
.dd-verr__col-title--pink{color:var(--color-pink);}
.dd-verr__col-title--orange{color:var(--color-orange);}
.dd-verr__col-title--yellow{color:var(--color-yellow);}
.dd-verr__col-title--ink{color:var(--color-ink);}
.dd-verr__col-title:hover{opacity:.8;}
.dd-verr__col-desc{font-family:var(--font-body);font-size:.75rem;color:var(--color-muted);line-height:1.4;margin:2px 0 0;}
.dd-verr__chevron{flex-shrink:0;color:var(--color-muted);opacity:.5;transition:opacity 120ms,transform 120ms;}
.dd-verr__products{display:flex;flex-direction:column;gap:2px;}
.dd-verr__product{display:flex;align-items:center;gap:12px;padding:8px 8px;border-radius:var(--radius-md);text-decoration:none;color:var(--color-ink);transition:background 120ms;}
.dd-verr__product:hover{background:var(--color-cream);}
.dd-verr__product:hover .dd-verr__chevron{opacity:.8;transform:translateX(2px);}
.dd-verr__product-img{width:64px;height:64px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0;}
.dd-verr__product-info{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px;}
.dd-verr__product-name-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.dd-verr__product-name-row strong{font-family:var(--font-body);font-size:.88rem;font-weight:700;color:var(--color-ink);}
.dd-verr__product-badge{background:var(--color-pink);color:#fff;font-family:var(--font-body);font-size:.6rem;font-weight:800;padding:2px 8px;border-radius:999px;white-space:nowrap;}
.dd-verr__product-desc{font-family:var(--font-body);font-size:.72rem;color:var(--color-muted);}
.dd-verr__extra-links{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:1px;padding-top:10px;border-top:1px solid var(--color-line);}
.dd-verr__extra-link{display:grid;grid-template-columns:28px 1fr 12px;align-items:center;gap:8px;padding:8px 8px;border-radius:var(--radius-sm);text-decoration:none;font-family:var(--font-body);font-size:.83rem;font-weight:600;color:var(--color-ink);transition:background 120ms;}
.dd-verr__extra-link:hover{background:var(--color-cream);}
.dd-verr__extra-link:hover .dd-verr__chevron{opacity:.8;transform:translateX(2px);}

.dd-verr__col-links{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:1px;}
.dd-verr__col-link{display:grid;grid-template-columns:28px 1fr 12px;align-items:center;gap:8px;padding:7px 8px;border-radius:var(--radius-sm);text-decoration:none;font-family:var(--font-body);font-size:.83rem;font-weight:600;color:var(--color-ink);transition:background 120ms;}
.dd-verr__col-link--no-icon{grid-template-columns:1fr 12px;}
.dd-verr__col-link:hover{background:var(--color-cream);}
.dd-verr__col-link:hover .dd-verr__chevron{opacity:.8;transform:translateX(2px);}

.dd-verr__link-icon{width:28px;height:28px;aspect-ratio:1;border-radius:50%;flex-shrink:0;flex-grow:0;display:flex;align-items:center;justify-content:center;box-sizing:content-box;}
.dd-verr__link-icon svg{width:12px;height:12px;flex-shrink:0;}
.dd-verr__link-icon--green{background:#d4edca;color:var(--color-green);}
.dd-verr__link-icon--pink{background:#ffc8de;color:var(--color-pink);}
.dd-verr__link-icon--orange{background:#fde3c8;color:var(--color-orange);}
.dd-verr__link-icon--yellow{background:#fef3b0;color:#b07d00;}
.dd-verr__link-icon--ink{background:var(--color-cream);color:var(--color-ink);}
.dd-verr__link-icon-sm--pink{background:#ffe0ee;color:var(--color-pink);}
.dd-verr__link-icon-sm--orange{background:#fff0e4;color:var(--color-orange);}
.dd-verr__link-icon-sm--yellow{background:#fffae0;color:var(--color-yellow);}
.dd-verr__col-cta{display:inline-flex;align-items:center;gap:5px;margin-top:12px;padding-top:10px;border-top:1px solid var(--color-line);font-family:var(--font-body);font-size:.82rem;font-weight:800;text-decoration:none;transition:gap 160ms;}
.dd-verr__col-cta:hover{gap:8px;}
.dd-verr__col-cta svg{width:13px;height:13px;}
.dd-verr__col-cta--green{color:var(--color-green);}
.dd-verr__col-cta--pink{color:var(--color-pink);}
.dd-verr__col-cta--orange{color:var(--color-orange);}
.dd-verr__col-cta--yellow{color:var(--color-yellow);}
.dd-verr__col-cta--ink{color:var(--color-ink);}
.dd-verr__mini-banner{display:flex;align-items:center;gap:8px;margin-top:auto;padding:10px 10px;border-radius:var(--radius-md);background:var(--color-cream);}
.dd-verr__mini-banner-text{flex:1;display:flex;flex-direction:column;gap:3px;}
.dd-verr__mini-banner-text strong{font-family:var(--font-body);font-size:.78rem;font-weight:800;color:var(--color-ink);}
.dd-verr__mini-banner-text span{font-family:var(--font-body);font-size:.72rem;color:var(--color-muted);}
.dd-verr__mini-banner-btn{width:26px;height:26px;border-radius:50%;background:var(--color-orange);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:4px;}
.dd-verr__mini-banner-btn svg{width:13px;height:13px;color:#fff;}
.dd-verr__mini-banner-img{width:64px;height:64px;object-fit:contain;flex-shrink:0;}
.dd-verr__banner{width:220px;flex-shrink:0;background:var(--color-cream);display:flex;flex-direction:column;overflow:hidden;border-left:1.5px solid var(--color-line);}
.dd-verr__banner-body{padding:18px 18px 0;display:flex;flex-direction:column;gap:6px;}
.dd-verr__banner-title{font-family:var(--font-heading);font-size:1.15rem;color:var(--color-ink);line-height:1.2;}
.dd-verr__banner-text{font-family:var(--font-body);font-size:.78rem;color:var(--color-muted);line-height:1.5;}
.dd-verr__banner-img-wrap{flex:1;overflow:hidden;min-height:160px;}
.dd-verr__banner-img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;}
.dd-verr__banner-cta-wrap{padding:14px 16px;flex-shrink:0;}
.dd-verr__banner-cta{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:12px 16px;background:var(--color-pink);color:#fff;border-radius:var(--radius-pill);font-family:var(--font-heading);font-size:.88rem;text-decoration:none;transition:background 160ms;}
.dd-verr__banner-cta:hover{background:#c4396a;}
.dd-verr__banner-cta svg{width:16px;height:16px;}
/* ══ MOBIEL DRAWER ══════════════════════════════════════ */
.header-drawer{position:fixed;top:0;left:0;bottom:0;width:min(390px,100vw);background:#fff;z-index:300;overflow-y:auto;overscroll-behavior:contain;transform:translateX(-100%);transition:transform 280ms cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;}
.header-drawer[aria-hidden="false"]{transform:translateX(0);}
.header-drawer__header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;flex-shrink:0;}
.header-drawer__logo{display:flex;align-items:center;text-decoration:none;}
.header-drawer__logo-img{height:48px;width:auto;}
.header-drawer__logo-text{font-family:var(--font-heading);font-size:1.4rem;color:var(--color-ink);}
.header-drawer__header-actions{display:flex;align-items:center;gap:4px;}
.header-drawer__icon-btn{display:flex;align-items:center;justify-content:center;position:relative;background:none;border:none;cursor:pointer;padding:8px;color:var(--color-ink);border-radius:var(--radius-sm);text-decoration:none;}
.header-drawer__icon-btn svg{width:22px;height:22px;}
.header-drawer__cart-btn{position:relative;}
.header-drawer__cart-count{position:absolute;top:-2px;right:-2px;background:var(--color-pink);color:#fff;font-family:var(--font-body);font-size:.6rem;font-weight:800;min-width:18px;height:18px;padding:0 4px;border-radius:999px;display:flex;align-items:center;justify-content:center;border:2px solid #fff;}
.header-drawer__close{display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:8px;color:var(--color-ink);}
.header-drawer__close svg{width:22px;height:22px;}
.header-drawer__trust{display:flex;background:var(--color-cream);padding:12px 20px;gap:0;border-top:1px solid var(--color-line);border-bottom:1px solid var(--color-line);flex-shrink:0;}
.header-drawer__trust-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;text-align:center;padding:0 4px;}
.header-drawer__trust-item+.header-drawer__trust-item{border-left:1px solid var(--color-line);}
.header-drawer__trust-icon{display:flex;align-items:center;justify-content:center;color:var(--color-muted);}
.header-drawer__trust-icon svg{width:18px;height:18px;}
.header-drawer__trust-text{font-family:var(--font-body);font-size:.65rem;font-weight:600;color:var(--color-body);line-height:1.3;}
.header-drawer__nav-wrap{flex-shrink:0;}
.header-drawer__nav{list-style:none;margin:0;padding:8px 0;}
.header-drawer__nav-item{border-bottom:1px solid var(--color-line);}
.header-drawer__nav-row{display:grid;grid-template-columns:64px 1fr 40px;align-items:center;padding:4px 16px;}
.header-drawer__nav-icon{width:48px;height:48px;aspect-ratio:1;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;flex-grow:0;}
.header-drawer__nav-icon svg{width:22px;height:22px;}
.header-drawer__nav-icon--green{background:#e8f5e2;color:var(--color-green);}
.header-drawer__nav-icon--pink{background:#ffe0ee;color:var(--color-pink);}
.header-drawer__nav-icon--orange{background:#fff0e4;color:var(--color-orange);}
.header-drawer__nav-link{font-family:var(--font-body);font-size:1.05rem;font-weight:700;color:var(--color-ink);text-decoration:none;padding:16px 0;display:flex;align-items:center;}
.header-drawer__nav-chevron{color:var(--color-muted);opacity:.4;flex-shrink:0;}
.header-drawer__sub-toggle{background:none;border:none;cursor:pointer;padding:8px;color:var(--color-muted);display:flex;align-items:center;justify-content:center;transition:transform 200ms;}
.header-drawer__sub-toggle svg{width:18px;height:18px;}
.header-drawer__sub-toggle[aria-expanded="true"]{transform:rotate(180deg);}
.header-drawer__sub-nav{list-style:none;margin:0;padding:0;background:var(--color-cream);}
.header-drawer__sub-link{display:block;padding:10px 20px 10px 80px;text-decoration:none;font-family:var(--font-body);font-size:.88rem;color:var(--color-body);border-top:1px solid var(--color-line);}
.header-drawer__sub-link:hover{color:var(--color-pink);}
.header-drawer__extras{padding:8px 0;border-top:1px solid var(--color-line);flex-shrink:0;}
.header-drawer__extra-link{display:grid;grid-template-columns:44px 1fr auto;align-items:center;gap:4px;padding:12px 20px;text-decoration:none;color:var(--color-ink);font-family:var(--font-body);font-size:.9rem;font-weight:600;transition:background 120ms;}
.header-drawer__extra-link:hover{background:var(--color-cream);}
.header-drawer__extra-icon{width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--color-muted);}
.header-drawer__extra-icon svg{width:18px;height:18px;}
.header-drawer__extra-badge{display:flex;align-items:center;gap:4px;}
.header-drawer__banner{margin:16px;border-radius:var(--radius-lg);background:var(--color-cream);display:flex;align-items:flex-end;overflow:hidden;min-height:160px;flex-shrink:0;}
.header-drawer__banner-content{flex:1;padding:20px 16px 20px 20px;display:flex;flex-direction:column;gap:10px;}
.header-drawer__banner-title{font-family:var(--font-heading);font-size:1.3rem;color:var(--color-green);line-height:1.2;}
.header-drawer__banner-text{font-family:var(--font-body);font-size:.82rem;color:var(--color-body);line-height:1.5;margin:0;}
.header-drawer__banner-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 18px;background:var(--color-green);color:#fff;border-radius:var(--radius-pill);font-family:var(--font-heading);font-size:.85rem;text-decoration:none;width:fit-content;}
.header-drawer__banner-btn svg{width:14px;height:14px;}
.header-drawer__banner-img-wrap{width:140px;flex-shrink:0;}
.header-drawer__banner-img{width:100%;height:100%;object-fit:cover;object-position:top;}
.header-drawer__footer{flex-shrink:0;margin-top:auto;}
.header-drawer__footer-text{display:block;text-align:center;font-family:var(--font-heading);font-size:.95rem;color:var(--color-muted);padding:16px 20px 8px;}
.header-drawer__footer-wave{display:block;line-height:0;}
.header-drawer__footer-wave svg{width:100%;height:48px;}
.header-drawer__overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:299;opacity:0;visibility:hidden;transition:opacity 280ms,visibility 280ms;}
.header-drawer__overlay[aria-hidden="false"]{opacity:1;visibility:visible;}
.header-drawer__nav-item--has-sub .header-drawer__nav-chevron{display:none;}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  var wrapper   = document.querySelector('.site-header__wrapper');
  var searchBar = document.querySelector('.site-header__search-bar');
  var overlay   = document.getElementById('nav-overlay');
  var triggers  = document.querySelectorAll('[data-nav-trigger]');
  var closeTimer = null;
  var openTimer  = null;
  var activeDD   = null;

  function updateTop() {
    if (!wrapper) return;
    var h = wrapper.getBoundingClientRect().bottom;
    document.querySelectorAll('.site-header__dropdown').forEach(function (d) {
      d.style.top = h + 'px';
    });
  }
  updateTop();
  window.addEventListener('resize', updateTop, { passive: true });

  function openDD(dd, trigger) {
    clearTimeout(closeTimer);
    clearTimeout(openTimer);
    if (activeDD && activeDD !== dd) closeDD(activeDD, null);
    dd.setAttribute('data-open', '');
    trigger && trigger.setAttribute('aria-expanded', 'true');
    overlay && overlay.setAttribute('aria-hidden', 'false');
    activeDD = dd;
  }

  function closeDD(dd, trigger) {
    dd.removeAttribute('data-open');
    var t = trigger || dd.closest('.site-header__chip-item') && dd.closest('.site-header__chip-item').querySelector('[data-nav-trigger]');
    t && t.setAttribute('aria-expanded', 'false');
  }

  function closeAll() {
    closeTimer = setTimeout(function () {
      document.querySelectorAll('[data-nav-dropdown][data-open]').forEach(function (d) { closeDD(d, null); });
      overlay && overlay.setAttribute('aria-hidden', 'true');
      activeDD = null;
    }, 120);
  }

  triggers.forEach(function (trigger) {
    var item = trigger.closest('.site-header__chip-item--has-dd');
    var dd   = item && item.querySelector('[data-nav-dropdown]');
    if (!dd) return;

    item.addEventListener('mouseenter', function () {
      clearTimeout(closeTimer);
      openTimer = setTimeout(function () { openDD(dd, trigger); }, 80);
    });
    item.addEventListener('mouseleave', closeAll);

    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        if (trigger.getAttribute('aria-expanded') === 'true') closeAll();
        else openDD(dd, trigger);
      }
      if (e.key === 'Escape') { closeAll(); trigger.focus(); }
    });
  });

  document.querySelectorAll('[data-nav-dropdown]').forEach(function (dd) {
    dd.addEventListener('mouseenter', function () { clearTimeout(closeTimer); clearTimeout(openTimer); });
    dd.addEventListener('mouseleave', closeAll);
  });

  overlay && overlay.addEventListener('click', closeAll);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && activeDD) closeAll(); });

  /* ── Zoekpaneel ──────────────────────────────────────── */
  var searchToggle  = document.querySelector('[data-search-toggle]');
  var searchPanel   = document.getElementById('header-search-panel');
  var searchInput   = document.querySelector('[data-search-input]');
  var searchResults = document.querySelector('[data-search-results]');
  var searchClear   = document.querySelector('[data-search-clear]');
  var searchForm    = document.querySelector('[data-search-form]');

  if (searchToggle && searchPanel) {
    searchToggle.addEventListener('click', function () {
      var open = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !open);
      searchPanel.setAttribute('aria-hidden', open);
      if (!open && searchInput) setTimeout(function () { searchInput.focus(); }, 300);
    });
  }

  if (searchInput && searchResults) {
    var debounceTimer = null;
    function money(c) { return '\u20ac' + (c / 100).toFixed(2).replace('.', ','); }
    function renderResults(results, q) {
      if (!results.length) { searchResults.hidden = true; return; }
      var html = results.map(function (i) {
        var img = i.image ? '<img src="' + i.image + '" alt="" class="search-result-item__img" width="44" height="44" loading="lazy">' : '<div class="search-result-item__img"></div>';
        var price = i.price ? '<span class="search-result-item__price">' + money(i.price) + '</span>' : '';
        return '<a href="' + i.url + '" class="search-result-item" role="option">' + img + '<span><span class="search-result-item__title">' + i.title + '</span>' + price + '</span></a>';
      }).join('') + '<a href="/search?type=product&q=' + encodeURIComponent(q) + '" class="search-result-item__all">Alle resultaten &rarr;</a>';
      searchResults.innerHTML = html;
      searchResults.hidden = false;
    }
    function fetchSuggestions(q) {
      if (q.length < 2) { searchResults.hidden = true; return; }
      fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=5&resources[fields]=title,handle,image,price')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var p = (data.resources && data.resources.results && data.resources.results.products) || [];
          renderResults(p.map(function (x) { return { title: x.title, url: x.url, image: x.image ? x.image.src : null, price: x.price }; }), q);
        }).catch(function () { searchResults.hidden = true; });
    }
    searchInput.addEventListener('input', function () {
      var q = this.value.trim();
      searchClear && (searchClear.hidden = q.length === 0);
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function () { fetchSuggestions(q); }, 220);
    });
    searchClear && searchClear.addEventListener('click', function () { searchInput.value = ''; searchInput.focus(); this.hidden = true; searchResults.hidden = true; });
    document.addEventListener('click', function (e) {
      if (searchForm && !searchForm.contains(e.target) && searchToggle && !searchToggle.contains(e.target)) searchResults.hidden = true;
    });
  }

  /* ── Mobiel drawer ───────────────────────────────────── */
  var drawer  = document.getElementById('header-drawer');
  var drOvrl  = document.getElementById('header-overlay');
  var burger  = document.querySelector('.site-header__burger');
  var closeBtn = document.querySelector('[data-drawer-close]');

  function openDrawer() {
    if (!drawer) return;
    drawer.setAttribute('aria-hidden','false');
    drOvrl && drOvrl.setAttribute('aria-hidden','false');
    burger && burger.setAttribute('aria-expanded','true');
    document.documentElement.style.overflow = 'hidden';
    closeBtn && closeBtn.focus();
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.setAttribute('aria-hidden','true');
    drOvrl && drOvrl.setAttribute('aria-hidden','true');
    burger && burger.setAttribute('aria-expanded','false');
    document.documentElement.style.overflow = '';
    burger && burger.focus();
  }
  burger   && burger.addEventListener('click', openDrawer);
  closeBtn && closeBtn.addEventListener('click', closeDrawer);
  drOvrl   && drOvrl.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer && drawer.getAttribute('aria-hidden') === 'false') closeDrawer();
  });
  document.querySelectorAll('.header-drawer__sub-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var exp = this.getAttribute('aria-expanded') === 'true';
      var sub = this.closest('.header-drawer__nav-item').querySelector('.header-drawer__sub-nav');
      this.setAttribute('aria-expanded', !exp);
      if (sub) sub.hidden = exp;
    });
  });
}());
{% endjavascript %}

