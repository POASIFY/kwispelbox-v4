                                  </a>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          </div>
                        </div>

                      {%- comment -%} ══ LAYOUT: ABOUT (Over ons) ══ {%- endcomment -%}
                      {%- elsif layout == 'about' -%}
                        <div class="dd-about">
