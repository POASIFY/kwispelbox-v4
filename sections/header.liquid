.dd-se__promo-deco--heart{bottom:10px;right:14px;width:20px;height:20px;color:#fff;opacity:.85;transform:rotate(10deg);}
.dd-se__promo-body{padding:16px 18px 18px;display:flex;flex-direction:column;gap:8px;}
.dd-se__promo-title{font-family:var(--font-heading);font-size:1.35rem;color:var(--color-ink);line-height:1.1;}
