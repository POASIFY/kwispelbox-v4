.dd-shop__wave-deco--4{bottom:14px;left:84%;width:13px;height:13px;animation:dd-bob 3s ease-in-out 1.2s infinite;}
@keyframes dd-bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}

