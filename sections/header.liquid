                                  <span class="dd-se__promo-deco dd-se__promo-deco--heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                                </div>
                                <div class="dd-se__promo-body">
                                  <strong class="dd-se__promo-title">{{ dd.settings.banner_title }}</strong>
                                  {%- if dd.settings.banner_text != blank -%}<p class="dd-se__promo-text">{{ dd.settings.banner_text }}</p>{%- endif -%}
                                  {%- if dd.settings.banner_cta_label != blank -%}
                                    <div class="dd-se__promo-cta-row">
                                      <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-se__promo-cta">
                                        {{ dd.settings.banner_cta_label }}
                                        {{- 'icon-paw.svg' | inline_asset_content -}}
                                      </a>
                                      <span class="dd-se__promo-scribble" aria-hidden="true"><svg viewBox="0 0 40 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 16c4-9 7 6 11-2s7 6 11-2"/></svg></span>
                                    </div>
                                  {%- endif -%}
                                </div>
                              </div>
                            {%- endif -%}
                          </div>

                          {%- assign se_usp_count = 0 -%}
                          {%- for u in se_usp_blocks -%}{%- if u.settings.menu_item_index == lx -%}{%- assign se_usp_count = se_usp_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
                          {%- if se_usp_count > 0 -%}
                            <div class="dd-se__trust">
                              {%- for u in se_usp_blocks -%}
                                {%- if u.settings.menu_item_index == lx -%}
                                  <span class="dd-se__usp" {{ u.shopify_attributes }}>
                                    <span class="dd-se__usp-icon dd-se__usp-icon--{{ u.settings.color }}" aria-hidden="true">{%- render 'lucide', icon: u.settings.icon -%}</span>
                                    {{ u.settings.text }}
                                  </span>
                                {%- endif -%}
                              {%- endfor -%}
                            </div>
                          {%- endif -%}
                        </div>

                      {%- comment -%} ══ LAYOUT: SHOP (mega categorieën) ══ {%- endcomment -%}
                      {%- elsif layout == 'shop' -%}
                        <div class="dd-shop">
                          <span class="dd-se__pointer" aria-hidden="true"></span>
                          <div class="dd-shop__body">
                            <div class="dd-shop__cats">
                              {%- for cb in shop_blocks -%}
                                {%- if cb.settings.menu_item_index == lx -%}
                                  <div class="dd-shop__cat dd-shop__cat--{{ cb.settings.color }}" {{ cb.shopify_attributes }}>
                                    <div class="dd-shop__cat-head">
                                      <span class="dd-shop__cat-icon" aria-hidden="true">{%- render 'lucide', icon: cb.settings.icon -%}</span>
                                      <div>
                                        <strong class="dd-shop__cat-title">{{ cb.settings.title }}</strong>
                                        {%- if cb.settings.description != blank -%}<span class="dd-shop__cat-desc">{{ cb.settings.description }}</span>{%- endif -%}
                                      </div>
                                    </div>
                                    {%- if cb.settings.link_list != blank and cb.settings.link_list.links.size > 0 -%}
                                      <ul class="dd-shop__cat-links" role="list">
                                        {%- for child in cb.settings.link_list.links -%}
                                          <li><a href="{{ child.url }}" class="dd-shop__cat-link"><span class="dd-shop__cat-dot" aria-hidden="true"></span>{{ child.title }}</a></li>
                                        {%- endfor -%}
                                      </ul>
                                    {%- endif -%}
                                    {%- if cb.settings.cta_label != blank -%}
                                      <a href="{{ cb.settings.cta_url | default: '#' }}" class="dd-shop__cat-cta">{{ cb.settings.cta_label }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
                                    {%- endif -%}
                                    {%- if cb.settings.image != blank -%}
                                      <div class="dd-shop__cat-photo">
                                        <img src="{{ cb.settings.image | image_url: width: 460 }}" alt="{{ cb.settings.image.alt | default: cb.settings.title | escape }}" width="230" height="130" loading="lazy">
                                        <span class="dd-shop__cat-photo-deco" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                                      </div>
                                    {%- endif -%}
                                  </div>
                                {%- endif -%}
                              {%- endfor -%}
                            </div>

                            {%- if dd.settings.banner_title != blank or dd.settings.banner_image != blank -%}
                              <div class="dd-shop__promo">
                                <div class="dd-shop__promo-top">
                                  {%- if dd.settings.banner_badge != blank -%}<span class="dd-shop__promo-badge">{{ dd.settings.banner_badge }}</span>{%- endif -%}
                                  <strong class="dd-shop__promo-title">{{ dd.settings.banner_title }}</strong>
                                  {%- if dd.settings.banner_text != blank -%}<p class="dd-shop__promo-text">{{ dd.settings.banner_text }}</p>{%- endif -%}
                                </div>
                                <div class="dd-shop__promo-media">
                                  {%- if dd.settings.banner_image != blank -%}
                                    <img src="{{ dd.settings.banner_image | image_url: width: 700 }}" alt="{{ dd.settings.banner_image.alt | default: dd.settings.banner_title | escape }}" width="350" height="280" loading="lazy" class="dd-shop__promo-img">
                                  {%- else -%}
                                    <div class="dd-shop__promo-img dd-shop__promo-img--ph">{%- render 'lucide', icon: 'gift' -%}</div>
                                  {%- endif -%}
                                  <span class="dd-shop__promo-deco dd-shop__promo-deco--paw" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM4 8a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 5a6 6 0 0 0-5.91 5.04A2.4 2.4 0 0 0 7.45 21c.86 0 1.62-.45 2.3-.86.43-.26.83-.5 1.25-.5s.82.24 1.25.5c.68.41 1.44.86 2.3.86a2.4 2.4 0 0 0 2.36-2.96A6 6 0 0 0 11 13Z"/></svg></span>
                                  <span class="dd-shop__promo-deco dd-shop__promo-deco--heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                                </div>
                                {%- if dd.settings.banner_cta_label != blank -%}
                                  <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-shop__promo-cta">{{ dd.settings.banner_cta_label }}{{- 'icon-paw.svg' | inline_asset_content -}}</a>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          </div>

                          {%- assign shop_usp_count = 0 -%}
                          {%- for u in se_usp_blocks -%}{%- if u.settings.menu_item_index == lx -%}{%- assign shop_usp_count = shop_usp_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
                          {%- if shop_usp_count > 0 -%}
                            <div class="dd-shop__trust">
                              {%- for u in se_usp_blocks -%}
                                {%- if u.settings.menu_item_index == lx -%}
                                  <span class="dd-se__usp" {{ u.shopify_attributes }}>
                                    <span class="dd-se__usp-icon dd-se__usp-icon--{{ u.settings.color }}" aria-hidden="true">{%- render 'lucide', icon: u.settings.icon -%}</span>
                                    {{ u.settings.text }}
                                  </span>
                                {%- endif -%}
                              {%- endfor -%}
                            </div>
                          {%- endif -%}

                          <div class="dd-shop__wave" aria-hidden="true">
                            <svg class="dd-shop__wave-svg" viewBox="0 0 1200 48" preserveAspectRatio="none"><path d="M0 26 C150 6 300 44 450 24 C600 6 750 44 900 24 C1050 8 1150 18 1200 26 L1200 48 L0 48 Z" fill="var(--color-green)"/></svg>
                            <span class="dd-shop__wave-deco dd-shop__wave-deco--1"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM4 8a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 5a6 6 0 0 0-5.91 5.04A2.4 2.4 0 0 0 7.45 21c.86 0 1.62-.45 2.3-.86.43-.26.83-.5 1.25-.5s.82.24 1.25.5c.68.41 1.44.86 2.3.86a2.4 2.4 0 0 0 2.36-2.96A6 6 0 0 0 11 13Z"/></svg></span>
                            <span class="dd-shop__wave-deco dd-shop__wave-deco--2"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                            <span class="dd-shop__wave-deco dd-shop__wave-deco--3"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM4 8a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 5a6 6 0 0 0-5.91 5.04A2.4 2.4 0 0 0 7.45 21c.86 0 1.62-.45 2.3-.86.43-.26.83-.5 1.25-.5s.82.24 1.25.5c.68.41 1.44.86 2.3.86a2.4 2.4 0 0 0 2.36-2.96A6 6 0 0 0 11 13Z"/></svg></span>
                            <span class="dd-shop__wave-deco dd-shop__wave-deco--4"><svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg></span>
                          </div>
                        </div>

                      {%- comment -%} ══ LAYOUT: STANDARD (Special Editions, default) ══ {%- endcomment -%}
                      {%- else -%}
                        <div class="dd-standard">
                          <div class="dd-standard__links-wrap">
                            {%- if dd.settings.link_list != blank -%}
                              <div class="dd-standard__grid">
                                {%- for child in dd.settings.link_list.links -%}
                                  <a href="{{ child.url }}" class="dd-standard__item"
                                     {% if child.active %}aria-current="page"{% endif %}>
                                    <span class="dd-standard__item-icon dd-link-icon--{{ dd.settings.accent_color }}" aria-hidden="true">
                                      {{- 'icon-paw.svg' | inline_asset_content -}}
                                    </span>
                                    <span class="dd-standard__item-text">
                                      <strong>{{ child.title }}</strong>
                                    </span>
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endfor -%}
                              </div>
                            {%- endif -%}
                            {%- if dd.settings.view_all_label != blank -%}
                              <a href="{{ dd.settings.view_all_url | default: link.url }}" class="dd-view-all dd-view-all--{{ dd.settings.accent_color }}">
                                {{ dd.settings.view_all_label }}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                              </a>
                            {%- endif -%}
                          </div>
                          {%- if dd.settings.banner_title != blank -%}
                            <div class="dd-banner">
                              {%- if dd.settings.banner_image != blank -%}
                                <div class="dd-banner__img-wrap">
                                  <img src="{{ dd.settings.banner_image | image_url: width: 600 }}"
                                       alt="{{ dd.settings.banner_image.alt | default: dd.settings.banner_title | escape }}"
                                       width="600" height="400" loading="lazy" class="dd-banner__img">
                                  {%- if dd.settings.banner_badge != blank -%}
                                    <span class="dd-banner__badge dd-banner__badge--{{ dd.settings.accent_color }}">{{ dd.settings.banner_badge }}</span>
                                  {%- endif -%}
                                </div>
                              {%- endif -%}
                              <div class="dd-banner__body">
                                <strong class="dd-banner__title">{{ dd.settings.banner_title }}</strong>
                                {%- if dd.settings.banner_text != blank -%}<span class="dd-banner__text">{{ dd.settings.banner_text }}</span>{%- endif -%}
                                {%- if dd.settings.banner_cta_label != blank -%}
                                  <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--{{ dd.settings.accent_color }}">
                                    {{ dd.settings.banner_cta_label }}
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endif -%}
                              </div>
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                    </div>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>

      </div>
    </header>
  {%- endif -%}



</div>

<!-- ══ OVERLAY ══════════════════════════════════════════ -->
<div class="site-header__overlay" id="nav-overlay" aria-hidden="true" data-nav-overlay></div>

<!-- ══ MOBIEL DRAWER ════════════════════════════════════ -->
<div class="header-drawer" id="header-drawer" role="dialog" aria-modal="true" aria-label="Navigatiemenu" aria-hidden="true">

  <!-- Header -->
  <div class="header-drawer__header">
    <a href="{{ routes.root_url }}" class="header-drawer__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}"
             alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
             width="120" height="auto" loading="lazy" class="header-drawer__logo-img">
      {%- else -%}
        <span class="header-drawer__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <div class="header-drawer__header-actions">
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header-drawer__icon-btn" aria-label="Account">
          {{- 'icon-account.svg' | inline_asset_content -}}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="header-drawer__icon-btn header-drawer__cart-btn" aria-label="Winkelwagen">
        {{- 'icon-cart.svg' | inline_asset_content -}}
        {%- if cart.item_count > 0 -%}
          <span class="header-drawer__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button class="header-drawer__close" aria-label="Sluiten" data-drawer-close>
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </div>
  </div>

  <!-- Trust bar -->
  {%- assign trust_blocks_drawer = section.blocks | where: 'type', 'trust_item' -%}
  {%- if trust_blocks_drawer.size > 0 -%}
    <div class="header-drawer__trust">
      {%- for block in trust_blocks_drawer limit: 3 -%}
        <div class="header-drawer__trust-item">
          <span class="header-drawer__trust-icon" aria-hidden="true">{{- block.settings.icon | inline_asset_content -}}</span>
          <span class="header-drawer__trust-text">{{ block.settings.title }}{%- if block.settings.subtitle != blank -%} {{ block.settings.subtitle }}{%- endif -%}</span>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Navigatie -->
  <nav aria-label="Mobiel menu" class="header-drawer__nav-wrap">
    <ul class="header-drawer__nav" role="list">
      {%- for link in section.settings.menu.links -%}
        {%- assign nav_lx = forloop.index -%}
        {%- assign nav_se_count = 0 -%}
        {%- for b in se_blocks -%}{%- if b.settings.menu_item_index == nav_lx -%}{%- assign nav_se_count = nav_se_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
        {%- assign nav_shop_count = 0 -%}
        {%- for b in shop_blocks -%}{%- if b.settings.menu_item_index == nav_lx -%}{%- assign nav_shop_count = nav_shop_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
        {%- assign nav_club_count = 0 -%}
        {%- for b in club_item_blocks -%}{%- if b.settings.menu_item_index == nav_lx -%}{%- assign nav_club_count = nav_club_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
        {%- assign drawer_has_sub = false -%}
        {%- if link.links.size > 0 or nav_se_count > 0 or nav_shop_count > 0 or nav_club_count > 0 -%}{%- assign drawer_has_sub = true -%}{%- endif -%}
        <li class="header-drawer__nav-item{% if drawer_has_sub %} header-drawer__nav-item--has-sub{% endif %}">
          <div class="header-drawer__nav-row">
            <span class="header-drawer__nav-icon header-drawer__nav-icon--{% if nav_lx == 1 %}green{% elsif nav_lx == 2 %}pink{% elsif nav_lx == 3 %}green{% elsif nav_lx == 4 %}orange{% else %}orange{% endif %}" aria-hidden="true">
              {%- if nav_lx == 1 -%}{{- 'icon-gift.svg' | inline_asset_content -}}
              {%- elsif nav_lx == 2 -%}{{- 'icon-gift.svg' | inline_asset_content -}}
              {%- elsif nav_lx == 3 -%}{{- 'icon-bone.svg' | inline_asset_content -}}
              {%- elsif nav_lx == 4 -%}{{- 'icon-paw.svg' | inline_asset_content -}}
              {%- else -%}{{- 'icon-heart.svg' | inline_asset_content -}}
              {%- endif -%}
            </span>
            <a href="{{ link.url }}" class="header-drawer__nav-link" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a>
            {%- if drawer_has_sub -%}
              <button class="header-drawer__sub-toggle" aria-expanded="false" aria-label="{{ link.title }} submenu">
                {{- 'icon-chevron-down.svg' | inline_asset_content -}}
              </button>
            {%- else -%}
              <svg class="header-drawer__nav-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
            {%- endif -%}
          </div>
          {%- if nav_se_count > 0 -%}
            <div class="header-drawer__sub-nav header-drawer__sub-nav--se" hidden>
              <ul class="header-drawer__se-list" role="list">
                {%- for b in se_blocks -%}
                  {%- if b.settings.menu_item_index == nav_lx -%}
                    <li>
                      <a href="{{ b.settings.url | default: '#' }}" class="header-drawer__se-link">
                        <span class="header-drawer__se-icon header-drawer__se-icon--{{ b.settings.color }}" aria-hidden="true">{%- render 'lucide', icon: b.settings.icon -%}</span>
                        <span class="header-drawer__se-text">
                          <strong>{{ b.settings.title }}</strong>
                          {%- if b.settings.description != blank -%}<span>{{ b.settings.description }}</span>{%- endif -%}
                        </span>
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
              {%- assign dd_se = nil -%}
              {%- for b in dd_blocks -%}{%- if b.settings.menu_item_index == nav_lx and b.settings.layout_type == 'special' -%}{%- assign dd_se = b -%}{%- endif -%}{%- endfor -%}
              {%- if dd_se and dd_se.settings.banner_title != blank -%}
                <a href="{{ dd_se.settings.banner_cta_url | default: link.url }}" class="header-drawer__se-promo">
                  {%- if dd_se.settings.banner_image != blank -%}
                    <img src="{{ dd_se.settings.banner_image | image_url: width: 640 }}" alt="{{ dd_se.settings.banner_title | escape }}" width="320" height="170" loading="lazy" class="header-drawer__se-promo-img">
                  {%- endif -%}
                  <span class="header-drawer__se-promo-body">
                    {%- if dd_se.settings.banner_badge != blank -%}<span class="header-drawer__se-promo-badge">{{ dd_se.settings.banner_badge }}</span>{%- endif -%}
                    <strong>{{ dd_se.settings.banner_title }}</strong>
                    {%- if dd_se.settings.banner_cta_label != blank -%}
                      <span class="header-drawer__se-promo-cta">{{ dd_se.settings.banner_cta_label }}{{- 'icon-paw.svg' | inline_asset_content -}}</span>
                    {%- endif -%}
                  </span>
                </a>
              {%- endif -%}
            </div>
          {%- elsif nav_shop_count > 0 -%}
            <div class="header-drawer__sub-nav header-drawer__sub-nav--shop" hidden>
              {%- for cb in shop_blocks -%}
                {%- if cb.settings.menu_item_index == nav_lx -%}
                  <details class="header-drawer__shop-cat header-drawer__shop-cat--{{ cb.settings.color }}" {{ cb.shopify_attributes }}>
                    <summary class="header-drawer__shop-summary">
                      <span class="header-drawer__shop-icon" aria-hidden="true">{%- render 'lucide', icon: cb.settings.icon -%}</span>
                      <span class="header-drawer__shop-text">
                        <strong>{{ cb.settings.title }}</strong>
                        {%- if cb.settings.description != blank -%}<span>{{ cb.settings.description }}</span>{%- endif -%}
                      </span>
                      <svg class="header-drawer__shop-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                    </summary>
                    {%- if cb.settings.link_list != blank and cb.settings.link_list.links.size > 0 -%}
                      <ul class="header-drawer__shop-links" role="list">
                        {%- for child in cb.settings.link_list.links -%}
                          <li><a href="{{ child.url }}" class="header-drawer__shop-link">{{ child.title }}</a></li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                    {%- if cb.settings.cta_label != blank -%}
                      <a href="{{ cb.settings.cta_url | default: '#' }}" class="header-drawer__shop-cta header-drawer__shop-cta--{{ cb.settings.color }}">{{ cb.settings.cta_label }}</a>
                    {%- endif -%}
                  </details>
                {%- endif -%}
              {%- endfor -%}
              {%- assign dd_shop = nil -%}
              {%- for b in dd_blocks -%}{%- if b.settings.menu_item_index == nav_lx and b.settings.layout_type == 'shop' -%}{%- assign dd_shop = b -%}{%- endif -%}{%- endfor -%}
              {%- if dd_shop and dd_shop.settings.banner_title != blank -%}
                <a href="{{ dd_shop.settings.banner_cta_url | default: link.url }}" class="header-drawer__se-promo">
                  {%- if dd_shop.settings.banner_image != blank -%}
                    <img src="{{ dd_shop.settings.banner_image | image_url: width: 640 }}" alt="{{ dd_shop.settings.banner_title | escape }}" width="320" height="170" loading="lazy" class="header-drawer__se-promo-img">
                  {%- endif -%}
                  <span class="header-drawer__se-promo-body">
                    {%- if dd_shop.settings.banner_badge != blank -%}<span class="header-drawer__se-promo-badge">{{ dd_shop.settings.banner_badge }}</span>{%- endif -%}
                    <strong>{{ dd_shop.settings.banner_title }}</strong>
                    {%- if dd_shop.settings.banner_cta_label != blank -%}<span class="header-drawer__se-promo-cta">{{ dd_shop.settings.banner_cta_label }}{{- 'icon-paw.svg' | inline_asset_content -}}</span>{%- endif -%}
                  </span>
                </a>
              {%- endif -%}
            </div>
          {%- elsif nav_club_count > 0 -%}
            <div class="header-drawer__sub-nav header-drawer__sub-nav--club" hidden>
              {%- assign dd_club = nil -%}
              {%- for b in dd_blocks -%}{%- if b.settings.menu_item_index == nav_lx and b.settings.layout_type == 'club' -%}{%- assign dd_club = b -%}{%- endif -%}{%- endfor -%}
              {%- if dd_club -%}
                <div class="header-drawer__club-intro">
                  <strong>{{ dd_club.settings.club_intro_title }}</strong>
                  {%- if dd_club.settings.club_intro_text != blank -%}<p>{{ dd_club.settings.club_intro_text }}</p>{%- endif -%}
                  {%- if dd_club.settings.banner_cta_label != blank -%}<a href="{{ dd_club.settings.banner_cta_url | default: link.url }}" class="header-drawer__club-cta">{{ dd_club.settings.banner_cta_label }}{{- 'icon-paw.svg' | inline_asset_content -}}</a>{%- endif -%}
                </div>
              {%- endif -%}
              <ul class="header-drawer__club-items" role="list">
                {%- for ci in club_item_blocks -%}{%- if ci.settings.menu_item_index == nav_lx -%}
                  <li><a href="{{ ci.settings.url | default: '#' }}" class="header-drawer__club-item header-drawer__club-item--{{ ci.settings.color }}">
                    <span class="header-drawer__club-item-icon" aria-hidden="true">{%- render 'lucide', icon: ci.settings.icon -%}</span>
                    <span class="header-drawer__club-item-text"><strong>{{ ci.settings.title }}</strong>{%- if ci.settings.description != blank -%}<span>{{ ci.settings.description }}</span>{%- endif -%}</span>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                  </a></li>
                {%- endif -%}{%- endfor -%}
              </ul>
              {%- if dd_club and dd_club.settings.club_rewards_title != blank -%}
                <a href="{{ dd_club.settings.view_all_url | default: link.url }}" class="header-drawer__club-card header-drawer__club-card--rewards">
                  <strong>{{ dd_club.settings.club_rewards_title }}</strong>
                  {%- if dd_club.settings.view_all_label != blank -%}<span class="header-drawer__club-pill">{{ dd_club.settings.view_all_label }}</span>{%- endif -%}
                </a>
              {%- endif -%}
              {%- if dd_club and dd_club.settings.club_motm_title != blank -%}
                <div class="header-drawer__club-card header-drawer__club-card--motm">
                  {%- if dd_club.settings.club_motm_image != blank -%}<img src="{{ dd_club.settings.club_motm_image | image_url: width: 400 }}" alt="{{ dd_club.settings.club_motm_name | escape }}" width="200" height="140" loading="lazy">{%- endif -%}
                  <strong>{{ dd_club.settings.club_motm_title }}{%- if dd_club.settings.club_motm_name != blank %} · {{ dd_club.settings.club_motm_name }}{%- endif -%}</strong>
                  {%- if dd_club.settings.club_motm_quote != blank -%}<p>{{ dd_club.settings.club_motm_quote }}</p>{%- endif -%}
                  {%- if dd_club.settings.club_motm_cta != blank -%}<a href="{{ dd_club.settings.club_motm_cta_url | default: link.url }}" class="header-drawer__club-pill">{{ dd_club.settings.club_motm_cta }}</a>{%- endif -%}
                </div>
              {%- endif -%}
              {%- if dd_club and dd_club.settings.campaign_title != blank -%}
                <div class="header-drawer__club-card header-drawer__club-card--campaign">
                  <strong>{{ dd_club.settings.campaign_title }}</strong>
                  {%- if dd_club.settings.campaign_text != blank -%}<p>{{ dd_club.settings.campaign_text }}</p>{%- endif -%}
                  {%- if dd_club.settings.campaign_cta_label != blank -%}<a href="{{ dd_club.settings.campaign_cta_url | default: link.url }}" class="header-drawer__club-pill">{{ dd_club.settings.campaign_cta_label }}</a>{%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- elsif link.links.size > 0 -%}
            <ul class="header-drawer__sub-nav" role="list" hidden>
              {%- for child in link.links -%}
                <li><a href="{{ child.url }}" class="header-drawer__sub-link" {% if child.active %}aria-current="page"{% endif %}>{{ child.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  <!-- Extra links -->
  <div class="header-drawer__extras">
    <a href="{{ routes.search_url }}" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
      <span>Zoeken</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    {%- if shop.customer_accounts_enabled -%}
      <a href="{{ routes.account_url }}" class="header-drawer__extra-link">
        <span class="header-drawer__extra-icon" aria-hidden="true">{{- 'icon-account.svg' | inline_asset_content -}}</span>
        <span>{%- if customer -%}Mijn account{%- else -%}{{ section.settings.account_label }}{%- endif -%}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    {%- endif -%}
    <a href="{{ routes.cart_url }}" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">{{- 'icon-cart.svg' | inline_asset_content -}}</span>
      <span>Winkelwagen</span>
      <span class="header-drawer__extra-badge">
        {%- if cart.item_count > 0 -%}<span class="header-drawer__cart-count">{{ cart.item_count }}</span>{%- endif -%}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </span>
    </a>
    <a href="/pages/klantenservice" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
      </span>
      <span>Klantenservice</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </a>
    <a href="/pages/veelgestelde-vragen" class="header-drawer__extra-link">
      <span class="header-drawer__extra-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </span>
      <span>Veelgestelde vragen</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </a>
  </div>

  <!-- Banner Kwispelclub -->
  {%- if section.settings.drawer_banner_title != blank -%}
    <div class="header-drawer__banner">
      <div class="header-drawer__banner-content">
        <strong class="header-drawer__banner-title">{{ section.settings.drawer_banner_title }}</strong>
        {%- if section.settings.drawer_banner_text != blank -%}
          <p class="header-drawer__banner-text">{{ section.settings.drawer_banner_text }}</p>
        {%- endif -%}
        {%- if section.settings.drawer_banner_cta != blank -%}
          <a href="{{ section.settings.drawer_banner_url | default: routes.root_url }}" class="header-drawer__banner-btn">
            {{ section.settings.drawer_banner_cta }}
            {{- 'icon-paw.svg' | inline_asset_content -}}
          </a>
        {%- endif -%}
      </div>
      {%- if section.settings.drawer_banner_image != blank -%}
        <div class="header-drawer__banner-img-wrap">
          <img src="{{ section.settings.drawer_banner_image | image_url: width: 300 }}"
               alt="{{ section.settings.drawer_banner_image.alt | escape }}"
               width="150" height="150" loading="lazy" class="header-drawer__banner-img">
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- Footer -->
  <div class="header-drawer__footer">
    <span class="header-drawer__footer-text">Woeff, tot snel! ♡</span>
    <div class="header-drawer__footer-wave" aria-hidden="true">
      <svg viewBox="0 0 375 48" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 24C62.5 24 62.5 48 125 48C187.5 48 187.5 24 250 24C312.5 24 312.5 48 375 48V0H0V24Z" fill="var(--color-green)" opacity="0.3"/>
        <path d="M0 32C62.5 32 62.5 48 125 48C187.5 48 187.5 32 250 32C312.5 32 312.5 48 375 48V48H0V32Z" fill="var(--color-green)"/>
      </svg>
    </div>
  </div>

</div>
<div class="header-drawer__overlay" id="header-overlay" aria-hidden="true" data-drawer-overlay></div>

{% stylesheet %}
/* ── Helpers ──────────────────────────────────────────── */
.site-header__sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;}

/* ── Wrapper ──────────────────────────────────────────── */
.site-header__wrapper{position:sticky;top:0;z-index:100;background:#fff;box-shadow:0 1px 0 rgba(61,34,9,.05);}

/* ══ TRUSTBAR ════════════════════════════════════════ */
.site-header__trust{background:var(--color-cream);border-bottom:1px solid var(--color-line);}
.site-header__trust-inner{max-width:var(--page-width);margin:0 auto;padding:0 var(--page-margin);}
.site-header__trust-list{list-style:none;margin:0;padding:0;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:14px 30px;min-height:42px;}
.site-header__trust-item{display:inline-flex;align-items:center;gap:8px;font-family:var(--font-body);font-size:.78rem;font-weight:700;color:var(--color-ink);}
.site-header__trust-icon{display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--color-green);}
.site-header__trust-icon svg{width:17px;height:17px;}
.site-header__trust-item:nth-child(2) .site-header__trust-icon{color:var(--color-pink);}
.site-header__trust-item:nth-child(3) .site-header__trust-icon{color:var(--color-orange);}
.site-header__trust-item:nth-child(4) .site-header__trust-icon{color:#d99100;}

/* ══ RIJ 1: TOP BAR (Logo + Zoek + Acties) ═══════════ */
.site-header__top{background:#fff;}
.site-header__top-inner{
  max-width:var(--page-width);
  margin:0 auto;
  padding:0 var(--page-margin);
  min-height:96px;
  display:grid;
  grid-template-columns:auto 1fr auto;
  align-items:center;
  gap:32px;
}

/* Logo — groot merkankerpunt */
.site-header__logo{display:flex;align-items:center;text-decoration:none;flex-shrink:0;}
.site-header__logo-img{height:auto;max-height:72px;width:auto;display:block;transition:transform 240ms ease;}
.site-header__logo:hover .site-header__logo-img{transform:scale(1.03) rotate(-1.5deg);}
.site-header__logo-text{font-family:var(--font-heading);font-size:1.75rem;color:var(--color-ink);white-space:nowrap;}

/* Premium zoekbalk */
.site-header__search-bar{position:relative;display:flex;align-items:center;width:100%;max-width:560px;margin:0 auto;}
.site-header__search-bar-field{
  flex:1;
  display:flex;
  align-items:center;
  gap:12px;
  height:56px;
  background:#fff;
  border:1.5px solid var(--color-line);
  border-radius:var(--radius-pill);
  padding:0 8px 0 22px;
  box-shadow:0 4px 16px rgba(61,34,9,.06);
  transition:border-color 220ms,box-shadow 220ms,transform 220ms;
}
.site-header__search-bar-field:focus-within{
  border-color:var(--color-green);
  box-shadow:0 10px 30px rgba(102,170,68,.18);
  transform:translateY(-1px);
}
.site-header__search-bar-icon{display:flex;align-items:center;color:var(--color-muted);flex-shrink:0;transition:color 220ms;}
.site-header__search-bar-field:focus-within .site-header__search-bar-icon{color:var(--color-green);}
.site-header__search-bar-icon svg{width:20px;height:20px;}
.site-header__search-bar-input{
  flex:1;
  background:none;
  border:none;
  outline:none;
  font-family:var(--font-body);
  font-size:.98rem;
  color:var(--color-ink);
  min-width:0;
  height:100%;
}
.site-header__search-bar-input::placeholder{color:var(--color-muted);}
.site-header__search-clear{display:flex;align-items:center;background:none;border:none;cursor:pointer;color:var(--color-muted);padding:4px;}
.site-header__search-clear svg{width:16px;height:16px;}
.site-header__search-bar-btn{
  height:44px;
  width:44px;
  background:var(--color-green);
  border:none;
  border-radius:var(--radius-pill);
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  flex-shrink:0;
  color:#fff;
  transition:background 160ms,transform 160ms;
}
.site-header__search-bar-btn:hover{background:#5a9a3b;transform:scale(1.06);}
.site-header__search-bar-btn svg{width:20px;height:20px;}
.site-header__search-results{
  position:absolute;
  top:calc(100% + 8px);
  left:0;
  right:0;
  background:#fff;
  border:1.5px solid var(--color-line);
  border-radius:var(--radius-lg);
  box-shadow:0 16px 44px rgba(61,34,9,.14);
  overflow:hidden;
  z-index:200;
}

/* Acties rechts — afgeronde Lucide icon buttons */
.site-header__actions{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.site-header__icon-btn{
  position:relative;
  display:flex;
  align-items:center;
  justify-content:center;
  width:48px;
  height:48px;
  border-radius:50%;
  background:var(--color-cream);
  border:1.5px solid var(--color-line);
  color:var(--color-ink);
  text-decoration:none;
  cursor:pointer;
  transition:background 200ms,border-color 200ms,transform 200ms,box-shadow 200ms;
}
.site-header__icon-btn:hover{
  background:#fff;
  border-color:var(--color-green);
  transform:translateY(-2px);
  box-shadow:0 10px 22px rgba(61,34,9,.10);
}
.site-header__icon-btn--cart:hover{border-color:var(--color-pink);}
.site-header__icon-btn svg{width:22px;height:22px;}
.site-header__cart-count{
  position:absolute;
  top:-5px;right:-5px;
  background:var(--color-pink);
  color:#fff;
  font-family:var(--font-body);
  font-size:.62rem;
  font-weight:800;
  min-width:20px;
  height:20px;
  padding:0 5px;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  border:2.5px solid #fff;
  box-shadow:0 2px 8px rgba(212,83,126,.4);
}

/* Hamburger (mobiel) */
.site-header__burger{display:none;align-items:center;justify-content:center;width:48px;height:48px;border-radius:50%;background:var(--color-cream);border:1.5px solid var(--color-line);cursor:pointer;color:var(--color-ink);}
.site-header__burger svg{width:24px;height:24px;display:block;}

/* ══ RIJ 2: NAVIGATIE ════════════════════════════════ */
.site-header{background:#fff;}
.site-header__nav-row{
  position:relative;
  max-width:var(--page-width);
  margin:0 auto;
  padding:6px var(--page-margin) 16px;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
}
/* Subtiele decoratieve merkaccenten rond de nav */
.site-header__nav-deco{position:absolute;inset:0;pointer-events:none;z-index:0;}
.site-header__nav-deco span{position:absolute;display:block;}
.site-header__nav-deco span svg{display:block;width:100%;height:100%;}
.site-header__nav-deco-1{top:10px;left:5%;width:22px;height:22px;color:var(--color-green);opacity:.16;transform:rotate(-14deg);}
.site-header__nav-deco-2{top:20px;left:22%;width:13px;height:13px;color:var(--color-pink);opacity:.22;}
.site-header__nav-deco-3{top:12px;right:22%;width:15px;height:15px;color:var(--color-yellow);opacity:.55;transform:rotate(10deg);}
.site-header__nav-deco-4{bottom:6px;right:6%;width:42px;height:18px;color:var(--color-orange);opacity:.28;}
.site-header__nav{position:relative;z-index:1;display:flex;align-items:center;}
.site-header__chips{display:flex;align-items:center;gap:6px;list-style:none;margin:0;padding:0;}
.site-header__chip-item{position:static;}
.site-header__chip{
  display:inline-flex;align-items:center;gap:8px;
  padding:10px 18px;
  border-radius:var(--radius-pill);
  font-family:var(--font-body);
  font-size:.92rem;
  font-weight:700;
  text-decoration:none;
  white-space:nowrap;
  color:var(--color-ink);
  background:none;
  border:1.5px solid transparent;
  cursor:pointer;
  transition:background 180ms,color 180ms,border-color 180ms,transform 180ms;
}
.site-header__chip:hover{transform:translateY(-1px);}
.site-header__chip:hover,.site-header__chip[aria-expanded="true"]{background:var(--color-cream);}
.site-header__chip[aria-current="page"]{background:#e8f5e2;color:var(--color-green);border-color:rgba(102,170,68,.28);}
.site-header__chip--green{color:var(--color-green);}
.site-header__chip--green:hover,.site-header__chip--green[aria-expanded="true"]{background:#e8f5e2;}
.site-header__chip--pink{color:var(--color-pink);}.site-header__chip--pink:hover,.site-header__chip--pink[aria-expanded="true"]{background:#ffe0ee;}
.site-header__chip--orange{color:var(--color-orange);}.site-header__chip--orange:hover,.site-header__chip--orange[aria-expanded="true"]{background:#fff0e4;}
.site-header__chip--yellow{color:var(--color-yellow);}.site-header__chip--yellow:hover,.site-header__chip--yellow[aria-expanded="true"]{background:#fffae0;}
.site-header__chip-icon{display:inline-flex;align-items:center;flex-shrink:0;}
.site-header__chip-icon svg{width:17px;height:17px;}
.site-header__chip-chevron{display:inline-flex;align-items:center;margin-left:2px;transition:transform 200ms ease;}
.site-header__chip-chevron svg{width:13px;height:13px;}
.site-header__chip[aria-expanded="true"] .site-header__chip-chevron{transform:rotate(180deg);}

/* ══ DROPDOWN ════════════════════════════════════════ */
.site-header__dropdown{
  position:fixed;
  left:0;right:0;
  top:var(--header-bottom,136px);
  background:transparent;
  z-index:99;
  opacity:0;visibility:hidden;
  transform:translateY(-6px);
  transition:opacity 200ms ease,visibility 200ms ease,transform 200ms ease;
  pointer-events:none;
  padding:8px 0 0;
}
.site-header__dropdown[data-open]{opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto;}
.site-header__dropdown-card{
  background:#fff;
  border-radius:20px;
  box-shadow:0 20px 60px rgba(61,34,9,.12);
  border:1.5px solid var(--color-line);
  overflow:hidden;
  max-width:var(--page-width);
  margin:0 auto;
}

/* Trust bar verwijderd */

/* ══ OVERLAY ═════════════════════════════════════════ */
.site-header__overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:98;opacity:0;visibility:hidden;transition:opacity 200ms,visibility 200ms;}
.site-header__overlay[aria-hidden="false"]{opacity:1;visibility:visible;}

/* ══ ZOEKRESULTATEN ══════════════════════════════════ */
.search-result-item{display:flex;align-items:center;gap:12px;padding:10px 16px;text-decoration:none;color:var(--color-ink);border-bottom:1px solid var(--color-line);transition:background 120ms;}
.search-result-item:last-child{border-bottom:none;}
.search-result-item:hover,.search-result-item[aria-selected="true"]{background:var(--color-cream);}
.search-result-item__img{width:44px;height:44px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0;background:var(--color-cream);}
.search-result-item__title{font-family:var(--font-body);font-size:.88rem;font-weight:700;color:var(--color-ink);}
.search-result-item__price{font-family:var(--font-body);font-size:.82rem;color:var(--color-muted);margin-top:2px;}
.search-result-item__all{display:block;padding:10px 16px;font-family:var(--font-body);font-size:.85rem;font-weight:700;color:var(--color-ink);text-decoration:none;text-align:center;border-top:1px solid var(--color-line);}
.search-result-item__all:hover{background:var(--color-cream);}

/* ══ MOBIEL ══════════════════════════════════════════ */
@media(max-width:989px){
  .site-header__top-inner{
    grid-template-columns:1fr auto;
    min-height:68px;
    gap:12px;
  }
  .site-header__search-bar{display:none;}
