                                  <span class="dd-club__polaroid-ph" aria-hidden="true">{%- render 'lucide', icon: 'dog' -%}</span>
                                {%- endif -%}
                                {%- if dd.settings.club_motm_name != blank -%}<span class="dd-club__polaroid-label">{{ dd.settings.club_motm_name }}</span>{%- endif -%}
                              </div>
                              {%- if dd.settings.club_motm_quote != blank -%}<p class="dd-club__motm-quote">{{ dd.settings.club_motm_quote }}</p>{%- endif -%}
                              {%- if dd.settings.club_motm_cta != blank -%}
                                <a href="{{ dd.settings.club_motm_cta_url | default: link.url }}" class="dd-club__motm-cta"><span aria-hidden="true">{%- render 'lucide', icon: 'camera' -%}</span>{{ dd.settings.club_motm_cta }}</a>
                              {%- endif -%}
                            </div>

                          </div>

                          {%- if dd.settings.campaign_title != blank -%}
