                              <div class="dd-club__campaign-img">
                                {%- if dd.settings.campaign_image != blank -%}<img src="{{ dd.settings.campaign_image | image_url: width: 200 }}" alt="" width="80" height="80" loading="lazy">{%- else -%}<span aria-hidden="true">{%- render 'lucide', icon: 'gift' -%}</span>{%- endif -%}
                              </div>
                              <div class="dd-club__campaign-text">
                                <strong>{{ dd.settings.campaign_title }}</strong>
                                {%- if dd.settings.campaign_text != blank -%}
                                  {%- assign camp = dd.settings.campaign_text -%}
                                  {%- if dd.settings.campaign_highlight != blank -%}{%- capture chh -%}<span class="dd-club__pink">{{ dd.settings.campaign_highlight }}</span>{%- endcapture -%}{%- assign camp = camp | replace: dd.settings.campaign_highlight, chh -%}{%- endif -%}
                                  <span>{{ camp }}</span>
                                {%- endif -%}
                              </div>
                              {%- if dd.settings.campaign_cta_label != blank -%}
                                <a href="{{ dd.settings.campaign_cta_url | default: link.url }}" class="dd-club__campaign-cta">{{ dd.settings.campaign_cta_label }}</a>
                              {%- endif -%}
                              <span class="dd-club__campaign-deco dd-club__campaign-deco--1" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                              <span class="dd-club__campaign-deco dd-club__campaign-deco--2" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg></span>
                            </div>
                          {%- endif -%}

                          {%- assign club_usp_count = 0 -%}
                          {%- for u in se_usp_blocks -%}{%- if u.settings.menu_item_index == lx -%}{%- assign club_usp_count = club_usp_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
                          {%- if club_usp_count > 0 -%}
                            <div class="dd-club__trust">
                              {%- for u in se_usp_blocks -%}{%- if u.settings.menu_item_index == lx -%}
                                <span class="dd-se__usp" {{ u.shopify_attributes }}>
                                  <span class="dd-se__usp-icon dd-se__usp-icon--{{ u.settings.color }}" aria-hidden="true">{%- render 'lucide', icon: u.settings.icon -%}</span>
                                  {{ u.settings.text }}
                                </span>
                              {%- endif -%}{%- endfor -%}
                            </div>
                          {%- endif -%}

                          {%- if dd.settings.club_peek_image != blank -%}
