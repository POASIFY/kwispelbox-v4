                                  <span class="dd-club__item-text">
                                    <strong>{{ ci.settings.title }}</strong>
                                    {%- if ci.settings.description != blank -%}<span>{{ ci.settings.description }}</span>{%- endif -%}
                                  </span>
                                  <svg class="dd-club__item-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                                </a>
                              {%- endif -%}{%- endfor -%}
                            </div>

                            <div class="dd-club__rewards">
                              <span class="dd-club__reward-deco dd-club__reward-deco--star" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg></span>
                              <strong class="dd-club__card-title">{{ dd.settings.club_rewards_title }}</strong>
                              {%- if club_reward_blocks.size > 0 -%}
                                <div class="dd-club__reward-grid">
                                  {%- for cr in club_reward_blocks -%}{%- if cr.settings.menu_item_index == lx -%}
                                    <div class="dd-club__reward" {{ cr.shopify_attributes }}>
                                      <span class="dd-club__reward-bubble">
                                        {%- if cr.settings.image != blank -%}<img src="{{ cr.settings.image | image_url: width: 160 }}" alt="{{ cr.settings.image.alt | escape }}" width="80" height="80" loading="lazy">{%- else -%}<span class="dd-club__reward-ph" aria-hidden="true">{%- render 'lucide', icon: 'gift' -%}</span>{%- endif -%}
                                      </span>
                                      {%- if cr.settings.points != blank -%}<span class="dd-club__reward-badge">{{ cr.settings.points }}</span>{%- endif -%}
                                    </div>
                                  {%- endif -%}{%- endfor -%}
                                </div>
                              {%- endif -%}
                              {%- if dd.settings.view_all_label != blank -%}
                                <a href="{{ dd.settings.view_all_url | default: link.url }}" class="dd-club__rewards-cta">{{ dd.settings.view_all_label }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
                              {%- endif -%}
                            </div>

                            <div class="dd-club__motm">
                              <strong class="dd-club__card-title"><span class="dd-club__motm-star" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg></span>{{ dd.settings.club_motm_title }}</strong>
                              <div class="dd-club__polaroid">
                                <span class="dd-club__polaroid-tape" aria-hidden="true"></span>
                                <span class="dd-club__polaroid-crown" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"/></svg></span>
                                {%- if dd.settings.club_motm_image != blank -%}
