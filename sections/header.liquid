                                {%- capture chl -%}<span class="dd-club__pink">{{ dd.settings.club_intro_highlight }}</span>{%- endcapture -%}
                                {%- assign club_title = club_title | replace: dd.settings.club_intro_highlight, chl -%}
                              {%- endif -%}
                              <strong class="dd-club__intro-title">{{ club_title }}</strong>
