                                  <span class="dd-club__intro-photo-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                                </div>
                              {%- endif -%}
                              {%- if dd.settings.banner_cta_label != blank -%}
                                <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-club__intro-cta">{{ dd.settings.banner_cta_label }}{{- 'icon-paw.svg' | inline_asset_content -}}</a>
                              {%- endif -%}
                              {%- if dd.settings.club_intro_note != blank -%}
                                <span class="dd-club__intro-note">{{ dd.settings.club_intro_note }}<span class="dd-club__squiggle" aria-hidden="true"><svg viewBox="0 0 42 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 8c5-7 8 5 13-1s7 5 12-1 8 4 13-1"/></svg></span></span>
                              {%- endif -%}
                            </div>

                            <div class="dd-club__items">
