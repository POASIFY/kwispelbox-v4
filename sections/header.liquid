.dd-se__viewall svg{width:15px;height:15px;}

/* Promotiekaart rechts */
.dd-se__promo{display:flex;flex-direction:column;background:#f3e7d2;border-radius:20px;overflow:hidden;border:1.5px solid rgba(61,34,9,.07);}
