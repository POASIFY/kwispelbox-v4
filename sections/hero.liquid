{%- comment -%}
  sections/hero.liquid — Kwispelbox KB-v4
  Split layout: tekst links, afbeelding rechts
  LCP-geoptimaliseerd
{%- endcomment -%}

<section class="hero">
  <div class="hero__inner">

    <!-- Tekst kolom -->
    <div class="hero__content">

      {%- if section.settings.label != blank -%}
        <span class="hero__label">{{ section.settings.label }}</span>
      {%- endif -%}

      <h1 class="hero__title">
        {{ section.settings.title }}
        {%- if section.settings.title_highlight != blank -%}
          <span class="hero__title-highlight">{{ section.settings.title_highlight }}</span>
        {%- endif -%}
      </h1>

      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}

      <div class="hero__buttons">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="hero__btn hero__btn--primary">
            {{ section.settings.cta_primary_label }}
            <span class="hero__btn-icon" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="hero__btn hero__btn--secondary">
            {{ section.settings.cta_secondary_label }}
            <span class="hero__btn-icon" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.review_text != blank -%}
        <div class="hero__reviews">
          {%- if section.settings.review_avatars != blank -%}
            <img src="{{ section.settings.review_avatars | image_url: width: 120 }}" alt="" width="60" height="20" loading="lazy" class="hero__review-avatars">
          {%- endif -%}
          <span class="hero__review-stars" aria-hidden="true">★★★★★</span>
          <span class="hero__review-text">{{ section.settings.review_text }}</span>
        </div>
      {%- endif -%}

    </div>

    <!-- Afbeelding kolom -->
    {%- if section.settings.image != blank -%}
      <div class="hero__media">
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="{{ section.settings.image | image_url: width: 400 }} 400w,
                  {{ section.settings.image | image_url: width: 800 }} 800w,
                  {{ section.settings.image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 749px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: shop.name | escape }}"
          width="800"
          height="600"
          {%- if section.index <= 1 -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
          class="hero__img">

        {%- if section.settings.badge_text != blank -%}
          <div class="hero__badge">
            <span class="hero__badge-text">{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}

.hero {
  background: var(--color-cream);
  overflow: hidden;
}

.hero__inner {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 48px var(--page-margin);
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 48px;
  min-height: 480px;
}

/* Tekst kolom */
.hero__label {
  display: inline-block;
  font-family: var(--font-body);
  font-size: .78rem;
  font-weight: 800;
  color: var(--color-green);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-bottom: 12px;
}

.hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 3.5vw, 3rem);
  color: var(--color-ink);
  line-height: 1.15;
  margin: 0 0 8px;
}

.hero__title-highlight {
  display: block;
  color: var(--color-pink);
}

.hero__text {
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--color-body);
  line-height: 1.6;
  margin: 16px 0 28px;
  max-width: 42ch;
}

.hero__buttons {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.hero__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 24px;
  border-radius: var(--radius-pill);
  font-family: var(--font-heading);
  font-size: 1rem;
  text-decoration: none;
  transition: transform 160ms, box-shadow 160ms;
}

.hero__btn:hover { transform: translateY(-1px); }

.hero__btn--primary {
  background: var(--color-pink);
  color: #fff;
}

.hero__btn--primary:hover {
  box-shadow: 0 6px 20px rgba(212,83,126,.35);
}

.hero__btn--secondary {
  background: none;
  color: var(--color-green);
  border: 2px solid var(--color-green);
}

.hero__btn--secondary:hover {
  background: #e8f5e2;
}

.hero__btn-icon {
  display: flex;
  align-items: center;
}

.hero__btn-icon svg {
  width: 18px;
  height: 18px;
}

.hero__btn--secondary .hero__btn-icon svg {
  transform: rotate(-90deg);
}

.hero__reviews {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 24px;
}

.hero__review-avatars {
  height: 28px;
  width: auto;
  border-radius: var(--radius-pill);
}

.hero__review-stars {
  color: var(--color-yellow);
  font-size: 1rem;
  letter-spacing: 1px;
}

.hero__review-text {
  font-family: var(--font-body);
  font-size: .8rem;
  color: var(--color-muted);
  font-weight: 600;
}

/* Afbeelding kolom */
.hero__media {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.hero__img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: var(--radius-lg);
  object-fit: cover;
  aspect-ratio: 4/3;
}

.hero__badge {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 100px;
  height: 100px;
  background: var(--color-pink);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px;
}

.hero__badge-text {
  font-family: var(--font-heading);
  font-size: .75rem;
  color: #fff;
  text-align: center;
  line-height: 1.3;
}

/* Mobiel */
@media (max-width: 749px) {
  .hero__inner {
    grid-template-columns: 1fr;
    padding: 32px var(--page-margin);
    gap: 24px;
    min-height: auto;
  }

  .hero__media { order: -1; }

  .hero__title { font-size: 2rem; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label boven titel" },
    { "type": "textarea", "id": "title", "label": "Titel", "default": "Elke box een nieuwe" },
    { "type": "text", "id": "title_highlight", "label": "Gemarkeerde tekst (roze)", "default": "verrassing!" },
    { "type": "textarea", "id": "text", "label": "Tekst", "default": "Met liefde samengesteld voor jouw hond.\nVol plezier, verwennerij en gezonde snacks." },
    { "type": "text", "id": "cta_primary_label", "label": "Knop 1 tekst", "default": "Ontdek de boxen" },
    { "type": "url", "id": "cta_primary_url", "label": "Knop 1 link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Knop 2 tekst", "default": "Hoe het werkt" },
    { "type": "url", "id": "cta_secondary_url", "label": "Knop 2 link" },
    { "type": "text", "id": "review_text", "label": "Review tekst", "default": "4,9/5 uit 1.200+ reviews" },
    { "type": "image_picker", "id": "review_avatars", "label": "Avatar foto's (optioneel)" },
    { "type": "image_picker", "id": "image", "label": "Hero afbeelding" },
    { "type": "text", "id": "badge_text", "label": "Badge tekst (optioneel)", "default": "Elke maand een feestje voor je hond" }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "title": "Elke box een nieuwe",
        "title_highlight": "verrassing!",
        "text": "Met liefde samengesteld voor jouw hond.\nVol plezier, verwennerij en gezonde snacks.",
        "cta_primary_label": "Ontdek de boxen",
        "cta_secondary_label": "Hoe het werkt",
        "review_text": "4,9/5 uit 1.200+ reviews",
        "badge_text": "Elke maand een feestje voor je hond \u2665"
      }
    }
  ]
}
{% endschema %}
