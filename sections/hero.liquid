{% comment %}
  sections/hero.liquid — Kwispelbox KB-v3
  Homepage hero sectie met twee layouts:
  - split: tekst links, afbeelding rechts (desktop), gestapeld op mobiel
  - fullscreen: afbeelding op volle breedte met tekst overlay

  LCP-geoptimaliseerd: <img> tag met fetchpriority="high" en loading="eager"
  als section.index <= 3 (boven de vouw).
{% endcomment %}

{%- assign is_above_fold = false -%}
{%- if section.index <= 3 -%}
  {%- assign is_above_fold = true -%}
{%- endif -%}

{%- assign layout = section.settings.layout -%}
{%- assign has_image = false -%}
{%- if section.settings.image != blank -%}{%- assign has_image = true -%}{%- endif -%}
{%- assign has_mobile_image = false -%}
{%- if section.settings.mobile_image != blank -%}{%- assign has_mobile_image = true -%}{%- endif -%}

<div class="hero hero--{{ layout }}{% if section.settings.full_width %} full-width{% endif %}"
     data-section-id="{{ section.id }}">

  {%- if layout == 'split' -%}
    {# ── SPLIT LAYOUT ── #}
    <div class="hero__inner hero__inner--split">

      {# Tekst kolom #}
      <div class="hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="hero__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url }}"
             class="hero__btn hero__btn--primary">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_url_2 }}"
             class="hero__btn hero__btn--secondary">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}

        {# Trust badges blokken #}
        {%- assign trust_blocks = section.blocks | where: 'type', 'trust_badge' -%}
        {%- if trust_blocks.size > 0 -%}
          <ul class="hero__trust-list" role="list">
            {%- for block in trust_blocks -%}
              <li class="hero__trust-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="hero__trust-icon">
                    {{- block.settings.icon | inline_asset_content -}}
                  </span>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="hero__trust-label">{{ block.settings.label }}</span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {# Afbeelding kolom #}
      <div class="hero__media">
        {%- if has_image -%}
          {%- if is_above_fold -%}
            {{- section.settings.image
                | image_url: width: 1200
                | image_tag:
                    loading: 'eager',
                    fetchpriority: 'high',
                    widths: '400, 600, 800, 1000, 1200',
                    sizes: '(max-width: 749px) 100vw, 50vw',
                    class: 'hero__img',
                    alt: section.settings.image.alt | default: shop.name -}}
          {%- else -%}
            {{- section.settings.image
                | image_url: width: 1200
                | image_tag:
                    loading: 'lazy',
                    widths: '400, 600, 800, 1000, 1200',
                    sizes: '(max-width: 749px) 100vw, 50vw',
                    class: 'hero__img',
                    alt: section.settings.image.alt | default: shop.name -}}
          {%- endif -%}
        {%- else -%}
          <div class="hero__img-placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

    </div>

  {%- else -%}
    {# ── FULLSCREEN LAYOUT ── #}
    <div class="hero__inner hero__inner--fullscreen">

      {# Achtergrondafbeelding #}
      {%- if has_image -%}
        <div class="hero__bg-wrap">
          {%- if has_mobile_image -%}
            <picture>
              <source
                media="(max-width: 749px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 800 }} 800w,
                        {{ section.settings.mobile_image | image_url: width: 600 }} 600w,
                        {{ section.settings.mobile_image | image_url: width: 400 }} 400w"
                sizes="100vw">
              <source
                media="(min-width: 750px)"
                srcset="{{ section.settings.image | image_url: width: 2000 }} 2000w,
                        {{ section.settings.image | image_url: width: 1600 }} 1600w,
                        {{ section.settings.image | image_url: width: 1200 }} 1200w"
                sizes="100vw">
              <img
                src="{{ section.settings.image | image_url: width: 1600 }}"
                alt="{{ section.settings.image.alt | default: shop.name }}"
                class="hero__bg-img"
                width="{{ section.settings.image.width }}"
                height="{{ section.settings.image.height }}"
              loading="{% if is_above_fold %}eager{% else %}lazy{% endif %}"
                {% if is_above_fold %}fetchpriority="high"{% endif %}>
            </picture>
          {%- else -%}
            <img
              src="{{ section.settings.image | image_url: width: 1600 }}"
              srcset="{{ section.settings.image | image_url: width: 2000 }} 2000w,
                      {{ section.settings.image | image_url: width: 1600 }} 1600w,
                      {{ section.settings.image | image_url: width: 1200 }} 1200w,
                      {{ section.settings.image | image_url: width: 800  }} 800w"
              sizes="100vw"
              alt="{{ section.settings.image.alt | default: shop.name }}"
              class="hero__bg-img"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="{% if is_above_fold %}eager{% else %}lazy{% endif %}"
              {% if is_above_fold %}fetchpriority="high"{% endif %}>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="hero__bg-placeholder">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'hero__placeholder-svg' }}
        </div>
      {%- endif -%}

      {# Overlay #}
      <div class="hero__overlay" style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

      {# Tekst inhoud #}
      <div class="hero__content hero__content--{{ section.settings.text_align }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="hero__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        <div class="hero__btn-group">
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_url }}"
               class="hero__btn hero__btn--primary">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_url_2 }}"
               class="hero__btn hero__btn--secondary">
              {{ section.settings.button_label_2 }}
            </a>
          {%- endif -%}
        </div>

        {# Trust badges blokken #}
        {%- assign trust_blocks = section.blocks | where: 'type', 'trust_badge' -%}
        {%- if trust_blocks.size > 0 -%}
          <ul class="hero__trust-list" role="list">
            {%- for block in trust_blocks -%}
              <li class="hero__trust-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="hero__trust-icon">
                    {{- block.settings.icon | inline_asset_content -}}
                  </span>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="hero__trust-label">{{ block.settings.label }}</span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

    </div>
  {%- endif -%}

</div>

{% stylesheet %}

/* ─── Hero base ─────────────────────────────────────── */
.hero {
  position: relative;
  overflow: hidden;
}

.hero.full-width {
  width: 100%;
}

/* ─── Split layout ──────────────────────────────────── */
.hero--split .hero__inner--split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 48px;
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 80px var(--page-margin);
}

.hero--split .hero__media {
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.hero--split .hero__img {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: var(--radius-lg);
}

/* ─── Fullscreen layout ─────────────────────────────── */
.hero--fullscreen .hero__inner--fullscreen {
  position: relative;
  min-height: 560px;
  display: flex;
  align-items: center;
}

.hero__bg-wrap {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.hero__bg-placeholder {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero__bg-placeholder .hero__placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background-color: rgba(0, 0, 0, var(--overlay-opacity, 0.3));
}

.hero--fullscreen .hero__content {
  position: relative;
  z-index: 2;
  max-width: var(--page-width);
  width: 100%;
  margin: 0 auto;
  padding: 80px var(--page-margin);
  color: #fff;
}

.hero--fullscreen .hero__content--center {
  text-align: center;
}

.hero--fullscreen .hero__content--left {
  text-align: left;
  max-width: 640px;
}

/* ─── Gedeelde tekst stijlen ────────────────────────── */
.hero__eyebrow {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: 12px;
}

.hero--fullscreen .hero__eyebrow {
  color: var(--color-yellow);
}

.hero__heading {
  font-family: var(--font-heading);
  font-size: clamp(36px, 5vw, 64px);
  line-height: 1.1;
  color: var(--color-ink);
  margin-bottom: 16px;
}

.hero--fullscreen .hero__heading {
  color: #fff;
}

.hero__subheading {
  font-family: var(--font-body);
  font-size: clamp(16px, 2vw, 20px);
  line-height: 1.6;
  color: var(--color-body);
  margin-bottom: 32px;
  max-width: 520px;
}

.hero--fullscreen .hero__subheading {
  color: rgba(255, 255, 255, 0.88);
}

.hero--fullscreen .hero__content--center .hero__subheading {
  margin-left: auto;
  margin-right: auto;
}

/* ─── Knoppen ───────────────────────────────────────── */
.hero__btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.hero--fullscreen .hero__content--center .hero__btn-group {
  justify-content: center;
}

.hero__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 28px;
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  cursor: pointer;
}

.hero__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
}

.hero__btn--primary {
  background-color: var(--color-orange);
  color: #fff;
}

.hero__btn--secondary {
  background-color: transparent;
  color: var(--color-ink);
  border: 2px solid var(--color-ink);
}

.hero--fullscreen .hero__btn--secondary {
  color: #fff;
  border-color: rgba(255, 255, 255, 0.6);
}

/* Hero split: knoppen naast elkaar */
.hero--split .hero__btn + .hero__btn {
  margin-top: 0;
}
.hero--split .hero__content .hero__btn {
  margin-top: 0;
}
.hero--split .hero__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.hero--split .hero__btn--primary,
.hero--split .hero__btn--secondary {
  margin-top: 0;
}
.hero--split .hero__btn + .hero__btn--secondary {
  margin-top: 0;
}
.hero--split .hero__content > .hero__btn {
  margin-bottom: 0;
}
/* Knoppenrij voor split layout */
.hero--split .hero__btn-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 8px;
}

/* ─── Trust badges ──────────────────────────────────── */
.hero__trust-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  list-style: none;
  padding: 0;
  margin-top: 28px;
}

.hero__trust-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  color: var(--color-body);
}

.hero--fullscreen .hero__trust-item {
  color: rgba(255, 255, 255, 0.85);
}

.hero__trust-icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  width: 18px;
  height: 18px;
  color: var(--color-green);
}

.hero--fullscreen .hero__trust-icon {
  color: var(--color-yellow);
}

.hero__trust-icon svg {
  width: 100%;
  height: 100%;
}

/* ─── Placeholder ───────────────────────────────────── */
.hero__img-placeholder {
  border-radius: var(--radius-lg);
  overflow: hidden;
  aspect-ratio: 4 / 3;
  background-color: var(--color-cream);
}

.hero__placeholder-svg {
  width: 100%;
  height: 100%;
}

/* ─── Mobiel (≤ 749px) ──────────────────────────────── */
@media (max-width: 749px) {
  .hero--split .hero__inner--split {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 48px var(--page-margin);
  }

  /* Afbeelding boven tekst op mobiel */
  .hero--split .hero__media {
    order: -1;
  }

  .hero--fullscreen .hero__inner--fullscreen {
    min-height: 480px;
  }

  .hero--fullscreen .hero__content {
    padding: 48px var(--page-margin);
  }

  .hero__heading {
    font-size: clamp(30px, 8vw, 42px);
  }

  .hero__trust-list {
    gap: 12px;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "split",      "label": "Split (tekst + foto)" },
        { "value": "fullscreen", "label": "Fullscreen (foto achtergrond)" }
      ],
      "default": "split"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Volledige paginabreedte",
      "default": true
    },
    {
      "type": "header",
      "content": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobiele afbeelding (optioneel)",
      "info": "Alleen voor fullscreen layout. Laat leeg om de hoofdafbeelding te gebruiken."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay donkerheid",
      "min": 0,
      "max": 70,
      "step": 5,
      "default": 30,
      "unit": "%",
      "info": "Alleen voor fullscreen layout"
    },
    {
      "type": "header",
      "content": "Tekst"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow tekst"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Koptekst"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtekst"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Tekstuitlijning",
      "options": [
        { "value": "left",   "label": "Links" },
        { "value": "center", "label": "Gecentreerd" }
      ],
      "default": "left",
      "info": "Alleen voor fullscreen layout"
    },
    {
      "type": "header",
      "content": "Knoppen"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primaire knop tekst"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Primaire knop URL"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secundaire knop tekst"
    },
    {
      "type": "url",
      "id": "button_url_2",
      "label": "Secundaire knop URL"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "icon",
          "label": "SVG icoon (asset naam)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Tekst"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "layout": "split",
        "eyebrow": "Verrassingen voor jouw hond",
        "heading": "Een feestje voor je hond.",
        "subheading": "Verrassingsboxen vol speelgoed waar staarten sneller van gaan kwispelen.",
        "button_label": "Ontdek de boxen",
        "button_label_2": "Hoe werkt het?"
      }
    }
  ]
}
{% endschema %}
