{%- comment -%}
  sections/hero.liquid — Kwispelbox KB-v4
  Levendige 2-koloms hero: tekst + hond naast elkaar (ook mobiel),
  zwevende hartjes/krabbels, groene golf boven, roze golf onder.
{%- endcomment -%}

<section class="hero full-width">

  <div class="hero__wave hero__wave--top" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,15 C180,60 360,0 540,30 C720,60 900,8 1080,38 C1260,60 1380,15 1440,30 L1440,0 L0,0 Z" fill="#66AA44"/>
    </svg>
  </div>

  <div class="hero__inner">
    <div class="hero__content">

      {%- if section.settings.label != blank -%}
        <span class="hero__label">{{ section.settings.label }}</span>
      {%- endif -%}

      <h1 class="hero__title">
        {{ section.settings.title }}
        {%- if section.settings.title_highlight != blank %} <span class="hero__hl hero__hl--green">{{ section.settings.title_highlight }}</span>{%- endif -%}
        {%- if section.settings.title_highlight2 != blank %} <span class="hero__hl hero__hl--pink">{{ section.settings.title_highlight2 }}</span>{%- endif -%}
        <span class="hero__title-heart" aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span>
      </h1>

      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}

      <div class="hero__buttons">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="hero__btn hero__btn--primary">
            {{ section.settings.cta_primary_label }}
            <span class="hero__btn-icon" aria-hidden="true">{%- render 'lucide', icon: 'paw' -%}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="hero__btn hero__btn--secondary">
            {{ section.settings.cta_secondary_label }}
            <span class="hero__btn-icon hero__btn-icon--chev" aria-hidden="true">›</span>
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.review_text != blank -%}
        <div class="hero__social">
          <span class="hero__arrow" aria-hidden="true">
            <svg viewBox="0 0 44 40" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 5c16 2 22 13 17 28"/><path d="M16 31l8 3 2-8"/></svg>
          </span>
          <div class="hero__review">
            <span class="hero__stars" aria-hidden="true">★★★★★</span>
            <span class="hero__review-text">{{ section.settings.review_text }}</span>
          </div>
        </div>
      {%- endif -%}

    </div>

    <div class="hero__media{% if section.settings.image_mobile != blank %} hero__media--has-mobile{% endif %}">
      {%- if section.settings.image_mobile != blank -%}
        <img
          src="{{ section.settings.image_mobile | image_url: width: 760 }}"
          srcset="{{ section.settings.image_mobile | image_url: width: 480 }} 480w, {{ section.settings.image_mobile | image_url: width: 760 }} 760w"
          sizes="48vw"
          alt="{{ section.settings.image_mobile.alt | default: shop.name | escape }}"
          width="760" height="760"
          {%- if section.settings.image_priority -%} loading="eager" fetchpriority="high"{%- else -%} loading="lazy"{%- endif -%}
          class="hero__img hero__img--mobile">
      {%- endif -%}
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          srcset="{{ section.settings.image | image_url: width: 500 }} 500w, {{ section.settings.image | image_url: width: 900 }} 900w"
          sizes="45vw"
          alt="{{ section.settings.image.alt | default: shop.name | escape }}"
          width="900" height="800"
          {%- if section.settings.image_priority -%} loading="eager" fetchpriority="high"{%- else -%} loading="lazy"{%- endif -%}
          class="hero__img hero__img--desktop">
      {%- elsif section.settings.image_mobile == blank -%}
        <span class="hero__img hero__img--ph">{%- render 'lucide', icon: 'dog' -%}</span>
      {%- endif -%}

      <span class="hero__deco hero__deco--h1" aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span>
      <span class="hero__deco hero__deco--h2" aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span>
      <span class="hero__deco hero__deco--h3" aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span>
      <span class="hero__deco hero__deco--scribble" aria-hidden="true">
        <svg viewBox="0 0 40 18" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M2 13c5-7 8 5 13-1s8 5 13-2"/></svg>
      </span>
    </div>
  </div>

  <div class="hero__wave hero__wave--bottom" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 70" preserveAspectRatio="none">
      <path d="M0,40 C180,10 360,60 540,40 C720,20 900,64 1080,44 C1260,24 1380,52 1440,38 L1440,70 L0,70 Z" fill="#fbe4ee"/>
    </svg>
  </div>

</section>

<style>
.hero { position: relative; background: var(--color-cream); overflow: hidden; margin-top: -1px; }

.hero__wave { position: absolute; left: 0; right: 0; line-height: 0; pointer-events: none; z-index: 2; }
.hero__wave svg { display: block; width: 100%; }
.hero__wave--top { top: 0; }
.hero__wave--top svg { height: 52px; }
.hero__wave--bottom { bottom: -1px; }
.hero__wave--bottom svg { height: 64px; }

.hero__inner { position: relative; z-index: 1; max-width: var(--page-width); margin: 0 auto; padding: 76px var(--page-margin) 84px; display: flex; align-items: center; gap: 24px; }
.hero__content { flex: 1 1 53%; min-width: 0; }
.hero__media { flex: 1 1 47%; min-width: 0; position: relative; align-self: stretch; display: flex; align-items: center; justify-content: center; }

.hero__label { display: inline-block; font-family: var(--font-body); font-size: .78rem; font-weight: 800; color: var(--color-green); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 12px; }

.hero__title { font-family: var(--font-heading); font-size: clamp(2rem, 4.4vw, 3.3rem); color: var(--color-ink); line-height: 1.08; margin: 0 0 16px; }
.hero__hl--green { color: var(--color-green); }
.hero__hl--pink { color: var(--color-pink); }
.hero__title-heart { display: inline-flex; color: var(--color-pink); vertical-align: middle; }
.hero__title-heart .lucide { width: .72em; height: .72em; fill: currentColor; }

.hero__text { font-family: var(--font-body); font-size: 1.05rem; color: var(--color-body); line-height: 1.6; margin: 16px 0 26px; max-width: 40ch; }

.hero__buttons { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.hero__btn { display: inline-flex; align-items: center; gap: 9px; padding: 15px 26px; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.05rem; text-decoration: none; transition: transform 160ms, box-shadow 160ms, background 160ms; }
.hero__btn:hover { transform: translateY(-2px); }
.hero__btn--primary { background: var(--color-green); color: #fff; }
.hero__btn--primary:hover { background: #5a9a3b; box-shadow: 0 12px 28px rgba(102,170,68,.3); }
.hero__btn--secondary { background: #fff; color: var(--color-green); border: 2px solid var(--color-green); }
.hero__btn--secondary:hover { background: #e8f5e2; }
.hero__btn-icon { display: inline-flex; }
.hero__btn-icon .lucide { width: 17px; height: 17px; }
.hero__btn-icon--chev { font-size: 1.2rem; line-height: 1; }

.hero__social { display: flex; align-items: center; gap: 12px; margin-top: 24px; }
.hero__arrow { width: 38px; height: 34px; color: var(--color-green); flex-shrink: 0; transform: rotate(-6deg); }
.hero__arrow svg { width: 100%; height: 100%; display: block; }
.hero__review { display: flex; flex-direction: column; gap: 1px; }
.hero__stars { color: #f5b301; font-size: 1rem; letter-spacing: 1px; }
.hero__review-text { font-family: var(--font-body); font-size: .82rem; font-weight: 600; color: var(--color-muted); }

/* media + foto */
.hero__img { width: 100%; height: auto; max-height: 480px; object-fit: contain; display: block; }
.hero__img--mobile { display: none; }
.hero__img--ph { aspect-ratio: 1; width: 80%; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-green); box-shadow: 0 20px 50px rgba(0,0,0,.06); }
.hero__img--ph .lucide { width: 44%; height: 44%; }

/* zwevende decoraties */
.hero__deco { position: absolute; pointer-events: none; z-index: 2; }
.hero__deco .lucide, .hero__deco svg { width: 100%; height: 100%; display: block; }
.hero__deco--h1 { top: 4%; right: 6%; width: 28px; color: var(--color-pink); }
.hero__deco--h2 { top: 26%; left: -4%; width: 20px; color: var(--color-pink); }
.hero__deco--h3 { bottom: 22%; right: 0; width: 22px; color: var(--color-pink); }
.hero__deco--h1 .lucide, .hero__deco--h2 .lucide, .hero__deco--h3 .lucide { fill: none; stroke: currentColor; stroke-width: 2.2; }
.hero__deco--scribble { top: 12%; right: 30%; width: 34px; color: var(--color-green); }

/* mobiel: blijft naast elkaar, hond peekt groter */
@media (max-width: 749px) {
  .hero__inner { padding: 58px var(--page-margin) 64px; gap: 6px; }
  .hero__content { flex: 1 1 60%; }
  .hero__media { flex: 1 1 40%; }
  .hero__title { font-size: clamp(1.5rem, 6.6vw, 2.1rem); margin-bottom: 12px; }
  .hero__text { font-size: .92rem; margin: 12px 0 20px; }
  .hero__btn { padding: 13px 20px; font-size: .98rem; }
  .hero__buttons { gap: 9px; }
  .hero__img--desktop { width: 142%; max-width: none; max-height: 360px; object-position: left center; margin-right: -42%; }
  .hero__media--has-mobile .hero__img--desktop { display: none; }
  .hero__media--has-mobile .hero__img--mobile { display: block; width: 100%; max-width: 100%; margin: 0; max-height: 380px; object-fit: contain; }
  .hero__deco--h2 { left: 2%; }
}
</style>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "label", "label": "Label boven titel", "default": "Voor blije honden" },
    { "type": "textarea", "id": "title", "label": "Titel", "default": "Een verrassing vol" },
    { "type": "text", "id": "title_highlight", "label": "Gemarkeerd (groen)", "default": "speelplezier," },
    { "type": "text", "id": "title_highlight2", "label": "Gemarkeerd 2 (roze)", "default": "lekkers en liefde" },
    { "type": "textarea", "id": "text", "label": "Tekst", "default": "De leukste verrassingsbox voor jouw hond." },
    { "type": "text", "id": "cta_primary_label", "label": "Knop 1 tekst", "default": "Ontdek onze boxen" },
    { "type": "url", "id": "cta_primary_url", "label": "Knop 1 link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Knop 2 tekst", "default": "Zo werkt het" },
    { "type": "url", "id": "cta_secondary_url", "label": "Knop 2 link" },
    { "type": "text", "id": "review_text", "label": "Review tekst", "default": "Al meer dan 1.200 blije honden!" },
    { "type": "image_picker", "id": "image", "label": "Hero afbeelding (desktop)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Hero afbeelding (mobiel) — eigen portret/grote hond+box" },
    { "type": "checkbox", "id": "image_priority", "label": "Afbeelding met hoge prioriteit laden", "default": true }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "label": "Voor blije honden",
        "title": "Een verrassing vol",
        "title_highlight": "speelplezier,",
        "title_highlight2": "lekkers en liefde",
        "text": "De leukste verrassingsbox voor jouw hond.",
        "cta_primary_label": "Ontdek onze boxen",
        "cta_secondary_label": "Zo werkt het",
        "review_text": "Al meer dan 1.200 blije honden!"
      }
    }
  ]
}
{% endschema %}
