{%- comment -%}
  sections/payment-page.liquid — Kwispelbox KB-v4
  Premium "Betaalmogelijkheden" pagina: hero · betaalmethoden-grid ·
  trust-banner · FAQ + contactkaart · afsluitende CTA.
  Mobiel-first, volledig instelbaar via settings + blocks (payment / faq).
{%- endcomment -%}

{%- assign payment_blocks = section.blocks | where: 'type', 'payment' -%}
{%- assign faq_blocks     = section.blocks | where: 'type', 'faq' -%}

<div class="pay full-width">
  <div class="pay__inner">

    {%- comment -%} ── HERO ─────────────────────────────── {%- endcomment -%}
    <section class="pay-hero">
      <div class="pay-hero__text">
        {%- if section.settings.hero_eyebrow != blank -%}<span class="pay-hero__eyebrow">{{ section.settings.hero_eyebrow }}</span>{%- endif -%}
        <h1 class="pay-hero__title">
          <span>{{ section.settings.hero_title_1 | default: 'Betaal zoals' }}</span>
          {%- if section.settings.hero_title_2 != blank -%}<span class="pay-hero__title-em">{{ section.settings.hero_title_2 }}</span>{%- endif -%}
        </h1>
        {%- if section.settings.hero_intro != blank -%}<p class="pay-hero__intro">{{ section.settings.hero_intro }}</p>{%- endif -%}
        {%- if section.settings.hero_trust != blank -%}
          <span class="pay-hero__trustline">
            <span class="pay-hero__trustline-icon" aria-hidden="true">{%- render 'lucide', icon: 'shield-check' -%}</span>
            {{ section.settings.hero_trust }}
          </span>
        {%- endif -%}
      </div>
      <div class="pay-hero__media">
        {%- if section.settings.hero_image != blank -%}
          <img src="{{ section.settings.hero_image | image_url: width: 1100 }}"
               srcset="{{ section.settings.hero_image | image_url: width: 700 }} 700w, {{ section.settings.hero_image | image_url: width: 1100 }} 1100w"
               sizes="(max-width: 989px) 92vw, 48vw"
               alt="{{ section.settings.hero_image.alt | default: section.settings.hero_title_1 | escape }}"
               width="560" height="460" loading="eager" fetchpriority="high" class="pay-hero__img">
        {%- else -%}
          <div class="pay-hero__img pay-hero__img--ph">{%- render 'lucide', icon: 'dog' -%}</div>
        {%- endif -%}
        {%- if section.settings.show_decorations -%}
          <span class="pay-deco pay-hero__deco--heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
          <span class="pay-deco pay-hero__deco--paw" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM4 8a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 5a6 6 0 0 0-5.91 5.04A2.4 2.4 0 0 0 7.45 21c.86 0 1.62-.45 2.3-.86.43-.26.83-.5 1.25-.5s.82.24 1.25.5c.68.41 1.44.86 2.3.86a2.4 2.4 0 0 0 2.36-2.96A6 6 0 0 0 11 13Z"/></svg></span>
          <span class="pay-deco pay-hero__deco--squiggle" aria-hidden="true"><svg viewBox="0 0 48 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 11c5-8 8 5 13-1s7 5 12-1 8 4 14-2"/></svg></span>
        {%- endif -%}
      </div>
    </section>

    {%- comment -%} ── BETAALMETHODEN-GRID ──────────────── {%- endcomment -%}
    {%- if payment_blocks.size > 0 -%}
      <section class="pay-grid">
        <div class="pay-grid__head">
          <span class="pay-grid__head-icon" aria-hidden="true">{%- render 'lucide', icon: section.settings.grid_icon -%}</span>
          {%- if section.settings.grid_title != blank -%}<h2 class="pay-grid__title">{{ section.settings.grid_title }}</h2>{%- endif -%}
        </div>
        <div class="pay-grid__list">
          {%- for block in payment_blocks -%}
            <div class="pay-card" {{ block.shopify_attributes }}>
              <div class="pay-card__logo">
                {%- if block.settings.logo != blank -%}
                  <img src="{{ block.settings.logo | image_url: width: 200 }}" alt="{{ block.settings.name | escape }}" width="100" height="48" loading="lazy">
                {%- else -%}
                  <span class="pay-card__logo-ph" aria-hidden="true">{%- render 'lucide', icon: 'credit-card' -%}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.name != blank -%}<strong class="pay-card__name">{{ block.settings.name }}</strong>{%- endif -%}
              {%- if block.settings.description != blank -%}<span class="pay-card__desc">{{ block.settings.description }}</span>{%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </section>
    {%- endif -%}

    {%- comment -%} ── TRUST-BANNER ─────────────────────── {%- endcomment -%}
    {%- if section.settings.trust_title != blank -%}
      <section class="pay-trustbanner">
        <span class="pay-trustbanner__icon" aria-hidden="true">{%- render 'lucide', icon: 'shield-check' -%}</span>
        <div class="pay-trustbanner__body">
          <strong class="pay-trustbanner__title">{{ section.settings.trust_title }}</strong>
          {%- if section.settings.trust_text != blank -%}<p class="pay-trustbanner__text">{{ section.settings.trust_text }}</p>{%- endif -%}
        </div>
        {%- if section.settings.trust_badge_text != blank -%}
          <div class="pay-trustbanner__badge">
            <span class="pay-trustbanner__badge-icon" aria-hidden="true">{%- render 'lucide', icon: 'lock' -%}</span>
            <span>{{ section.settings.trust_badge_text }}</span>
          </div>
        {%- endif -%}
      </section>
    {%- endif -%}

    {%- comment -%} ── FAQ + CONTACT ────────────────────── {%- endcomment -%}
    {%- if faq_blocks.size > 0 or section.settings.contact_title != blank -%}
      <section class="pay-faqwrap">
        {%- if faq_blocks.size > 0 -%}
          <div class="pay-faq">
            {%- if section.settings.faq_title != blank -%}<h2 class="pay-faq__title">{{ section.settings.faq_title }}</h2>{%- endif -%}
            {%- for block in faq_blocks -%}
              <details class="pay-faq__item" {{ block.shopify_attributes }}>
                <summary class="pay-faq__q">
                  {{ block.settings.question }}
                  <span class="pay-faq__chev" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg></span>
                </summary>
                {%- if block.settings.answer != blank -%}<div class="pay-faq__a">{{ block.settings.answer }}</div>{%- endif -%}
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- if section.settings.contact_title != blank -%}
          <div class="pay-contact">
            <span class="pay-contact__icon" aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span>
            <strong class="pay-contact__title">{{ section.settings.contact_title }}</strong>
            {%- if section.settings.contact_text != blank -%}<p class="pay-contact__text">{{ section.settings.contact_text }}</p>{%- endif -%}
            {%- if section.settings.contact_cta_label != blank -%}
              <a href="{{ section.settings.contact_cta_url | default: '#' }}" class="pay-contact__cta">{{ section.settings.contact_cta_label }}</a>
            {%- endif -%}
            <ul class="pay-contact__meta" role="list">
              {%- if section.settings.contact_email != blank -%}
                <li><span aria-hidden="true">{%- render 'lucide', icon: 'mail' -%}</span><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></li>
              {%- endif -%}
              {%- if section.settings.contact_response != blank -%}
                <li><span aria-hidden="true">{%- render 'lucide', icon: 'sparkles' -%}</span>{{ section.settings.contact_response }}</li>
              {%- endif -%}
              {%- if section.settings.contact_phone != blank -%}
                <li><span aria-hidden="true">{%- render 'lucide', icon: 'phone' -%}</span><a href="tel:{{ section.settings.contact_phone | remove: ' ' }}">{{ section.settings.contact_phone }}</a></li>
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      </section>
    {%- endif -%}

    {%- comment -%} ── AFSLUITENDE CTA ──────────────────── {%- endcomment -%}
    {%- if section.settings.cta_title != blank -%}
      <section class="pay-cta">
        <div class="pay-cta__text">
          <h2 class="pay-cta__title">{{ section.settings.cta_title }}</h2>
          {%- if section.settings.cta_text != blank -%}<p class="pay-cta__intro">{{ section.settings.cta_text }}</p>{%- endif -%}
          {%- if section.settings.cta_button_label != blank -%}
            <a href="{{ section.settings.cta_button_url | default: '#' }}" class="pay-cta__btn">
              {{ section.settings.cta_button_label }}
              <span aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="pay-cta__media">
          {%- if section.settings.cta_image != blank -%}
            <img src="{{ section.settings.cta_image | image_url: width: 800 }}" alt="{{ section.settings.cta_image.alt | escape }}" width="400" height="300" loading="lazy" class="pay-cta__img">
          {%- else -%}
            <div class="pay-cta__img pay-cta__img--ph">{%- render 'lucide', icon: 'dog' -%}</div>
          {%- endif -%}
          {%- if section.settings.show_decorations -%}
            <span class="pay-deco pay-cta__deco--heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
            <span class="pay-deco pay-cta__deco--paw" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM4 8a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm7 5a6 6 0 0 0-5.91 5.04A2.4 2.4 0 0 0 7.45 21c.86 0 1.62-.45 2.3-.86.43-.26.83-.5 1.25-.5s.82.24 1.25.5c.68.41 1.44.86 2.3.86a2.4 2.4 0 0 0 2.36-2.96A6 6 0 0 0 11 13Z"/></svg></span>
          {%- endif -%}
        </div>
      </section>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}

.pay { background: var(--color-cream); padding: 40px 0 72px; }
.pay__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); display: flex; flex-direction: column; gap: 40px; }

.pay-deco { position: absolute; pointer-events: none; }
.pay-deco svg { display: block; width: 100%; height: 100%; }

/* ── HERO ─────────────────────────────────────────────── */
.pay-hero {
  position: relative; background: #fff; border-radius: 32px;
  box-shadow: 0 24px 60px rgba(61, 34, 9, .10);
  display: flex; flex-direction: column; gap: 8px; overflow: hidden;
}
.pay-hero__text { padding: 36px 28px 8px; }
.pay-hero__eyebrow { display: inline-block; font-family: var(--font-body); font-size: .78rem; font-weight: 800; text-transform: uppercase; letter-spacing: .09em; color: var(--color-pink); margin-bottom: 12px; }
.pay-hero__title { font-family: var(--font-heading); font-size: clamp(2rem, 7vw, 3.2rem); line-height: 1.05; color: var(--color-ink); margin: 0; }
.pay-hero__title span { display: block; }
.pay-hero__title-em { color: var(--color-green); }
.pay-hero__intro { font-family: var(--font-body); font-size: 1.02rem; line-height: 1.6; color: var(--color-body); margin: 16px 0 0; max-width: 46ch; }
.pay-hero__trustline { display: inline-flex; align-items: center; gap: 9px; margin-top: 18px; font-family: var(--font-body); font-size: .85rem; font-weight: 700; color: var(--color-green); }
.pay-hero__trustline-icon { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 50%; background: #e8f5e2; }
.pay-hero__trustline-icon .lucide { width: 17px; height: 17px; }
.pay-hero__media { position: relative; padding: 12px 28px 28px; }
.pay-hero__img { width: 100%; height: 260px; object-fit: cover; border-radius: 24px; display: block; }
.pay-hero__img--ph { display: flex; align-items: center; justify-content: center; background: #e8f5e2; color: var(--color-green); }
.pay-hero__img--ph .lucide { width: 80px; height: 80px; }
.pay-hero__deco--heart { top: 0; right: 36px; width: 30px; height: 30px; color: var(--color-pink); transform: rotate(12deg); }
.pay-hero__deco--paw { bottom: 16px; left: 14px; width: 30px; height: 30px; color: var(--color-orange); opacity: .55; transform: rotate(-12deg); }
.pay-hero__deco--squiggle { top: 30px; left: 18px; width: 48px; height: 16px; color: var(--color-yellow); }

/* ── GRID ─────────────────────────────────────────────── */
.pay-grid__head { text-align: center; margin-bottom: 26px; }
.pay-grid__head-icon { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); margin-bottom: 12px; }
.pay-grid__head-icon .lucide { width: 22px; height: 22px; }
.pay-grid__title { font-family: var(--font-heading); font-size: clamp(1.6rem, 4vw, 2.3rem); color: var(--color-ink); margin: 0; }
.pay-grid__list { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 16px; }
.pay-card {
  display: flex; flex-direction: column; align-items: center; text-align: center;
  background: #fff; border: 1.5px solid var(--color-line); border-radius: 24px; padding: 22px 18px;
  transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
}
.pay-card:hover { transform: translateY(-4px); box-shadow: 0 16px 34px rgba(61, 34, 9, .1); border-color: var(--color-green); }
.pay-card__logo { display: flex; align-items: center; justify-content: center; height: 50px; margin-bottom: 14px; }
.pay-card__logo img { max-height: 44px; max-width: 110px; width: auto; object-fit: contain; }
.pay-card__logo-ph { display: flex; align-items: center; justify-content: center; width: 56px; height: 40px; border-radius: 9px; background: var(--color-cream); color: var(--color-muted); }
.pay-card__logo-ph .lucide { width: 26px; height: 26px; }
.pay-card__name { font-family: var(--font-heading); font-size: 1.05rem; color: var(--color-ink); line-height: 1.15; }
.pay-card__desc { font-family: var(--font-body); font-size: .8rem; line-height: 1.4; color: var(--color-muted); margin-top: 5px; }

/* ── TRUST-BANNER ─────────────────────────────────────── */
.pay-trustbanner {
  display: flex; flex-direction: column; align-items: flex-start; gap: 16px;
  background: #e8f5e2; border: 1.5px solid rgba(102, 170, 68, .2); border-radius: 24px; padding: 26px 24px;
}
.pay-trustbanner__icon { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: 50%; background: #fff; color: var(--color-green); flex-shrink: 0; }
.pay-trustbanner__icon .lucide { width: 28px; height: 28px; }
.pay-trustbanner__body { flex: 1; }
.pay-trustbanner__title { display: block; font-family: var(--font-heading); font-size: 1.3rem; color: var(--color-ink); line-height: 1.15; }
.pay-trustbanner__text { font-family: var(--font-body); font-size: .9rem; line-height: 1.55; color: var(--color-body); margin: 6px 0 0; }
.pay-trustbanner__badge { display: inline-flex; align-items: center; gap: 11px; background: #fff; border-radius: var(--radius-pill); padding: 10px 18px 10px 10px; font-family: var(--font-heading); font-size: .95rem; color: var(--color-ink); }
.pay-trustbanner__badge-icon { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: var(--color-green); color: #fff; flex-shrink: 0; }
.pay-trustbanner__badge-icon .lucide { width: 20px; height: 20px; }

/* ── FAQ + CONTACT ────────────────────────────────────── */
.pay-faqwrap { display: flex; flex-direction: column; gap: 24px; }
.pay-faq__title { font-family: var(--font-heading); font-size: clamp(1.5rem, 4vw, 2rem); color: var(--color-ink); margin: 0 0 18px; }
.pay-faq__item { background: #fff; border: 1.5px solid var(--color-line); border-radius: 18px; box-shadow: 0 6px 18px rgba(61, 34, 9, .05); margin-bottom: 12px; overflow: hidden; }
.pay-faq__q { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 18px 20px; cursor: pointer; list-style: none; font-family: var(--font-heading); font-size: 1.05rem; color: var(--color-ink); }
.pay-faq__q::-webkit-details-marker { display: none; }
.pay-faq__chev { display: flex; flex-shrink: 0; color: var(--color-green); transition: transform 260ms ease; }
.pay-faq__chev svg { width: 20px; height: 20px; }
.pay-faq__item[open] .pay-faq__chev { transform: rotate(180deg); }
.pay-faq__a { padding: 0 20px 18px; font-family: var(--font-body); font-size: .92rem; line-height: 1.6; color: var(--color-body); }
.pay-contact { background: #fff; border: 1.5px solid var(--color-line); border-radius: 24px; box-shadow: 0 14px 34px rgba(61, 34, 9, .07); padding: 28px 24px; text-align: center; }
.pay-contact__icon { display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: 50%; background: #ffe0ee; color: var(--color-pink); margin-bottom: 14px; }
.pay-contact__icon .lucide { width: 26px; height: 26px; }
.pay-contact__title { display: block; font-family: var(--font-heading); font-size: 1.4rem; color: var(--color-ink); }
.pay-contact__text { font-family: var(--font-body); font-size: .92rem; line-height: 1.55; color: var(--color-body); margin: 10px 0 18px; }
.pay-contact__cta { display: inline-flex; align-items: center; justify-content: center; padding: 13px 26px; background: var(--color-green); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1rem; text-decoration: none; transition: background 160ms, transform 160ms; }
.pay-contact__cta:hover { background: #5a9a3b; transform: translateY(-1px); }
.pay-contact__meta { list-style: none; margin: 18px 0 0; padding: 0; display: flex; flex-direction: column; gap: 10px; align-items: center; }
.pay-contact__meta li { display: inline-flex; align-items: center; gap: 9px; font-family: var(--font-body); font-size: .85rem; font-weight: 600; color: var(--color-body); }
.pay-contact__meta li span { display: inline-flex; color: var(--color-green); }
.pay-contact__meta li .lucide { width: 16px; height: 16px; }
.pay-contact__meta a { color: var(--color-ink); text-decoration: none; }
.pay-contact__meta a:hover { text-decoration: underline; }

/* ── AFSLUITENDE CTA ──────────────────────────────────── */
.pay-cta { position: relative; display: flex; flex-direction: column; gap: 8px; background: #e8f5e2; border-radius: 32px; overflow: hidden; }
.pay-cta__text { padding: 36px 28px 16px; }
.pay-cta__title { font-family: var(--font-heading); font-size: clamp(1.7rem, 5vw, 2.6rem); color: var(--color-ink); line-height: 1.08; margin: 0; }
.pay-cta__intro { font-family: var(--font-body); font-size: 1rem; line-height: 1.6; color: var(--color-body); margin: 14px 0 22px; max-width: 42ch; }
.pay-cta__btn { display: inline-flex; align-items: center; gap: 9px; padding: 15px 28px; background: var(--color-green); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.05rem; text-decoration: none; transition: background 160ms, transform 160ms; }
.pay-cta__btn:hover { background: #5a9a3b; transform: translateY(-1px); }
.pay-cta__btn span { display: inline-flex; }
.pay-cta__btn svg { width: 18px; height: 18px; }
.pay-cta__media { position: relative; padding: 12px 28px 28px; }
.pay-cta__img { width: 100%; height: 220px; object-fit: cover; border-radius: 24px; display: block; }
.pay-cta__img--ph { display: flex; align-items: center; justify-content: center; background: #fff; color: var(--color-green); }
.pay-cta__img--ph .lucide { width: 70px; height: 70px; }
.pay-cta__deco--heart { top: 0; right: 36px; width: 28px; height: 28px; color: var(--color-pink); transform: rotate(12deg); }
.pay-cta__deco--paw { bottom: 18px; left: 16px; width: 28px; height: 28px; color: var(--color-orange); opacity: .55; transform: rotate(-12deg); }

/* ── Tablet ───────────────────────────────────────────── */
@media (min-width: 750px) {
  .pay { padding: 48px 0 88px; }
  .pay__inner { gap: 52px; }
  .pay-hero { flex-direction: row; align-items: center; }
  .pay-hero__text { flex: 1; padding: 48px 8px 48px 44px; }
  .pay-hero__media { flex: 1; padding: 24px; }
  .pay-hero__img, .pay-hero__img--ph { height: 360px; }
  .pay-trustbanner { flex-direction: row; align-items: center; padding: 28px 30px; }
  .pay-trustbanner__badge { margin-left: auto; }
  .pay-cta { flex-direction: row; align-items: center; }
  .pay-cta__text { flex: 1.1; padding: 48px 8px 48px 44px; }
  .pay-cta__media { flex: 1; padding: 24px; }
  .pay-cta__img, .pay-cta__img--ph { height: 280px; }
}

/* ── Desktop ──────────────────────────────────────────── */
@media (min-width: 990px) {
  .pay-grid__list { grid-template-columns: repeat(4, 1fr); }
  .pay-faqwrap { flex-direction: row; align-items: flex-start; gap: 32px; }
  .pay-faq { flex: 1.5; }
  .pay-contact { flex: 1; position: sticky; top: 150px; }
}

@media (prefers-reduced-motion: reduce) {
  .pay-card, .pay-faq__chev, .pay-contact__cta, .pay-cta__btn { transition: none; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Betaalpagina",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Betaalmogelijkheden" },
