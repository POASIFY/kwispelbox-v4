{%- comment -%}
  sections/cart.liquid — Kwispelbox KB-v4
  Merkgerichte winkelwagen: de cadeautjes voor je hond, klaar om in te pakken.
  Behoudt volledige Shopify cart-functionaliteit (updates[], remove, checkout).
{%- endcomment -%}

<div class="kbcart full-width">
  <div class="kbcart__inner">

    {%- if cart.item_count == 0 -%}
      {%- comment -%} ── Lege winkelwagen ───────────────────────── {%- endcomment -%}
      <div class="kbcart__empty">
        <span class="kbcart__empty-icon" aria-hidden="true">{%- render 'lucide', icon: 'gift' -%}</span>
        <h1 class="kbcart__empty-title">{{ section.settings.empty_title | default: 'Nog geen cadeautjes ingepakt' }}</h1>
        <p class="kbcart__empty-text">{{ section.settings.empty_text | default: 'Je winkelwagen wacht op iets moois. Kies een box en verras je hond met het moment waar hij niet meer op kan wachten.' }}</p>
        <a href="{{ section.settings.empty_button_url | default: routes.all_products_collection_url }}" class="kbcart__btn kbcart__btn--primary">
          {{ section.settings.empty_button_label | default: 'Verras je hond' }}<span aria-hidden="true">{%- render 'lucide', icon: 'paw' -%}</span>
        </a>
      </div>

    {%- else -%}
      {%- comment -%} ── Gevulde winkelwagen ────────────────────── {%- endcomment -%}
      <header class="kbcart__head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="kbcart__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h1 class="kbcart__title">{{ section.settings.title | default: 'Klaar om in te pakken' }}</h1>
        <p class="kbcart__sub">
          {%- if cart.item_count == 1 -%}
            1 cadeautje wacht op jouw hond.
          {%- else -%}
            {{ cart.item_count }} cadeautjes wachten op jouw hond.
          {%- endif -%}
        </p>
      </header>

      {%- comment -%} ── Gratis-verzending voortgang ─────────────── {%- endcomment -%}
      {%- if section.settings.show_shipping_bar -%}
        {%- assign threshold = section.settings.free_shipping_threshold | times: 100 -%}
        {%- if threshold > 0 -%}
          <div class="kbcart__ship">
            {%- if cart.total_price >= threshold -%}
              <p class="kbcart__ship-msg kbcart__ship-msg--done">
                <span aria-hidden="true">{%- render 'lucide', icon: 'truck' -%}</span>
                Hoera! Je krijgt <strong>gratis verzending</strong>.
              </p>
              {%- assign ship_pct = 100 -%}
            {%- else -%}
              {%- assign remaining = threshold | minus: cart.total_price -%}
              <p class="kbcart__ship-msg">
                <span aria-hidden="true">{%- render 'lucide', icon: 'truck' -%}</span>
                Nog <strong>{{ remaining | money }}</strong> tot gratis verzending.
              </p>
              {%- assign ship_pct = cart.total_price | times: 100 | divided_by: threshold -%}
            {%- endif -%}
            <div class="kbcart__ship-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ ship_pct }}">
              <span class="kbcart__ship-fill" style="width: {{ ship_pct }}%;"></span>
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}

      <form action="{{ routes.cart_url }}" method="post" novalidate class="kbcart__form">
        <ul class="kbcart__items" role="list">
          {%- for item in cart.items -%}
            <li class="kbcart__item" {{ item.shopify_attributes }}>
              <a href="{{ item.url }}" class="kbcart__item-media" aria-hidden="true" tabindex="-1">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | escape }}" width="90" height="90" loading="lazy">
                {%- else -%}
                  <span class="kbcart__item-ph">{%- render 'lucide', icon: 'package' -%}</span>
                {%- endif -%}
              </a>

              <div class="kbcart__item-body">
                <a href="{{ item.url }}" class="kbcart__item-title">{{ item.product.title }}</a>
                {%- unless item.variant.title contains 'Default' -%}
                  <p class="kbcart__item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}

                {%- comment -%} Personalisatie (hondennaam, etc.) {%- endcomment -%}
                {%- capture prop_items -%}
                  {%- for prop in item.properties -%}
                    {%- assign first_char = prop.first | slice: 0 -%}
                    {%- if prop.last != blank and first_char != '_' -%}
                      <li><span>{{ prop.first }}:</span> {{ prop.last }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endcapture -%}
                {%- if prop_items != blank -%}
                  <ul class="kbcart__item-props" role="list">{{ prop_items }}</ul>
                {%- endif -%}

                <a href="{{ item.url_to_remove }}" class="kbcart__item-remove">{{ 'cart.remove' | t | default: 'Verwijderen' }}</a>
              </div>

              <div class="kbcart__item-controls">
                <label class="kbcart__qty">
                  <span class="visually-hidden">Aantal voor {{ item.product.title | escape }}</span>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" inputmode="numeric" class="kbcart__qty-input">
                </label>
                <p class="kbcart__item-price">{{ item.final_line_price | money }}</p>
              </div>
            </li>
          {%- endfor -%}
        </ul>

        <div class="kbcart__footer">
          <button type="submit" name="update" class="kbcart__update">{%- render 'lucide', icon: 'refresh' -%}Aantallen bijwerken</button>

          <div class="kbcart__summary">
            <div class="kbcart__totals">
              <span>Subtotaal</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>
            <p class="kbcart__note">Verzending en kortingen worden bij de kassa berekend.</p>
            <button type="submit" name="checkout" class="kbcart__btn kbcart__btn--primary kbcart__checkout">
              Afrekenen<span aria-hidden="true">{%- render 'lucide', icon: 'paw' -%}</span>
            </button>
            <a href="{{ routes.all_products_collection_url }}" class="kbcart__continue">Verder snuffelen</a>
            <ul class="kbcart__reassure" role="list">
              <li><span aria-hidden="true">{%- render 'lucide', icon: 'lock' -%}</span> Veilig betalen</li>
              <li><span aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span> Met liefde ingepakt</li>
            </ul>
          </div>
        </div>
      </form>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.kbcart { background: var(--color-cream); padding: 48px 0 80px; }
.kbcart__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* ── Lege staat ─────────────────────────────────────── */
.kbcart__empty { max-width: 480px; margin: 24px auto; text-align: center; }
.kbcart__empty-icon {
  display: inline-flex; align-items: center; justify-content: center;
  width: 88px; height: 88px; border-radius: 50%;
  background: var(--color-pink); color: #fff; margin-bottom: 22px;
  box-shadow: 0 14px 30px rgba(0, 0, 0, .08);
}
.kbcart__empty-icon .lucide { width: 42px; height: 42px; }
.kbcart__empty-title { font-family: var(--font-heading); font-size: clamp(1.6rem, 5vw, 2.2rem); color: var(--color-ink); margin: 0 0 12px; }
.kbcart__empty-text { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.6; color: var(--color-body); margin: 0 0 28px; }

/* ── Kop ────────────────────────────────────────────── */
.kbcart__head { margin-bottom: 24px; }
.kbcart__eyebrow { font-family: var(--font-body); font-size: .9rem; font-weight: 800; letter-spacing: .04em; text-transform: uppercase; color: var(--color-green); margin: 0 0 8px; }
.kbcart__title { font-family: var(--font-heading); font-size: clamp(1.8rem, 5vw, 2.6rem); color: var(--color-ink); line-height: 1.1; margin: 0 0 6px; }
.kbcart__sub { font-family: var(--font-body); font-size: 1.05rem; color: var(--color-body); margin: 0; }

/* ── Gratis verzending ──────────────────────────────── */
.kbcart__ship { background: #fff; border-radius: var(--radius-md); padding: 16px 20px; margin-bottom: 24px; }
.kbcart__ship-msg { display: flex; align-items: center; gap: 9px; font-family: var(--font-body); font-size: .98rem; color: var(--color-body); margin: 0 0 10px; }
.kbcart__ship-msg strong { color: var(--color-ink); }
.kbcart__ship-msg .lucide { width: 20px; height: 20px; color: var(--color-green); flex-shrink: 0; }
.kbcart__ship-msg--done .lucide { color: var(--color-green); }
.kbcart__ship-track { height: 8px; border-radius: var(--radius-pill); background: var(--color-line); overflow: hidden; }
.kbcart__ship-fill { display: block; height: 100%; border-radius: var(--radius-pill); background: var(--color-green); transition: width 300ms ease; }

/* ── Lijst + layout ─────────────────────────────────── */
.kbcart__form { display: grid; gap: 28px; }
.kbcart__items { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
.kbcart__item {
  display: grid;
  grid-template-columns: 90px 1fr auto;
  gap: 16px;
  align-items: start;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 16px;
}
.kbcart__item-media { display: block; width: 90px; height: 90px; border-radius: var(--radius-sm); overflow: hidden; background: var(--color-cream); }
.kbcart__item-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
.kbcart__item-ph { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; color: var(--color-muted); }
.kbcart__item-ph .lucide { width: 34px; height: 34px; }

.kbcart__item-body { min-width: 0; }
.kbcart__item-title { font-family: var(--font-heading); font-size: 1.15rem; color: var(--color-ink); text-decoration: none; line-height: 1.2; }
.kbcart__item-title:hover { color: var(--color-green); }
.kbcart__item-variant { font-family: var(--font-body); font-size: .9rem; color: var(--color-muted); margin: 4px 0 0; }
.kbcart__item-props { list-style: none; margin: 8px 0 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
.kbcart__item-props li { font-family: var(--font-body); font-size: .85rem; color: var(--color-body); }
.kbcart__item-props span { font-weight: 700; color: var(--color-ink); }
.kbcart__item-remove { display: inline-block; margin-top: 10px; font-family: var(--font-body); font-size: .85rem; color: var(--color-muted); text-decoration: underline; text-underline-offset: 2px; }
.kbcart__item-remove:hover { color: var(--color-pink); }

.kbcart__item-controls { display: flex; flex-direction: column; align-items: flex-end; gap: 12px; }
.kbcart__qty-input {
  width: 64px; padding: 9px 8px; text-align: center;
  font-family: var(--font-body); font-size: 1rem; font-weight: 700; color: var(--color-ink);
  border: 2px solid var(--color-line); border-radius: var(--radius-sm); background: #fff;
}
.kbcart__qty-input:focus { outline: none; border-color: var(--color-green); }
.kbcart__item-price { font-family: var(--font-heading); font-size: 1.15rem; color: var(--color-ink); margin: 0; }

/* ── Footer / samenvatting ──────────────────────────── */
.kbcart__footer { display: grid; gap: 20px; }
.kbcart__update {
  justify-self: start; display: inline-flex; align-items: center; gap: 8px;
  background: none; border: none; cursor: pointer; padding: 4px 0;
  font-family: var(--font-body); font-size: .92rem; font-weight: 700; color: var(--color-body);
}
.kbcart__update:hover { color: var(--color-green); }
.kbcart__update .lucide { width: 16px; height: 16px; }

.kbcart__summary { background: #fff; border-radius: var(--radius-lg); padding: 24px; }
.kbcart__totals { display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 14px; border-bottom: 1px solid var(--color-line); }
.kbcart__totals span { font-family: var(--font-body); font-size: 1.05rem; color: var(--color-body); }
.kbcart__totals strong { font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-ink); }
.kbcart__note { font-family: var(--font-body); font-size: .85rem; color: var(--color-muted); margin: 12px 0 18px; }

.kbcart__btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 9px;
  padding: 16px 30px; border-radius: var(--radius-pill);
  font-family: var(--font-heading); font-size: 1.1rem; text-decoration: none; cursor: pointer; border: none;
  transition: background 160ms, transform 160ms, box-shadow 160ms;
}
.kbcart__btn span { display: inline-flex; }
.kbcart__btn svg, .kbcart__btn .lucide { width: 18px; height: 18px; }
.kbcart__btn--primary { background: var(--color-green); color: #fff; }
.kbcart__btn--primary:hover { background: #5a9a3b; transform: translateY(-2px); box-shadow: 0 12px 30px rgba(102, 170, 68, .3); }
.kbcart__checkout { width: 100%; }
.kbcart__continue { display: block; text-align: center; margin-top: 14px; font-family: var(--font-body); font-size: .95rem; font-weight: 700; color: var(--color-body); text-decoration: none; }
.kbcart__continue:hover { color: var(--color-green); }
.kbcart__reassure { list-style: none; margin: 18px 0 0; padding: 16px 0 0; border-top: 1px solid var(--color-line); display: flex; flex-wrap: wrap; gap: 18px; justify-content: center; }
.kbcart__reassure li { display: flex; align-items: center; gap: 7px; font-family: var(--font-body); font-size: .85rem; font-weight: 600; color: var(--color-body); }
.kbcart__reassure .lucide { width: 16px; height: 16px; color: var(--color-green); }

.visually-hidden { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }

/* ── Desktop ────────────────────────────────────────── */
@media (min-width: 990px) {
  .kbcart__form { grid-template-columns: 1fr 360px; align-items: start; }
  .kbcart__items { grid-column: 1; }
  .kbcart__footer { grid-column: 2; grid-row: 1; position: sticky; top: 24px; }
}

@media (max-width: 749px) {
  .kbcart__item { grid-template-columns: 72px 1fr; }
  .kbcart__item-media { width: 72px; height: 72px; }
  .kbcart__item-controls { grid-column: 1 / -1; flex-direction: row; align-items: center; justify-content: space-between; padding-top: 4px; border-top: 1px solid var(--color-line); }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Winkelwagen",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Kop (gevulde winkelwagen)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bijna bij je hond" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Klaar om in te pakken" },
    { "type": "header", "content": "Gratis verzending" },
    { "type": "checkbox", "id": "show_shipping_bar", "label": "Voortgangsbalk tonen", "default": true },
    { "type": "number", "id": "free_shipping_threshold", "label": "Drempel gratis verzending (in €)", "default": 75 },
    { "type": "header", "content": "Lege winkelwagen" },
    { "type": "text", "id": "empty_title", "label": "Titel", "default": "Nog geen cadeautjes ingepakt" },
    { "type": "textarea", "id": "empty_text", "label": "Tekst", "default": "Je winkelwagen wacht op iets moois. Kies een box en verras je hond met het moment waar hij niet meer op kan wachten." },
    { "type": "text", "id": "empty_button_label", "label": "Knoptekst", "default": "Verras je hond" },
    { "type": "url", "id": "empty_button_url", "label": "Knop link (leeg = alle producten)" }
  ]
}
{% endschema %}
