.kbcart__item.kbcart__item--gift { display: flex; align-items: center; gap: 14px; background: linear-gradient(180deg, #fff5f9, #fff); border: 1.5px dashed var(--color-pink); border-radius: 16px; padding: 14px 16px; margin-top: 4px; }
.kbcart__gift-icon { display: inline-flex; align-items: center; justify-content: center; width: 46px; height: 46px; border-radius: 50%; background: var(--color-pink); color: #fff; flex-shrink: 0; }
.kbcart__gift-icon .lucide { width: 22px; height: 22px; }
.kbcart__gift-body { flex: 1; min-width: 0; }
