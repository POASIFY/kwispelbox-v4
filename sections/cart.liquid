.kbcart__wrap-add:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(0,0,0,.12); }
.kbcart__wrap-add-price { font-family: var(--font-body); font-weight: 700; opacity: .9; }

/* Promo-banner */
.kbcart__promo { display: flex; align-items: center; gap: 14px; margin-top: 20px; padding: 16px 18px; border-radius: var(--radius-md); background: #fbeede; }
.kbcart__promo-icon { display: inline-flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 50%; background: #fff; color: var(--color-pink); flex-shrink: 0; }
.kbcart__promo-icon .lucide { width: 20px; height: 20px; fill: currentColor; }
.kbcart__promo-text { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
.kbcart__promo-text strong { font-family: var(--font-heading); font-size: 1.02rem; color: var(--color-ink); }
.kbcart__promo-text span { font-family: var(--font-body); font-size: .9rem; color: var(--color-body); }
.kbcart__promo-btn { display: inline-flex; align-items: center; gap: 6px; padding: 11px 18px; border-radius: var(--radius-pill); background: #fff; color: var(--color-ink); font-family: var(--font-body); font-weight: 800; font-size: .9rem; text-decoration: none; white-space: nowrap; transition: color 140ms, transform 140ms; }
.kbcart__promo-btn:hover { color: var(--color-green); transform: translateY(-2px); }

/* Maak de verrassing compleet */
