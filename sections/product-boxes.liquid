{%- comment -%}
  sections/product-boxes.liquid — Kwispelbox KB-v4
  "Kies jouw Kwispelbox" — 3 productkaarten (Mini / Happy / Mega) + reassurance-balk.
  - box blocks      → de productkaarten (foto, badge, voordelen, prijs, ronde pijl-knop)
  - benefit blocks  → de reassurance-balk onderaan (icoon + titel + omschrijving)
{%- endcomment -%}

{%- assign box_blocks     = section.blocks | where: 'type', 'box' -%}
{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}

<div class="kbx full-width">
  <div class="kbx__inner">

    {%- comment -%} ── Kop ───────────────────────────────────── {%- endcomment -%}
    <div class="kbx__head">
      {%- if section.settings.label != blank -%}
        <span class="kbx__eyebrow">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kbx__title">
          {{ section.settings.heading }}
          {%- if section.settings.heading_highlight != blank -%}
            <span class="kbx__title-em">{{ section.settings.heading_highlight }}</span>
          {%- endif -%}
          <span class="kbx__title-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
        </h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="kbx__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── De drie boxen ─────────────────────────── {%- endcomment -%}
    {%- if box_blocks.size > 0 -%}
      <div class="kbx__grid">
        {%- for block in box_blocks -%}
          {%- assign accent = block.settings.accent | default: 'green' -%}
          {%- assign card_url = block.settings.button_url -%}
          {%- if card_url != blank -%}{%- assign card_tag = 'a' -%}{%- else -%}{%- assign card_tag = 'article' -%}{%- endif -%}
          <{{ card_tag }} class="kbx-card kbx-card--{{ accent }}{% if block.settings.highlight %} kbx-card--featured{% endif %}{% if card_url != blank %} kbx-card--link{% endif %}"{% if card_url != blank %} href="{{ card_url }}" aria-label="{{ block.settings.title | escape }} bekijken"{% endif %} {{ block.shopify_attributes }}>

            <div class="kbx-card__media">
              <div class="kbx-card__stage" aria-hidden="true"></div>
              <span class="kbx-card__lines" aria-hidden="true"><svg viewBox="0 0 30 26" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 13h7"/><path d="M9 4l4 5"/><path d="M9 22l4-5"/></svg></span>
              {%- if block.settings.badge != blank -%}
                <span class="kbx-card__badge">{{ block.settings.badge }}</span>
              {%- endif -%}
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 760 }}"
                  srcset="{{ block.settings.image | image_url: width: 500 }} 500w,
                          {{ block.settings.image | image_url: width: 760 }} 760w,
                          {{ block.settings.image | image_url: width: 1000 }} 1000w"
                  sizes="(max-width: 749px) 42vw, 360px"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  width="360" height="270" loading="lazy"
                  class="kbx-card__img">
              {%- else -%}
                <div class="kbx-card__img kbx-card__img--placeholder">
                  {{- 'icon-gift.svg' | inline_asset_content -}}
                </div>
              {%- endif -%}
            </div>

            <div class="kbx-card__body">
              <h3 class="kbx-card__title">{{ block.settings.title }}</h3>

              {%- if block.settings.description != blank -%}
                <p class="kbx-card__desc">{{ block.settings.description }}</p>
              {%- endif -%}

              <span class="kbx-card__divider" aria-hidden="true"></span>

              {%- capture benefit_items -%}
                {%- for i in (1..5) -%}
                  {%- assign benefit_key = 'benefit_' | append: i -%}
                  {%- assign benefit_val = block.settings[benefit_key] -%}
                  {%- if benefit_val != blank -%}
                    <li>
                      <span class="kbx-card__check" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></span>
                      <span>{{ benefit_val }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              {%- endcapture -%}
              {%- if benefit_items != blank -%}
                <ul class="kbx-card__benefits" role="list">{{ benefit_items }}</ul>
              {%- endif -%}

              <div class="kbx-card__foot">
                {%- if block.settings.price != blank -%}
                  <p class="kbx-card__price">
                    {{ block.settings.price }}
                    {%- if block.settings.price_suffix != blank -%}
                      <span class="kbx-card__price-suffix">{{ block.settings.price_suffix }}</span>
                    {%- endif -%}
                  </p>
                {%- endif -%}
                <span class="kbx-card__btn" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
                </span>
              </div>
            </div>

          </{{ card_tag }}>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Reassurance-balk ──────────────────────── {%- endcomment -%}
    {%- if benefit_blocks.size > 0 -%}
      <div class="kbx-reassure">
        {%- for block in benefit_blocks -%}
          <div class="kbx-reassure__item" {{ block.shopify_attributes }}>
            <span class="kbx-reassure__icon kbx-reassure__icon--{{ block.settings.color | default: 'pink' }}" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'gift' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
                {%- when 'calendar' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M8 2v4M16 2v4M3 10h18"/></svg>
                {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
                {%- when 'paw' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg>
                {%- when 'star' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>
                {%- when 'sparkles' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
                {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              {%- endcase -%}
            </span>
            <div class="kbx-reassure__body">
              <strong class="kbx-reassure__title">{{ block.settings.title }}</strong>
              {%- if block.settings.description != blank -%}
                <span class="kbx-reassure__text">{{ block.settings.description }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.kbx { position: relative; background: transparent; padding: var(--section-pad) 0; overflow: hidden; }
.kbx__inner { position: relative; z-index: 1; max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* ── Kop ─────────────────────────────────────────────── */
.kbx__head { text-align: center; max-width: 640px; margin: 0 auto 48px; }
.kbx__eyebrow { display: inline-block; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .08em; color: var(--color-green); margin-bottom: 12px; }
.kbx__title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.08; color: var(--color-ink); margin: 0; }
.kbx__title-em { color: var(--color-green); }
.kbx__title-heart { display: inline-flex; vertical-align: middle; color: var(--color-pink); margin-left: .12em; }
.kbx__title-heart svg { width: .78em; height: .78em; }
.kbx__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 16px auto 0; max-width: 560px; }

/* ── Grid ────────────────────────────────────────────── */
.kbx__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 26px; align-items: stretch; }

.kbx-card--green  { --c: var(--color-green);  --c-soft: #eef7e8; }
.kbx-card--pink   { --c: var(--color-pink);   --c-soft: #fdeaf2; }
.kbx-card--orange { --c: var(--color-orange); --c-soft: #fdf0e2; }
.kbx-card--purple { --c: #9579cc;             --c-soft: #f1ecf9; }
.kbx-card--yellow { --c: #b07d00;             --c-soft: #fffae0; }

/* ── Kaart ───────────────────────────────────────────── */
.kbx-card { position: relative; display: flex; flex-direction: column; background: #fff; border: 1.5px solid var(--color-line); border-radius: 24px; padding: 16px 16px 20px; transition: transform 220ms ease, box-shadow 220ms ease; text-decoration: none; color: inherit; }
.kbx-card--link { cursor: pointer; }
.kbx-card--link:hover { transform: translateY(-3px); box-shadow: 0 16px 32px rgba(61, 34, 9, .10); border-color: var(--c); }
.kbx-card--link:focus-visible { outline: 2px solid var(--c); outline-offset: 2px; }
.kbx-card--link:hover .kbx-card__btn { transform: translateY(-2px) scale(1.04); box-shadow: 0 12px 24px rgba(0,0,0,.18); }
.kbx-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-card-hover); }
.kbx-card--featured { background: #fdeef4; border: 2px solid var(--c); }

/* Media */
.kbx-card__media { position: relative; border-radius: 18px; overflow: hidden; margin-bottom: 16px; }
.kbx-card__stage { position: absolute; inset: 0; background: radial-gradient(120% 92% at 50% 8%, var(--c-soft) 0%, rgba(255,255,255,0) 76%); }
.kbx-card__lines { position: absolute; top: 14px; right: 12px; width: 30px; height: 26px; color: var(--c); opacity: .7; z-index: 2; }
.kbx-card__lines svg { display: block; width: 100%; height: 100%; }
.kbx-card__img { position: relative; z-index: 1; width: 100%; height: 210px; object-fit: contain; display: block; }
.kbx-card__img--placeholder { display: flex; align-items: center; justify-content: center; color: var(--c); background: linear-gradient(140deg, #fff, var(--c-soft)); }
.kbx-card__img--placeholder svg { width: 72px; height: 72px; }

/* Badge linksboven */
.kbx-card__badge { position: absolute; top: 12px; left: 12px; z-index: 3; display: inline-flex; align-items: center; background: var(--c); color: #fff; font-family: var(--font-body); font-size: .76rem; font-weight: 800; padding: 6px 14px; border-radius: var(--radius-pill); box-shadow: 0 6px 16px rgba(0,0,0,.12); white-space: nowrap; }

/* Body */
.kbx-card__body { display: flex; flex-direction: column; flex: 1; padding: 0 6px; }
.kbx-card__title { font-family: var(--font-heading); font-size: 1.45rem; color: var(--color-ink); line-height: 1.1; margin: 0 0 8px; }
.kbx-card__desc { font-family: var(--font-body); font-size: .96rem; color: var(--color-body); line-height: 1.5; margin: 0 0 16px; }
.kbx-card__divider { display: block; height: 1.5px; background: var(--color-line); margin: 0 0 16px; }

.kbx-card__benefits { list-style: none; margin: 0 0 22px; padding: 0; display: flex; flex-direction: column; gap: 11px; }
.kbx-card__benefits li { display: flex; align-items: center; gap: 11px; font-family: var(--font-body); font-size: .94rem; color: var(--color-ink); line-height: 1.35; }
.kbx-card__check { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 22px; height: 22px; color: var(--c); }
.kbx-card__check svg { width: 21px; height: 21px; }

/* Prijs + ronde pijl */
.kbx-card__foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
.kbx-card__price { font-family: var(--font-heading); font-size: 1.9rem; color: var(--c); line-height: 1; margin: 0; }
.kbx-card__price-suffix { font-family: var(--font-body); font-size: .78rem; font-weight: 600; color: var(--color-muted); margin-left: 4px; }
.kbx-card__btn { display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; width: 52px; height: 52px; border-radius: 50%; background: var(--c); color: #fff; text-decoration: none; transition: transform 160ms, box-shadow 160ms; }
.kbx-card__btn:hover { transform: translateY(-2px) scale(1.04); box-shadow: 0 12px 24px rgba(0,0,0,.18); }
.kbx-card__btn svg { width: 22px; height: 22px; }

/* ── Reassurance-balk ────────────────────────────────── */
.kbx-reassure { margin-top: 40px; background: linear-gradient(180deg, #fffdf8 0%, #fff6ec 100%); border: 1.5px solid var(--color-line); border-radius: 24px; padding: 26px 30px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.kbx-reassure__item { display: flex; align-items: center; gap: 16px; }
.kbx-reassure__item + .kbx-reassure__item { border-left: 1.5px solid var(--color-line); padding-left: 22px; }
.kbx-reassure__icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 54px; height: 54px; border-radius: 50%; }
.kbx-reassure__icon svg { width: 25px; height: 25px; }
.kbx-reassure__icon--green  { background: #eef7e8; color: var(--color-green); }
.kbx-reassure__icon--pink   { background: #fdeaf2; color: var(--color-pink); }
.kbx-reassure__icon--orange { background: #fdf0e2; color: var(--color-orange); }
.kbx-reassure__icon--purple { background: #f1ecf9; color: #9579cc; }
.kbx-reassure__icon--yellow { background: #fffae0; color: #b07d00; }
.kbx-reassure__body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.kbx-reassure__title { font-family: var(--font-heading); font-size: 1.02rem; color: var(--color-ink); line-height: 1.2; }
.kbx-reassure__text { font-family: var(--font-body); font-size: .85rem; color: var(--color-body); line-height: 1.4; }

/* ── Tablet ──────────────────────────────────────────── */
@media (max-width: 989px) and (min-width: 750px) {
  .kbx__grid { gap: 16px; }
  .kbx-card__body { padding: 0 2px; }
  .kbx-card__title { font-size: 1.25rem; }
}

/* ── Mobiel: gestapelde kaart — foto bovenaan, tekst eronder ──── */
@media (max-width: 749px) {
  .kbx__head { margin-bottom: 28px; }
  .kbx__grid { display: flex; flex-direction: column; gap: 18px; }

  .kbx-card { padding: 14px 14px 18px; }
  .kbx-card__media { margin-bottom: 14px; }
  /* afbeelding vult de hele kaartbreedte (geen witruimte rondom) */
  .kbx-card__img { width: 100%; height: 230px; object-fit: cover; }
  .kbx-card__stage { display: none; }
  .kbx-card__lines { display: none; }
  .kbx-card__body { padding: 0 4px; }
  .kbx-card__title { font-size: 1.4rem; margin-bottom: 6px; }
  .kbx-card__desc { font-size: .92rem; line-height: 1.45; margin-bottom: 14px; }
  .kbx-card__divider { margin-bottom: 14px; }
  .kbx-card__benefits { gap: 9px; margin-bottom: 18px; }
  .kbx-card__benefits li { font-size: .9rem; gap: 10px; }
  .kbx-card__check { width: 20px; height: 20px; }
  .kbx-card__check svg { width: 19px; height: 19px; }
  .kbx-card__price { font-size: 1.6rem; }
  .kbx-card__btn { width: 50px; height: 50px; }
  .kbx-card__btn svg { width: 22px; height: 22px; }

  .kbx-reassure { margin-top: 28px; padding: 20px 14px; gap: 6px; border-radius: 20px; }
  .kbx-reassure__item { flex-direction: column; text-align: center; gap: 9px; }
  .kbx-reassure__item + .kbx-reassure__item { padding-left: 6px; }
  .kbx-reassure__icon { width: 48px; height: 48px; }
  .kbx-reassure__icon svg { width: 22px; height: 22px; }
  .kbx-reassure__title { font-size: .9rem; }
  .kbx-reassure__text { font-size: .76rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Kwispelboxen",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow (optioneel)" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Kies jouw" },
    { "type": "text", "id": "heading_highlight", "label": "Kop accent (groen)", "default": "Kwispelbox" },
    { "type": "textarea", "id": "intro", "label": "Subtekst", "default": "Voor elke hond de perfecte verrassing. Elke box zit boordevol speelplezier, lekkers en liefde." }
  ],
  "blocks": [
    {
      "type": "box",
      "name": "Box",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Productfoto (rijk gevulde box)" },
        {
          "type": "select", "id": "accent", "label": "Accentkleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "purple", "label": "Paars" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "badge", "label": "Badge (bv. Klein maar fijn)" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Mini Kwispelbox" },
        { "type": "textarea", "id": "description", "label": "Korte omschrijving", "default": "Een fijne eerste verrassing of klein cadeautje." },
        { "type": "header", "content": "Voordelen (checklist)" },
        { "type": "text", "id": "benefit_1", "label": "Voordeel 1", "default": "± 5 verrassingen op maat" },
        { "type": "text", "id": "benefit_2", "label": "Voordeel 2", "default": "Speeltjes & lekkere snacks" },
        { "type": "text", "id": "benefit_3", "label": "Voordeel 3", "default": "Met liefde samengesteld" },
        { "type": "text", "id": "benefit_4", "label": "Voordeel 4 (optioneel)" },
        { "type": "text", "id": "benefit_5", "label": "Voordeel 5 (optioneel)" },
        { "type": "header", "content": "Prijs & knop" },
        { "type": "text", "id": "price", "label": "Prijs", "default": "€39,95" },
        { "type": "text", "id": "price_suffix", "label": "Prijs achtervoegsel (optioneel)" },
        { "type": "checkbox", "id": "highlight", "label": "Uitlichten (roze achtergrond)", "default": false },
        { "type": "text", "id": "button_label", "label": "Knop aria-label", "default": "Bekijk box" },
        { "type": "url", "id": "button_url", "label": "Knop link" }
      ]
    },
    {
      "type": "benefit",
      "name": "Reassurance-item",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "Elke box voelt als een cadeautje" },
        { "type": "textarea", "id": "description", "label": "Omschrijving", "default": "Met zorg samengesteld en feestelijk verpakt." },
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "gift",
          "options": [
            { "value": "gift", "label": "Cadeau" },
            { "value": "calendar", "label": "Kalender" },
            { "value": "heart", "label": "Hart" },
            { "value": "shield", "label": "Schild" },
            { "value": "paw", "label": "Poot" },
            { "value": "star", "label": "Ster" },
            { "value": "sparkles", "label": "Sparkles" }
          ]
        },
        {
