{%- comment -%}
  sections/product-boxes.liquid — Kwispelbox KB-v4
  Premium productvergelijking: 3 boxen (Mini / Happy / Mega) + vertrouwenslaag.
  - box blocks      → de productkaarten (grote foto, voordelen, prijs, knop)
  - benefit blocks  → de visuele afsluiting met merkvoordelen
  Crème achtergrond, subtiele decoratieve accenten, mobiel-first uitgelicht.
{%- endcomment -%}

{%- assign box_blocks     = section.blocks | where: 'type', 'box' -%}
{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}

<div class="kbx full-width">

  {%- if section.settings.show_decorations -%}
    <div class="kbx__deco" aria-hidden="true">
      <span class="kbx__deco-item kbx__deco-item--1">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
      <span class="kbx__deco-item kbx__deco-item--2">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
      <span class="kbx__deco-item kbx__deco-item--3">{{- 'icon-star.svg' | inline_asset_content -}}</span>
      <span class="kbx__deco-item kbx__deco-item--4">{{- 'icon-sparkles.svg' | inline_asset_content -}}</span>
      <span class="kbx__deco-item kbx__deco-item--5">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
    </div>
  {%- endif -%}

  <div class="kbx__inner">

    {%- comment -%} ── Introductie ───────────────────────────── {%- endcomment -%}
    <div class="kbx__head">
      {%- if section.settings.label != blank -%}
        <span class="kbx__eyebrow">
          <span class="kbx__eyebrow-icon" aria-hidden="true">{{- 'icon-gift.svg' | inline_asset_content -}}</span>
          {{ section.settings.label }}
        </span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kbx__title">
          {{ section.settings.heading }}
          {%- if section.settings.heading_highlight != blank -%}
            <span class="kbx__title-em">{{ section.settings.heading_highlight }}</span>
          {%- endif -%}
        </h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="kbx__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── De drie boxen ─────────────────────────── {%- endcomment -%}
    {%- if box_blocks.size > 0 -%}
      <div class="kbx__grid">
        {%- for block in box_blocks -%}
          {%- assign accent = block.settings.accent | default: 'green' -%}
          <article class="kbx-card kbx-card--{{ accent }}{% if block.settings.highlight %} kbx-card--featured{% endif %}" {{ block.shopify_attributes }}>

            {%- if block.settings.badge != blank -%}
              <span class="kbx-card__badge">
                <span class="kbx-card__badge-icon" aria-hidden="true">{{- 'icon-star.svg' | inline_asset_content -}}</span>
                {{ block.settings.badge }}
              </span>
            {%- endif -%}

            <div class="kbx-card__media">
              <div class="kbx-card__stage" aria-hidden="true"></div>
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 700 }}"
                  srcset="{{ block.settings.image | image_url: width: 500 }} 500w,
                          {{ block.settings.image | image_url: width: 700 }} 700w,
                          {{ block.settings.image | image_url: width: 900 }} 900w"
                  sizes="(max-width: 749px) 88vw, 360px"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  width="360" height="280" loading="lazy"
                  class="kbx-card__img">
              {%- else -%}
                <div class="kbx-card__img kbx-card__img--placeholder">
                  {{- 'icon-gift.svg' | inline_asset_content -}}
                </div>
              {%- endif -%}
            </div>

            <div class="kbx-card__body">
              <h3 class="kbx-card__title">{{ block.settings.title }}</h3>

              {%- if block.settings.description != blank -%}
                <p class="kbx-card__desc">{{ block.settings.description }}</p>
              {%- endif -%}

              {%- assign box_benefits = block.settings.benefits | newline_to_br | split: '<br />' -%}
              {%- if box_benefits.size > 0 -%}
                <ul class="kbx-card__benefits" role="list">
                  {%- for benefit in box_benefits -%}
                    {%- assign benefit = benefit | strip -%}
                    {%- if benefit != blank -%}
                      <li>
                        <span class="kbx-card__check" aria-hidden="true">{{- 'icon-check-circle.svg' | inline_asset_content -}}</span>
                        <span>{{ benefit }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              <div class="kbx-card__foot">
                {%- if block.settings.price != blank -%}
                  <p class="kbx-card__price">
                    {{ block.settings.price }}
                    {%- if block.settings.price_suffix != blank -%}
                      <span class="kbx-card__price-suffix">{{ block.settings.price_suffix }}</span>
                    {%- endif -%}
                  </p>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <a href="{{ block.settings.button_url | default: '#' }}" class="kbx-card__btn">
                    {{ block.settings.button_label }}
                    <span class="kbx-card__btn-icon" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
                  </a>
                {%- endif -%}
              </div>
            </div>

          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Vertrouwenslaag (visuele afsluiting) ──── {%- endcomment -%}
    {%- if benefit_blocks.size > 0 -%}
      <div class="kbx-trust">
        {%- if section.settings.trust_title != blank -%}
          <h3 class="kbx-trust__title">{{ section.settings.trust_title }}</h3>
        {%- endif -%}
        <ul class="kbx-trust__list" role="list">
          {%- for block in benefit_blocks -%}
            <li class="kbx-trust__item" {{ block.shopify_attributes }}>
              <span class="kbx-trust__icon kbx-trust__icon--{{ block.settings.color | default: 'green' }}" aria-hidden="true">
                {{- block.settings.icon | inline_asset_content -}}
              </span>
              <span class="kbx-trust__text">{{ block.settings.title }}</span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}

.kbx {
  position: relative;
  background: var(--color-cream);
  padding: 88px 0;
  overflow: hidden;
}

.kbx__inner {
  position: relative;
  z-index: 1;
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 var(--page-margin);
}

/* ── Decoratieve accenten ─────────────────────────────── */
.kbx__deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.kbx__deco-item { position: absolute; display: block; }
.kbx__deco-item svg { display: block; width: 100%; height: 100%; }
.kbx__deco-item--1 { top: 60px;  left: 4%;   width: 38px; height: 38px; color: var(--color-green);  opacity: .14; transform: rotate(-18deg); }
.kbx__deco-item--2 { top: 130px; right: 7%;  width: 30px; height: 30px; color: var(--color-pink);   opacity: .18; transform: rotate(12deg); }
.kbx__deco-item--3 { top: 42%;   left: 2.5%; width: 26px; height: 26px; color: var(--color-yellow); opacity: .5;  transform: rotate(8deg); }
.kbx__deco-item--4 { bottom: 16%; right: 3%; width: 34px; height: 34px; color: var(--color-orange); opacity: .22; }
.kbx__deco-item--5 { bottom: 8%;  left: 8%;  width: 28px; height: 28px; color: var(--color-pink);   opacity: .12; transform: rotate(24deg); }

/* ── Introductie ──────────────────────────────────────── */
.kbx__head { text-align: center; max-width: 600px; margin: 0 auto 60px; }

.kbx__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  border: 1.5px solid var(--color-line);
  border-radius: var(--radius-pill);
  padding: 7px 16px 7px 12px;
  font-family: var(--font-body);
  font-size: .76rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--color-green);
  margin-bottom: 20px;
}
.kbx__eyebrow-icon { display: inline-flex; }
.kbx__eyebrow-icon svg { width: 15px; height: 15px; }

.kbx__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3.1rem);
  line-height: 1.1;
  color: var(--color-ink);
  margin: 0;
}
.kbx__title-em { color: var(--color-green); }

.kbx__intro {
  font-family: var(--font-body);
  font-size: 1.05rem;
  line-height: 1.65;
  color: var(--color-body);
  margin: 18px auto 0;
  max-width: 520px;
}

/* ── Grid met de boxen ────────────────────────────────── */
.kbx__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  align-items: start;
}

/* Accent-paletten per kaart */
.kbx-card--green  { --c: var(--color-green);  --c-soft: #e8f5e2; }
.kbx-card--pink   { --c: var(--color-pink);   --c-soft: #ffe0ee; }
.kbx-card--orange { --c: var(--color-orange); --c-soft: #fff0e4; }
.kbx-card--yellow { --c: #b07d00;             --c-soft: #fffae0; }

/* ── Kaart ────────────────────────────────────────────── */
.kbx-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1.5px solid var(--color-line);
  border-radius: var(--radius-lg);
  padding: 14px;
  transition: transform 220ms ease, box-shadow 220ms ease;
}

.kbx-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 48px rgba(61, 34, 9, .12);
}

/* Uitgelichte kaart (Meest gekozen) */
.kbx-card--featured {
  border: 2.5px solid var(--color-green);
  box-shadow: 0 24px 60px rgba(102, 170, 68, .20);
  margin-block: -20px;       /* tilt 'm op t.o.v. de buren op desktop */
  padding-top: 22px;
  z-index: 2;
}
.kbx-card--featured:hover { transform: translateY(-8px); }

/* Badge */
.kbx-card__badge {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 3;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--color-green);
  color: #fff;
  font-family: var(--font-body);
  font-size: .72rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .05em;
  padding: 7px 16px;
  border-radius: var(--radius-pill);
  box-shadow: 0 6px 16px rgba(102, 170, 68, .35);
  white-space: nowrap;
}
.kbx-card__badge-icon { display: inline-flex; }
.kbx-card__badge-icon svg { width: 13px; height: 13px; }

/* Media — de productfoto is de held */
.kbx-card__media {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 18px;
}
.kbx-card__stage {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(120% 90% at 50% 0%, var(--c-soft) 0%, #fff 78%);
}
.kbx-card__img {
  position: relative;
  width: 100%;
  height: 248px;
  object-fit: cover;
  display: block;
}
.kbx-card__img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c);
}
.kbx-card__img--placeholder svg { width: 72px; height: 72px; }

/* Body */
.kbx-card__body {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 0 10px 8px;
}

.kbx-card__title {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  color: var(--color-ink);
  line-height: 1.15;
  margin: 0 0 6px;
}

.kbx-card__desc {
  font-family: var(--font-body);
  font-size: .92rem;
  color: var(--color-body);
  line-height: 1.6;
  margin: 0 0 16px;
}

/* Voordelenlijst */
.kbx-card__benefits {
  list-style: none;
  margin: 0 0 22px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.kbx-card__benefits li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-family: var(--font-body);
  font-size: .9rem;
  color: var(--color-body);
  line-height: 1.4;
}
.kbx-card__check {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  margin-top: 1px;
  color: var(--c);
}
.kbx-card__check svg { width: 18px; height: 18px; }

/* Prijs + knop onderaan vastgepind */
.kbx-card__foot { margin-top: auto; }

.kbx-card__price {
  font-family: var(--font-heading);
  font-size: 1.85rem;
  color: var(--color-ink);
  line-height: 1;
  margin: 0 0 14px;
}
.kbx-card__price-suffix {
  font-family: var(--font-body);
  font-size: .8rem;
  font-weight: 600;
  color: var(--color-muted);
  margin-left: 4px;
}

.kbx-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 14px 22px;
  background: var(--color-green);
  color: #fff;
  border-radius: var(--radius-pill);
  font-family: var(--font-heading);
  font-size: 1.02rem;
  text-decoration: none;
  transition: background 160ms, transform 160ms, box-shadow 160ms;
}
.kbx-card__btn:hover {
  background: #5a9a3b;
  transform: translateY(-1px);
  box-shadow: 0 10px 24px rgba(102, 170, 68, .3);
}
.kbx-card__btn-icon { display: flex; align-items: center; }
.kbx-card__btn-icon svg { width: 18px; height: 18px; }

/* ── Vertrouwenslaag ──────────────────────────────────── */
.kbx-trust {
  margin-top: 64px;
  background: linear-gradient(180deg, #fff 0%, #fffaf0 100%);
  border: 1.5px solid var(--color-line);
  border-radius: var(--radius-lg);
  padding: 36px 32px;
  box-shadow: 0 12px 40px rgba(61, 34, 9, .06);
}
.kbx-trust__title {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  color: var(--color-ink);
  text-align: center;
  margin: 0 0 28px;
}
.kbx-trust__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px 28px;
}
.kbx-trust__item {
  display: flex;
  align-items: center;
  gap: 14px;
}
.kbx-trust__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 52px;
  height: 52px;
  border-radius: 50%;
}
.kbx-trust__icon svg { width: 24px; height: 24px; }
.kbx-trust__icon--green  { background: #e8f5e2; color: var(--color-green); }
.kbx-trust__icon--pink   { background: #ffe0ee; color: var(--color-pink); }
.kbx-trust__icon--orange { background: #fff0e4; color: var(--color-orange); }
.kbx-trust__icon--yellow { background: #fffae0; color: #b07d00; }
.kbx-trust__text {
  font-family: var(--font-body);
  font-size: .95rem;
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.35;
}

/* ── Tablet ───────────────────────────────────────────── */
@media (max-width: 989px) and (min-width: 750px) {
  .kbx__grid { gap: 18px; }
  .kbx-card--featured { margin-block: -12px; }
  .kbx-card__body { padding: 0 4px 6px; }
  .kbx-trust__list { grid-template-columns: repeat(2, 1fr); }
}

/* ── Mobiel: een eigen, zorgvuldig ontworpen ervaring ─── */
@media (max-width: 749px) {
  .kbx { padding: 56px 0; }
  .kbx__head { margin-bottom: 40px; }

  .kbx__grid {
    grid-template-columns: 1fr;
    gap: 40px;
    max-width: 440px;
    margin: 0 auto;
  }

  /* De populairste box als eerste én geaccentueerd tonen */
  .kbx-card--featured {
    order: -1;
    margin-block: 0;
  }

  .kbx-card { padding: 12px; }
  .kbx-card__img { height: 230px; }
  .kbx-card__title { font-size: 1.6rem; }

  /* Decoraties subtieler op klein scherm */
  .kbx__deco-item--1,
  .kbx__deco-item--4 { display: none; }

  .kbx-trust {
    margin-top: 48px;
    padding: 28px 20px;
    border-radius: var(--radius-md);
  }
  .kbx-trust__list { grid-template-columns: 1fr; gap: 18px; }
  .kbx-trust__title { font-size: 1.25rem; margin-bottom: 22px; }
}

{% endstylesheet %}

{% schema %}
