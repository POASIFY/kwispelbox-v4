{%- comment -%}
  sections/product-boxes.liquid — Kwispelbox KB-v4
  3 productkaarten (Mini / Happy / Mega) op crème achtergrond.
  Ronde kaarten, foto bovenaan, beschrijving, groene bestelknop.
  Eén block per box; highlight + badge voor "Meest gekozen".
{%- endcomment -%}

{%- assign box_blocks = section.blocks | where: 'type', 'box' -%}

<div class="boxes full-width">
  <div class="boxes__inner">

    {%- if section.settings.heading != blank -%}
      <div class="boxes__head">
        {%- if section.settings.label != blank -%}
          <span class="boxes__label">{{ section.settings.label }}</span>
        {%- endif -%}
        <h2 class="boxes__title">{{ section.settings.heading }}</h2>
        {%- if section.settings.intro != blank -%}
          <p class="boxes__intro">{{ section.settings.intro }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if box_blocks.size > 0 -%}
      <div class="boxes__grid">
        {%- for block in box_blocks -%}
          <article class="box-card{% if block.settings.highlight %} box-card--highlight{% endif %}" {{ block.shopify_attributes }}>

            {%- if block.settings.badge != blank -%}
              <span class="box-card__badge">{{ block.settings.badge }}</span>
            {%- endif -%}

            <div class="box-card__media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                          {{ block.settings.image | image_url: width: 600 }} 600w"
                  sizes="(max-width: 749px) 90vw, 360px"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  width="360" height="270" loading="lazy"
                  class="box-card__img">
              {%- else -%}
                <div class="box-card__img box-card__img--placeholder" aria-hidden="true">
                  {{- 'icon-gift.svg' | inline_asset_content -}}
                </div>
              {%- endif -%}
            </div>

            <div class="box-card__body">
              <h3 class="box-card__title">{{ block.settings.title }}</h3>

              {%- if block.settings.price != blank -%}
                <p class="box-card__price">
                  {{ block.settings.price }}
                  {%- if block.settings.price_suffix != blank -%}
                    <span class="box-card__price-suffix">{{ block.settings.price_suffix }}</span>
                  {%- endif -%}
                </p>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="box-card__desc">{{ block.settings.description }}</p>
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_url | default: '#' }}" class="box-card__btn">
                  {{ block.settings.button_label }}
                  <span class="box-card__btn-icon" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
                </a>
              {%- endif -%}
            </div>

          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}

.boxes {
  background: var(--color-cream);
  padding: 64px 0;
}

.boxes__inner {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 var(--page-margin);
}

/* Kop */
.boxes__head {
  text-align: center;
  max-width: 620px;
  margin: 0 auto 40px;
}

.boxes__label {
  display: inline-block;
  font-family: var(--font-body);
  font-size: .78rem;
  font-weight: 800;
  color: var(--color-green);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-bottom: 10px;
}

.boxes__title {
  font-family: var(--font-heading);
  font-size: clamp(1.7rem, 3vw, 2.4rem);
  color: var(--color-ink);
  line-height: 1.15;
  margin: 0;
}

.boxes__intro {
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--color-body);
  line-height: 1.6;
  margin: 14px 0 0;
}

/* Grid */
.boxes__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  align-items: stretch;
}

/* Kaart */
.box-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1.5px solid var(--color-line);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: transform 200ms ease, box-shadow 200ms ease;
}

.box-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(61, 34, 9, .12);
}

/* Highlight kaart (Meest gekozen) */
.box-card--highlight {
  border-color: var(--color-green);
  border-width: 2.5px;
  box-shadow: 0 16px 40px rgba(102, 170, 68, .18);
}

.box-card__badge {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 2;
  background: var(--color-green);
  color: #fff;
  font-family: var(--font-body);
  font-size: .68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .04em;
  padding: 5px 12px;
  border-radius: var(--radius-pill);
}

/* Media */
.box-card__media {
  background: var(--color-cream);
  padding: 16px;
}

.box-card__img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  border-radius: var(--radius-md);
  display: block;
}

.box-card__img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-green);
  background: #e8f5e2;
}

.box-card__img--placeholder svg {
  width: 64px;
  height: 64px;
}

/* Body */
.box-card__body {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 20px 22px 24px;
  text-align: center;
}

.box-card__title {
  font-family: var(--font-heading);
  font-size: 1.45rem;
  color: var(--color-ink);
  line-height: 1.15;
  margin: 0 0 6px;
}

.box-card__price {
  font-family: var(--font-heading);
  font-size: 1.65rem;
  color: var(--color-green);
  margin: 0 0 12px;
}

.box-card__price-suffix {
  font-family: var(--font-body);
  font-size: .8rem;
  font-weight: 600;
  color: var(--color-muted);
}

.box-card__desc {
  font-family: var(--font-body);
  font-size: .92rem;
  color: var(--color-body);
  line-height: 1.6;
  margin: 0 0 22px;
}

/* Knop onderaan vastpinnen */
.box-card__btn {
  margin-top: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 13px 22px;
  background: var(--color-green);
  color: #fff;
  border-radius: var(--radius-pill);
  font-family: var(--font-heading);
  font-size: 1rem;
  text-decoration: none;
  transition: background 160ms, transform 160ms;
}

.box-card__btn:hover {
  background: #5a9a3b;
  transform: translateY(-1px);
}

.box-card__btn-icon {
  display: flex;
  align-items: center;
}

.box-card__btn-icon svg {
  width: 18px;
  height: 18px;
}

/* Tablet */
@media (max-width: 989px) and (min-width: 750px) {
  .boxes__grid { gap: 16px; }
  .box-card__body { padding: 18px 16px 20px; }
}

/* Mobiel */
@media (max-width: 749px) {
  .boxes { padding: 44px 0; }
  .boxes__grid {
    grid-template-columns: 1fr;
    gap: 20px;
    max-width: 420px;
    margin: 0 auto;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Kwispelboxen",
  "tag": "section",
  "enabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "text", "id": "label", "label": "Label boven titel", "default": "Onze boxen" },
    { "type": "text", "id": "heading", "label": "Titel", "default": "Kies de box die past bij jouw hond" },
    { "type": "textarea", "id": "intro", "label": "Introtekst", "default": "Elke maand een nieuwe verrassing, met liefde samengesteld. Geen verplichtingen, altijd opzegbaar." }
  ],
  "blocks": [
    {
      "type": "box",
      "name": "Box",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Productfoto" },
        { "type": "text", "id": "title", "label": "Naam", "default": "Mini Box" },
        { "type": "text", "id": "price", "label": "Prijs", "default": "€49,95" },
        { "type": "text", "id": "price_suffix", "label": "Prijs achtervoegsel", "default": "per maand" },
        { "type": "textarea", "id": "description", "label": "Beschrijving", "default": "Een leuke kennismaking met 3 tot 4 verrassingen voor jouw hond." },
        { "type": "text", "id": "badge", "label": "Badge (optioneel, bv. Meest gekozen)" },
        { "type": "checkbox", "id": "highlight", "label": "Uitlichten (groene rand)", "default": false },
        { "type": "text", "id": "button_label", "label": "Knoptekst", "default": "Bestel nu" },
        { "type": "url", "id": "button_url", "label": "Knop link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kwispelboxen",
      "blocks": [
        {
          "type": "box",
          "settings": {
            "title": "Mini Box",
            "price": "€49,95",
            "price_suffix": "per maand",
            "description": "Een leuke kennismaking met 3 tot 4 verrassingen voor jouw hond.",
            "button_label": "Bestel nu"
          }
        },
        {
          "type": "box",
          "settings": {
            "title": "Happy Box",
            "price": "€64,95",
            "price_suffix": "per maand",
            "description": "Onze populairste box boordevol speeltjes, snacks en verwennerij.",
            "badge": "Meest gekozen",
            "highlight": true,
            "button_label": "Bestel nu"
          }
        },
        {
          "type": "box",
          "settings": {
            "title": "Mega Box",
            "price": "€79,95",
            "price_suffix": "per maand",
            "description": "Het ultieme feestje: extra veel speelgoed, snacks en cadeautjes.",
            "button_label": "Bestel nu"
          }
        }
      ]
    }
  ]
}
{% endschema %}
