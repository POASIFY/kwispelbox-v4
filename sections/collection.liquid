{%- comment -%}
  sections/collection.liquid — Kwispelbox KB-v4
  Mobiel-veilige, licht gebrande collectie-grid.
{%- endcomment -%}

<div class="kbcol full-width">
  <div class="kbcol__inner">
    <header class="kbcol__head">
      <p class="kbcol__eyebrow">Voor blije honden</p>
      <h1 class="kbcol__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="kbcol__desc">{{ collection.description }}</div>
      {%- endif -%}
    </header>

    {%- paginate collection.products by 24 -%}
      {%- if collection.products.size > 0 -%}
        <ul class="kbcol__grid" role="list">
          {%- for product in collection.products -%}
            <li class="kbcol__card">
              <a href="{{ product.url }}" class="kbcol__media">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" width="400" height="400" loading="lazy">
                {%- else -%}
                  <span class="kbcol__ph">{%- render 'lucide', icon: 'gift' -%}</span>
                {%- endif -%}
              </a>
              <div class="kbcol__info">
                <a href="{{ product.url }}" class="kbcol__name">{{ product.title }}</a>
                <span class="kbcol__price">{{ product.price | money }}</span>
              </div>
            </li>
          {%- endfor -%}
        </ul>
        {%- if paginate.pages > 1 -%}
          <nav class="kbcol__pag" role="navigation">{{ paginate | default_pagination }}</nav>
        {%- endif -%}
      {%- else -%}
        <p class="kbcol__empty">Nog geen producten in deze collectie. Kom snel terug — er is altijd iets nieuws op komst voor je hond.</p>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

<style>
.kbcol { background: var(--color-cream); padding: 40px 0 72px; }
.kbcol__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }
.kbcol__head { text-align: center; margin-bottom: 32px; }
.kbcol__eyebrow { font-family: var(--font-body); font-size: .9rem; font-weight: 800; letter-spacing: .04em; text-transform: uppercase; color: var(--color-green); margin: 0 0 8px; }
.kbcol__title { font-family: var(--font-heading); font-size: clamp(2rem, 6vw, 3rem); color: var(--color-ink); margin: 0; }
.kbcol__desc { font-family: var(--font-body); color: var(--color-body); line-height: 1.6; margin: 12px auto 0; max-width: 60ch; }
.kbcol__grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr)); gap: 20px; }
.kbcol__card { display: flex; flex-direction: column; min-width: 0; background: #fff; border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 12px 30px rgba(0,0,0,.05); transition: transform 160ms, box-shadow 160ms; }
.kbcol__card:hover { transform: translateY(-4px); box-shadow: 0 20px 44px rgba(0,0,0,.09); }
.kbcol__media { display: block; aspect-ratio: 1; background: var(--color-cream); }
.kbcol__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
.kbcol__ph { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; color: var(--color-green); }
.kbcol__ph .lucide { width: 48px; height: 48px; }
.kbcol__info { display: flex; flex-direction: column; gap: 6px; padding: 16px; }
.kbcol__name { font-family: var(--font-heading); font-size: 1.05rem; line-height: 1.2; color: var(--color-ink); text-decoration: none; overflow-wrap: anywhere; }
.kbcol__name:hover { color: var(--color-green); }
.kbcol__price { font-family: var(--font-heading); font-size: 1rem; color: var(--color-green); }
.kbcol__empty { text-align: center; font-family: var(--font-body); color: var(--color-body); padding: 40px 0; }
.kbcol__pag { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin-top: 44px; font-family: var(--font-body); font-weight: 700; }
.kbcol__pag a, .kbcol__pag span { color: var(--color-ink); text-decoration: none; padding: 6px 12px; border-radius: var(--radius-pill); }
.kbcol__pag a:hover { background: #fff; color: var(--color-green); }
@media (max-width: 749px) {
  .kbcol__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  .kbcol__info { padding: 12px; }
  .kbcol__name { font-size: .95rem; }
}
</style>

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
