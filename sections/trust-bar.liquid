{%- comment -%}
  sections/trust-bar.liquid — Kwispelbox KB-v4
  Groene balk met USPs en optionele hond foto rechts
{%- endcomment -%}

{%- assign usp_blocks = section.blocks | where: 'type', 'usp' -%}

{%- if usp_blocks.size > 0 -%}
<div class="trust-bar">
  <div class="trust-bar__inner">

    <ul class="trust-bar__list" role="list">
      {%- for block in usp_blocks -%}
        <li class="trust-bar__item" {{ block.shopify_attributes }}>
          <span class="trust-bar__icon-wrap" aria-hidden="true">
            {{- block.settings.icon | inline_asset_content -}}
          </span>
          <span class="trust-bar__text">
            <strong>{{ block.settings.title }}</strong>
            {%- if block.settings.subtitle != blank -%}
              <span>{{ block.settings.subtitle }}</span>
            {%- endif -%}
          </span>
        </li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.dog_image != blank -%}
      <div class="trust-bar__dog" aria-hidden="true">
        <img
          src="{{ section.settings.dog_image | image_url: width: 300 }}"
          alt=""
          width="150"
          height="180"
          loading="lazy">
      </div>
    {%- endif -%}

  </div>
    <div class="trust-bar__wave" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 48" preserveAspectRatio="none">
        <path d="M0,24 C180,48 360,0 540,24 C720,48 900,0 1080,24 C1260,48 1380,12 1440,20 L1440,48 L0,48 Z" fill="#fff"/>
      </svg>
    </div>
  </div>
</div>
{%- endif -%}

{% stylesheet %}

.trust-bar {
  background: var(--color-green);
  position: relative;
  overflow: visible;
  padding-bottom: 28px;
}

.trust-bar__inner {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 var(--page-margin);
  display: flex;
  align-items: center;
  min-height: 80px;
  position: relative;
}

.trust-bar__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  flex: 1;
  gap: 0;
}

.trust-bar__item {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
  padding: 16px 20px;
  border-right: 1px solid rgba(255,255,255,.2);
}

.trust-bar__item:last-child {
  border-right: none;
}

.trust-bar__icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,.2);
  flex-shrink: 0;
}

.trust-bar__icon-wrap svg {
  width: 20px;
  height: 20px;
  color: #fff;
}

.trust-bar__text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.trust-bar__text strong {
  font-family: var(--font-body);
  font-size: .82rem;
  font-weight: 800;
  color: #fff;
  line-height: 1.3;
}

.trust-bar__text span {
  font-family: var(--font-body);
  font-size: .75rem;
  font-weight: 600;
  color: rgba(255,255,255,.8);
}

.trust-bar__dog {
  position: absolute;
  right: var(--page-margin);
  bottom: 0;
  width: 150px;
  pointer-events: none;
}

.trust-bar__dog img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: contain;
  object-position: bottom;
}

.trust-bar__wave {
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  line-height: 0;
  pointer-events: none;
}

.trust-bar__wave svg {
  display: block;
  width: 100%;
  height: 32px;
}

@media (max-width: 749px) {
  .trust-bar__list { flex-wrap: wrap; }
  .trust-bar__item { flex: 0 0 50%; border-right: none; border-bottom: 1px solid rgba(255,255,255,.2); }
  .trust-bar__item:nth-last-child(-n+2) { border-bottom: none; }
  .trust-bar__dog { display: none; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Trust balk",
  "tag": "section",
  "enabled_on": { "groups": ["header"] },
  "settings": [
    {
      "type": "image_picker",
      "id": "dog_image",
      "label": "Hond afbeelding (optioneel)"
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Gratis verzending"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitel",
          "default": "vanaf €75"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icoon",
          "default": "icon-truck.svg",
          "options": [
            { "value": "icon-truck.svg", "label": "Vrachtwagen" },
            { "value": "icon-heart.svg", "label": "Hart" },
            { "value": "icon-shield.svg", "label": "Schild" },
            { "value": "icon-gift.svg", "label": "Cadeau" },
            { "value": "icon-star.svg", "label": "Ster" },
            { "value": "icon-check-circle.svg", "label": "Vinkje" },
            { "value": "icon-paw.svg", "label": "Poot" },
            { "value": "icon-refresh.svg", "label": "Terugbetaling" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust balk",
      "blocks": [
        { "type": "usp", "settings": { "title": "Gratis verzending", "subtitle": "vanaf \u20ac75", "icon": "icon-truck.svg" } },
        { "type": "usp", "settings": { "title": "Niet goed?", "subtitle": "Geld terug", "icon": "icon-refresh.svg" } },
        { "type": "usp", "settings": { "title": "100% blije honden", "subtitle": "garantie", "icon": "icon-heart.svg" } },
        { "type": "usp", "settings": { "title": "Voor 23:59 besteld", "subtitle": "morgen in huis", "icon": "icon-truck.svg" } }
      ]
    }
  ]
}
{% endschema %}
