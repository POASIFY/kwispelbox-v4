{%- comment -%}
  sections/trust-bar.liquid — Kwispelbox KB-v4
  Witte trust-kaart met 4 cirkel-iconen (onder de hero), naar mockup.
{%- endcomment -%}

{%- assign usp_blocks = section.blocks | where: 'type', 'usp' -%}

{%- if usp_blocks.size > 0 -%}
<div class="kbtrust full-width">
  <div class="kbtrust__inner">
    <ul class="kbtrust__list" role="list">
      {%- for block in usp_blocks -%}
        <li class="kbtrust__item" {{ block.shopify_attributes }}>
          <span class="kbtrust__icon kbtrust__icon--{{ block.settings.color | default: 'green' }}" aria-hidden="true">
            {{- block.settings.icon | inline_asset_content -}}
          </span>
          <span class="kbtrust__text">
            <strong>{{ block.settings.title }}</strong>
            {%- if block.settings.subtitle != blank -%}<span>{{ block.settings.subtitle }}</span>{%- endif -%}
          </span>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>
{%- endif -%}

{% stylesheet %}
.kbtrust { background: var(--color-cream); padding: 0 0 var(--section-pad-sm); }
.kbtrust__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }
.kbtrust__list { list-style: none; margin: 0; padding: 18px 8px; display: grid; grid-template-columns: repeat(4, 1fr); background: #fff; border-radius: var(--radius-lg); box-shadow: var(--shadow-card); }
.kbtrust__item { display: flex; align-items: center; gap: 14px; padding: 8px 22px; min-width: 0; }
.kbtrust__item + .kbtrust__item { border-left: 1px solid var(--color-line); }
.kbtrust__icon { display: inline-flex; align-items: center; justify-content: center; width: 50px; height: 50px; border-radius: 50%; flex-shrink: 0; }
.kbtrust__icon svg { width: 24px; height: 24px; }
.kbtrust__icon--green { background: #e8f5e2; color: var(--color-green); }
.kbtrust__icon--orange { background: #fff0e4; color: var(--color-orange); }
.kbtrust__icon--pink { background: #ffe0ee; color: var(--color-pink); }
.kbtrust__icon--purple { background: #ede7f7; color: #8b6fc4; }
.kbtrust__icon--yellow { background: #fff6da; color: #d9a400; }
.kbtrust__text { display: flex; flex-direction: column; min-width: 0; }
.kbtrust__text strong { font-family: var(--font-body); font-size: .95rem; font-weight: 800; color: var(--color-ink); line-height: 1.25; }
.kbtrust__text span { font-family: var(--font-body); font-size: .88rem; color: var(--color-muted); line-height: 1.25; }

/* Mobiel: 4 kolommen blijven, icoon boven de tekst (naar mockup) */
@media (max-width: 749px) {
  .kbtrust__list { grid-template-columns: repeat(4, 1fr); padding: 16px 2px; }
  .kbtrust__item { flex-direction: column; align-items: center; text-align: center; gap: 9px; padding: 4px 5px; }
  .kbtrust__item + .kbtrust__item { border-left: 1px solid var(--color-line); border-top: none; }
  .kbtrust__icon { width: 40px; height: 40px; }
  .kbtrust__icon svg { width: 20px; height: 20px; }
  .kbtrust__text { align-items: center; }
  .kbtrust__text strong { font-size: .68rem; line-height: 1.2; }
  .kbtrust__text span { font-size: .66rem; line-height: 1.2; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Trust balk",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "Gratis verzending" },
        { "type": "text", "id": "subtitle", "label": "Subtitel", "default": "vanaf €75" },
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "icon-truck.svg",
          "options": [
            { "value": "icon-truck.svg", "label": "Vrachtwagen" },
            { "value": "icon-paw.svg", "label": "Poot" },
            { "value": "icon-gift.svg", "label": "Cadeau" },
            { "value": "icon-shield.svg", "label": "Schild" },
            { "value": "icon-heart.svg", "label": "Hart" },
            { "value": "icon-star.svg", "label": "Ster" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Kleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" }, { "value": "orange", "label": "Oranje" },
            { "value": "pink", "label": "Roze" }, { "value": "purple", "label": "Paars" }, { "value": "yellow", "label": "Geel" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust balk",
      "blocks": [
        { "type": "usp", "settings": { "title": "Gratis verzending", "subtitle": "vanaf €75", "icon": "icon-truck.svg", "color": "green" } },
        { "type": "usp", "settings": { "title": "Meer dan 1.200", "subtitle": "blije honden", "icon": "icon-paw.svg", "color": "orange" } },
        { "type": "usp", "settings": { "title": "Elke box voelt als", "subtitle": "een cadeautje", "icon": "icon-gift.svg", "color": "pink" } },
        { "type": "usp", "settings": { "title": "Veilig & vertrouwd", "subtitle": "betalen", "icon": "icon-shield.svg", "color": "purple" } }
      ]
    }
  ]
}
{% endschema %}
