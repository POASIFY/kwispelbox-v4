{%- comment -%}
  sections/404.liquid — Kwispelbox KB-v4
  Speelse "even het spoor bijster" 404 met warme redemption-CTA's.
{%- endcomment -%}

<div class="kb404 full-width">
  <div class="kb404__inner">

    <span class="kb404__deco kb404__deco--paw1" aria-hidden="true">{%- render 'lucide', icon: 'paw' -%}</span>
    <span class="kb404__deco kb404__deco--heart" aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span>
    <span class="kb404__deco kb404__deco--bone" aria-hidden="true">{%- render 'lucide', icon: 'bone' -%}</span>

    <p class="kb404__eyebrow">{{ section.settings.eyebrow | default: 'Oeps, even het spoor bijster' }}</p>

    <div class="kb404__art" aria-hidden="true">
      <span class="kb404__digit">4</span>
      <span class="kb404__pup">{%- render 'lucide', icon: 'dog' -%}</span>
      <span class="kb404__digit">4</span>
    </div>

    <h1 class="kb404__title">{{ section.settings.title | default: 'Deze pagina is er met de staart vandoor' }}</h1>
    <p class="kb404__text">{{ section.settings.text | default: 'Geen zorgen — net als een hond die zijn bal kwijt is, snuffelen we samen wel iets leuks bij elkaar. Loop verder tussen de boxen en verras je hond met een nieuw cadeautje.' }}</p>

    <div class="kb404__actions">
      <a href="{{ section.settings.button_url | default: routes.all_products_collection_url }}" class="kb404__btn kb404__btn--primary">
        {{ section.settings.button_label | default: 'Bekijk de boxen' }}<span aria-hidden="true">{%- render 'lucide', icon: 'paw' -%}</span>
      </a>
      <a href="{{ section.settings.button2_url | default: routes.root_url }}" class="kb404__btn kb404__btn--ghost">{{ section.settings.button2_label | default: 'Terug naar home' }}</a>
    </div>

  </div>
</div>

{% stylesheet %}
.kb404 { background: var(--color-cream); padding: var(--section-pad) 0; }
.kb404__inner { position: relative; max-width: 640px; margin: 0 auto; padding: 0 var(--page-margin); text-align: center; }

.kb404__deco { position: absolute; pointer-events: none; }
.kb404__deco .lucide { display: block; width: 100%; height: 100%; }
.kb404__deco--paw1 { top: 0; left: 4%; width: 36px; height: 36px; color: var(--color-green); opacity: .3; transform: rotate(-14deg); }
.kb404__deco--heart { top: 60px; right: 6%; width: 26px; height: 26px; color: var(--color-pink); opacity: .4; }
.kb404__deco--bone { bottom: 8%; left: 8%; width: 32px; height: 32px; color: var(--color-orange); opacity: .32; transform: rotate(18deg); }

.kb404__eyebrow { font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; letter-spacing: .05em; text-transform: uppercase; color: var(--color-green); margin: 0 0 14px; }

.kb404__art { display: inline-flex; align-items: center; justify-content: center; gap: 6px; margin: 0 0 10px; }
.kb404__digit { font-family: var(--font-heading); font-size: clamp(5rem, 22vw, 9rem); line-height: 1; color: var(--color-ink); }
.kb404__pup { display: inline-flex; align-items: center; justify-content: center; width: clamp(5rem, 22vw, 9rem); height: clamp(5rem, 22vw, 9rem); border-radius: 50%; background: var(--color-pink); box-shadow: var(--shadow-card); }
.kb404__pup .lucide { width: 56%; height: 56%; color: #fff; }

.kb404__title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.1; color: var(--color-ink); margin: 0 0 14px; }
.kb404__text { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.65; color: var(--color-body); margin: 0 auto 30px; max-width: 46ch; }

.kb404__actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
.kb404__btn { display: inline-flex; align-items: center; gap: 9px; padding: 16px 30px; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.08rem; text-decoration: none; transition: background 160ms, transform 160ms, box-shadow 160ms, border-color 160ms; }
.kb404__btn .lucide { width: 18px; height: 18px; }
.kb404__btn--primary { background: var(--color-green); color: #fff; }
.kb404__btn--primary:hover { background: #5a9a3b; transform: translateY(-2px); box-shadow: 0 12px 30px rgba(102,170,68,.3); }
.kb404__btn--ghost { background: #fff; color: var(--color-ink); border: 2px solid var(--color-line); }
.kb404__btn--ghost:hover { border-color: var(--color-green); transform: translateY(-2px); }
{% endstylesheet %}

{% schema %}
{
  "name": "404 pagina",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Oeps, even het spoor bijster" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Deze pagina is er met de staart vandoor" },
    { "type": "textarea", "id": "text", "label": "Tekst", "default": "Geen zorgen — net als een hond die zijn bal kwijt is, snuffelen we samen wel iets leuks bij elkaar. Loop verder tussen de boxen en verras je hond met een nieuw cadeautje." },
    { "type": "text", "id": "button_label", "label": "Knop 1 tekst", "default": "Bekijk de boxen" },
    { "type": "url", "id": "button_url", "label": "Knop 1 link (leeg = alle producten)" },
    { "type": "text", "id": "button2_label", "label": "Knop 2 tekst", "default": "Terug naar home" },
    { "type": "url", "id": "button2_url", "label": "Knop 2 link (leeg = homepage)" }
  ]
}
{% endschema %}
