{%- comment -%}
  sections/why-kwispelbox.liquid — Kwispelbox KB-v4
  "Waarom honden dol zijn op Kwispelbox" — gecentreerde kop, links lifestyle-foto,
  rechts 4 voordeel-rijen (stippellijn-dividers) + CTA. Mobiel: foto → witte kaarten → CTA.
{%- endcomment -%}

{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}

<div class="why full-width">

  {%- if section.settings.show_decorations -%}
    <div class="why__deco" aria-hidden="true">
      <span class="why__deco why__deco--lines"><svg viewBox="0 0 48 26" fill="none" stroke-width="2.6" stroke-linecap="round"><path d="M5 17C10 7 14 20 19 12" stroke="var(--color-green)"/><path d="M3 9c2-3 5-4 8-3" stroke="var(--color-pink)"/><path d="M9 22c1-3 3-5 6-5" stroke="var(--color-yellow)"/></svg></span>
      <span class="why__deco why__deco--heart"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-pink)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
      <span class="why__deco why__deco--paw"><svg viewBox="0 0 24 24" fill="var(--color-orange)"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
      <span class="why__deco why__deco--heart2"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-pink)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
    </div>
  {%- endif -%}

  <div class="why__inner">

    <div class="why__head">
      {%- if section.settings.heading != blank -%}
        <h2 class="why__heading">{{ section.settings.heading }}{%- if section.settings.heading_highlight != blank %} <span class="why__heading-em">{{ section.settings.heading_highlight }}</span>{%- endif -%}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="why__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="why__layout">

      <figure class="why__media">
        <span class="why__media-glow" aria-hidden="true"></span>
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 700 }} 700w,
                    {{ section.settings.image | image_url: width: 1200 }} 1200w,
                    {{ section.settings.image | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 859px) 92vw, 48vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            width="720" height="760" loading="lazy"
            class="why__img">
        {%- else -%}
          <div class="why__img why__img--placeholder">{%- render 'kb-icon', icon: 'paw' -%}</div>
        {%- endif -%}

        {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
          <div class="why__badge">
            <svg class="why__badge-shape" viewBox="0 0 124 124" aria-hidden="true"><g fill="currentColor"><circle cx="110" cy="62" r="13"/><circle cx="103.6" cy="86" r="13"/><circle cx="86" cy="103.6" r="13"/><circle cx="62" cy="110" r="13"/><circle cx="38" cy="103.6" r="13"/><circle cx="20.4" cy="86" r="13"/><circle cx="14" cy="62" r="13"/><circle cx="20.4" cy="38" r="13"/><circle cx="38" cy="20.4" r="13"/><circle cx="62" cy="14" r="13"/><circle cx="86" cy="20.4" r="13"/><circle cx="103.6" cy="38" r="13"/><circle cx="62" cy="62" r="47"/></g></svg>
            <span class="why__badge-inner">
              <span class="why__badge-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
              <span class="why__badge-text">{{ section.settings.badge_text }}</span>
            </span>
          </div>
        {%- endif -%}
      </figure>

      <div class="why__col">
        {%- if benefit_blocks.size > 0 -%}
          <div class="why__benefits">
            {%- for block in benefit_blocks -%}
              <div class="why__benefit why__benefit--{{ block.settings.color }}" {{ block.shopify_attributes }}>
                <span class="why__benefit-icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
                <div class="why__benefit-body">
                  <h3 class="why__benefit-title">{{ block.settings.title }}</h3>
                  {%- if block.settings.text != blank -%}<p class="why__benefit-text">{{ block.settings.text }}</p>{%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <div class="why__cta-wrap">
            <span class="why__cta-arrow" aria-hidden="true"><svg viewBox="0 0 60 44" fill="none" stroke="var(--color-green)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14c10 16 26 18 40 12"/><path d="M37 30l8-4 2 8"/></svg></span>
            <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="why__cta">
              {{ section.settings.cta_label }}
              <span class="why__cta-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span>
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
.why { position: relative; background: transparent; padding: var(--section-pad) 0; overflow: hidden; }
.why__inner { position: relative; z-index: 1; max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* Decoratie */
/* Decoraties hangen rond de (gecentreerde) titel/omschrijving — vaste px boven, aan de randen,
   zodat ze op zowel desktop als mobiel netjes rond de header blijven i.p.v. midden in de sectie. */
.why__deco { position: absolute; top: 0; left: 0; right: 0; height: 230px; z-index: 0; pointer-events: none; }
.why__deco span { position: absolute; display: block; }
.why__deco span svg { display: block; width: 100%; height: 100%; }
.why__deco--lines { top: 58px; left: 8%; width: 48px; height: 26px; }
.why__deco--heart { top: 18px; left: 13%; width: 30px; height: 30px; }
.why__deco--paw { top: 28px; right: 11%; width: 28px; height: 28px; opacity: .16; transform: rotate(12deg); }
.why__deco--heart2 { top: 80px; right: 8%; width: 32px; height: 32px; }

/* Kop */
.why__head { text-align: center; margin: 0 auto 44px; }
.why__heading { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.05; color: var(--color-ink); margin: 0; }
.why__heading-em { color: var(--color-green); }
.why__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 16px auto 0; max-width: 540px; }

/* Layout: foto | kolom */
.why__layout { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: stretch; }

/* Media */
.why__media { position: relative; margin: 0; border-radius: 28px; min-height: 420px; }
.why__media-glow { position: absolute; inset: -18px auto -10px -26px; width: 55%; z-index: -1; border-radius: 50%; background: radial-gradient(60% 60% at 40% 50%, rgba(102,170,68,.22), transparent 72%); }
.why__img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 28px; box-shadow: 0 26px 60px rgba(61, 34, 9, .16); }
.why__img--placeholder { display: flex; align-items: center; justify-content: center; min-height: 420px; background: linear-gradient(140deg, #fff, #eef7e8); color: var(--color-green); }
.why__img--placeholder svg { width: 92px; height: 92px; }

/* Scalloped badge (optioneel) */
.why__badge { position: absolute; top: 16px; right: 16px; width: 116px; height: 116px; color: var(--color-yellow); transform: rotate(7deg); filter: drop-shadow(0 10px 20px rgba(61,34,9,.2)); }
.why__badge-shape { position: absolute; inset: 0; width: 100%; height: 100%; }
.why__badge-inner { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; padding: 14px; text-align: center; }
.why__badge-heart { display: inline-flex; color: #fff; }
.why__badge-heart svg { width: 20px; height: 20px; }
.why__badge-text { font-family: var(--font-heading); font-size: .76rem; line-height: 1.12; color: var(--color-ink); max-width: 80px; }

/* Kolom: voordelen + CTA */
.why__col { display: flex; flex-direction: column; justify-content: center; }
.why__benefits { display: flex; flex-direction: column; }
.why__benefit { --c: var(--color-green); --c-soft: #eef7e8; display: flex; align-items: flex-start; gap: 18px; padding: 20px 4px; border-bottom: 1.5px dashed var(--color-line); }
.why__benefit:last-child { border-bottom: none; }
.why__benefit--green  { --c: var(--color-green);  --c-soft: #eef7e8; }
.why__benefit--pink   { --c: var(--color-pink);   --c-soft: #fdeaf2; }
.why__benefit--orange { --c: var(--color-orange); --c-soft: #fdf0e2; }
.why__benefit--yellow { --c: #d99100;             --c-soft: #fdf6e0; }
.why__benefit-icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 56px; height: 56px; border-radius: 50%; background: var(--c-soft); color: var(--c); }
.why__benefit-icon svg { width: 28px; height: 28px; }
.why__benefit-title { font-family: var(--font-heading); font-size: 1.2rem; color: var(--color-ink); line-height: 1.15; margin: 4px 0 5px; }
.why__benefit-text { font-family: var(--font-body); font-size: .94rem; line-height: 1.5; color: var(--color-body); margin: 0; }

/* CTA */
.why__cta-wrap { display: flex; align-items: center; gap: 14px; margin-top: 26px; }
.why__cta-arrow { flex-shrink: 0; width: 54px; height: 40px; }
.why__cta-arrow svg { width: 100%; height: 100%; }
.why__cta { display: inline-flex; align-items: center; gap: 12px; padding: 17px 34px; background: var(--color-green); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.15rem; text-decoration: none; box-shadow: 0 12px 28px rgba(102,170,68,.28); transition: background 160ms, transform 160ms; }
.why__cta:hover { background: #5a9a3b; transform: translateY(-2px); }
.why__cta-icon { display: inline-flex; }
.why__cta-icon svg { width: 20px; height: 20px; }

/* Tablet */
@media (max-width: 1100px) and (min-width: 860px) {
  .why__layout { gap: 30px; }
  .why__benefit { gap: 14px; padding: 16px 2px; }
  .why__benefit-icon { width: 50px; height: 50px; }
}

/* Mobiel: kop → foto → witte kaarten → CTA */
@media (max-width: 859px) {
  .why__head { margin-bottom: 28px; }
  .why__layout { grid-template-columns: 1fr; gap: 0; }
  .why__media { min-height: 0; aspect-ratio: 16 / 13; margin-bottom: 22px; }
  .why__img--placeholder { min-height: 0; height: 100%; }
  .why__media-glow { inset: -14px -10px 10px -14px; width: 60%; }

  .why__benefits { gap: 12px; }
  .why__benefit { align-items: center; background: #fff; border: 1px solid #f1ead9; border-bottom: 1px solid #f1ead9; border-radius: 18px; box-shadow: 0 8px 22px rgba(61,34,9,.05); padding: 16px; gap: 14px; }
  .why__benefit-icon { width: 50px; height: 50px; }
  .why__benefit-icon svg { width: 25px; height: 25px; }
  .why__benefit-title { font-size: 1.08rem; }
  .why__benefit-text { font-size: .9rem; }

  /* CTA: gecentreerd, comfortabel breed; decoratieve pijl verbergen op mobiel */
  .why__cta-wrap { justify-content: center; margin-top: 28px; }
  .why__cta-arrow { display: none; }
  .why__cta { width: 100%; max-width: 420px; justify-content: center; }
  /* decoraties dichter naar de randen rond de titel + iets kleiner op mobiel */
  .why__deco { height: 190px; }
  .why__deco--lines { top: 46px; left: 3%; width: 38px; }
  .why__deco--heart { top: 10px; left: 4%; width: 26px; height: 26px; }
  .why__deco--paw { top: 16px; right: 4%; width: 24px; height: 24px; }
  .why__deco--heart2 { top: 66px; right: 3%; width: 26px; height: 26px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Waarom Kwispelbox",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Tekst" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Waarom honden dol zijn op" },
    { "type": "text", "id": "heading_highlight", "label": "Kop accent (groen)", "default": "Kwispelbox" },
    { "type": "textarea", "id": "intro", "label": "Subtekst", "default": "Omdat elke box een feestje is voor jouw hond én voor jou." },
    { "type": "header", "content": "Afbeelding" },
    { "type": "image_picker", "id": "image", "label": "Lifestyle-afbeelding (hond + box)" },
    { "type": "checkbox", "id": "show_badge", "label": "Scalloped badge tonen", "default": false },
    { "type": "text", "id": "badge_text", "label": "Badge tekst", "default": "Geen twee boxen zijn hetzelfde" },
    { "type": "header", "content": "Knop" },
    { "type": "text", "id": "cta_label", "label": "Knoptekst", "default": "Bekijk de boxen" },
    { "type": "url", "id": "cta_url", "label": "Knop link" },
    { "type": "header", "content": "Decoratie" },
    { "type": "checkbox", "id": "show_decorations", "label": "Decoratieve merkaccenten tonen", "default": true }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Voordeel",
      "limit": 5,
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "teddy",
          "options": [
            { "value": "teddy", "label": "Knuffel" },
            { "value": "heart", "label": "Hart" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "calendar", "label": "Kalender" },
            { "value": "ball", "label": "Bal" },
            { "value": "bone", "label": "Botje" },
            { "value": "leaf", "label": "Blad" },
            { "value": "paw", "label": "Poot" },
            { "value": "star", "label": "Ster" },
            { "value": "sparkles", "label": "Sparkles" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Accentkleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "Altijd iets nieuws om te ontdekken" },
        { "type": "textarea", "id": "text", "label": "Tekst", "default": "Honden houden van afwisseling. Nieuwe geuren, vormen en texturen zorgen voor meer uitdaging." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Waarom Kwispelbox",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "teddy", "color": "pink", "title": "Altijd iets nieuws om te ontdekken", "text": "Honden houden van afwisseling. Nieuwe geuren, vormen en texturen zorgen voor meer uitdaging." } },
        { "type": "benefit", "settings": { "icon": "heart", "color": "green", "title": "Samengesteld met liefde", "text": "Elke box wordt zorgvuldig samengesteld met veilige en kwalitatieve producten." } },
        { "type": "benefit", "settings": { "icon": "gift", "color": "yellow", "title": "Een cadeautje voor hond én baasje", "text": "Het uitpakken is minstens zo leuk als de inhoud zelf." } },
        { "type": "benefit", "settings": { "icon": "calendar", "color": "orange", "title": "Afgestemd op het seizoen", "text": "Verjaardag, Pasen, Kerst of gewoon zomaar een leuke verrassing." } }
      ]
    }
  ]
}
{% endschema %}
