{%- comment -%}
  sections/why-kwispelbox.liquid — Kwispelbox KB-v4
  Premium brand-story blok: grote lifestyle-foto links, merkboodschap +
  3 voordeelkaarten rechts, met een trustbar als afsluiting.
  Volledig instelbaar via section settings + blocks (benefit / trust).
  Mobiele volgorde via grid-areas: eyebrow → heading → intro → foto → kaarten → trustbar.
{%- endcomment -%}

{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
{%- assign trust_blocks   = section.blocks | where: 'type', 'trust' -%}

<div class="why full-width">
  <div class="why__inner">

    <div class="why__card">

      <!-- ── Media ─────────────────────────────────── -->
      <div class="why__media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 700 }} 700w,
                    {{ section.settings.image | image_url: width: 1200 }} 1200w,
                    {{ section.settings.image | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 859px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            width="720" height="600" loading="lazy"
            class="why__img">
        {%- else -%}
          <div class="why__img why__img--placeholder">
            {%- render 'lucide', icon: 'dog' -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
          <div class="why__badge why__badge--{{ section.settings.badge_color }}">
            <span class="why__badge-icon" aria-hidden="true">{%- render 'lucide', icon: section.settings.badge_icon -%}</span>
            <span class="why__badge-text">{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.show_decorations -%}
          <span class="why__media-deco why__media-deco--heart" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </span>
          <span class="why__media-deco why__media-deco--lines" aria-hidden="true">
            <svg viewBox="0 0 40 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 14c5-7 8 5 13-1M24 6c5 7 8-5 13 1"/></svg>
          </span>
        {%- endif -%}
      </div>

      <!-- ── Kop (eyebrow + heading + intro) ───────── -->
      <div class="why__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="why__eyebrow">
            {{ section.settings.eyebrow }}
            <span class="why__eyebrow-icon" aria-hidden="true">{%- render 'lucide', icon: 'sparkles' -%}</span>
          </span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="why__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.intro != blank -%}
          <p class="why__intro">{{ section.settings.intro }}</p>
        {%- endif -%}
      </div>

      <!-- ── Voordeelkaarten ──────────────────────── -->
      {%- if benefit_blocks.size > 0 -%}
        <div class="why__benefits">
          {%- for block in benefit_blocks -%}
            <div class="why__benefit why__benefit--{{ block.settings.color }}" {{ block.shopify_attributes }}>
              <span class="why__benefit-icon" aria-hidden="true">{%- render 'lucide', icon: block.settings.icon -%}</span>
              <div class="why__benefit-body">
                <h3 class="why__benefit-title">{{ block.settings.title }}</h3>
                {%- if block.settings.text != blank -%}
                  <p class="why__benefit-text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

    <!-- ── Trustbar ───────────────────────────────── -->
    {%- if trust_blocks.size > 0 -%}
      <div class="why__trust">
        <ul class="why__trust-list" role="list">
          {%- for block in trust_blocks -%}
            <li class="why__trust-item" {{ block.shopify_attributes }}>
              <span class="why__trust-icon why__trust-icon--{{ block.settings.color }}" aria-hidden="true">{%- render 'lucide', icon: block.settings.icon -%}</span>
              <span class="why__trust-text">{{ block.settings.title }}</span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}

.why {
  background: transparent;
  padding: var(--section-pad) 0;
}

.why__inner {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 var(--page-margin);
}

/* ── Grote contentkaart ──────────────────────────────── */
.why__card {
  position: relative;
  background: #fff;
  border-radius: 32px;
  box-shadow: var(--shadow-card);
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-areas:
    "media head"
    "media benefits";
  overflow: hidden;
}

/* Media */
.why__media {
  grid-area: media;
  position: relative;
  min-height: 100%;
  background: #e8f5e2;
}
.why__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.why__img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 420px;
  color: var(--color-green);
}
.why__img--placeholder .lucide { width: 88px; height: 88px; }

/* Badge linksboven over de foto */
.why__badge {
  position: absolute;
  top: 22px;
  left: 22px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  width: 104px;
  height: 104px;
  border-radius: 50%;
  text-align: center;
  background: var(--color-pink);
  color: var(--color-ink);
  box-shadow: 0 10px 26px rgba(61, 34, 9, .18);
  transform: rotate(-7deg);
}
.why__badge--green  { background: var(--color-green);  color: #fff; }
.why__badge--orange { background: var(--color-orange); color: #fff; }
.why__badge--yellow { background: var(--color-yellow); color: var(--color-ink); }
.why__badge--cream  { background: var(--color-cream);  color: var(--color-ink); }
.why__badge-icon .lucide { width: 22px; height: 22px; }
.why__badge-text {
  font-family: var(--font-heading);
  font-size: .72rem;
  line-height: 1.1;
  max-width: 86px;
}

/* Decoratieve accenten op de foto */
.why__media-deco { position: absolute; display: block; pointer-events: none; }
.why__media-deco svg { display: block; width: 100%; height: 100%; }
.why__media-deco--heart { bottom: 20px; right: 22px; width: 30px; height: 30px; color: #fff; opacity: .9; filter: drop-shadow(0 4px 8px rgba(61,34,9,.25)); transform: rotate(10deg); }
.why__media-deco--lines { top: 26px; right: 24px; width: 46px; height: 22px; color: #fff; opacity: .8; }

/* Kop */
.why__head {
  grid-area: head;
  padding: 56px 56px 8px;
}
.why__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: var(--font-body);
  font-size: var(--fs-eyebrow);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: var(--color-green);
  margin-bottom: 10px;
}
.why__eyebrow-icon { display: inline-flex; color: var(--color-orange); }
.why__eyebrow-icon .lucide { width: 16px; height: 16px; }
.why__heading {
  font-family: var(--font-heading);
  font-size: var(--fs-h2);
  line-height: 1.05;
  color: var(--color-ink);
  margin: 0 0 14px;
}
.why__intro {
  font-family: var(--font-body);
  font-size: var(--fs-lead);
  line-height: 1.65;
  color: var(--color-body);
  margin: 0;
  max-width: 46ch;
}

/* Voordeelkaarten */
.why__benefits {
  grid-area: benefits;
  padding: 22px 56px 56px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.why__benefit {
  --c: var(--color-green);
  --c-soft: #e8f5e2;
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 18px 20px;
  background: #fff;
  border: 1.5px solid var(--color-line);
  border-radius: var(--radius-lg);
  transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
}
.why__benefit:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-card-hover);
  border-color: var(--c);
}
.why__benefit--green  { --c: var(--color-green);  --c-soft: #e8f5e2; }
.why__benefit--pink   { --c: var(--color-pink);   --c-soft: #ffe0ee; }
.why__benefit--orange { --c: var(--color-orange); --c-soft: #fff0e4; }
.why__benefit--yellow { --c: #d99100;             --c-soft: #fffae0; }
.why__benefit-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 52px;
  height: 52px;
  border-radius: 16px;
  background: var(--c-soft);
  color: var(--c);
}
.why__benefit-icon .lucide { width: 26px; height: 26px; }
.why__benefit-title {
  font-family: var(--font-heading);
  font-size: var(--fs-h3);
  color: var(--color-ink);
  line-height: 1.15;
  margin: 2px 0 4px;
}
.why__benefit-text {
  font-family: var(--font-body);
  font-size: .9rem;
  line-height: 1.55;
  color: var(--color-body);
  margin: 0;
}

/* ── Trustbar ────────────────────────────────────────── */
.why__trust {
  margin-top: 18px;
  background: #fff;
  border: 1.5px solid var(--color-line);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.why__trust-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: stretch;
}
.why__trust-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 20px 22px;
  border-left: 1px solid var(--color-line);
  font-family: var(--font-body);
  font-size: .92rem;
  font-weight: 700;
  color: var(--color-ink);
  text-align: left;
}
.why__trust-item:first-child { border-left: none; }
.why__trust-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #e8f5e2;
  color: var(--color-green);
}
.why__trust-icon .lucide { width: 21px; height: 21px; }
.why__trust-icon--green  { background: #e8f5e2; color: var(--color-green); }
.why__trust-icon--pink   { background: #ffe0ee; color: var(--color-pink); }
.why__trust-icon--orange { background: #fff0e4; color: var(--color-orange); }
.why__trust-icon--yellow { background: #fffae0; color: #d99100; }

/* ── Tablet ──────────────────────────────────────────── */
@media (max-width: 1100px) and (min-width: 860px) {
  .why__head { padding: 44px 40px 6px; }
  .why__benefits { padding: 18px 40px 44px; }
}

/* ── Mobiel: eigen, zorgvuldig ontworpen volgorde ────── */
@media (max-width: 859px) {
  .why__card {
    grid-template-columns: 1fr;
    grid-template-areas:
      "head"
      "media"
      "benefits";
    border-radius: 26px;
  }

  /* Foto groot, met afgeronde hoeken, ingebed tussen intro en kaarten */
  .why__media {
    margin: 4px 20px 0;
    border-radius: 22px;
    overflow: hidden;
    min-height: 0;
    height: 300px;
  }
  .why__img--placeholder { min-height: 300px; }

  .why__badge { width: 84px; height: 84px; top: 16px; left: 16px; }
  .why__badge-icon .lucide { width: 18px; height: 18px; }
  .why__badge-text { font-size: .64rem; max-width: 70px; }

  .why__head { padding: 36px 26px 4px; text-align: center; }
  .why__eyebrow { justify-content: center; }
  .why__intro { margin-left: auto; margin-right: auto; }

  .why__benefits { padding: 24px 20px 32px; gap: 12px; }

  /* Trustbar: 2 kolommen (alles in beeld, geen verborgen content) */
  .why__trust { border-radius: 20px; }
  .why__trust-list { flex-wrap: wrap; }
  .why__trust-item {
    flex: 0 0 50%;
    justify-content: flex-start;
    border-left: none;
    border-top: 1px solid var(--color-line);
    padding: 16px 18px;
    font-size: .84rem;
  }
  .why__trust-item:nth-child(odd) { border-right: 1px solid var(--color-line); }
  .why__trust-item:nth-child(1),
  .why__trust-item:nth-child(2) { border-top: none; }
}

@media (max-width: 459px) {
  .why__trust-item { flex-basis: 100%; border-right: none; }
  .why__trust-item:nth-child(2) { border-top: 1px solid var(--color-line); }
}

{% endstylesheet %}

