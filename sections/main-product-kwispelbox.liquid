{%- comment -%}
  sections/main-product-kwispelbox.liquid — Kwispelbox KB-v4
  Premium product-hero: mediagalerij · productinfo · variant-kaarten ·
  personalisatie · prominente Add-to-Cart. Mobiel-first.
  Blocks: box_option (variantkaart) · trust_badge.
{%- endcomment -%}

{%- assign opt_blocks   = section.blocks | where: 'type', 'box_option' -%}
{%- assign badge_blocks = section.blocks | where: 'type', 'trust_badge' -%}
{%- assign value_blocks = section.blocks | where: 'type', 'value_item' -%}
{%- assign ugc_blocks   = section.blocks | where: 'type', 'ugc' -%}
{%- assign current = product.selected_or_first_available_variant -%}

<div class="pdp pdp--{{ section.settings.accent | default: 'green' }} full-width">
  <div class="pdp__inner">

    <div class="pdp-hero">

      {%- comment -%} ── Mediagalerij ─────────────────────── {%- endcomment -%}
      <div class="pdp-gallery" data-gallery>
        <div class="pdp-gallery__main" data-gallery-main>
          {%- if product.media.size > 0 -%}
            {%- for media in product.media -%}
              <div class="pdp-gallery__slide{% if forloop.first %} is-active{% endif %}" data-media-id="{{ media.id }}">
                {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                  {{ media | media_tag: image_size: '1200x', autoplay: false, loop: false, controls: true }}
                {%- else -%}
                  <img src="{{ media | image_url: width: 1200 }}"
                       srcset="{{ media | image_url: width: 700 }} 700w, {{ media | image_url: width: 1200 }} 1200w"
                       sizes="(max-width: 989px) 92vw, 46vw"
                       alt="{{ media.alt | default: product.title | escape }}"
                       width="600" height="600" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" class="pdp-gallery__img">
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="pdp-gallery__slide is-active"><div class="pdp-gallery__img pdp-gallery__img--ph">{%- render 'kb-icon', icon: 'gift' -%}</div></div>
          {%- endif -%}

          {%- if section.settings.badge_primary != blank -%}<span class="pdp-gallery__badge pdp-gallery__badge--pink">{{ section.settings.badge_primary }}</span>{%- endif -%}
          {%- if section.settings.badge_secondary != blank -%}<span class="pdp-gallery__badge pdp-gallery__badge--green">{{ section.settings.badge_secondary }}</span>{%- endif -%}
          {%- if product.media.size > 0 -%}
            <button type="button" class="pdp-gallery__zoom" data-zoom aria-label="Bekijk afbeelding groter">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6M8 11h6"/></svg>
            </button>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="pdp-gallery__thumbs" data-gallery-thumbs>
            {%- for media in product.media -%}
              <button type="button" class="pdp-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-thumb="{{ media.id }}" aria-label="Afbeelding {{ forloop.index }}">
                <img src="{{ media | image_url: width: 160 }}" alt="" width="70" height="70" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <span class="pdp-gallery__deco pdp-gallery__deco--heart" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>
        <span class="pdp-gallery__deco pdp-gallery__deco--paw" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span>
        <span class="pdp-gallery__deco pdp-gallery__deco--spark" aria-hidden="true">{%- render 'kb-icon', icon: 'sparkles' -%}</span>

        <div class="pdp-lightbox" data-lightbox hidden>
          <button type="button" class="pdp-lightbox__close" data-lightbox-close aria-label="Sluiten">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
          <img class="pdp-lightbox__img" data-lightbox-img alt="" width="1200" height="1200">
        </div>
      </div>

      {%- comment -%} ── Productinfo + formulier ──────────── {%- endcomment -%}
      <div class="pdp-info">
        {%- if section.settings.eyebrow != blank -%}
          <span class="pdp-info__eyebrow">{{ section.settings.eyebrow }}<span class="pdp-info__eyebrow-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span></span>
        {%- endif -%}
        <h1 class="pdp-info__title">{{ product.title }}</h1>

        {%- capture reviewrow_inner -%}
          <span class="pdp-info__stars" aria-hidden="true">★★★★★</span>
          {%- if section.settings.rating != blank -%}<strong>{{ section.settings.rating }}</strong>{%- endif -%}
          {%- if section.settings.review_count != blank -%}<span class="pdp-info__reviews">{{ section.settings.review_count }}</span>{%- endif -%}
        {%- endcapture -%}
        {%- if section.settings.reviews_url != blank -%}
          <a class="pdp-info__reviewrow pdp-info__reviewrow--link" href="{{ section.settings.reviews_url }}">
            {{ reviewrow_inner }}
            <span class="pdp-info__reviewrow-arrow" aria-hidden="true">{%- render 'kb-icon', icon: 'arrow' -%}</span>
            <span class="pdp-info__sr">— lees alle reviews</span>
          </a>
        {%- else -%}
          <div class="pdp-info__reviewrow">{{ reviewrow_inner }}</div>
        {%- endif -%}

        <div class="pdp-info__price" data-price-wrap>
          <span class="pdp-info__price-now" data-price>{{ current.price | money }}</span>
          {%- if current.compare_at_price > current.price -%}
            <span class="pdp-info__price-was" data-compare>{{ current.compare_at_price | money }}</span>
            <span class="pdp-info__save" data-save>Bespaar {{ current.compare_at_price | minus: current.price | money }}</span>
          {%- else -%}
            <span class="pdp-info__price-was" data-compare hidden></span>
            <span class="pdp-info__save" data-save hidden></span>
          {%- endif -%}
          {%- if section.settings.urgency_text != blank -%}<span class="pdp-info__urgency">{{ section.settings.urgency_text }}</span>{%- endif -%}
        </div>

        {%- if section.settings.delivery_text != blank -%}
          <p class="pdp-info__delivery"><span class="pdp-info__delivery-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'truck' -%}</span>{{ section.settings.delivery_text }}</p>
        {%- endif -%}

        {%- if section.settings.countdown_date != blank -%}
          <div class="pdp-countdown" data-countdown="{{ section.settings.countdown_date }}">
            <span class="pdp-countdown__icon" aria-hidden="true">{%- render 'kb-icon', icon: 'sparkles' -%}</span>
            <span class="pdp-countdown__label">{{ section.settings.countdown_label | default: 'Nog te bestellen:' }}</span>
            <span class="pdp-countdown__time" data-countdown-time>—</span>
          </div>
        {%- endif -%}

        {%- if section.settings.intro != blank -%}<div class="pdp-info__intro">{{ section.settings.intro }}</div>
        {%- elsif product.description != blank -%}<div class="pdp-info__intro">{{ product.description }}</div>{%- endif -%}

        {%- if badge_blocks.size > 0 -%}
          <ul class="pdp-info__badges" role="list">
            {%- for block in badge_blocks -%}
              <li {{ block.shopify_attributes }}>
                <span class="pdp-info__badge-icon pdp-info__badge-icon--{{ block.settings.color }}" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
                {{ block.settings.text }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.show_value_stack and value_blocks.size > 0 -%}
          <div class="pdp-value">
            <div class="pdp-value__head">
              <span class="pdp-value__head-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'gift' -%}</span>
              <strong>{{ section.settings.value_title | default: 'Wat krijgt jouw hond?' }}</strong>
            </div>
            <ul class="pdp-value__list" role="list">
              {%- for block in value_blocks -%}
                <li {{ block.shopify_attributes }}>
                  <span class="pdp-value__check" aria-hidden="true">{%- render 'kb-icon', icon: 'check' -%}</span>
                  <span class="pdp-value__text">{{ block.settings.text }}</span>
                  {%- if block.settings.worth != blank -%}<span class="pdp-value__worth">{{ block.settings.worth }}</span>{%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
            {%- if section.settings.value_total != blank -%}
              <div class="pdp-value__total">
                <span class="pdp-value__total-label">Totale waarde</span>
                <span class="pdp-value__total-was">{{ section.settings.value_total }}</span>
                <span class="pdp-value__total-now">jij betaalt {{ current.price | money }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- form 'product', product, id: 'pdp-form', class: 'pdp-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ current.id }}" data-variant-id>

          {%- comment -%} Variant-kaarten {%- endcomment -%}
          {%- if product.variants.size > 1 -%}
            <fieldset class="pdp-options">
              <legend class="pdp-options__legend">{{ section.settings.options_title | default: 'Kies jouw box' }}</legend>
              <div class="pdp-options__grid">
                {%- for variant in product.variants -%}
                  {%- assign opt = nil -%}
                  {%- for ob in opt_blocks -%}
                    {%- if ob.settings.variant_title != blank and ob.settings.variant_title == variant.title -%}{%- assign opt = ob -%}{%- endif -%}
                  {%- endfor -%}
                  {%- unless opt -%}{%- assign opt = opt_blocks[forloop.index0] -%}{%- endunless -%}
                  <label class="pdp-opt{% unless variant.available %} pdp-opt--sold{% endunless %}"{% if opt %} {{ opt.shopify_attributes }}{% endif %}>
                    <input type="radio" name="id" value="{{ variant.id }}" data-variant-price="{{ variant.price | money }}" data-variant-compare="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}" data-variant-save="{% if variant.compare_at_price > variant.price %}Bespaar {{ variant.compare_at_price | minus: variant.price | money }}{% endif %}" {% if variant == current %}checked{% endif %} {% unless variant.available %}disabled{% endunless %}>
                    {%- if opt.settings.badge_text != blank -%}<span class="pdp-opt__badge pdp-opt__badge--{{ opt.settings.badge_color }}">{{ opt.settings.badge_text }}</span>{%- endif -%}
                    <span class="pdp-opt__media">
                      {%- if opt.settings.image != blank -%}<img src="{{ opt.settings.image | image_url: width: 200 }}" alt="" width="90" height="90" loading="lazy">
                      {%- elsif variant.featured_image -%}<img src="{{ variant.featured_image | image_url: width: 200 }}" alt="" width="90" height="90" loading="lazy">
                      {%- else -%}<span class="pdp-opt__ph" aria-hidden="true">{%- render 'kb-icon', icon: 'gift' -%}</span>{%- endif -%}
                    </span>
                    <span class="pdp-opt__name">{{ variant.title }}</span>
                    {%- if opt.settings.description != blank -%}<span class="pdp-opt__desc">{{ opt.settings.description }}</span>{%- endif -%}
                    {%- if opt.settings.item_count != blank -%}<span class="pdp-opt__count">{{ opt.settings.item_count }}</span>{%- endif -%}
                    <span class="pdp-opt__price">{{ variant.price | money }}</span>
                    <span class="pdp-opt__check" aria-hidden="true">{%- render 'kb-icon', icon: 'check' -%}</span>
                  </label>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- endif -%}

          {%- comment -%} Personalisatie {%- endcomment -%}
          {%- if section.settings.show_personalize -%}
            <details class="pdp-personalize"{% if section.settings.personalize_open %} open{% endif %}>
              <summary class="pdp-personalize__head">
                <span class="pdp-personalize__icon" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>
                <div>
                  <strong>{{ section.settings.personalize_title | default: 'Vertel iets over je hond' }} <span class="pdp-personalize__opt">optioneel</span></strong>
                  {%- if section.settings.personalize_text != blank -%}<span>{{ section.settings.personalize_text }}</span>{%- endif -%}
                </div>
                <span class="pdp-personalize__chev" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span>
              </summary>
              <div class="pdp-personalize__grid">
                <label class="pdp-field"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'dog' -%}</span>Naam hond</span><input type="text" name="properties[Naam hond]" placeholder="Bijv. Luna"></label>
                <label class="pdp-field"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span>Levensfase</span><select name="properties[Levensfase]"><option value="">Kies…</option><option>Puppy</option><option>Volwassen</option><option>Senior</option></select></label>
                <label class="pdp-field"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'calendar' -%}</span>Geboortedatum hond</span><input type="date" name="properties[Geboortedatum]"></label>
                <label class="pdp-field"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'ruler' -%}</span>Formaat</span>
                  <select name="properties[Formaat]"><option value="">Kies…</option><option>Klein</option><option>Middel</option><option>Groot</option></select>
                </label>
                <label class="pdp-field"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'ball' -%}</span>Favoriete speeltjes</span><input type="text" name="properties[Favoriete speeltjes]" placeholder="Bijv. piepers, touwen"></label>
                <label class="pdp-field"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'leaf' -%}</span>Allergieën</span><input type="text" name="properties[Allergieen]" placeholder="Bijv. graanvrij"></label>
                <label class="pdp-field pdp-field--wide"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'mail' -%}</span>Persoonlijk bericht</span><input type="text" name="properties[Bericht]" placeholder="Een lief berichtje voor in de box"></label>
                {%- if section.settings.show_photo_upload -%}
                  <label class="pdp-field pdp-field--wide pdp-field--upload"><span class="pdp-field__lbl"><span aria-hidden="true">{%- render 'kb-icon', icon: 'upload' -%}</span>Foto van je hond (optioneel)</span><input type="file" name="properties[Foto]" accept="image/*"></label>
                {%- endif -%}
              </div>
              {%- if section.settings.personalize_note != blank -%}<p class="pdp-personalize__note">{%- render 'kb-icon', icon: 'sparkles' -%}{{ section.settings.personalize_note }}</p>{%- endif -%}
            </details>
          {%- endif -%}

          {%- comment -%} Maak je box compleet — box-builder add-ons {%- endcomment -%}
          {%- if section.settings.show_addons -%}
            {%- assign addon_coll = section.settings.addons_collection -%}
            {%- unless addon_coll -%}{%- assign addon_coll = collections['cadeau-extras'] -%}{%- endunless -%}
            {%- if addon_coll != blank and addon_coll.products.size > 0 -%}
              <div class="pdp-addons" data-addons>
                <div class="pdp-addons__head">
                  <span class="pdp-addons__icon" aria-hidden="true">{%- render 'kb-icon', icon: 'gift' -%}</span>
                  <div>
                    <strong>{{ section.settings.addons_title | default: 'Maak je box compleet' }}</strong>
                    {%- if section.settings.addons_text != blank -%}<span>{{ section.settings.addons_text }}</span>{%- endif -%}
                  </div>
                </div>
                <div class="pdp-addons__grid">
                  {%- assign addon_max = section.settings.addons_count | default: 4 -%}
                  {%- for ap in addon_coll.products limit: addon_max -%}
                    {%- assign av = ap.selected_or_first_available_variant -%}
                    {%- if av == blank or av.available == false -%}{%- continue -%}{%- endif -%}
                    <label class="pdp-addon">
                      <input type="checkbox" class="pdp-addon__cb" value="{{ av.id }}" data-addon>
                      <span class="pdp-addon__media" aria-hidden="true">
                        {%- if ap.featured_image -%}<img src="{{ ap.featured_image | image_url: width: 160 }}" alt="" width="64" height="64" loading="lazy">
                        {%- else -%}<span class="pdp-addon__ph">{%- render 'kb-icon', icon: 'gift' -%}</span>{%- endif -%}
                      </span>
                      <span class="pdp-addon__body">
                        <span class="pdp-addon__name">{{ ap.title }}</span>
                        <span class="pdp-addon__price">+ {{ av.price | money }}</span>
                      </span>
                      <span class="pdp-addon__check" aria-hidden="true">{%- render 'kb-icon', icon: 'check' -%}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}

          {%- comment -%} Add to cart {%- endcomment -%}
          <div class="pdp-atc">
            {%- if section.settings.atc_summary != blank -%}<p class="pdp-atc__summary">{{ section.settings.atc_summary }}</p>{%- endif -%}
            {%- if section.settings.show_guarantee -%}
              <div class="pdp-guarantee">
                <span class="pdp-guarantee__seal" aria-hidden="true">
                  <span class="pdp-guarantee__seal-days">{{ section.settings.guarantee_days | default: '30' }}</span>
                  <span class="pdp-guarantee__seal-unit">dagen</span>
                </span>
                <span class="pdp-guarantee__body">
                  <strong>{{ section.settings.guarantee_title | default: 'Niet-goed-geld-terug garantie' }}</strong>
                  {%- if section.settings.guarantee_text != blank -%}<span>{{ section.settings.guarantee_text }}</span>{%- endif -%}
                </span>
              </div>
            {%- endif -%}
            <div class="pdp-atc__row">
              <button type="submit" name="add" class="pdp-atc__btn"{% unless product.available %} disabled{% endunless %}>
                <span>{% if product.available %}{{ section.settings.atc_label | default: 'In winkelwagen' }}{% else %}Uitverkocht{% endif %}</span>
                <span class="pdp-atc__btn-paw" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span>
              </button>
            </div>
            <ul class="pdp-atc__trust" role="list">
              <li><span aria-hidden="true">{%- render 'kb-icon', icon: 'shield-check' -%}</span>Veilig betalen</li>
              <li><span aria-hidden="true">{%- render 'kb-icon', icon: 'refresh' -%}</span>Niet goed? Geld terug</li>
              <li><span aria-hidden="true">{%- render 'kb-icon', icon: 'truck' -%}</span>Snel in huis</li>
            </ul>
            {%- if shop.enabled_payment_types.size > 0 -%}
              <div class="pdp-atc__pay" role="img" aria-label="Veilig betalen met de bekende betaalmethoden">
                {%- for type in shop.enabled_payment_types -%}{{ type | payment_type_svg_tag: class: 'pdp-atc__pay-icon' }}{%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endform -%}
      </div>
    </div>

    {%- if ugc_blocks.size > 0 -%}
      <div class="pdp-ugc">
        <div class="pdp-ugc__head">
          <span class="pdp-ugc__eyebrow"><span aria-hidden="true">{%- render 'kb-icon', icon: 'camera' -%}</span>{{ section.settings.ugc_title | default: 'Blije honden, échte foto’s' }}</span>
        </div>
        <div class="pdp-ugc__track">
          {%- for block in ugc_blocks -%}
            <figure class="pdp-ugc__card" {{ block.shopify_attributes }}>
              <div class="pdp-ugc__media">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 480 }}" srcset="{{ block.settings.image | image_url: width: 320 }} 320w, {{ block.settings.image | image_url: width: 480 }} 480w" sizes="240px" alt="{{ block.settings.name | default: 'Blije hond' | escape }}" width="240" height="240" loading="lazy">
                {%- else -%}
                  <div class="pdp-ugc__media-ph" aria-hidden="true">{%- render 'kb-icon', icon: 'dog' -%}</div>
                {%- endif -%}
                <span class="pdp-ugc__stars" aria-hidden="true">★★★★★</span>
              </div>
              <figcaption class="pdp-ugc__body">
                {%- if block.settings.quote != blank -%}<p class="pdp-ugc__quote">“{{ block.settings.quote }}”</p>{%- endif -%}
                <span class="pdp-ugc__name">{{ block.settings.name }}{% if block.settings.dog != blank %} <span class="pdp-ugc__dog">&amp; {{ block.settings.dog }}</span>{% endif %}</span>
              </figcaption>
            </figure>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="pdp-sticky" data-sticky>
      <div class="pdp-sticky__info">
        <span class="pdp-sticky__name">{{ product.title }}</span>
        <span class="pdp-sticky__price" data-sticky-price>{{ current.price | money }}</span>
      </div>
      <button type="submit" form="pdp-form" name="add" class="pdp-sticky__btn"{% unless product.available %} disabled{% endunless %}>
        {% if product.available %}{{ section.settings.atc_label | default: 'In winkelwagen' }}{% else %}Uitverkocht{% endif %}
        <span class="pdp-sticky__paw" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span>
      </button>
    </div>
  </div>
</div>

{% stylesheet %}

.pdp { --pac: var(--color-green); --pac-soft: #e8f5e2; background: var(--color-cream); padding: 32px 0 56px; }
.pdp--green { --pac: var(--color-green); --pac-soft: #e8f5e2; }
.pdp--pink { --pac: var(--color-pink); --pac-soft: #ffe0ee; }
.pdp--orange { --pac: var(--color-orange); --pac-soft: #fff0e4; }
.pdp--yellow { --pac: #d99100; --pac-soft: #fffae0; }
.pdp--purple { --pac: #8b5fd1; --pac-soft: #efe6fb; }
.pdp__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }
/* urgency + countdown */
.pdp-info__urgency { display: inline-flex; align-items: center; background: var(--pac-soft); color: var(--pac); font-family: var(--font-body); font-size: .76rem; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; padding: 5px 12px; border-radius: var(--radius-pill); }
.pdp-countdown { display: inline-flex; align-items: center; gap: 9px; background: #fff; border: 1.5px solid var(--pac); border-radius: 16px; padding: 10px 16px; margin-bottom: 18px; }
.pdp-countdown__icon { display: inline-flex; color: var(--pac); }
.pdp-countdown__icon svg { width: 17px; height: 17px; }
.pdp-countdown__label { font-family: var(--font-body); font-size: .82rem; font-weight: 700; color: var(--color-ink); }
.pdp-countdown__time { font-family: var(--font-heading); font-size: .95rem; color: var(--pac); font-variant-numeric: tabular-nums; }
.pdp-hero { display: flex; flex-direction: column; gap: 28px; }

/* ── Galerij ──────────────────────────────────────────── */
.pdp-gallery__main { position: relative; background: #fff; border-radius: 28px; overflow: hidden; box-shadow: 0 18px 44px rgba(61, 34, 9, .08); }
.pdp-gallery__slide { display: none; }
.pdp-gallery__slide.is-active { display: block; }
.pdp-gallery__img, .pdp-gallery__slide img, .pdp-gallery__slide video, .pdp-gallery__slide iframe { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; transition: transform 500ms ease; }
.pdp-gallery__main:hover .pdp-gallery__img { transform: scale(1.04); }
.pdp-gallery__img--ph { display: flex; align-items: center; justify-content: center; background: #e8f5e2; color: var(--color-green); }
.pdp-gallery__img--ph svg { width: 80px; height: 80px; }
.pdp-gallery__badge { position: absolute; z-index: 2; font-family: var(--font-body); font-size: .72rem; font-weight: 800; padding: 6px 13px; border-radius: var(--radius-pill); color: #fff; box-shadow: 0 6px 16px rgba(61, 34, 9, .2); }
.pdp-gallery__badge--pink { top: 16px; left: 16px; background: var(--color-pink); }
.pdp-gallery__badge--green { top: 16px; right: 16px; background: var(--color-green); }
.pdp-gallery__thumbs { display: flex; gap: 10px; margin-top: 12px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; }
.pdp-gallery__thumbs::-webkit-scrollbar { display: none; }
.pdp-gallery__thumb { flex: 0 0 auto; width: 70px; height: 70px; border-radius: 16px; overflow: hidden; border: 2px solid transparent; background: #fff; cursor: pointer; padding: 0; transition: border-color 160ms; }
.pdp-gallery__thumb.is-active { border-color: var(--color-green); }
.pdp-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Info ─────────────────────────────────────────────── */
.pdp-info__eyebrow { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-body); font-size: .76rem; font-weight: 800; text-transform: uppercase; letter-spacing: .09em; color: var(--color-pink); margin-bottom: 10px; }
.pdp-info__eyebrow-icon { display: inline-flex; }
.pdp-info__eyebrow-icon svg { width: 14px; height: 14px; }
.pdp-info__title { font-family: var(--font-heading); font-size: clamp(2rem, 6vw, 3rem); line-height: 1.05; color: var(--color-ink); margin: 0 0 12px; }
.pdp-info__reviewrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: .9rem; color: var(--color-ink); margin-bottom: 16px; }
.pdp-info__stars { color: var(--color-yellow); letter-spacing: 1px; }
.pdp-info__reviews { color: var(--color-muted); font-weight: 600; }
.pdp-info__reviewrow--link { text-decoration: none; cursor: pointer; transition: color 140ms; }
.pdp-info__reviewrow--link:hover { color: var(--color-green); }
.pdp-info__reviewrow--link:hover .pdp-info__reviews { color: var(--color-green); text-decoration: underline; }
.pdp-info__reviewrow-arrow { display: inline-flex; color: var(--color-green); transition: transform 160ms; }
.pdp-info__reviewrow-arrow svg { width: 16px; height: 16px; }
.pdp-info__reviewrow--link:hover .pdp-info__reviewrow-arrow { transform: translateX(3px); }
.pdp-info__sr { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }
.pdp-info__intro { font-family: var(--font-body); font-size: 1rem; line-height: 1.6; color: var(--color-body); margin: 0 0 20px; }
.pdp-info__price { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; }
.pdp-info__price-now { font-family: var(--font-heading); font-size: 2.2rem; color: var(--pac); }
.pdp-info__price-was { font-family: var(--font-body); font-size: 1.1rem; color: var(--color-muted); text-decoration: line-through; }
.pdp-info__badges { list-style: none; margin: 0 0 24px; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; }
.pdp-info__badges li { display: flex; align-items: center; gap: 9px; font-family: var(--font-body); font-size: .82rem; font-weight: 700; color: var(--color-ink); }
.pdp-info__badge-icon { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); flex-shrink: 0; }
.pdp-info__badge-icon--green { background: #e8f5e2; color: var(--color-green); }
.pdp-info__badge-icon--pink { background: #ffe0ee; color: var(--color-pink); }
.pdp-info__badge-icon--orange { background: #fff0e4; color: var(--color-orange); }
.pdp-info__badge-icon--yellow { background: #fffae0; color: #d99100; }
.pdp-info__badge-icon svg { width: 16px; height: 16px; }

/* ── Variant-kaarten ──────────────────────────────────── */
.pdp-options { border: none; margin: 0 0 24px; padding: 0; }
.pdp-options__legend { font-family: var(--font-heading); font-size: 1.15rem; color: var(--color-ink); margin-bottom: 12px; padding: 0; }
.pdp-options__grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
.pdp-opt { position: relative; display: grid; grid-template-columns: 72px 1fr auto; grid-template-areas: "media name price" "media desc price" "media count price"; align-items: center; column-gap: 14px; row-gap: 2px; background: #fff; border: 2px solid var(--color-line); border-radius: 20px; padding: 14px; cursor: pointer; transition: border-color 180ms, box-shadow 180ms, transform 180ms; }
.pdp-opt:hover { transform: translateY(-2px); }
.pdp-opt input { position: absolute; opacity: 0; pointer-events: none; }
.pdp-opt:has(input:checked) { border-color: var(--pac); box-shadow: 0 10px 28px rgba(61, 34, 9, .14); }
.pdp-opt--sold { opacity: .55; }
.pdp-opt__media { grid-area: media; width: 72px; height: 72px; border-radius: 14px; overflow: hidden; background: #e8f5e2; display: flex; align-items: center; justify-content: center; }
.pdp-opt__media img { width: 100%; height: 100%; object-fit: cover; }
.pdp-opt__ph { display: flex; color: var(--color-green); }
.pdp-opt__ph svg { width: 30px; height: 30px; }
.pdp-opt__name { grid-area: name; font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-ink); line-height: 1.1; }
.pdp-opt__desc { grid-area: desc; font-family: var(--font-body); font-size: .78rem; color: var(--color-muted); }
.pdp-opt__count { grid-area: count; font-family: var(--font-body); font-size: .74rem; font-weight: 700; color: var(--color-green); }
.pdp-opt__price { grid-area: price; font-family: var(--font-heading); font-size: 1.15rem; color: var(--color-ink); white-space: nowrap; }
.pdp-opt__badge { position: absolute; top: -10px; left: 16px; z-index: 2; font-family: var(--font-body); font-size: .64rem; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; padding: 4px 11px; border-radius: var(--radius-pill); color: #fff; }
.pdp-opt__badge--pink { background: var(--color-pink); }
.pdp-opt__badge--green { background: var(--color-green); }
.pdp-opt__badge--orange { background: var(--color-orange); }
.pdp-opt__check { position: absolute; top: 12px; right: 12px; width: 24px; height: 24px; border-radius: 50%; background: var(--pac); color: #fff; display: flex; align-items: center; justify-content: center; opacity: 0; transform: scale(.6); transition: opacity 180ms, transform 180ms; }
.pdp-opt__check svg { width: 14px; height: 14px; }
.pdp-opt:has(input:checked) .pdp-opt__check { opacity: 1; transform: scale(1); }

/* ── Personalisatie (inklapbaar) ──────────────────────── */
.pdp-personalize { background: #fff; border: 1.5px solid var(--color-line); border-radius: 22px; padding: 18px 22px; margin-bottom: 24px; }
.pdp-personalize[open] { padding-bottom: 22px; }
.pdp-personalize__head { display: flex; align-items: center; gap: 13px; cursor: pointer; list-style: none; }
.pdp-personalize__head::-webkit-details-marker { display: none; }
.pdp-personalize__icon { display: flex; align-items: center; justify-content: center; width: 46px; height: 46px; border-radius: 50%; background: #ffe0ee; color: var(--color-pink); flex-shrink: 0; }
.pdp-personalize__icon svg { width: 22px; height: 22px; }
.pdp-personalize__head > div { flex: 1; min-width: 0; }
.pdp-personalize__head strong { display: block; font-family: var(--font-heading); font-size: 1.2rem; color: var(--color-ink); line-height: 1.15; }
.pdp-personalize__opt { font-family: var(--font-body); font-size: .64rem; font-weight: 800; text-transform: uppercase; letter-spacing: .05em; color: var(--color-green); background: #e8f5e2; padding: 3px 8px; border-radius: var(--radius-pill); vertical-align: middle; }
.pdp-personalize__head span { font-family: var(--font-body); font-size: .82rem; color: var(--color-muted); }
.pdp-personalize__chev { display: inline-flex; color: var(--color-pink); flex-shrink: 0; transition: transform 220ms; }
.pdp-personalize__chev svg { width: 22px; height: 22px; }
.pdp-personalize[open] .pdp-personalize__chev { transform: rotate(180deg); }
.pdp-personalize__grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 18px; }
.pdp-field { display: flex; flex-direction: column; gap: 6px; }
.pdp-field__lbl { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-body); font-size: .8rem; font-weight: 700; color: var(--color-ink); }
.pdp-field__lbl span { display: inline-flex; color: var(--color-green); }
.pdp-field__lbl svg { width: 15px; height: 15px; }
.pdp-field input, .pdp-field select { height: 46px; border: 1.5px solid var(--color-line); border-radius: 14px; padding: 0 14px; font-family: var(--font-body); font-size: .92rem; color: var(--color-ink); background: var(--color-cream); outline: none; transition: border-color 160ms, background 160ms; }
.pdp-field input:focus, .pdp-field select:focus { border-color: var(--color-green); background: #fff; }
.pdp-field--upload input { height: auto; padding: 12px 14px; background: var(--color-cream); }
.pdp-personalize__note { display: flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: .78rem; color: var(--color-muted); margin: 14px 0 0; }
.pdp-personalize__note svg { width: 15px; height: 15px; color: var(--color-orange); flex-shrink: 0; }

/* ── Box-builder add-ons ──────────────────────────────── */
.pdp-addons { margin: 4px 0 20px; }
.pdp-addons__head { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.pdp-addons__icon { display: inline-flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 50%; background: #ffe9f1; color: var(--color-pink); flex-shrink: 0; }
.pdp-addons__icon svg { width: 21px; height: 21px; }
.pdp-addons__head strong { display: block; font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-ink); }
.pdp-addons__head > div > span { font-family: var(--font-body); font-size: .88rem; color: var(--color-body); }
.pdp-addons__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.pdp-addon { position: relative; display: flex; align-items: center; gap: 10px; padding: 10px; border: 1.5px solid var(--color-line); border-radius: 14px; background: #fff; cursor: pointer; transition: border-color 160ms, box-shadow 160ms, background 160ms; }
.pdp-addon:has(input:checked) { border-color: var(--color-pink); box-shadow: 0 8px 20px rgba(61, 34, 9, .08); background: #fff7fb; }
.pdp-addon__cb { position: absolute; opacity: 0; pointer-events: none; }
.pdp-addon__cb:focus-visible + .pdp-addon__media { outline: 2px solid var(--color-pink); outline-offset: 2px; }
.pdp-addon__media { display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: 10px; background: var(--color-cream); overflow: hidden; flex-shrink: 0; }
.pdp-addon__media img { width: 100%; height: 100%; object-fit: cover; }
.pdp-addon__ph svg { width: 24px; height: 24px; color: var(--color-pink); }
.pdp-addon__body { min-width: 0; flex: 1; }
.pdp-addon__name { display: block; font-family: var(--font-body); font-weight: 700; font-size: .9rem; color: var(--color-ink); line-height: 1.25; }
.pdp-addon__price { display: block; font-family: var(--font-body); font-size: .85rem; color: var(--color-pink); font-weight: 700; margin-top: 2px; }
.pdp-addon__check { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; border: 1.5px solid var(--color-line); color: #fff; flex-shrink: 0; transition: background 160ms, border-color 160ms; }
.pdp-addon__check svg { width: 13px; height: 13px; opacity: 0; transition: opacity 160ms; }
.pdp-addon:has(input:checked) .pdp-addon__check { background: var(--color-pink); border-color: var(--color-pink); }
.pdp-addon:has(input:checked) .pdp-addon__check svg { opacity: 1; }
@media (max-width: 749px) { .pdp-addons__grid { grid-template-columns: 1fr; } }

/* ── Add to cart ──────────────────────────────────────── */
.pdp-atc { background: var(--pac-soft); border: 1.5px solid color-mix(in srgb, var(--pac) 30%, transparent); border-radius: 24px; padding: 22px; }
.pdp-atc__summary { display: flex; align-items: center; gap: 8px; font-family: var(--font-heading); font-size: 1.05rem; color: var(--color-ink); margin: 0 0 16px; }
.pdp-atc__btn { display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%; padding: 18px 24px; background: var(--pac); color: #fff; border: none; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.2rem; cursor: pointer; transition: filter 160ms, transform 160ms, box-shadow 160ms; }
.pdp-atc__btn:hover:not(:disabled) { filter: brightness(.93); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(61, 34, 9, .22); }
.pdp-atc__btn:disabled { background: var(--color-muted); cursor: not-allowed; }
.pdp-atc__btn-paw { display: inline-flex; animation: pdp-wag 1.6s ease-in-out infinite; }
.pdp-atc__btn-paw svg { width: 22px; height: 22px; }
@keyframes pdp-wag { 0%, 100% { transform: rotate(-12deg); } 50% { transform: rotate(12deg); } }
.pdp-atc__trust { list-style: none; margin: 16px 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 8px 18px; justify-content: center; }
.pdp-atc__trust li { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-body); font-size: .78rem; font-weight: 700; color: var(--color-ink); }
.pdp-atc__trust li span { display: inline-flex; color: var(--color-green); }
.pdp-atc__trust li svg { width: 15px; height: 15px; }

/* ── Sticky mobiele koopbalk ──────────────────────────── */
.pdp-sticky { display: none; }
.pdp-sticky__paw { display: inline-flex; }
@media (max-width: 749px) {
  .pdp-sticky {
    display: flex; align-items: center; gap: 12px;
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 60;
    background: #fff; border-top: 1.5px solid var(--color-line);
    padding: 10px 16px calc(10px + env(safe-area-inset-bottom));
    box-shadow: 0 -6px 20px rgba(61, 34, 9, .12);
    transform: translateY(120%); transition: transform 280ms cubic-bezier(.4, 0, .2, 1);
  }
  .pdp-sticky.is-visible { transform: translateY(0); }
  .pdp-sticky__info { display: flex; flex-direction: column; line-height: 1.2; min-width: 0; }
  .pdp-sticky__name { font-family: var(--font-body); font-size: .76rem; font-weight: 700; color: var(--color-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 36vw; }
  .pdp-sticky__price { font-family: var(--font-heading); font-size: 1.15rem; color: var(--pac); }
  .pdp-sticky__btn { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 18px; background: var(--pac); color: #fff; border: none; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1rem; cursor: pointer; }
  .pdp-sticky__btn:disabled { background: var(--color-muted); }
  .pdp-sticky__paw svg { width: 17px; height: 17px; }
}
@media (prefers-reduced-motion: reduce) { .pdp-sticky { transition: none; } }

/* ── Tablet/Desktop ───────────────────────────────────── */
@media (min-width: 750px) {
  .pdp-info__badges { grid-template-columns: 1fr 1fr; }
  .pdp-options__grid { grid-template-columns: repeat(3, 1fr); }
  .pdp-opt { grid-template-columns: 1fr; grid-template-areas: "media" "name" "desc" "count" "price"; justify-items: center; text-align: center; row-gap: 4px; padding: 18px 14px; }
  .pdp-opt__media { width: 84px; height: 84px; }
  .pdp-opt__badge { left: 50%; transform: translateX(-50%); }
  .pdp-personalize__grid { grid-template-columns: 1fr 1fr; }
  .pdp-field--wide { grid-column: 1 / -1; }
}
@media (min-width: 990px) {
  .pdp { padding: 44px 0 72px; }
  .pdp-hero { flex-direction: row; align-items: flex-start; gap: 44px; }
  .pdp-gallery { flex: 1; position: sticky; top: 150px; }
  .pdp-info { flex: 1; }
}
@media (prefers-reduced-motion: reduce) {
  .pdp-gallery__img { transition: none; }
  .pdp-atc__btn-paw { animation: none; }
}

/* ── Premium-upgrades ─────────────────────────────────── */
/* Bespaar-chip */
.pdp-info__save { display: inline-flex; align-items: center; background: var(--color-pink); color: #fff; font-family: var(--font-body); font-size: .76rem; font-weight: 800; letter-spacing: .01em; padding: 5px 12px; border-radius: var(--radius-pill); box-shadow: 0 4px 12px rgba(231, 84, 128, .26); }
.pdp-info__save[hidden] { display: none; }

/* Bezorg-belofte onder de prijs */
.pdp-info__delivery { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-body); font-size: .88rem; font-weight: 600; color: var(--color-ink); margin: 0 0 20px; }
.pdp-info__delivery-icon { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); flex-shrink: 0; }
.pdp-info__delivery-icon svg { width: 17px; height: 17px; }

/* Betaalmethode-iconen in de ATC */
.pdp-atc__pay { display: flex; flex-wrap: wrap; gap: 7px; justify-content: center; align-items: center; margin-top: 16px; padding-top: 15px; border-top: 1px solid color-mix(in srgb, var(--pac) 20%, transparent); }
.pdp-atc__pay-icon { width: 40px; height: 25px; border-radius: 5px; box-shadow: 0 1px 3px rgba(61, 34, 9, .14); background: #fff; }

/* Decoratieve flourishes rond de galerij */
.pdp-gallery { position: relative; }
.pdp-gallery__deco { position: absolute; pointer-events: none; z-index: 3; display: flex; }
.pdp-gallery__deco svg { width: 100%; height: 100%; }
.pdp-gallery__deco--heart { top: -15px; left: -13px; width: 32px; height: 32px; color: var(--color-pink); transform: rotate(-12deg); }
.pdp-gallery__deco--paw { top: 46%; left: -18px; width: 30px; height: 30px; color: var(--color-green); opacity: .55; transform: rotate(-14deg); }
.pdp-gallery__deco--spark { top: -11px; right: -11px; width: 23px; height: 23px; color: var(--color-orange); }
@media (max-width: 749px) {
  .pdp-gallery__deco--heart { width: 26px; height: 26px; top: -11px; left: -7px; }
  .pdp-gallery__deco--paw { display: none; }
  .pdp-gallery__deco--spark { width: 19px; height: 19px; top: -8px; right: -6px; }
}

/* ── Rijkere galerij: zoom + lightbox ─────────────────── */
.pdp-gallery__zoom { position: absolute; right: 14px; bottom: 14px; z-index: 2; width: 42px; height: 42px; border-radius: 50%; border: none; background: rgba(255, 255, 255, .92); color: var(--color-ink); display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 14px rgba(61, 34, 9, .18); transition: transform 160ms, background 160ms; }
.pdp-gallery__zoom:hover { transform: scale(1.08); background: #fff; }
.pdp-gallery__zoom svg { width: 20px; height: 20px; }
.pdp-lightbox { position: fixed; inset: 0; z-index: 120; display: flex; align-items: center; justify-content: center; padding: 24px; background: rgba(43, 26, 8, .82); }
.pdp-lightbox[hidden] { display: none; }
.pdp-lightbox__img { max-width: min(92vw, 900px); max-height: 88vh; width: auto; height: auto; border-radius: 18px; box-shadow: 0 24px 60px rgba(0, 0, 0, .4); }
.pdp-lightbox__close { position: absolute; top: 20px; right: 20px; width: 46px; height: 46px; border-radius: 50%; border: none; background: rgba(255, 255, 255, .16); color: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 160ms; }
.pdp-lightbox__close:hover { background: rgba(255, 255, 255, .3); }
.pdp-lightbox__close svg { width: 24px; height: 24px; }

/* ── Waarde-stack ─────────────────────────────────────── */
.pdp-value { background: #fff; border: 1.5px solid var(--color-line); border-radius: 22px; padding: 20px 22px; margin: 0 0 24px; }
.pdp-value__head { display: flex; align-items: center; gap: 11px; margin-bottom: 14px; }
.pdp-value__head-icon { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: #fff0e4; color: var(--color-orange); flex-shrink: 0; }
.pdp-value__head-icon svg { width: 20px; height: 20px; }
.pdp-value__head strong { font-family: var(--font-heading); font-size: 1.15rem; color: var(--color-ink); }
.pdp-value__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
.pdp-value__list li { display: flex; align-items: center; gap: 11px; font-family: var(--font-body); font-size: .92rem; color: var(--color-ink); }
.pdp-value__check { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; background: var(--pac-soft); color: var(--pac); flex-shrink: 0; }
.pdp-value__check svg { width: 13px; height: 13px; }
.pdp-value__text { flex: 1; }
.pdp-value__worth { font-family: var(--font-body); font-size: .82rem; font-weight: 700; color: var(--color-muted); }
.pdp-value__total { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 16px; padding-top: 15px; border-top: 1px dashed var(--color-line); }
.pdp-value__total-label { font-family: var(--font-body); font-size: .86rem; font-weight: 700; color: var(--color-ink); }
.pdp-value__total-was { font-family: var(--font-heading); font-size: 1.05rem; color: var(--color-muted); text-decoration: line-through; }
.pdp-value__total-now { margin-left: auto; font-family: var(--font-heading); font-size: .92rem; color: var(--pac); background: var(--pac-soft); padding: 6px 13px; border-radius: var(--radius-pill); }

/* ── Garantie-zegel ───────────────────────────────────── */
.pdp-guarantee { display: flex; align-items: center; gap: 14px; background: #fff; border: 1.5px dashed color-mix(in srgb, var(--pac) 48%, transparent); border-radius: 18px; padding: 12px 16px; margin: 0 0 16px; }
.pdp-guarantee__seal { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 54px; height: 54px; border-radius: 50%; background: var(--pac); color: #fff; flex-shrink: 0; line-height: 1; box-shadow: 0 6px 14px color-mix(in srgb, var(--pac) 36%, transparent); }
.pdp-guarantee__seal-days { font-family: var(--font-heading); font-size: 1.3rem; }
.pdp-guarantee__seal-unit { font-family: var(--font-body); font-size: .56rem; font-weight: 800; text-transform: uppercase; letter-spacing: .07em; }
.pdp-guarantee__body { display: flex; flex-direction: column; gap: 2px; }
.pdp-guarantee__body strong { font-family: var(--font-heading); font-size: 1.02rem; color: var(--color-ink); line-height: 1.15; }
.pdp-guarantee__body span { font-family: var(--font-body); font-size: .82rem; color: var(--color-body); line-height: 1.3; }

/* ── UGC-reviews strook ───────────────────────────────── */
.pdp-ugc { margin: 10px 0 0; }
.pdp-ugc__head { margin-bottom: 14px; }
.pdp-ugc__eyebrow { display: inline-flex; align-items: center; gap: 9px; font-family: var(--font-body); font-size: .82rem; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; color: var(--color-pink); }
.pdp-ugc__eyebrow span { display: inline-flex; }
.pdp-ugc__eyebrow svg { width: 17px; height: 17px; }
.pdp-ugc__track { display: flex; gap: 16px; overflow-x: auto; padding: 6px 2px 14px; scroll-snap-type: x mandatory; scrollbar-width: none; }
.pdp-ugc__track::-webkit-scrollbar { display: none; }
.pdp-ugc__card { flex: 0 0 auto; width: 230px; margin: 0; background: #fff; border: 1.5px solid var(--color-line); border-radius: 20px; overflow: hidden; box-shadow: 0 8px 22px rgba(61, 34, 9, .06); scroll-snap-align: start; }
.pdp-ugc__media { position: relative; aspect-ratio: 1/1; background: #e8f5e2; }
.pdp-ugc__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pdp-ugc__media-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--color-green); }
.pdp-ugc__media-ph svg { width: 64px; height: 64px; }
.pdp-ugc__stars { position: absolute; left: 10px; bottom: 10px; color: var(--color-yellow); font-size: .9rem; letter-spacing: 1px; background: rgba(255, 255, 255, .92); padding: 3px 9px; border-radius: var(--radius-pill); }
.pdp-ugc__body { padding: 14px 16px 16px; }
.pdp-ugc__quote { font-family: var(--font-body); font-size: .88rem; line-height: 1.45; color: var(--color-ink); margin: 0 0 8px; }
.pdp-ugc__name { font-family: var(--font-heading); font-size: .92rem; color: var(--color-ink); }
.pdp-ugc__dog { color: var(--color-pink); }
@media (min-width: 990px) { .pdp-ugc { margin-top: 28px; } .pdp-ugc__card { width: 250px; } }

{% endstylesheet %}

{% javascript %}
(function () {
  function init() {
  document.querySelectorAll('[data-gallery]').forEach(function (gallery) {
    var slides = gallery.querySelectorAll('[data-gallery-main] .pdp-gallery__slide');
    var thumbs = gallery.querySelectorAll('[data-thumb]');
    thumbs.forEach(function (t) {
      t.addEventListener('click', function () {
        var id = t.getAttribute('data-thumb');
        slides.forEach(function (s) { s.classList.toggle('is-active', s.getAttribute('data-media-id') === id); });
        thumbs.forEach(function (x) { x.classList.toggle('is-active', x === t); });
      });
    });

    /* Klik-to-zoom lightbox */
    var lightbox = gallery.querySelector('[data-lightbox]');
    var zoomBtn = gallery.querySelector('[data-zoom]');
    if (lightbox && zoomBtn) {
      var lbImg = lightbox.querySelector('[data-lightbox-img]');
      var lbClose = lightbox.querySelector('[data-lightbox-close]');
      var openLb = function () {
        var active = gallery.querySelector('[data-gallery-main] .pdp-gallery__slide.is-active img');
        if (!active) return;
        lbImg.src = active.currentSrc || active.src;
        lbImg.alt = active.alt || '';
        lightbox.hidden = false;
        document.documentElement.style.overflow = 'hidden';
        lbClose.focus();
      };
      var closeLb = function () { lightbox.hidden = true; document.documentElement.style.overflow = ''; zoomBtn.focus(); };
      zoomBtn.addEventListener('click', openLb);
      lbClose.addEventListener('click', closeLb);
      lightbox.addEventListener('click', function (e) { if (e.target === lightbox) closeLb(); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !lightbox.hidden) closeLb(); });
    }
  });

  var form = document.getElementById('pdp-form');
  if (form) {
    var hidden = form.querySelector('[data-variant-id]');
    var priceEl = document.querySelector('[data-price]');
    var compareEl = document.querySelector('[data-compare]');
    var saveEl = document.querySelector('[data-save]');
    var stickyPrice = document.querySelector('[data-sticky-price]');
    form.querySelectorAll('input[name="id"][type="radio"]').forEach(function (radio) {
      radio.addEventListener('change', function () {
        if (hidden) hidden.value = radio.value;
        if (radio.dataset.variantPrice) {
          if (priceEl) priceEl.textContent = radio.dataset.variantPrice;
          if (stickyPrice) stickyPrice.textContent = radio.dataset.variantPrice;
        }
        if (compareEl) {
          if (radio.dataset.variantCompare) { compareEl.textContent = radio.dataset.variantCompare; compareEl.hidden = false; }
          else { compareEl.hidden = true; }
        }
        if (saveEl) {
          if (radio.dataset.variantSave) { saveEl.textContent = radio.dataset.variantSave; saveEl.hidden = false; }
          else { saveEl.hidden = true; }
        }
      });
    });

    /* Box-builder: extra's als losse regels meesturen.
       Alleen onderscheppen als er iets is aangevinkt — anders normale POST (behoudt foto-upload). */
    form.addEventListener('submit', function (e) {
      var addons = Array.prototype.slice.call(form.querySelectorAll('[data-addon]:checked')).map(function (c) { return c.value; });
      if (!addons.length) return;
      e.preventDefault();
      var radio = form.querySelector('input[name="id"][type="radio"]:checked');
      var mainId = radio ? radio.value : (hidden ? hidden.value : null);
      if (!mainId) { form.submit(); return; }
      var btns = Array.prototype.slice.call(form.querySelectorAll('[name="add"]'));
      btns.forEach(function (b) { b.disabled = true; });
      var fd = new FormData(form);
      fd.set('id', mainId);
      fd.delete('add');
      fetch('/cart/add.js', { method: 'POST', body: fd })
        .then(function () {
          return fetch('/cart/add.js', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: addons.map(function (id) { return { id: id, quantity: 1 }; }) })
          });
        })
        .then(function () { window.location = '/cart'; })
        .catch(function () { btns.forEach(function (b) { b.disabled = false; }); });
    });
  }

  /* Sticky koopbalk: tonen wanneer hoofd-ATC uit beeld is en niet onderaan de pagina */
  var sticky = document.querySelector('[data-sticky]');
  var mainBtn = form ? form.querySelector('.pdp-atc__btn') : null;
  if (sticky && mainBtn && 'IntersectionObserver' in window) {
    var atcVisible = true, nearBottom = false;
    var refresh = function () { sticky.classList.toggle('is-visible', !atcVisible && !nearBottom); };
    new IntersectionObserver(function (entries) { atcVisible = entries[0].isIntersecting; refresh(); }, { rootMargin: '0px 0px -10% 0px' }).observe(mainBtn);
    window.addEventListener('scroll', function () {
      nearBottom = (window.innerHeight + window.scrollY) >= (document.body.offsetHeight - 90);
      refresh();
    }, { passive: true });
  }

  /* Countdown */
  document.querySelectorAll('[data-countdown]').forEach(function (el) {
    var target = new Date(el.getAttribute('data-countdown')).getTime();
    var out = el.querySelector('[data-countdown-time]');
    if (isNaN(target) || !out) return;
    var tick = function () {
      var diff = target - Date.now();
      if (diff <= 0) { el.style.display = 'none'; return; }
      var d = Math.floor(diff / 86400000), h = Math.floor(diff % 86400000 / 3600000),
          m = Math.floor(diff % 3600000 / 60000), s = Math.floor(diff % 60000 / 1000);
      out.textContent = (d > 0 ? d + 'd ' : '') + h + 'u ' + m + 'm ' + s + 's';
    };
    tick();
    setInterval(tick, 1000);
  });
  }
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
}());
{% endjavascript %}

