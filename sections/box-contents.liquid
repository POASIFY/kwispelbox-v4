{%- comment -%}
  sections/box-contents.liquid — Kwispelbox KB-v4
  "Wat zit er in een Kwispelbox?" — centrale held-afbeelding met
  informatiekaarten links/rechts + geïntegreerde trustbar.
  Onbeperkt kaarten (blocks), volledig instelbaar via de Theme Editor.

  Desktop: kaarten verdeeld over linker- en rechterkolom rond de foto.
  Mobiel: kop → grote foto → kaarten (2-koloms, natuurlijke volgorde via
  display:contents + per-kaart order) → trustbar (swipebare kaarten).
{%- endcomment -%}

{%- assign card_blocks  = section.blocks | where: 'type', 'card' -%}
{%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}

<div class="kbox full-width">

  {%- if section.settings.show_decorations -%}
    <div class="kbox__deco" aria-hidden="true">
      <span class="kbox__deco kbox__deco--1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
      <span class="kbox__deco kbox__deco--2"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
      <span class="kbox__deco kbox__deco--3"><svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg></span>
      <span class="kbox__deco kbox__deco--4"><svg viewBox="0 0 48 22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 15C9 6 13 18 19 11M28 11c6 7 10-5 16 2"/></svg></span>
      <span class="kbox__deco kbox__deco--5"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
    </div>
  {%- endif -%}

  <div class="kbox__inner">

    <!-- ── Kop ─────────────────────────────────────── -->
    <div class="kbox__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="kbox__eyebrow">
          <span class="kbox__eyebrow-icon" aria-hidden="true">{%- render 'lucide', icon: 'sparkles' -%}</span>
          {{ section.settings.eyebrow }}
        </span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kbox__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="kbox__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <!-- ── Held-afbeelding met flankerende kaarten ─── -->
    <div class="kbox__stage">

      <div class="kbox__col kbox__col--left">
        {%- for block in card_blocks -%}
          {%- assign col = forloop.index | modulo: 2 -%}
          {%- if col == 1 -%}
            <div class="kbox-card kbox-card--{{ block.settings.color }}" style="order:{{ forloop.index }}" {{ block.shopify_attributes }}>
              <span class="kbox-card__icon" aria-hidden="true">{%- render 'lucide', icon: block.settings.icon -%}</span>
              <div class="kbox-card__body">
                <h3 class="kbox-card__title">{{ block.settings.title }}</h3>
                {%- if block.settings.text != blank -%}<p class="kbox-card__text">{{ block.settings.text }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="kbox__media">
        <div class="kbox__media-glow" aria-hidden="true"></div>
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 700 }} 700w,
                    {{ section.settings.image | image_url: width: 1000 }} 1000w,
                    {{ section.settings.image | image_url: width: 1400 }} 1400w"
            sizes="(max-width: 859px) 92vw, 46vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            width="640" height="720" loading="lazy"
            class="kbox__img">
        {%- else -%}
          <div class="kbox__img kbox__img--placeholder">{%- render 'lucide', icon: 'dog' -%}</div>
        {%- endif -%}

        {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
          <div class="kbox__badge kbox__badge--{{ section.settings.badge_color }}">
            <span class="kbox__badge-icon" aria-hidden="true">{%- render 'lucide', icon: section.settings.badge_icon -%}</span>
            <span class="kbox__badge-text">{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.show_decorations -%}
          <span class="kbox__media-deco kbox__media-deco--lines" aria-hidden="true"><svg viewBox="0 0 40 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M3 14c5-7 8 5 13-1M24 6c5 7 8-5 13 1"/></svg></span>
        {%- endif -%}
      </div>

      <div class="kbox__col kbox__col--right">
        {%- for block in card_blocks -%}
          {%- assign col = forloop.index | modulo: 2 -%}
          {%- if col == 0 -%}
            <div class="kbox-card kbox-card--{{ block.settings.color }}" style="order:{{ forloop.index }}" {{ block.shopify_attributes }}>
              <span class="kbox-card__icon" aria-hidden="true">{%- render 'lucide', icon: block.settings.icon -%}</span>
              <div class="kbox-card__body">
                <h3 class="kbox-card__title">{{ block.settings.title }}</h3>
                {%- if block.settings.text != blank -%}<p class="kbox-card__text">{{ block.settings.text }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    <!-- ── Trustbar ────────────────────────────────── -->
    {%- if trust_blocks.size > 0 -%}
      <div class="kbox__trust">
        <ul class="kbox__trust-list" role="list">
          {%- for block in trust_blocks -%}
            <li class="kbox__trust-item" {{ block.shopify_attributes }}>
              <span class="kbox__trust-icon kbox__trust-icon--{{ block.settings.color }}" aria-hidden="true">{%- render 'lucide', icon: block.settings.icon -%}</span>
              <span class="kbox__trust-text">{{ block.settings.title }}</span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}

.kbox {
  position: relative;
  background: var(--color-cream);
  padding: var(--section-pad) 0;
  overflow: hidden;
}
.kbox__inner {
  position: relative;
  z-index: 1;
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 var(--page-margin);
}

/* ── Decoratieve merkaccenten (sectie) ───────────────── */
.kbox__deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.kbox__deco span { position: absolute; display: block; }
.kbox__deco span svg { display: block; width: 100%; height: 100%; }
.kbox__deco--1 { top: 90px;  left: 3%;   width: 40px; height: 40px; color: var(--color-green);  opacity: .14; transform: rotate(-16deg); }
.kbox__deco--2 { top: 150px; right: 5%;  width: 30px; height: 30px; color: var(--color-pink);   opacity: .20; transform: rotate(12deg); }
.kbox__deco--3 { top: 46%;   left: 2%;   width: 26px; height: 26px; color: var(--color-yellow); opacity: .55; transform: rotate(8deg); }
.kbox__deco--4 { bottom: 16%; right: 3%; width: 56px; height: 26px; color: var(--color-orange); opacity: .30; }
.kbox__deco--5 { bottom: 9%; left: 7%;   width: 26px; height: 26px; color: var(--color-pink);   opacity: .14; transform: rotate(20deg); }

/* ── Kop ─────────────────────────────────────────────── */
.kbox__head { text-align: center; max-width: 640px; margin: 0 auto 52px; }
.kbox__eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800;
  text-transform: uppercase; letter-spacing: .1em; color: var(--color-green);
  margin-bottom: 14px;
}
.kbox__eyebrow-icon { display: inline-flex; color: var(--color-orange); }
.kbox__eyebrow-icon .lucide { width: 16px; height: 16px; }
.kbox__heading {
  font-family: var(--font-heading);
  font-size: var(--fs-h2);
  line-height: 1.08; color: var(--color-ink); margin: 0;
}
.kbox__intro {
  font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.65;
  color: var(--color-body); margin: 16px auto 0; max-width: 540px;
}

/* ── Stage: kaarten | foto | kaarten ─────────────────── */
.kbox__stage {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.5fr) minmax(0, 1fr);
  gap: 26px;
  align-items: center;
}
.kbox__col { display: flex; flex-direction: column; justify-content: center; gap: 18px; }

/* Held-afbeelding */
.kbox__media {
  position: relative;
  border-radius: 30px;
  aspect-ratio: 4 / 5;
  box-shadow: 0 28px 70px rgba(61, 34, 9, .16);
}
.kbox__media-glow {
  position: absolute; inset: -16px; z-index: -1; border-radius: 40px;
  background: radial-gradient(60% 60% at 50% 30%, rgba(102,170,68,.20), transparent 70%);
}
.kbox__img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  border-radius: 30px;
}
.kbox__img--placeholder {
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(140deg, #fff, #e8f5e2); color: var(--color-green);
}
.kbox__img--placeholder .lucide { width: 96px; height: 96px; }

/* Badge over de foto */
.kbox__badge {
  position: absolute; top: 18px; left: 18px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 3px; width: 112px; height: 112px; border-radius: 50%; text-align: center;
  background: var(--color-pink); color: var(--color-ink);
  box-shadow: 0 12px 28px rgba(61, 34, 9, .22); transform: rotate(-8deg);
}
.kbox__badge--green  { background: var(--color-green);  color: #fff; }
.kbox__badge--orange { background: var(--color-orange); color: #fff; }
.kbox__badge--yellow { background: var(--color-yellow); color: var(--color-ink); }
.kbox__badge--cream  { background: var(--color-cream);  color: var(--color-ink); }
.kbox__badge-icon .lucide { width: 20px; height: 20px; }
.kbox__badge-text { font-family: var(--font-heading); font-size: .72rem; line-height: 1.1; max-width: 92px; }

.kbox__media-deco { position: absolute; pointer-events: none; }
.kbox__media-deco svg { display: block; width: 100%; height: 100%; }
.kbox__media-deco--lines { top: 16px; right: 18px; width: 44px; height: 22px; color: #fff; opacity: .85; }

/* ── Informatiekaart ─────────────────────────────────── */
.kbox-card {
  --c: var(--color-green); --c-soft: #e8f5e2;
  background: #fff; border: 1.5px solid var(--color-line);
  border-radius: var(--radius-lg); padding: 20px;
  transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
}
.kbox-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card-hover); border-color: var(--c); }
.kbox-card--green  { --c: var(--color-green);  --c-soft: #e8f5e2; }
.kbox-card--pink   { --c: var(--color-pink);   --c-soft: #ffe0ee; }
.kbox-card--orange { --c: var(--color-orange); --c-soft: #fff0e4; }
.kbox-card--yellow { --c: #d99100;             --c-soft: #fffae0; }
.kbox-card__icon {
  display: flex; align-items: center; justify-content: center;
  width: 50px; height: 50px; border-radius: 15px;
  background: var(--c-soft); color: var(--c); margin-bottom: 12px;
}
.kbox-card__icon .lucide { width: 25px; height: 25px; }
.kbox-card__title { font-family: var(--font-heading); font-size: var(--fs-h3); color: var(--color-ink); line-height: 1.15; margin: 0 0 5px; }
.kbox-card__text { font-family: var(--font-body); font-size: var(--fs-body); line-height: 1.55; color: var(--color-body); margin: 0; }

/* ── Trustbar ────────────────────────────────────────── */
.kbox__trust {
  margin-top: 48px; background: #fff;
  border: 1.5px solid var(--color-line); border-radius: 24px;
  box-shadow: var(--shadow-card);
}
.kbox__trust-list { list-style: none; margin: 0; padding: 0; display: flex; align-items: stretch; }
.kbox__trust-item {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 12px;
  padding: 22px; border-left: 1px solid var(--color-line);
  font-family: var(--font-body); font-size: .92rem; font-weight: 700; color: var(--color-ink);
}
.kbox__trust-item:first-child { border-left: none; }
.kbox__trust-icon {
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  width: 46px; height: 46px; border-radius: 50%; background: #e8f5e2; color: var(--color-green);
}
.kbox__trust-icon .lucide { width: 22px; height: 22px; }
.kbox__trust-icon--green  { background: #e8f5e2; color: var(--color-green); }
.kbox__trust-icon--pink   { background: #ffe0ee; color: var(--color-pink); }
.kbox__trust-icon--orange { background: #fff0e4; color: var(--color-orange); }
.kbox__trust-icon--yellow { background: #fffae0; color: #d99100; }

/* ── Tablet ──────────────────────────────────────────── */
@media (max-width: 1100px) and (min-width: 860px) {
  .kbox__stage { gap: 18px; }
  .kbox-card { padding: 16px; }
}

/* ── Mobiel: eigen ontwerp ───────────────────────────── */
@media (max-width: 859px) {
  .kbox__head { margin-bottom: 36px; }

  /* Kop → grote foto → kaarten (2-koloms, natuurlijke volgorde) */
  .kbox__stage { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: stretch; }
  .kbox__col { display: contents; }
  .kbox__media {
    grid-column: 1 / -1; order: -1;
    aspect-ratio: 4 / 3; margin-bottom: 8px;
  }
  .kbox__deco--1, .kbox__deco--4 { display: none; }

  /* Trustbar → swipebare kaarten */
  .kbox__trust { background: none; border: none; box-shadow: none; border-radius: 0; margin-top: 36px; }
  .kbox__trust-list {
    flex-wrap: nowrap; overflow-x: auto; gap: 12px; padding: 4px 2px 12px;
    scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none;
  }
  .kbox__trust-list::-webkit-scrollbar { display: none; }
  .kbox__trust-item {
    flex: 0 0 76%; scroll-snap-align: center; justify-content: flex-start;
    border-left: none; background: #fff; border: 1.5px solid var(--color-line);
    border-radius: 20px; box-shadow: var(--shadow-card);
    padding: 18px 20px; font-size: .9rem;
  }
}

/* ── Klein mobiel: kaarten 1-koloms ──────────────────── */
@media (max-width: 459px) {
  .kbox__stage { grid-template-columns: 1fr; }
  .kbox__media { aspect-ratio: 1 / 1; }
  .kbox__trust-item { flex-basis: 86%; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Inhoud Kwispelbox",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Held-afbeelding" },
    { "type": "image_picker", "id": "image", "label": "Afbeelding (blije hond + geopende box)" },
    { "type": "checkbox", "id": "show_badge", "label": "Badge tonen", "default": true },
    { "type": "text", "id": "badge_text", "label": "Badge tekst", "default": "Geen twee boxen zijn hetzelfde" },
    {
      "type": "select", "id": "badge_icon", "label": "Badge icoon", "default": "sparkles",
      "options": [
        { "value": "sparkles", "label": "Sparkles" },
        { "value": "heart", "label": "Hart" },
        { "value": "paw", "label": "Poot" },
        { "value": "gift", "label": "Cadeau" },
        { "value": "star", "label": "Ster" }
      ]
    },
    {
      "type": "select", "id": "badge_color", "label": "Badge kleur", "default": "pink",
      "options": [
        { "value": "pink", "label": "Roze" },
        { "value": "green", "label": "Groen" },
        { "value": "orange", "label": "Oranje" },
        { "value": "yellow", "label": "Geel" },
        { "value": "cream", "label": "Crème" }
      ]
    },
    { "type": "header", "content": "Decoratie" },
    { "type": "checkbox", "id": "show_decorations", "label": "Decoratieve merkaccenten tonen", "default": true },
    { "type": "header", "content": "Tekst" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elke box zorgvuldig samengesteld" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "Wat zit er in een Kwispelbox?" },
    { "type": "textarea", "id": "intro", "label": "Introtekst", "default": "Elke box is een feestje om uit te pakken. Vol speeltjes, snacks en verrassingen die jouw hond laten stralen — zorgvuldig samengesteld met liefde." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Informatiekaart",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "bone",
          "options": [
            { "value": "bone", "label": "Botje" },
            { "value": "paw", "label": "Poot" },
            { "value": "leaf", "label": "Blad" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "sparkles", "label": "Sparkles" },
            { "value": "heart", "label": "Hart" },
            { "value": "star", "label": "Ster" },
            { "value": "award", "label": "Award" },
            { "value": "shield-check", "label": "Schild check" },
            { "value": "dog", "label": "Hond" },
            { "value": "package", "label": "Pakket" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Accentkleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "Speeltjes" },
        { "type": "textarea", "id": "text", "label": "Beschrijving", "default": "Stevige speeltjes om uren mee te ravotten en kwispelen." }
      ]
    },
    {
      "type": "trust",
      "name": "Trust item",
      "limit": 5,
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "truck",
          "options": [
            { "value": "truck", "label": "Vrachtwagen" },
            { "value": "heart", "label": "Hart" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "shield-check", "label": "Schild check" },
            { "value": "paw", "label": "Poot" },
            { "value": "star", "label": "Ster" },
            { "value": "leaf", "label": "Blad" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Icoon kleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "title", "label": "Tekst", "default": "Gratis verzending vanaf €75" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inhoud Kwispelbox",
      "blocks": [
        { "type": "card", "settings": { "icon": "bone", "color": "green", "title": "Speeltjes", "text": "Stevige speeltjes om uren mee te ravotten en kwispelen." } },
        { "type": "card", "settings": { "icon": "leaf", "color": "orange", "title": "Gezonde snacks", "text": "Natuurlijke, smakelijke beloningen waar honden dol op zijn." } },
        { "type": "card", "settings": { "icon": "sparkles", "color": "pink", "title": "Maandelijkse verrassing", "text": "Elke box zit vol nieuwe avonturen om te ontdekken." } },
        { "type": "card", "settings": { "icon": "shield-check", "color": "yellow", "title": "Veilig & zorgvuldig", "text": "Alleen producten die wij zelf met een gerust hart geven." } },
        { "type": "trust", "settings": { "icon": "truck", "color": "green", "title": "Gratis verzending vanaf €75" } },
        { "type": "trust", "settings": { "icon": "heart", "color": "pink", "title": "Meer dan 1.200 blije honden" } },
        { "type": "trust", "settings": { "icon": "gift", "color": "orange", "title": "Elke box voelt als een cadeautje" } },
        { "type": "trust", "settings": { "icon": "shield-check", "color": "green", "title": "100% veilig betalen" } }
      ]
    }
  ]
}
{% endschema %}
