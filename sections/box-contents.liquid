{%- comment -%}
  sections/box-contents.liquid — Kwispelbox KB-v4
  "Wat zit er in een Kwispelbox?" — held-foto met 4 kaarten links + 4 rechts,
  scalloped badge, en trustbalk onderaan. Mobiel: foto boven → 2-koloms kaarten.
{%- endcomment -%}

{%- assign card_blocks  = section.blocks | where: 'type', 'card' -%}

<div class="kbox full-width">

  {%- if section.settings.show_decorations -%}
    <div class="kbox__deco" aria-hidden="true">
      <span class="kbox__deco kbox__deco--lines"><svg viewBox="0 0 48 26" fill="none" stroke-width="2.6" stroke-linecap="round"><path d="M5 17C10 7 14 20 19 12" stroke="var(--color-green)"/><path d="M3 9c2-3 5-4 8-3" stroke="var(--color-pink)"/><path d="M9 22c1-3 3-5 6-5" stroke="var(--color-yellow)"/></svg></span>
      <span class="kbox__deco kbox__deco--heart"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-pink)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
      <span class="kbox__deco kbox__deco--paw1"><svg viewBox="0 0 24 24" fill="var(--color-orange)"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
      <span class="kbox__deco kbox__deco--paw2"><svg viewBox="0 0 24 24" fill="var(--color-orange)"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
    </div>
  {%- endif -%}

  <div class="kbox__inner">

    <div class="kbox__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="kbox__eyebrow">
          <span class="kbox__eyebrow-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>
          {{ section.settings.eyebrow }}
        </span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kbox__heading">{{ section.settings.heading }}{%- if section.settings.heading_highlight != blank %} <span class="kbox__heading-em">{{ section.settings.heading_highlight }}</span>{%- endif -%}{{ section.settings.heading_suffix }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="kbox__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="kbox__stage">

      <div class="kbox__col kbox__col--left">
        {%- for block in card_blocks -%}
          {%- assign col = forloop.index | modulo: 2 -%}
          {%- if col == 1 -%}
            <div class="kbox-card kbox-card--{{ block.settings.color }}" style="order:{{ forloop.index }}" {{ block.shopify_attributes }}>
              <span class="kbox-card__icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
              <div class="kbox-card__body">
                <h3 class="kbox-card__title">{{ block.settings.title }}</h3>
                {%- if block.settings.text != blank -%}<p class="kbox-card__text">{{ block.settings.text }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="kbox__media">
        <div class="kbox__media-glow" aria-hidden="true"></div>
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 700 }} 700w,
                    {{ section.settings.image | image_url: width: 1000 }} 1000w,
                    {{ section.settings.image | image_url: width: 1400 }} 1400w"
            sizes="(max-width: 859px) 92vw, 42vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            width="640" height="640" loading="lazy"
            class="kbox__img">
        {%- else -%}
          <div class="kbox__img kbox__img--placeholder">{%- render 'kb-icon', icon: 'paw' -%}</div>
        {%- endif -%}

        {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
          <div class="kbox__badge">
            <svg class="kbox__badge-shape" viewBox="0 0 124 124" aria-hidden="true"><g fill="currentColor"><circle cx="110" cy="62" r="13"/><circle cx="103.6" cy="86" r="13"/><circle cx="86" cy="103.6" r="13"/><circle cx="62" cy="110" r="13"/><circle cx="38" cy="103.6" r="13"/><circle cx="20.4" cy="86" r="13"/><circle cx="14" cy="62" r="13"/><circle cx="20.4" cy="38" r="13"/><circle cx="38" cy="20.4" r="13"/><circle cx="62" cy="14" r="13"/><circle cx="86" cy="20.4" r="13"/><circle cx="103.6" cy="38" r="13"/><circle cx="62" cy="62" r="47"/></g></svg>
            <span class="kbox__badge-inner">
              <span class="kbox__badge-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
              <span class="kbox__badge-text">{{ section.settings.badge_text }}</span>
            </span>
          </div>
        {%- endif -%}
      </div>

      <div class="kbox__col kbox__col--right">
        {%- for block in card_blocks -%}
          {%- assign col = forloop.index | modulo: 2 -%}
          {%- if col == 0 -%}
            <div class="kbox-card kbox-card--{{ block.settings.color }}" style="order:{{ forloop.index }}" {{ block.shopify_attributes }}>
              <span class="kbox-card__icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
              <div class="kbox-card__body">
                <h3 class="kbox-card__title">{{ block.settings.title }}</h3>
                {%- if block.settings.text != blank -%}<p class="kbox-card__text">{{ block.settings.text }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

  </div>
</div>

{% stylesheet %}
.kbox { position: relative; background: transparent; padding: var(--section-pad) 0; overflow: hidden; }
.kbox__inner { position: relative; z-index: 1; max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* Decoratie */
.kbox__deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.kbox__deco span { position: absolute; display: block; }
.kbox__deco span svg { display: block; width: 100%; height: 100%; }
.kbox__deco--lines { top: 70px; left: 5%; width: 52px; height: 28px; }
.kbox__deco--heart { top: 80px; right: 6%; width: 34px; height: 34px; }
.kbox__deco--paw1 { top: 44%; left: 2.5%; width: 26px; height: 26px; opacity: .14; transform: rotate(-12deg); }
.kbox__deco--paw2 { bottom: 22%; right: 3%; width: 30px; height: 30px; opacity: .12; transform: rotate(14deg); }

/* Kop */
.kbox__head { text-align: center; max-width: 660px; margin: 0 auto 48px; }
.kbox__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--color-pink); margin-bottom: 14px; }
.kbox__eyebrow-icon { display: inline-flex; }
.kbox__eyebrow-icon svg { width: 16px; height: 16px; }
.kbox__heading { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.08; color: var(--color-ink); margin: 0; }
.kbox__heading-em { color: var(--color-green); }
.kbox__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 16px auto 0; max-width: 560px; }

/* Stage: kaarten | foto | kaarten */
.kbox__stage { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr) minmax(0, 1fr); gap: 24px; align-items: center; }
.kbox__col { display: flex; flex-direction: column; justify-content: center; gap: 16px; }

/* Held-afbeelding */
.kbox__media { position: relative; border-radius: 28px; aspect-ratio: 1 / 1; }
.kbox__media-glow { position: absolute; inset: -20px -10px -10px -28px; z-index: -1; border-radius: 50%; background: radial-gradient(55% 60% at 35% 55%, rgba(102,170,68,.22), transparent 72%); }
.kbox__img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 28px; box-shadow: 0 26px 60px rgba(61, 34, 9, .16); }
.kbox__img--placeholder { display: flex; align-items: center; justify-content: center; background: linear-gradient(140deg, #fff, #eef7e8); color: var(--color-green); }
.kbox__img--placeholder svg { width: 96px; height: 96px; }

/* Scalloped badge */
.kbox__badge { position: absolute; top: -10px; left: -14px; width: 132px; height: 132px; color: var(--color-yellow); transform: rotate(-9deg); filter: drop-shadow(0 10px 20px rgba(61,34,9,.2)); }
.kbox__badge-shape { position: absolute; inset: 0; width: 100%; height: 100%; }
.kbox__badge-inner { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; padding: 16px; text-align: center; }
.kbox__badge-heart { display: inline-flex; color: #fff; }
.kbox__badge-heart svg { width: 22px; height: 22px; }
.kbox__badge-text { font-family: var(--font-heading); font-size: .82rem; line-height: 1.12; color: var(--color-ink); max-width: 86px; }

/* Informatiekaart — icoon links, tekst rechts */
.kbox-card { --c: var(--color-green); --c-soft: #eef7e8; display: flex; align-items: flex-start; gap: 14px; background: #fff; border: 1px solid #f1ead9; border-radius: 20px; padding: 16px 18px; box-shadow: 0 8px 24px rgba(61,34,9,.05); transition: transform 200ms ease, box-shadow 200ms ease; }
.kbox-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card-hover); }
.kbox-card--green  { --c: var(--color-green);  --c-soft: #eef7e8; }
.kbox-card--pink   { --c: var(--color-pink);   --c-soft: #fdeaf2; }
.kbox-card--orange { --c: var(--color-orange); --c-soft: #fdf0e2; }
.kbox-card--yellow { --c: #d99100;             --c-soft: #fdf6e0; }
.kbox-card__icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 48px; height: 48px; border-radius: 50%; background: var(--c-soft); color: var(--c); }
.kbox-card__icon svg { width: 24px; height: 24px; }
.kbox-card__body { min-width: 0; }
.kbox-card__title { font-family: var(--font-heading); font-size: 1.08rem; color: var(--color-ink); line-height: 1.15; margin: 2px 0 4px; }
.kbox-card__text { font-family: var(--font-body); font-size: .9rem; line-height: 1.5; color: var(--color-body); margin: 0; }

/* Tablet */
@media (max-width: 1100px) and (min-width: 860px) {
  .kbox__stage { gap: 16px; }
  .kbox-card { padding: 14px; gap: 11px; }
  .kbox-card__icon { width: 44px; height: 44px; }
}

/* Mobiel: kop → foto → 2-koloms kaarten → trustbalk */
@media (max-width: 859px) {
  .kbox__head { margin-bottom: 32px; }
  .kbox__stage { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-items: stretch; }
  .kbox__col { display: contents; }
  .kbox__media { grid-column: 1 / -1; order: -1; aspect-ratio: 16 / 13; margin-bottom: 10px; }
  .kbox__badge { width: 108px; height: 108px; top: 10px; left: 10px; }
  .kbox__badge-text { font-size: .72rem; }
  .kbox-card { flex-direction: column; gap: 10px; padding: 14px; }
  .kbox-card__icon { width: 44px; height: 44px; }
  .kbox-card__title { font-size: 1rem; }
  .kbox-card__text { font-size: .85rem; line-height: 1.45; }
  .kbox__deco--paw1, .kbox__deco--lines { display: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Inhoud Kwispelbox",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Tekst" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Elke box met liefde samengesteld" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Wat zit er in een" },
    { "type": "text", "id": "heading_highlight", "label": "Kop accent (groen)", "default": "Kwispelbox" },
    { "type": "text", "id": "heading_suffix", "label": "Kop slot", "default": "?" },
    { "type": "textarea", "id": "intro", "label": "Subtekst", "default": "Geen standaard cadeautje, maar een zorgvuldig samengestelde verrassing afgestemd op jouw hond." },
    { "type": "header", "content": "Held-afbeelding" },
    { "type": "image_picker", "id": "image", "label": "Afbeelding (blije hond + geopende box)" },
    { "type": "checkbox", "id": "show_badge", "label": "Badge tonen", "default": true },
    { "type": "text", "id": "badge_text", "label": "Badge tekst", "default": "Geen twee boxen zijn hetzelfde" },
    { "type": "header", "content": "Decoratie" },
    { "type": "checkbox", "id": "show_decorations", "label": "Decoratieve merkaccenten tonen", "default": true }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Informatiekaart",
      "limit": 8,
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "teddy",
          "options": [
            { "value": "teddy", "label": "Knuffel" },
            { "value": "ball", "label": "Bal" },
            { "value": "bone", "label": "Botje" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "leaf", "label": "Blad / snack" },
            { "value": "squeak", "label": "Geluid / pieper" },
            { "value": "partyhat", "label": "Feesthoed" },
            { "value": "envelope", "label": "Envelop met hart" },
            { "value": "paw", "label": "Poot" },
            { "value": "star", "label": "Ster" },
            { "value": "sparkles", "label": "Sparkles" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Accentkleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "Speeltjes" },
        { "type": "textarea", "id": "text", "label": "Beschrijving", "default": "Interactieve speeltjes voor urenlang speelplezier." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inhoud Kwispelbox",
      "blocks": [
        { "type": "card", "settings": { "icon": "teddy", "color": "pink", "title": "Knuffels", "text": "Zachte vriendjes om mee te spelen en te knuffelen." } },
        { "type": "card", "settings": { "icon": "leaf", "color": "orange", "title": "Natuurlijke snacks", "text": "Verantwoord verwennen met heerlijke traktaties." } },
        { "type": "card", "settings": { "icon": "ball", "color": "green", "title": "Speeltjes", "text": "Interactieve speeltjes voor urenlang speelplezier." } },
        { "type": "card", "settings": { "icon": "squeak", "color": "yellow", "title": "Piepers & geluid", "text": "Voor nieuwsgierige honden die van ontdekken houden." } },
        { "type": "card", "settings": { "icon": "bone", "color": "orange", "title": "Touw & trekspelletjes", "text": "Voor actieve honden die van uitdaging houden." } },
        { "type": "card", "settings": { "icon": "partyhat", "color": "pink", "title": "Passend thema", "text": "Bijvoorbeeld verjaardag, Pasen, zomer of kerst." } },
        { "type": "card", "settings": { "icon": "gift", "color": "yellow", "title": "Extra verrassing", "text": "Elke box bevat iets onverwachts." } },
        { "type": "card", "settings": { "icon": "envelope", "color": "green", "title": "Persoonlijk kaartje", "text": "Met een warme boodschap speciaal voor jouw hond." } }
      ]
    }
  ]
}
{% endschema %}
