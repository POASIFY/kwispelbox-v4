{%- comment -%}
  sections/info-page.liquid — KB-v4 herbruikbare informatiepagina.
  Hero + artikel-blokken (kop + richtext) + optionele contact-CTA.
  Gebruikt voor Verzending & retour, juridische pagina's, etc. Namespace `inf`.
{%- endcomment -%}

<div class="inf full-width">
  <div class="inf__inner">

    <header class="inf__head">
      {%- if section.settings.eyebrow != blank -%}<span class="inf__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.title != blank -%}<h1 class="inf__title">{{ section.settings.title }}</h1>{%- endif -%}
      {%- if section.settings.intro != blank -%}<p class="inf__intro">{{ section.settings.intro }}</p>{%- endif -%}
      {%- if section.settings.updated != blank -%}<span class="inf__updated">{{ section.settings.updated }}</span>{%- endif -%}
    </header>

    <article class="inf__article">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <section class="inf__item" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="inf__item-title">{%- if block.settings.icon != blank and block.settings.icon != 'none' -%}<span class="inf__item-icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>{%- endif -%}{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}<div class="inf__item-text">{{ block.settings.text }}</div>{%- endif -%}
          </section>
        {%- endif -%}
      {%- endfor -%}
    </article>

    {%- if section.settings.cta_text != blank -%}
      <div class="inf__cta">
        <span class="inf__cta-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'chat' -%}</span>
        <div class="inf__cta-body">
          <strong>{{ section.settings.cta_title | default: 'Nog vragen?' }}</strong>
          <span>{{ section.settings.cta_text }}</span>
        </div>
        {%- if section.settings.cta_label != blank -%}<a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="inf__cta-btn">{{ section.settings.cta_label }}</a>{%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.inf { background: transparent; padding: var(--section-pad) 0; }
.inf__inner { max-width: 760px; margin: 0 auto; padding: 0 var(--page-margin); }
.inf__head { margin-bottom: 36px; }
.inf__eyebrow { display: inline-block; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .09em; color: var(--color-green); margin-bottom: 12px; }
.inf__title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.04; color: var(--color-ink); margin: 0 0 12px; }
.inf__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 0; }
.inf__updated { display: inline-block; margin-top: 14px; font-family: var(--font-body); font-size: .8rem; color: var(--color-muted); }

.inf__article { display: flex; flex-direction: column; gap: 30px; }
.inf__item { background: #fff; border: 1.5px solid var(--color-line); border-radius: 20px; padding: 24px 26px; box-shadow: 0 8px 22px rgba(61, 34, 9, .04); }
.inf__item-title { display: flex; align-items: center; gap: 11px; font-family: var(--font-heading); font-size: 1.35rem; color: var(--color-ink); line-height: 1.15; margin: 0 0 12px; }
.inf__item-icon { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); flex-shrink: 0; }
.inf__item-icon svg { width: 20px; height: 20px; }
.inf__item-text { font-family: var(--font-body); font-size: var(--fs-body); line-height: 1.7; color: var(--color-body); }
.inf__item-text p { margin: 0 0 12px; }
.inf__item-text p:last-child { margin-bottom: 0; }
.inf__item-text ul, .inf__item-text ol { margin: 0 0 12px; padding-left: 22px; }
.inf__item-text li { margin-bottom: 6px; }
.inf__item-text a { color: var(--color-green); }
.inf__item-text strong { color: var(--color-ink); }

.inf__cta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 34px; background: #fff0e4; border-radius: 22px; padding: 22px 26px; }
.inf__cta-icon { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; background: #fff; color: var(--color-orange); flex-shrink: 0; }
.inf__cta-icon svg { width: 24px; height: 24px; }
.inf__cta-body { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 180px; }
.inf__cta-body strong { font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-ink); }
.inf__cta-body span { font-family: var(--font-body); font-size: .9rem; color: var(--color-body); }
.inf__cta-btn { display: inline-flex; align-items: center; padding: 12px 24px; background: var(--color-orange); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1rem; text-decoration: none; transition: filter 160ms, transform 160ms; }
.inf__cta-btn:hover { filter: brightness(.95); transform: translateY(-2px); }
{% endstylesheet %}

{% schema %}
{
  "name": "Informatiepagina",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Goed om te weten" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Verzending & retour" },
    { "type": "textarea", "id": "intro", "label": "Intro" },
    { "type": "text", "id": "updated", "label": "Laatst bijgewerkt (optioneel)" },
    { "type": "header", "content": "Contact-blok onderaan" },
    { "type": "text", "id": "cta_title", "label": "Titel", "default": "Nog vragen?" },
    { "type": "text", "id": "cta_text", "label": "Tekst", "default": "Ons team helpt je graag verder." },
    { "type": "text", "id": "cta_label", "label": "Knoptekst", "default": "Neem contact op" },
    { "type": "url", "id": "cta_url", "label": "Knop link" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Tekstblok",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "none",
          "options": [
            { "value": "none", "label": "Geen" }, { "value": "truck", "label": "Verzending" }, { "value": "refresh", "label": "Retour" },
            { "value": "shield", "label": "Schild" }, { "value": "tag", "label": "Betaling" }, { "value": "package", "label": "Pakket" },
            { "value": "heart", "label": "Hart" }, { "value": "check", "label": "Vinkje" }, { "value": "bulb", "label": "Info" }
          ]
        },
        { "type": "text", "id": "heading", "label": "Kop", "default": "Verzending" },
        { "type": "richtext", "id": "text", "label": "Tekst", "default": "<p>We versturen je bestelling met zorg. Voor 16:00 besteld? Dan gaat 'ie dezelfde werkdag op de post.</p>" }
      ]
    }
  ],
  "presets": [ { "name": "Informatiepagina" } ]
}
{% endschema %}
