{%- comment -%}
  Partners-landingspagina: hero + partnertypes + zo-werkt-het + wat-krijg-je-eraan + aanmeldformulier.
  Het formulier gebruikt Shopify {% form 'contact' %} → mailt naar het winkel-e-mailadres. Namespace `prt`.
{%- endcomment -%}
<div class="prt full-width">
  <div class="prt__inner">

    {%- comment -%} Hero {%- endcomment -%}
    <header class="prt__hero">
      {%- if section.settings.eyebrow != blank -%}<span class="prt__eyebrow"><span aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h1 class="prt__title">{{ section.settings.title | default: 'Word partner van Kwispelbox' }}</h1>
      {%- if section.settings.intro != blank -%}<p class="prt__intro">{{ section.settings.intro }}</p>{%- endif -%}
      <a href="#aanmelden" class="prt__hero-btn">{{ section.settings.hero_cta | default: 'Word partner' }}<span class="prt__hero-btn-paw" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span></a>
    </header>

    {%- comment -%} Partnertypes {%- endcomment -%}
    {%- assign ptypes = section.blocks | where: 'type', 'ptype' -%}
    {%- if ptypes.size > 0 -%}
      <section class="prt__block">
        {%- if section.settings.types_title != blank -%}<h2 class="prt__h2">{{ section.settings.types_title }}</h2>{%- endif -%}
        {%- if section.settings.types_text != blank -%}<p class="prt__lead">{{ section.settings.types_text }}</p>{%- endif -%}
        <div class="prt__types">
          {%- for block in ptypes -%}
            <div class="prt-type" {{ block.shopify_attributes }}>
              <span class="prt-type__icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon | default: 'paw' -%}</span>
              <strong class="prt-type__title">{{ block.settings.title }}</strong>
              {%- if block.settings.text != blank -%}<span class="prt-type__text">{{ block.settings.text }}</span>{%- endif -%}
              {%- if block.settings.moment != blank -%}<span class="prt-type__moment"><span aria-hidden="true">{%- render 'kb-icon', icon: 'sparkles' -%}</span>{{ block.settings.moment }}</span>{%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </section>
    {%- endif -%}

    {%- comment -%} Zo werkt het {%- endcomment -%}
    {%- assign steps = section.blocks | where: 'type', 'step' -%}
    {%- if steps.size > 0 -%}
      <section class="prt__block">
        {%- if section.settings.steps_title != blank -%}<h2 class="prt__h2">{{ section.settings.steps_title }}</h2>{%- endif -%}
        <ol class="prt__steps">
          {%- for block in steps -%}
            <li class="prt-step" {{ block.shopify_attributes }}>
              <span class="prt-step__num">{{ forloop.index }}</span>
              <div>
                <strong class="prt-step__title">{{ block.settings.title }}</strong>
                {%- if block.settings.text != blank -%}<span class="prt-step__text">{{ block.settings.text }}</span>{%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ol>
      </section>
    {%- endif -%}

    {%- comment -%} Wat krijg je eraan {%- endcomment -%}
    {%- assign perks = section.blocks | where: 'type', 'perk' -%}
    {%- if perks.size > 0 -%}
      <section class="prt__block prt__block--perks">
        <div class="prt__perks-head">
          {%- if section.settings.perks_title != blank -%}<h2 class="prt__h2">{{ section.settings.perks_title }}</h2>{%- endif -%}
          {%- if section.settings.perks_text != blank -%}<p class="prt__lead">{{ section.settings.perks_text }}</p>{%- endif -%}
          {%- if section.settings.perks_quote != blank -%}<blockquote class="prt__quote">{%- render 'kb-icon', icon: 'heart' -%}{{ section.settings.perks_quote }}</blockquote>{%- endif -%}
        </div>
        <ul class="prt__perks" role="list">
          {%- for block in perks -%}
            <li class="prt-perk" {{ block.shopify_attributes }}>
              <span class="prt-perk__check" aria-hidden="true">{%- render 'kb-icon', icon: 'check' -%}</span>
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endfor -%}
        </ul>
      </section>
    {%- endif -%}

    {%- comment -%} Aanmeldformulier {%- endcomment -%}
    <section class="prt__block prt__signup" id="aanmelden">
      <div class="prt__signup-head">
        {%- if section.settings.form_title != blank -%}<h2 class="prt__h2">{{ section.settings.form_title }}</h2>{%- endif -%}
        {%- if section.settings.form_text != blank -%}<p class="prt__lead">{{ section.settings.form_text }}</p>{%- endif -%}
      </div>
      <div class="prt__form-wrap">
        {%- form 'contact', class: 'prt__form' -%}
          {%- if form.posted_successfully? -%}
            <div class="prt__success">
              <span class="prt__success-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'check' -%}</span>
              <strong>{{ section.settings.success_title | default: 'Bedankt voor je aanmelding!' }}</strong>
              <span>{{ section.settings.success_text | default: 'We nemen binnen 2 werkdagen contact met je op om de samenwerking te bespreken.' }}</span>
            </div>
          {%- else -%}
            {%- if form.errors -%}<div class="prt__errors">{{ form.errors | default_errors }}</div>{%- endif -%}
            <input type="hidden" name="contact[Aanvraag]" value="Partneraanmelding">
            <div class="prt__field-row">
              <label class="prt__field"><span class="prt__lbl">Bedrijfsnaam</span><input type="text" name="contact[Bedrijfsnaam]" placeholder="Bijv. Trimsalon Bella" required></label>
              <label class="prt__field"><span class="prt__lbl">Contactpersoon</span><input type="text" name="contact[name]" value="{{ form.name }}" placeholder="Je naam" required></label>
            </div>
            <div class="prt__field-row">
              <label class="prt__field"><span class="prt__lbl">E-mailadres</span><input type="email" name="contact[email]" value="{{ form.email }}" placeholder="jij@voorbeeld.nl" required></label>
              <label class="prt__field"><span class="prt__lbl">Website of Instagram</span><input type="text" name="contact[Website of Instagram]" placeholder="@jouwsalon of www…"></label>
            </div>
            <div class="prt__field-row">
              <label class="prt__field"><span class="prt__lbl">Type partner</span>
                <select name="contact[Type partner]" required>
                  <option value="">Kies…</option>
                  <option>Trimsalon</option>
                  <option>Puppytrainer / hondenschool</option>
                  <option>Dierenarts</option>
                  <option>Hondenopvang / uitlaatservice</option>
                  <option>Fokker / asiel</option>
                  <option>Hondenfotograaf</option>
                  <option>Hotel / vakantiepark</option>
                  <option>Dierenwinkel / boetiek</option>
                  <option>Anders</option>
                </select>
              </label>
              <label class="prt__field"><span class="prt__lbl">Locatie (plaats)</span><input type="text" name="contact[Locatie]" placeholder="Bijv. Utrecht"></label>
            </div>
            <label class="prt__field"><span class="prt__lbl">Geschat aantal klanten per maand</span>
              <select name="contact[Klanten per maand]">
                <option value="">Kies…</option>
                <option>1–25</option>
                <option>25–50</option>
                <option>50–100</option>
                <option>100–250</option>
                <option>250+</option>
              </select>
            </label>
            <fieldset class="prt__checks">
              <legend class="prt__lbl">Waar heb je interesse in? (meerdere mogelijk)</legend>
              <label class="prt__check"><input type="checkbox" name="contact[Interesse referralkaart]" value="Ja"><span>Referralkaart / QR-code</span></label>
              <label class="prt__check"><input type="checkbox" name="contact[Interesse samplebox]" value="Ja"><span>Samplebox op locatie</span></label>
              <label class="prt__check"><input type="checkbox" name="contact[Interesse winactie]" value="Ja"><span>Co-branded winactie</span></label>
              <label class="prt__check"><input type="checkbox" name="contact[Interesse bulk]" value="Ja"><span>Bulk / zakelijke samenwerking</span></label>
            </fieldset>
            <label class="prt__field"><span class="prt__lbl">Toelichting <span class="prt__opt">optioneel</span></span><textarea name="contact[body]" rows="4" placeholder="Vertel kort over je zaak en hoe je Kwispelbox zou willen aanbieden…">{{ form.body }}</textarea></label>
            <button type="submit" class="prt__submit">{{ section.settings.submit_label | default: 'Aanmelden als partner' }}<span class="prt__submit-paw" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span></button>
            {%- if section.settings.form_note != blank -%}<p class="prt__form-note">{{ section.settings.form_note }}</p>{%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>
    </section>

  </div>
</div>

{% stylesheet %}
.prt { padding: clamp(36px, 6vw, 72px) 0; }
.prt__inner { max-width: 1080px; margin: 0 auto; padding: 0 20px; }
.prt__hero { text-align: center; max-width: 720px; margin: 0 auto clamp(36px, 6vw, 60px); }
.prt__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--color-pink); margin-bottom: 12px; }
.prt__eyebrow svg { width: 16px; height: 16px; }
.prt__title { font-family: var(--font-heading); font-size: clamp(2rem, 6vw, 3.1rem); color: var(--color-ink); line-height: 1.05; margin: 0 0 16px; }
.prt__intro { font-family: var(--font-body); font-size: 1.1rem; color: var(--color-body); line-height: 1.6; margin: 0 0 26px; }
.prt__hero-btn { display: inline-flex; align-items: center; gap: 11px; padding: 15px 32px; background: var(--color-green); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.15rem; transition: filter 160ms, transform 160ms; }
.prt__hero-btn:hover { filter: brightness(1.05); transform: translateY(-1px); }
.prt__hero-btn-paw svg { width: 20px; height: 20px; }
.prt__block { margin-bottom: clamp(40px, 7vw, 72px); }
.prt__h2 { font-family: var(--font-heading); font-size: clamp(1.5rem, 4vw, 2.1rem); color: var(--color-ink); text-align: center; margin: 0 0 12px; }
.prt__lead { font-family: var(--font-body); font-size: 1rem; color: var(--color-body); text-align: center; max-width: 620px; margin: 0 auto 30px; line-height: 1.6; }
/* Partnertypes */
.prt__types { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.prt-type { background: #fff; border: 1.5px solid var(--color-line); border-radius: 20px; padding: 22px; transition: border-color 160ms, box-shadow 160ms; }
.prt-type:hover { border-color: var(--color-pink); box-shadow: 0 12px 28px rgba(61, 34, 9, .07); }
.prt-type__icon { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 14px; background: #ffe9f1; color: var(--color-pink); margin-bottom: 14px; }
.prt-type__icon svg { width: 24px; height: 24px; }
.prt-type__title { display: block; font-family: var(--font-heading); font-size: 1.2rem; color: var(--color-ink); margin-bottom: 6px; }
.prt-type__text { display: block; font-family: var(--font-body); font-size: .92rem; color: var(--color-body); line-height: 1.5; }
.prt-type__moment { display: inline-flex; align-items: center; gap: 6px; margin-top: 12px; font-family: var(--font-body); font-size: .8rem; font-weight: 700; color: var(--color-green); }
.prt-type__moment svg { width: 14px; height: 14px; }
/* Stappen */
.prt__steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; list-style: none; margin: 0; padding: 0; counter-reset: none; }
.prt-step { display: flex; gap: 14px; align-items: flex-start; }
.prt-step__num { flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: var(--color-green); color: #fff; font-family: var(--font-heading); font-size: 1.1rem; }
.prt-step__title { display: block; font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-ink); margin-bottom: 4px; }
.prt-step__text { display: block; font-family: var(--font-body); font-size: .92rem; color: var(--color-body); line-height: 1.5; }
/* Perks */
.prt__block--perks { background: var(--color-cream); border-radius: 28px; padding: clamp(28px, 5vw, 48px); }
.prt__perks-head { text-align: center; margin-bottom: 26px; }
.prt__quote { font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-pink); max-width: 600px; margin: 18px auto 0; line-height: 1.3; display: flex; align-items: center; justify-content: center; gap: 10px; }
.prt__quote svg { width: 22px; height: 22px; flex-shrink: 0; }
.prt__perks { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 26px; max-width: 760px; margin: 0 auto; padding: 0; list-style: none; }
.prt-perk { display: flex; align-items: flex-start; gap: 10px; font-family: var(--font-body); font-size: .98rem; color: var(--color-ink); }
.prt-perk__check { flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); }
.prt-perk__check svg { width: 14px; height: 14px; }
/* Formulier */
.prt__signup { scroll-margin-top: clamp(90px, 13vw, 150px); }
.prt__signup-head { text-align: center; margin-bottom: 26px; }
.prt__form-wrap { background: #fff; border: 1.5px solid var(--color-line); border-radius: 26px; padding: clamp(22px, 4vw, 34px); box-shadow: 0 12px 30px rgba(61, 34, 9, .06); max-width: 760px; margin: 0 auto; }
.prt__form { display: flex; flex-direction: column; gap: 16px; }
.prt__field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.prt__field { display: flex; flex-direction: column; gap: 6px; }
.prt__lbl { font-family: var(--font-body); font-size: .85rem; font-weight: 700; color: var(--color-ink); }
.prt__opt { font-weight: 400; color: var(--color-muted); }
.prt__field input, .prt__field select, .prt__field textarea { font-family: var(--font-body); font-size: .95rem; color: var(--color-ink); border: 1.5px solid var(--color-line); border-radius: 14px; padding: 13px 15px; background: var(--color-cream); outline: none; transition: border-color 160ms, background 160ms; }
.prt__field input:focus, .prt__field select:focus, .prt__field textarea:focus { border-color: var(--color-green); background: #fff; }
.prt__field textarea { resize: vertical; min-height: 96px; }
.prt__checks { border: 1.5px solid var(--color-line); border-radius: 14px; padding: 14px 16px; display: flex; flex-direction: column; gap: 10px; margin: 0; }
.prt__checks .prt__lbl { margin-bottom: 4px; }
.prt__check { display: flex; align-items: center; gap: 10px; font-family: var(--font-body); font-size: .92rem; color: var(--color-body); cursor: pointer; }
.prt__check input { width: 18px; height: 18px; accent-color: var(--color-green); flex-shrink: 0; }
.prt__submit { display: inline-flex; align-items: center; justify-content: center; gap: 11px; align-self: flex-start; padding: 15px 30px; background: var(--color-green); color: #fff; border: none; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.1rem; cursor: pointer; transition: filter 160ms, transform 160ms; }
.prt__submit:hover { filter: brightness(1.05); transform: translateY(-1px); }
.prt__submit-paw svg { width: 20px; height: 20px; }
.prt__form-note { font-family: var(--font-body); font-size: .8rem; color: var(--color-muted); margin: 0; }
.prt__success { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 8px; padding: 18px; }
.prt__success-icon { display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); }
.prt__success-icon svg { width: 26px; height: 26px; }
.prt__success strong { font-family: var(--font-heading); font-size: 1.3rem; color: var(--color-ink); }
.prt__success span { font-family: var(--font-body); color: var(--color-body); }
.prt__errors { font-family: var(--font-body); font-size: .9rem; color: #b3261e; background: #fdecea; border-radius: 12px; padding: 12px 14px; }
@media (max-width: 749px) {
  .prt__types, .prt__steps, .prt__perks { grid-template-columns: 1fr; }
  .prt__field-row { grid-template-columns: 1fr; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Partners pagina",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Kwispelbox Partnerprogramma" },
    { "type": "text", "id": "title", "label": "Titel (H1)", "default": "Word partner van Kwispelbox" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Samen zorgen we voor meer blije hondenmomenten. Sluit je aan en geef jouw klanten een extra verrassing voor hun hond — geen kortingsmerk, maar een cadeautje dat past bij jouw zaak." },
    { "type": "text", "id": "hero_cta", "label": "Knoptekst", "default": "Word partner" },
    { "type": "header", "content": "Partnertypes" },
    { "type": "text", "id": "types_title", "label": "Titel", "default": "Voor wie is het Partnerprogramma?" },
    { "type": "textarea", "id": "types_text", "label": "Subtekst", "default": "We werken samen met partijen die op natuurlijke momenten contact hebben met hondenbaasjes." },
    { "type": "header", "content": "Zo werkt het" },
    { "type": "text", "id": "steps_title", "label": "Titel", "default": "Zo werkt het" },
    { "type": "header", "content": "Wat krijg je eraan" },
    { "type": "text", "id": "perks_title", "label": "Titel", "default": "Wat krijg jij als partner?" },
    { "type": "textarea", "id": "perks_text", "label": "Subtekst", "default": "Je promoot geen webshop — je geeft je eigen klant iets waardevols." },
    { "type": "text", "id": "perks_quote", "label": "Quote", "default": "Samen geven we jouw klanten een extra blij hondenmoment." },
    { "type": "header", "content": "Aanmeldformulier" },
    { "type": "text", "id": "form_title", "label": "Titel", "default": "Meld je aan als partner" },
    { "type": "textarea", "id": "form_text", "label": "Subtekst", "default": "Laat je gegevens achter — we nemen binnen 2 werkdagen contact met je op." },
    { "type": "text", "id": "submit_label", "label": "Knoptekst", "default": "Aanmelden als partner" },
    { "type": "text", "id": "success_title", "label": "Succes-titel", "default": "Bedankt voor je aanmelding!" },
    { "type": "textarea", "id": "success_text", "label": "Succes-tekst", "default": "We nemen binnen 2 werkdagen contact met je op om de samenwerking te bespreken." },
    { "type": "textarea", "id": "form_note", "label": "Notitie onder formulier", "default": "We gebruiken je gegevens alleen om contact op te nemen over een samenwerking." }
  ],
  "blocks": [
    {
      "type": "ptype",
      "name": "Partnertype",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icoon (kb-icon naam)", "default": "paw" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Trimsalon" },
        { "type": "textarea", "id": "text", "label": "Tekst", "default": "Terugkerend klantcontact met baasjes die al in hun hond investeren." },
        { "type": "text", "id": "moment", "label": "Beste moment", "default": "Na elke trimbeurt" }
      ]
    },
    {
      "type": "step",
      "name": "Stap",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "Stap" },
        { "type": "textarea", "id": "text", "label": "Tekst" }
      ]
    },
    {
      "type": "perk",
      "name": "Voordeel",
      "settings": [
        { "type": "text", "id": "text", "label": "Tekst", "default": "Een gratis extra voor jouw klant" }
      ]
    }
  ],
  "presets": [{ "name": "Partners pagina" }]
}
{% endschema %}
