{%- comment -%}
  sections/newsletter.liquid — Kwispelbox KB-v4
  "Mis nooit meer een verrassing" — mint-kaart met foto + aanmeldformulier +
  voordelen, en een trust-balk onderaan. Blokken: benefit, stat.
{%- endcomment -%}

{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}

<div class="kbnl full-width">

  {%- if section.settings.show_decorations -%}
    <div class="kbnl__deco" aria-hidden="true">
      <span class="kbnl__deco kbnl__deco--heart"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-yellow)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
      <span class="kbnl__deco kbnl__deco--heart2"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-pink)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
      <span class="kbnl__deco kbnl__deco--paw"><svg viewBox="0 0 24 24" fill="var(--color-orange)"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
    </div>
  {%- endif -%}

  <div class="kbnl__inner">

    <div class="kbnl__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="kbnl__eyebrow"><span class="kbnl__eyebrow-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kbnl__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="kbnl__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="kbnl__card">

      <figure class="kbnl__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1000 }}" srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 1000 }} 1000w" sizes="(max-width:859px) 92vw, 40vw" alt="{{ section.settings.image.alt | escape }}" width="700" height="640" loading="lazy" class="kbnl__img">
        {%- else -%}
          <div class="kbnl__img kbnl__img--ph">{%- render 'kb-icon', icon: 'mail' -%}</div>
        {%- endif -%}
      </figure>

      <div class="kbnl__signup">
        <h3 class="kbnl__signup-title"><span class="kbnl__signup-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'mail' -%}</span>{{ section.settings.signup_title | default: 'Word lid van de Kwispelclub!' }}</h3>
        {%- if section.settings.signup_text != blank -%}<p class="kbnl__signup-text">{{ section.settings.signup_text }}</p>{%- endif -%}

        {%- form 'customer', class: 'kbnl__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="kbnl__success"><span class="kbnl__success-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ section.settings.success_text | default: 'Hoera! Je staat op de lijst.' }}</p>
          {%- else -%}
            <div class="kbnl__row">
              <span class="kbnl__field">
                <span class="kbnl__field-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'mail' -%}</span>
                <label class="kbnl__sr" for="kbnl-email">E-mailadres</label>
                <input id="kbnl-email" type="email" name="contact[email]" required placeholder="{{ section.settings.placeholder | default: 'Jouw e-mailadres' }}" class="kbnl__input">
              </span>
              <button type="submit" class="kbnl__btn">{{ section.settings.button_label | default: 'Aanmelden' }}<span class="kbnl__btn-arrow" aria-hidden="true">{%- render 'kb-icon', icon: 'arrow' -%}</span></button>
            </div>
            {%- if form.errors -%}<p class="kbnl__error">{{ form.errors | default_errors }}</p>{%- endif -%}
          {%- endif -%}
        {%- endform -%}

        {%- if section.settings.note != blank -%}
          <p class="kbnl__note"><span class="kbnl__note-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'shield' -%}</span>{{ section.settings.note }}</p>
        {%- endif -%}
      </div>

      {%- if benefit_blocks.size > 0 -%}
        <div class="kbnl__benefits">
          {%- for block in benefit_blocks -%}
            <div class="kbnl-benefit kbnl-benefit--{{ block.settings.color }}" {{ block.shopify_attributes }}>
              <span class="kbnl-benefit__icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
              <div class="kbnl-benefit__body">
                <strong class="kbnl-benefit__title">{{ block.settings.title }}</strong>
                {%- if block.settings.text != blank -%}<span class="kbnl-benefit__text">{{ block.settings.text }}</span>{%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

  </div>
</div>

{% stylesheet %}
.kbnl { position: relative; background: transparent; padding: var(--section-pad) 0; overflow: hidden; }
.kbnl__inner { position: relative; z-index: 1; max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* Decoratie */
.kbnl__deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.kbnl__deco span { position: absolute; display: block; }
.kbnl__deco span svg { display: block; width: 100%; height: 100%; }
.kbnl__deco--heart { top: 60px; left: 10%; width: 32px; height: 32px; }
.kbnl__deco--heart2 { top: 80px; right: 9%; width: 34px; height: 34px; }
.kbnl__deco--paw { top: 14%; right: 5%; width: 30px; height: 30px; opacity: .35; }

/* Kop */
.kbnl__head { text-align: center; margin: 0 auto 36px; }
.kbnl__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; letter-spacing: .04em; color: var(--color-pink); margin-bottom: 12px; }
.kbnl__eyebrow-icon { display: inline-flex; }
.kbnl__eyebrow-icon svg { width: 16px; height: 16px; fill: currentColor; stroke: currentColor; }
.kbnl__heading { font-family: var(--font-heading); font-size: clamp(2.1rem, 5vw, 3.4rem); line-height: 1.05; color: var(--color-ink); margin: 0; }
.kbnl__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 14px auto 0; max-width: 600px; }

/* Mint-kaart */
.kbnl__card { position: relative; background: linear-gradient(135deg, #eef6e6 0%, #e6f1dd 100%); border-radius: 28px; padding: 22px; display: grid; grid-template-columns: 0.82fr 1fr; grid-template-areas: "media signup" "media benefits"; gap: 22px 34px; align-items: start; }

.kbnl__media { grid-area: media; margin: 0; align-self: stretch; border-radius: 20px; overflow: hidden; min-height: 360px; }
.kbnl__img { width: 100%; height: 100%; object-fit: cover; display: block; }
.kbnl__img--ph { display: flex; align-items: center; justify-content: center; min-height: 360px; background: linear-gradient(140deg, #fff, #eef7e8); color: var(--color-green); }
.kbnl__img--ph svg { width: 72px; height: 72px; }

/* Aanmeld-blok */
.kbnl__signup { grid-area: signup; padding-top: 14px; }
.kbnl__signup-title { display: flex; align-items: center; gap: 12px; font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-ink); margin: 0 0 10px; line-height: 1.1; }
.kbnl__signup-icon { display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; width: 44px; height: 44px; border-radius: 50%; background: var(--color-green); color: #fff; }
.kbnl__signup-icon svg { width: 22px; height: 22px; }
.kbnl__signup-text { font-family: var(--font-body); font-size: 1rem; line-height: 1.5; color: var(--color-body); margin: 0 0 18px; max-width: 46ch; }

.kbnl__row { display: flex; gap: 12px; max-width: 560px; }
.kbnl__field { flex: 1; min-width: 0; display: flex; align-items: center; gap: 11px; height: 58px; padding: 0 8px 0 20px; background: #fff; border: 1.5px solid var(--color-line); border-radius: var(--radius-pill); box-shadow: 0 6px 18px rgba(61,34,9,.06); transition: border-color 180ms, box-shadow 180ms; }
.kbnl__field:focus-within { border-color: var(--color-pink); box-shadow: 0 8px 22px rgba(212,83,126,.14); }
.kbnl__field-icon { display: inline-flex; align-items: center; color: var(--color-pink); flex-shrink: 0; }
.kbnl__field-icon svg { width: 20px; height: 20px; }
.kbnl__input { flex: 1; min-width: 0; height: 100%; border: none; outline: none; background: none; font-family: var(--font-body); font-size: 1rem; color: var(--color-ink); }
.kbnl__input::placeholder { color: var(--color-muted); }
.kbnl__btn { flex-shrink: 0; display: inline-flex; align-items: center; gap: 9px; padding: 0 30px; height: 56px; border: none; border-radius: var(--radius-pill); background: var(--color-pink); color: #fff; font-family: var(--font-heading); font-size: 1.05rem; cursor: pointer; box-shadow: 0 10px 24px rgba(212,83,126,.28); transition: background 160ms, transform 160ms; }
.kbnl__btn:hover { background: #c13c6a; transform: translateY(-2px); }
.kbnl__btn-arrow { display: inline-flex; }
.kbnl__btn-arrow svg { width: 18px; height: 18px; }
.kbnl__success { display: inline-flex; align-items: center; gap: 9px; font-family: var(--font-body); font-weight: 700; color: var(--color-green); margin: 0; }
.kbnl__success-icon { display: inline-flex; color: var(--color-pink); }
.kbnl__success-icon svg { width: 18px; height: 18px; fill: currentColor; stroke: currentColor; }
.kbnl__error { font-family: var(--font-body); font-size: .88rem; color: #c0392b; margin: 8px 0 0; }
.kbnl__note { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: .85rem; font-weight: 600; color: var(--color-body); margin: 14px 0 0; }
.kbnl__note-icon { display: inline-flex; color: var(--color-green); }
.kbnl__note-icon svg { width: 18px; height: 18px; }

/* Voordelen */
.kbnl__benefits { grid-area: benefits; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.kbnl-benefit { --c: var(--color-green); --c-soft: #eef7e8; display: flex; align-items: center; gap: 11px; background: rgba(255,255,255,.7); border-radius: 16px; padding: 13px 14px; }
.kbnl-benefit--green  { --c: var(--color-green);  --c-soft: #e3f1d9; }
.kbnl-benefit--pink   { --c: var(--color-pink);   --c-soft: #fdeaf2; }
.kbnl-benefit--orange { --c: var(--color-orange); --c-soft: #fdeedd; }
.kbnl-benefit--yellow { --c: #d99100;             --c-soft: #fbf0d0; }
.kbnl-benefit__icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%; background: var(--c-soft); color: var(--c); }
.kbnl-benefit__icon svg { width: 20px; height: 20px; }
.kbnl-benefit__body { display: flex; flex-direction: column; min-width: 0; line-height: 1.2; }
.kbnl-benefit__title { font-family: var(--font-heading); font-size: .92rem; color: var(--color-ink); }
.kbnl-benefit__text { font-family: var(--font-body); font-size: .78rem; color: var(--color-muted); margin-top: 1px; }

.kbnl__sr { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }

/* Tablet */
@media (max-width: 1100px) and (min-width: 860px) {
  .kbnl__benefits { grid-template-columns: 1fr 1fr; }
  .kbnl__signup-title { font-size: 1.3rem; }
}

/* Mobiel: foto → voordelen → aanmeld → trust */
@media (max-width: 859px) {
  .kbnl__head { margin-bottom: 26px; }
  .kbnl__card { grid-template-columns: 1fr; grid-template-areas: "media" "benefits" "signup"; gap: 18px; padding: 16px; }
  .kbnl__media { min-height: 0; aspect-ratio: 16 / 12; }
  .kbnl__img--ph { min-height: 0; height: 100%; }
  .kbnl__signup { background: rgba(255,255,255,.6); border-radius: 20px; padding: 20px; }
  .kbnl__signup-title { font-size: 1.3rem; }
  .kbnl__row { flex-direction: column; max-width: none; }
  .kbnl__field, .kbnl__btn { width: 100%; }
  .kbnl__btn { justify-content: center; }
  .kbnl__note { margin-top: 12px; }
  .kbnl__benefits { grid-template-columns: 1fr 1fr; gap: 10px; }
  .kbnl-benefit { background: rgba(255,255,255,.78); align-items: flex-start; }
  .kbnl-benefit__title { font-size: .9rem; }
  .kbnl__deco--paw { display: none; }
}

@media (max-width: 479px) {
  .kbnl__benefits { grid-template-columns: 1fr; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Nieuwsbrief",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Tekst" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sluit je aan bij de Kwispelclub" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Mis nooit meer een verrassing" },
    { "type": "textarea", "id": "intro", "label": "Subtekst", "default": "Wees als eerste op de hoogte van onze Special Editions, exclusieve acties, handige hondentips en leuke verrassingen." },
    { "type": "header", "content": "Aanmeldblok" },
    { "type": "image_picker", "id": "image", "label": "Afbeelding (hond + box)" },
    { "type": "text", "id": "signup_title", "label": "Titel", "default": "Word lid van de Kwispelclub!" },
    { "type": "textarea", "id": "signup_text", "label": "Tekst", "default": "Meld je aan voor onze nieuwsbrief en ontvang pootje-voor updates, tips en exclusieve voordelen." },
    { "type": "text", "id": "placeholder", "label": "Veld-placeholder", "default": "Jouw e-mailadres" },
    { "type": "text", "id": "button_label", "label": "Knoptekst", "default": "Aanmelden" },
    { "type": "text", "id": "note", "label": "Notitie onder knop", "default": "Geen spam, alleen leuke updates." },
    { "type": "textarea", "id": "success_text", "label": "Bedank-tekst", "default": "Hoera! Je staat op de lijst. Houd je inbox in de gaten voor leuke verrassingen." },
    { "type": "header", "content": "Decoratie" },
    { "type": "checkbox", "id": "show_decorations", "label": "Decoratieve merkaccenten tonen", "default": true }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Voordeel",
      "limit": 4,
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "sparkles",
          "options": [
            { "value": "sparkles", "label": "Sparkles" },
            { "value": "bulb", "label": "Lampje" },
            { "value": "tag", "label": "Label" },
            { "value": "shield", "label": "Schild" },
            { "value": "news", "label": "Nieuws" },
            { "value": "cake", "label": "Taart" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "heart", "label": "Hart" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Kleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "Special Editions" },
        { "type": "text", "id": "text", "label": "Tekst", "default": "Als eerste weten" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nieuwsbrief",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "sparkles", "color": "green", "title": "Special Editions", "text": "Als eerste weten" } },
        { "type": "benefit", "settings": { "icon": "bulb", "color": "pink", "title": "Kwispeltips", "text": "Handig & inspirerend" } },
        { "type": "benefit", "settings": { "icon": "tag", "color": "orange", "title": "Exclusieve acties", "text": "Alleen voor leden" } },
        { "type": "benefit", "settings": { "icon": "shield", "color": "green", "title": "Geen spam,", "text": "alleen leuks" } }
      ]
    }
  ]
}
{% endschema %}
