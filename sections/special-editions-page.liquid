{%- comment -%}
  sections/special-editions-page.liquid — KB-v4 Special Editions overzicht.
  Hero + groepen (group-blokken) + edition-kaarten (edition-blokken) + CTA.
  Namespace `sep` om class-botsingen te voorkomen.
{%- endcomment -%}

<div class="sep full-width">
  <div class="sep__inner">

    <header class="sep__head">
      {%- if section.settings.eyebrow != blank -%}<span class="sep__eyebrow"><span aria-hidden="true">{%- render 'kb-icon', icon: 'sparkles' -%}</span>{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.title != blank -%}<h1 class="sep__title">{{ section.settings.title }}</h1>{%- endif -%}
      {%- if section.settings.intro != blank -%}<p class="sep__intro">{{ section.settings.intro }}</p>{%- endif -%}
    </header>

    <div class="sep__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'group' -%}
          <h2 class="sep__group" {{ block.shopify_attributes }}>{{ block.settings.heading }}</h2>
        {%- else -%}
          {%- assign accent = block.settings.accent | default: 'pink' -%}
          {%- if block.settings.coming_soon -%}
            <article class="sep-card sep-card--{{ accent }} is-soon" {{ block.shopify_attributes }}>
          {%- else -%}
            <a href="{{ block.settings.button_url | default: '#' }}" class="sep-card sep-card--{{ accent }}" {{ block.shopify_attributes }}>
          {%- endif -%}
            <div class="sep-card__media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 640 }}" srcset="{{ block.settings.image | image_url: width: 420 }} 420w, {{ block.settings.image | image_url: width: 640 }} 640w" sizes="(max-width: 749px) 46vw, 300px" alt="{{ block.settings.title | escape }}" width="320" height="320" loading="lazy">
              {%- else -%}
                <span class="sep-card__ph" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon | default: 'gift' -%}</span>
              {%- endif -%}
              {%- if block.settings.badge != blank -%}<span class="sep-card__badge">{{ block.settings.badge }}</span>{%- endif -%}
              {%- if block.settings.coming_soon -%}<span class="sep-card__soon">Binnenkort</span>{%- endif -%}
            </div>
            <div class="sep-card__body">
              <h3 class="sep-card__title">{{ block.settings.title }}</h3>
              {%- if block.settings.tagline != blank -%}<p class="sep-card__tagline">{{ block.settings.tagline }}</p>{%- endif -%}
              {%- unless block.settings.coming_soon -%}<span class="sep-card__link">{{ block.settings.button_label | default: 'Bekijk box' }}<span aria-hidden="true" class="sep-card__arrow">→</span></span>{%- endunless -%}
            </div>
          {%- if block.settings.coming_soon -%}</article>{%- else -%}</a>{%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="sep__cta">
        {%- if section.settings.cta_title != blank -%}<h2 class="sep__cta-title">{{ section.settings.cta_title }}</h2>{%- endif -%}
        {%- if section.settings.cta_text != blank -%}<p class="sep__cta-text">{{ section.settings.cta_text }}</p>{%- endif -%}
        <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="sep__cta-btn">{{ section.settings.cta_label }}<span aria-hidden="true">→</span></a>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.sep { background: transparent; padding: var(--section-pad) 0; }
.sep__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }
.sep__head { text-align: center; max-width: 720px; margin: 0 auto 44px; }
.sep__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--color-orange); margin-bottom: 12px; }
.sep__eyebrow span { display: inline-flex; }
.sep__eyebrow svg { width: 16px; height: 16px; }
.sep__title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.04; color: var(--color-ink); margin: 0 0 12px; }
.sep__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 0 auto; max-width: 56ch; }

.sep__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
.sep__group { grid-column: 1 / -1; font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-ink); margin: 22px 0 2px; display: flex; align-items: center; gap: 12px; }
.sep__group::after { content: ""; flex: 1; height: 2px; border-radius: 2px; background: repeating-linear-gradient(to right, var(--color-line) 0 8px, transparent 8px 16px); }

.sep-card { display: flex; flex-direction: column; background: #fff; border: 1.5px solid var(--color-line); border-radius: 22px; overflow: hidden; text-decoration: none; box-shadow: 0 8px 22px rgba(61, 34, 9, .05); transition: transform 200ms, box-shadow 200ms, border-color 200ms; }
a.sep-card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(61, 34, 9, .12); border-color: color-mix(in srgb, var(--sac) 50%, var(--color-line)); }
.sep-card--pink { --sac: var(--color-pink); }
.sep-card--green { --sac: var(--color-green); }
.sep-card--orange { --sac: var(--color-orange); }
.sep-card--yellow { --sac: #d99100; }
.sep-card--purple { --sac: #8b5fd1; }
.sep-card__media { position: relative; aspect-ratio: 4/3; background: color-mix(in srgb, var(--sac) 12%, #fff); display: flex; align-items: center; justify-content: center; overflow: hidden; }
.sep-card__media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 400ms; }
a.sep-card:hover .sep-card__media img { transform: scale(1.05); }
.sep-card__ph { display: flex; color: var(--sac); }
.sep-card__ph svg { width: 54px; height: 54px; }
.sep-card__badge { position: absolute; top: 12px; left: 12px; font-family: var(--font-body); font-size: .68rem; font-weight: 800; text-transform: uppercase; letter-spacing: .03em; color: #fff; background: var(--sac); padding: 4px 11px; border-radius: var(--radius-pill); box-shadow: 0 4px 12px rgba(61, 34, 9, .18); }
.sep-card__soon { position: absolute; top: 12px; right: 12px; font-family: var(--font-body); font-size: .66rem; font-weight: 800; text-transform: uppercase; color: var(--color-muted); background: rgba(255, 255, 255, .92); padding: 4px 10px; border-radius: var(--radius-pill); }
.sep-card.is-soon { opacity: .72; }
.sep-card__body { padding: 16px 18px 18px; display: flex; flex-direction: column; gap: 5px; flex: 1; }
.sep-card__title { font-family: var(--font-heading); font-size: 1.2rem; color: var(--color-ink); line-height: 1.1; margin: 0; }
.sep-card__tagline { font-family: var(--font-body); font-size: .85rem; color: var(--color-body); line-height: 1.45; margin: 0; flex: 1; }
.sep-card__link { display: inline-flex; align-items: center; gap: 7px; margin-top: 6px; font-family: var(--font-heading); font-size: .92rem; color: var(--sac); }
.sep-card__arrow { transition: transform 160ms; }
a.sep-card:hover .sep-card__arrow { transform: translateX(4px); }

.sep__cta { text-align: center; margin-top: 44px; padding: 42px 26px; background: #fff0e4; border-radius: 28px; }
.sep__cta-title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.1; color: var(--color-ink); margin: 0 0 10px; }
.sep__cta-text { font-family: var(--font-body); font-size: var(--fs-lead); color: var(--color-body); margin: 0 auto 22px; max-width: 48ch; }
.sep__cta-btn { display: inline-flex; align-items: center; gap: 10px; padding: 16px 30px; background: var(--color-orange); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.15rem; text-decoration: none; transition: filter 160ms, transform 160ms; }
.sep__cta-btn:hover { filter: brightness(.95); transform: translateY(-2px); }

@media (min-width: 700px) { .sep__grid { grid-template-columns: repeat(3, 1fr); gap: 22px; } }
@media (min-width: 1040px) { .sep__grid { grid-template-columns: repeat(4, 1fr); } }
{% endstylesheet %}

{% schema %}
{
  "name": "Special Editions",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Voor elk bijzonder moment" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Er is altijd een reden om te kwispelen" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Van verjaardagen tot de feestdagen — onze Special Editions maken elk moment net even specialer voor jouw hond." },
    { "type": "header", "content": "Oproep onderaan" },
    { "type": "text", "id": "cta_title", "label": "CTA titel", "default": "Niet kunnen kiezen?" },
    { "type": "text", "id": "cta_text", "label": "CTA tekst", "default": "Bekijk onze vaste Kwispelboxen — elke maand een nieuwe verrassing." },
    { "type": "text", "id": "cta_label", "label": "Knoptekst", "default": "Bekijk alle boxen" },
    { "type": "url", "id": "cta_url", "label": "Knop link" }
  ],
  "blocks": [
    { "type": "group", "name": "Groep-kop", "settings": [ { "type": "text", "id": "heading", "label": "Kop", "default": "Populaire momenten" } ] },
    {
      "type": "edition",
      "name": "Edition-kaart",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Afbeelding" },
        {
          "type": "select", "id": "icon", "label": "Icoon (zonder afbeelding)", "default": "gift",
          "options": [
            { "value": "gift", "label": "Cadeau" }, { "value": "cake", "label": "Taart" }, { "value": "tree", "label": "Kerstboom" },
            { "value": "heart", "label": "Hart" }, { "value": "pumpkin", "label": "Pompoen" }, { "value": "sun", "label": "Zon" },
            { "value": "paw", "label": "Poot" }, { "value": "star", "label": "Ster" }, { "value": "bone", "label": "Bot" }
          ]
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "Verjaardagsbox" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "Maak de hondenverjaardag onvergetelijk." },
        { "type": "text", "id": "badge", "label": "Badge (optioneel)" },
        { "type": "checkbox", "id": "coming_soon", "label": "Binnenkort (niet klikbaar)", "default": false },
        {
          "type": "select", "id": "accent", "label": "Kleur", "default": "pink",
          "options": [
            { "value": "pink", "label": "Roze" }, { "value": "green", "label": "Groen" }, { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }, { "value": "purple", "label": "Paars" }
          ]
        },
        { "type": "text", "id": "button_label", "label": "Linktekst", "default": "Bekijk box" },
        { "type": "url", "id": "button_url", "label": "Link naar box" }
      ]
    }
  ],
  "presets": [ { "name": "Special Editions overzicht" } ]
}
{% endschema %}
