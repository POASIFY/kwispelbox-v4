{%- comment -%}
  sections/reviews-page.liquid — KB-v4 dedicated reviews page.
  Samenvatting (score + sterrenverdeling) + masonry-grid reviewkaarten + CTA.
  Eigen namespace `rvp` om class-botsingen met andere secties te voorkomen.
{%- endcomment -%}

{%- assign review_blocks = section.blocks | where: 'type', 'review' -%}

<div class="rvp full-width">
  <div class="rvp__inner">

    <header class="rvp__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="rvp__eyebrow"><span aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}<h1 class="rvp__title">{{ section.settings.title }}</h1>{%- endif -%}
      {%- if section.settings.intro != blank -%}<p class="rvp__intro">{{ section.settings.intro }}</p>{%- endif -%}

      <div class="rvp__summary">
        <div class="rvp__score">
          <span class="rvp__score-num">{{ section.settings.rating_score | default: '4,9' }}</span>
          <span class="rvp__score-meta">
            <span class="rvp__score-stars" aria-hidden="true">
              {%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>{%- endfor -%}
            </span>
            <span class="rvp__score-count">{{ section.settings.review_count | default: '1.200+ reviews' }}</span>
          </span>
        </div>
        <div class="rvp__bars">
          {%- assign pcts = section.settings.bar_5 | append: ',' | append: section.settings.bar_4 | append: ',' | append: section.settings.bar_3 | append: ',' | append: section.settings.bar_2 | append: ',' | append: section.settings.bar_1 | split: ',' -%}
          {%- for n in (5..1) reversed -%}
            {%- assign idx = 5 | minus: n -%}
            {%- assign pct = pcts[idx] | default: 0 -%}
            <div class="rvp__bar-row">
              <span class="rvp__bar-label">{{ n }}<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg></span>
              <span class="rvp__bar-track"><span class="rvp__bar-fill" style="width: {{ pct }}%"></span></span>
              <span class="rvp__bar-pct">{{ pct }}%</span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </header>

    {%- if review_blocks.size > 0 -%}
      <div class="rvp__grid">
        {%- for block in review_blocks -%}
          {%- assign rating = block.settings.rating | default: 5 -%}
          <article class="rvp-card rvp-card--{{ block.settings.accent | default: 'pink' }}" {{ block.shopify_attributes }}>
            <div class="rvp-card__top">
              <div class="rvp-card__avatar">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 180 }}" alt="{{ block.settings.dog_name | escape }}" width="90" height="90" loading="lazy">
                {%- else -%}
                  <div class="rvp-card__avatar-ph" aria-hidden="true">{%- render 'kb-icon', icon: 'dog' -%}</div>
                {%- endif -%}
              </div>
              <div class="rvp-card__id">
                <span class="rvp-card__name">{{ block.settings.dog_name }}<span class="rvp-card__heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span></span>
                {%- if block.settings.breed != blank -%}<span class="rvp-card__breed">{{ block.settings.breed }}</span>{%- endif -%}
              </div>
              {%- if block.settings.badge != blank -%}<span class="rvp-card__badge rvp-card__badge--{{ block.settings.badge_color }}">{{ block.settings.badge }}</span>{%- endif -%}
            </div>

            <div class="rvp-card__stars" aria-label="{{ rating }} van 5 sterren">
              {%- for i in (1..5) -%}
                <svg viewBox="0 0 24 24" fill="currentColor" class="rvp-card__star{% if i > rating %} is-empty{% endif %}" aria-hidden="true"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>
              {%- endfor -%}
            </div>

            {%- if block.settings.review_title != blank -%}<h2 class="rvp-card__title">{{ block.settings.review_title }}</h2>{%- endif -%}
            {%- if block.settings.review_text != blank -%}<p class="rvp-card__text">{{ block.settings.review_text }}</p>{%- endif -%}

            <div class="rvp-card__foot">
              {%- if block.settings.verified_text != blank -%}
                <span class="rvp-card__verified"><span class="rvp-card__verified-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'check' -%}</span>{{ block.settings.verified_text }}</span>
              {%- endif -%}
              {%- if block.settings.date != blank -%}<span class="rvp-card__date">{{ block.settings.date }}</span>{%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="rvp__cta">
        {%- if section.settings.cta_title != blank -%}<h2 class="rvp__cta-title">{{ section.settings.cta_title }}</h2>{%- endif -%}
        {%- if section.settings.cta_text != blank -%}<p class="rvp__cta-text">{{ section.settings.cta_text }}</p>{%- endif -%}
        <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="rvp__cta-btn">{{ section.settings.cta_label }}<span class="rvp__cta-paw" aria-hidden="true">{%- render 'kb-icon', icon: 'paw' -%}</span></a>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.rvp { background: transparent; padding: var(--section-pad) 0; }
.rvp__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* Kop + samenvatting */
.rvp__head { text-align: center; max-width: 760px; margin: 0 auto 44px; }
.rvp__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--color-pink); margin-bottom: 12px; }
.rvp__eyebrow span { display: inline-flex; }
.rvp__eyebrow svg { width: 16px; height: 16px; }
.rvp__title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.04; color: var(--color-ink); margin: 0 0 12px; }
.rvp__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 0 auto; max-width: 56ch; }

.rvp__summary { display: grid; grid-template-columns: 1fr; gap: 24px; align-items: center; margin-top: 32px; background: #fff; border: 1.5px solid var(--color-line); border-radius: 24px; padding: 26px; box-shadow: 0 12px 30px rgba(61, 34, 9, .06); text-align: left; }
.rvp__score { display: flex; align-items: center; gap: 16px; justify-content: center; }
.rvp__score-num { font-family: var(--font-heading); font-size: 3.4rem; line-height: 1; color: var(--color-green); }
.rvp__score-meta { display: flex; flex-direction: column; gap: 5px; }
.rvp__score-stars { display: inline-flex; gap: 3px; color: var(--color-yellow); }
.rvp__score-stars svg { width: 20px; height: 20px; }
.rvp__score-count { font-family: var(--font-body); font-size: .9rem; font-weight: 700; color: var(--color-muted); }
.rvp__bars { display: flex; flex-direction: column; gap: 7px; }
.rvp__bar-row { display: grid; grid-template-columns: 34px 1fr 38px; align-items: center; gap: 10px; }
.rvp__bar-label { display: inline-flex; align-items: center; gap: 3px; font-family: var(--font-body); font-size: .82rem; font-weight: 700; color: var(--color-ink); }
.rvp__bar-label svg { width: 12px; height: 12px; color: var(--color-yellow); }
.rvp__bar-track { height: 9px; border-radius: 9px; background: var(--color-line); overflow: hidden; }
.rvp__bar-fill { display: block; height: 100%; border-radius: 9px; background: var(--color-green); }
.rvp__bar-pct { font-family: var(--font-body); font-size: .78rem; font-weight: 700; color: var(--color-muted); text-align: right; }

/* Masonry-grid */
.rvp__grid { columns: 1; column-gap: 22px; }
.rvp-card { --ac: var(--color-pink); break-inside: avoid; margin-bottom: 22px; background: #fff; border: 1.5px solid var(--color-line); border-radius: 22px; padding: 22px; box-shadow: 0 10px 26px rgba(61, 34, 9, .05); }
.rvp-card--pink { --ac: var(--color-pink); }
.rvp-card--orange { --ac: var(--color-orange); }
.rvp-card--green { --ac: var(--color-green); }
.rvp-card--yellow { --ac: #d99100; }
.rvp-card__top { display: flex; align-items: center; gap: 13px; }
.rvp-card__avatar { flex-shrink: 0; width: 60px; height: 60px; border-radius: 50%; overflow: hidden; background: color-mix(in srgb, var(--ac) 16%, #fff); box-shadow: 0 5px 13px rgba(61, 34, 9, .12); }
.rvp-card__avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rvp-card__avatar-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--ac); }
.rvp-card__avatar-ph svg { width: 30px; height: 30px; }
.rvp-card__id { display: flex; flex-direction: column; gap: 2px; min-width: 0; flex: 1; }
.rvp-card__name { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-heading); font-size: 1.15rem; color: var(--color-ink); line-height: 1.1; }
.rvp-card__heart { display: inline-flex; width: 13px; height: 13px; color: var(--color-pink); flex-shrink: 0; }
.rvp-card__heart svg { width: 100%; height: 100%; }
.rvp-card__breed { font-family: var(--font-body); font-size: .8rem; color: var(--color-muted); }
.rvp-card__badge { flex-shrink: 0; align-self: flex-start; font-family: var(--font-body); font-size: .68rem; font-weight: 800; padding: 4px 10px; border-radius: var(--radius-pill); }
.rvp-card__badge--pink { background: #ffe0ee; color: #c4396a; }
.rvp-card__badge--orange { background: #fff0e4; color: #c8721f; }
.rvp-card__badge--green { background: #e8f5e2; color: #4e8230; }
.rvp-card__badge--yellow { background: #fffae0; color: #9a7400; }
.rvp-card__stars { display: flex; gap: 3px; margin: 16px 0 10px; }
.rvp-card__star { width: 17px; height: 17px; color: var(--color-yellow); }
.rvp-card__star.is-empty { color: var(--color-line); }
.rvp-card__title { font-family: var(--font-heading); font-size: 1.15rem; line-height: 1.2; color: var(--color-ink); margin: 0 0 7px; }
.rvp-card__text { font-family: var(--font-body); font-size: .92rem; line-height: 1.6; color: var(--color-body); margin: 0; }
.rvp-card__foot { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--color-line); }
.rvp-card__verified { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-body); font-size: .76rem; font-weight: 700; color: var(--color-green); }
.rvp-card__verified-icon { display: inline-flex; align-items: center; justify-content: center; width: 19px; height: 19px; border-radius: 50%; background: #e8f5e2; }
.rvp-card__verified-icon svg { width: 12px; height: 12px; }
.rvp-card__date { font-family: var(--font-body); font-size: .76rem; color: var(--color-muted); }

/* CTA */
.rvp__cta { text-align: center; margin-top: 8px; padding: 40px 26px; background: #e8f5e2; border-radius: 28px; }
.rvp__cta-title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.1; color: var(--color-ink); margin: 0 0 10px; }
.rvp__cta-text { font-family: var(--font-body); font-size: var(--fs-lead); color: var(--color-body); margin: 0 auto 22px; max-width: 48ch; }
.rvp__cta-btn { display: inline-flex; align-items: center; gap: 11px; padding: 16px 30px; background: var(--color-green); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.15rem; text-decoration: none; transition: filter 160ms, transform 160ms, box-shadow 160ms; }
.rvp__cta-btn:hover { filter: brightness(.94); transform: translateY(-2px); box-shadow: 0 12px 28px rgba(61, 34, 9, .2); }
.rvp__cta-paw { display: inline-flex; }
.rvp__cta-paw svg { width: 20px; height: 20px; }

@media (min-width: 700px) {
  .rvp__summary { grid-template-columns: auto 1fr; gap: 40px; padding: 30px 38px; }
  .rvp__grid { columns: 2; }
}
@media (min-width: 1040px) {
  .rvp__grid { columns: 3; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Reviews pagina",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Kop" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Geliefd door honden én hun baasjes" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Wat baasjes over Kwispelbox zeggen" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Duizenden honden krijgen elke maand een verrassingsbox. Dit is wat hun baasjes ervan vinden." },
    { "type": "header", "content": "Samenvatting" },
    { "type": "text", "id": "rating_score", "label": "Gemiddelde score", "default": "4,9" },
    { "type": "text", "id": "review_count", "label": "Aantal reviews", "default": "1.200+ reviews" },
    { "type": "range", "id": "bar_5", "label": "% 5 sterren", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 92 },
    { "type": "range", "id": "bar_4", "label": "% 4 sterren", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 6 },
    { "type": "range", "id": "bar_3", "label": "% 3 sterren", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 1 },
    { "type": "range", "id": "bar_2", "label": "% 2 sterren", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 1 },
    { "type": "range", "id": "bar_1", "label": "% 1 ster", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 0 },
    { "type": "header", "content": "Oproep onderaan" },
    { "type": "text", "id": "cta_title", "label": "CTA titel", "default": "Ook jouw hond verdient een feestje" },
    { "type": "text", "id": "cta_text", "label": "CTA tekst", "default": "Geef je beste vriend elke maand het moment waar hij niet meer op kan wachten." },
    { "type": "text", "id": "cta_label", "label": "Knoptekst", "default": "Verras je hond" },
    { "type": "url", "id": "cta_url", "label": "Knop link" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Reviewkaart",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Foto hond" },
        { "type": "text", "id": "dog_name", "label": "Naam hond", "default": "Luna" },
        { "type": "text", "id": "breed", "label": "Ras", "default": "Golden Retriever" },
        { "type": "text", "id": "badge", "label": "Box badge", "default": "Happy Box" },
        {
          "type": "select", "id": "badge_color", "label": "Badge kleur", "default": "pink",
          "options": [
            { "value": "pink", "label": "Roze (Happy)" },
            { "value": "orange", "label": "Oranje (Mega)" },
            { "value": "green", "label": "Groen (Mini)" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "range", "id": "rating", "label": "Sterren", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "review_title", "label": "Reviewtitel", "default": "Elke maand weer een feestje!" },
        { "type": "textarea", "id": "review_text", "label": "Reviewtekst", "default": "Luna wordt altijd zó enthousiast als de Kwispelbox binnenkomt. De speeltjes zijn stevig en superleuk. Echt een aanrader!" },
        { "type": "text", "id": "verified_text", "label": "Verificatietekst", "default": "Geverifieerde aankoop" },
        { "type": "text", "id": "date", "label": "Datum", "default": "maart 2026" },
        {
          "type": "select", "id": "accent", "label": "Accentkleur", "default": "pink",
          "options": [
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "green", "label": "Groen" },
            { "value": "yellow", "label": "Geel" }
          ]
        }
      ]
    }
  ],
  "presets": [
    { "name": "Reviews pagina" }
  ]
}
{% endschema %}
