{%- comment -%}
  sections/judgeme-product-reviews.liquid — KB-v4
  Judge.me product-review-widget (de echte reviewlijst + schrijfformulier) op de PDP,
  met een merk-kop eromheen. De Judge.me-code zelf is exact overgenomen uit de app.
  Vereist: Judge.me app-embed AAN in Thema → App-insluitingen.
{%- endcomment -%}

<div class="jme full-width">
  <div class="jme__inner">
    {%- if section.settings.heading != blank -%}
      <header class="jme__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="jme__eyebrow"><span aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="jme__title">{{ section.settings.heading }}</h2>
      </header>
    {%- endif -%}

    {%- comment -%} theme-check-disable ParserBlockingJavaScript,RemoteAsset {%- endcomment -%}
    <!-- Start of Judge.me code -->{% assign has_legacy = false %}{% if product.metafields.judgeme.widget.size > 20 %}{% assign has_legacy = true %}{% endif %}<div style='clear:both'></div><div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-product-id='{{ product.id }}' data-widget='review' data-auto-install='false' data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' data-entry-point='review_widget.js' data-entry-key='review-widget/main.js'>{% if has_legacy %}<div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>{% endif %}</div>{% if product.metafields.judgeme.review_widget_data %}<script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>{% endif %}<!-- End of Judge.me code -->
    {%- comment -%} theme-check-enable ParserBlockingJavaScript,RemoteAsset {%- endcomment -%}
  </div>
</div>

{% stylesheet %}
.jme { background: transparent; padding: var(--section-pad) 0; }
.jme__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }
.jme__head { text-align: center; max-width: 640px; margin: 0 auto 34px; }
.jme__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--color-pink); margin-bottom: 12px; }
.jme__eyebrow span { display: inline-flex; }
.jme__eyebrow svg { width: 16px; height: 16px; }
.jme__title { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.04; color: var(--color-ink); margin: 0; }
/* Judge.me-accent op het merk afstemmen */
.jme .jdgm-star { color: var(--color-yellow) !important; }
.jme .jdgm-rev-widg__summary { font-family: var(--font-body); }
{% endstylesheet %}

{% schema %}
{
  "name": "Judge.me reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Geliefd door honden én hun baasjes" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Wat onze klanten zeggen" }
  ],
  "presets": [ { "name": "Judge.me reviews" } ]
}
{% endschema %}
