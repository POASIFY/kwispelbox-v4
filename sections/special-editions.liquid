{%- comment -%}
  sections/special-editions.liquid — Kwispelbox KB-v4
  "Er is altijd een reden om te kwispelen" — 1 featured editie + 4 thema-kaarten
  + groene CTA-balk. Blokken: special (featured of thema).
{%- endcomment -%}

{%- assign special_blocks = section.blocks | where: 'type', 'special' -%}

<div class="kbse full-width">

  {%- if section.settings.show_decorations -%}
    <div class="kbse__deco" aria-hidden="true">
      <span class="kbse__deco kbse__deco--lines"><svg viewBox="0 0 48 26" fill="none" stroke-width="2.6" stroke-linecap="round"><path d="M5 17C10 7 14 20 19 12" stroke="var(--color-green)"/><path d="M3 9c2-3 5-4 8-3" stroke="var(--color-pink)"/><path d="M9 22c1-3 3-5 6-5" stroke="var(--color-yellow)"/></svg></span>
      <span class="kbse__deco kbse__deco--heart"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-pink)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
      <span class="kbse__deco kbse__deco--paw1"><svg viewBox="0 0 24 24" fill="var(--color-orange)"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
      <span class="kbse__deco kbse__deco--paw2"><svg viewBox="0 0 24 24" fill="var(--color-green)"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
    </div>
  {%- endif -%}

  <div class="kbse__inner">

    <div class="kbse__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="kbse__eyebrow"><span class="kbse__eyebrow-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="kbse__heading">{{ section.settings.heading }}{%- if section.settings.heading_highlight != blank %} <span class="kbse__heading-em">{{ section.settings.heading_highlight }}</span>{%- endif -%}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="kbse__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="kbse__grid">
      {%- for block in special_blocks -%}
        {%- assign accent = block.settings.color | default: 'pink' -%}
        {%- if block.settings.featured -%}
          <article class="kbse-feat kbse--{{ accent }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1000 }}" srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 1000 }} 1000w" sizes="(max-width:859px) 92vw, 42vw" alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" width="700" height="800" loading="lazy" class="kbse-feat__img">
            {%- else -%}
              <span class="kbse-feat__img kbse-feat__img--ph" aria-hidden="true">{%- render 'kb-icon', icon: 'cake' -%}</span>
            {%- endif -%}
            <span class="kbse-feat__tint" aria-hidden="true"></span>
            {%- if block.settings.badge != blank -%}
              <span class="kbse-feat__label">{{ block.settings.badge }}</span>
            {%- endif -%}
            <h3 class="kbse-feat__title">{{ block.settings.title }}</h3>
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_url | default: '#' }}" class="kbse-feat__btn">{{ block.settings.button_label }}<span class="kbse-feat__btn-arrow" aria-hidden="true">→</span></a>
            {%- endif -%}
          </article>
        {%- else -%}
          <article class="kbse-card kbse--{{ accent }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 700 }}" srcset="{{ block.settings.image | image_url: width: 460 }} 460w, {{ block.settings.image | image_url: width: 700 }} 700w" sizes="(max-width:859px) 46vw, 24vw" alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" width="460" height="345" loading="lazy" class="kbse-card__img">
            {%- else -%}
              <span class="kbse-card__img kbse-card__img--ph" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
            {%- endif -%}
            <span class="kbse-card__tint" aria-hidden="true"></span>
            <span class="kbse-card__icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
            <h3 class="kbse-card__title">{{ block.settings.title }}</h3>
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_url | default: '#' }}" class="kbse-card__btn">{{ block.settings.button_label }}<span aria-hidden="true">→</span></a>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_title != blank -%}
      <div class="kbse__cta">
        <span class="kbse__cta-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'gift' -%}</span>
        <div class="kbse__cta-body">
          <strong class="kbse__cta-title">{{ section.settings.cta_title }}</strong>
          {%- if section.settings.cta_text != blank -%}<span class="kbse__cta-text">{{ section.settings.cta_text }}</span>{%- endif -%}
        </div>
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="kbse__cta-btn">{{ section.settings.cta_label }}<span aria-hidden="true">→</span></a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.kbse { position: relative; background: transparent; padding: var(--section-pad) 0; overflow: hidden; }
.kbse__inner { position: relative; z-index: 1; max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* Accent-paletten */
.kbse--pink   { --c: var(--color-pink);   --c-dark: #c13c6a; --tint: #fde3ee; }
.kbse--green  { --c: var(--color-green);  --c-dark: #4f8a32; --tint: #e3f2da; }
.kbse--orange { --c: var(--color-orange); --c-dark: #d9760f; --tint: #fde6d3; }
.kbse--yellow { --c: #e0a500;             --c-dark: #c08d00; --tint: #fcefc4; }
.kbse--purple { --c: #9579cc;             --c-dark: #7a5fb0; --tint: #ece4f7; }

/* Decoratie */
.kbse__deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.kbse__deco span { position: absolute; display: block; }
.kbse__deco span svg { display: block; width: 100%; height: 100%; }
.kbse__deco--lines { top: 64px; left: 5%; width: 52px; height: 28px; }
.kbse__deco--heart { top: 72px; right: 6%; width: 36px; height: 36px; }
.kbse__deco--paw1 { top: 14%; left: 3%; width: 26px; height: 26px; opacity: .14; transform: rotate(-12deg); }
.kbse__deco--paw2 { top: 15%; right: 4%; width: 28px; height: 28px; opacity: .12; transform: rotate(14deg); }

/* Kop */
.kbse__head { text-align: center; margin: 0 auto 40px; }
.kbse__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--color-pink); margin-bottom: 12px; }
.kbse__eyebrow-icon { display: inline-flex; }
.kbse__eyebrow-icon svg { width: 16px; height: 16px; }
.kbse__heading { font-family: var(--font-heading); font-size: clamp(2rem, 4.8vw, 3.2rem); line-height: 1.05; color: var(--color-ink); margin: 0; }
.kbse__heading-em { color: var(--color-green); }
.kbse__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 14px auto 0; max-width: 600px; }

/* Grid: featured links + 2x2 thema rechts */
.kbse__grid { display: grid; grid-template-columns: 1.12fr 1fr 1fr; gap: 20px; }
.kbse-feat { grid-column: 1; grid-row: 1 / span 2; }

/* Featured — zelfde stijl als de thema-kaarten, alleen groter */
.kbse-feat { position: relative; border-radius: 24px; overflow: hidden; min-height: 460px; box-shadow: 0 18px 44px rgba(61,34,9,.10); }
.kbse-feat__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
.kbse-feat__img--ph { display: flex; align-items: center; justify-content: center; background: linear-gradient(140deg, #fff, var(--tint)); color: var(--c); }
.kbse-feat__img--ph svg { width: 88px; height: 88px; }
.kbse-feat__tint { position: absolute; inset: 0; background: linear-gradient(180deg, var(--tint) 0%, rgba(255,255,255,0) 34%); }
.kbse-feat__label { position: absolute; top: 16px; right: 16px; z-index: 2; display: inline-flex; align-items: center; background: var(--c); color: #fff; font-family: var(--font-heading); font-size: .82rem; padding: 7px 16px; border-radius: var(--radius-pill); box-shadow: 0 6px 16px rgba(61,34,9,.18); }
.kbse-feat__title { position: absolute; top: 15px; left: 20px; right: 150px; z-index: 2; font-family: var(--font-heading); font-size: 1.9rem; color: var(--color-ink); line-height: 1.1; margin: 0; }
.kbse-feat__btn { position: absolute; left: 20px; bottom: 20px; z-index: 2; display: inline-flex; align-items: center; gap: 9px; padding: 14px 26px; background: var(--c); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.02rem; text-decoration: none; box-shadow: 0 10px 22px rgba(61,34,9,.2); transition: background 160ms, transform 160ms; }
.kbse-feat__btn:hover { background: var(--c-dark); transform: translateY(-2px); }

/* Thema-kaart */
.kbse-card { position: relative; border-radius: 20px; overflow: hidden; aspect-ratio: 4 / 3; box-shadow: 0 12px 30px rgba(61,34,9,.08); }
.kbse-card__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.kbse-card__img--ph { display: flex; align-items: center; justify-content: center; background: linear-gradient(140deg, #fff, var(--tint)); color: var(--c); }
.kbse-card__img--ph svg { width: 56px; height: 56px; }
.kbse-card__tint { position: absolute; inset: 0; background: linear-gradient(180deg, var(--tint) 0%, rgba(255,255,255,0) 42%); }
.kbse-card__icon { position: absolute; top: 13px; left: 13px; z-index: 2; display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: var(--c); color: #fff; box-shadow: 0 4px 10px rgba(61,34,9,.18); }
.kbse-card__icon svg { width: 20px; height: 20px; }
.kbse-card__title { position: absolute; top: 18px; left: 60px; right: 12px; z-index: 2; font-family: var(--font-heading); font-size: 1.18rem; color: var(--color-ink); line-height: 1.1; margin: 0; }
.kbse-card__btn { position: absolute; left: 13px; bottom: 13px; z-index: 2; display: inline-flex; align-items: center; gap: 7px; padding: 9px 16px; background: var(--c); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: .86rem; text-decoration: none; box-shadow: 0 6px 16px rgba(61,34,9,.18); transition: background 160ms, transform 160ms; }
.kbse-card__btn:hover { background: var(--c-dark); transform: translateY(-1px); }

/* CTA-balk */
.kbse__cta { margin-top: 26px; background: #e9f4e1; border-radius: 24px; padding: 24px 32px; display: flex; align-items: center; gap: 20px; }
.kbse__cta-icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 56px; height: 56px; border-radius: 50%; background: #fff; color: var(--color-green); }
.kbse__cta-icon svg { width: 28px; height: 28px; }
.kbse__cta-body { flex: 1; min-width: 0; }
.kbse__cta-title { display: block; font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-ink); line-height: 1.2; }
.kbse__cta-text { display: block; font-family: var(--font-body); font-size: .92rem; color: var(--color-body); margin-top: 3px; }
.kbse__cta-btn { display: inline-flex; align-items: center; gap: 9px; flex-shrink: 0; padding: 15px 28px; background: var(--color-green); color: #fff; border-radius: var(--radius-pill); font-family: var(--font-heading); font-size: 1.02rem; text-decoration: none; box-shadow: 0 12px 26px rgba(102,170,68,.26); transition: background 160ms, transform 160ms; }
.kbse__cta-btn:hover { background: #5a9a3b; transform: translateY(-2px); }

/* Tablet */
@media (max-width: 1100px) and (min-width: 860px) {
  .kbse-feat__panel { width: 52%; padding: 20px; }
  .kbse-feat__title { font-size: 1.3rem; }
}

/* Mobiel */
@media (max-width: 859px) {
  .kbse__head { margin-bottom: 28px; }
  .kbse__grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  .kbse-feat { grid-column: 1 / -1; grid-row: auto; min-height: 0; aspect-ratio: 16 / 9; }
  .kbse-feat__img { object-position: center; }
  .kbse-feat__title { font-size: 1.3rem; top: 14px; left: 16px; right: 132px; }
  .kbse-feat__label { top: 14px; right: 14px; font-size: .72rem; padding: 6px 13px; }
  .kbse-feat__btn { left: 16px; bottom: 16px; padding: 11px 20px; font-size: .92rem; }

  .kbse-card { aspect-ratio: 1 / 1; }
  .kbse-card__title { font-size: 1.02rem; left: 56px; top: 16px; }
  .kbse-card__btn { font-size: .76rem; padding: 8px 13px; }

  .kbse__cta { flex-direction: column; text-align: center; gap: 14px; padding: 24px 20px; }
  .kbse__cta-body { flex: none; }
  .kbse__cta-btn { width: 100%; justify-content: center; max-width: 420px; }
  .kbse__deco--paw1, .kbse__deco--paw2 { display: none; }
}

@media (max-width: 480px) {
  .kbse-feat { aspect-ratio: 16 / 11; }
  .kbse-feat__title { font-size: 1.15rem; right: 112px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Special Editions",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Tekst" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verrassingen voor elk speciaal moment" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Er is altijd een reden om te" },
    { "type": "text", "id": "heading_highlight", "label": "Kop accent (groen)", "default": "kwispelen" },
    { "type": "textarea", "id": "intro", "label": "Subtekst", "default": "Van verjaardagen tot feestdagen. Ontdek onze leukste speciale edities." },
    { "type": "header", "content": "CTA-balk onderaan" },
    { "type": "text", "id": "cta_title", "label": "Titel", "default": "Er komen regelmatig nieuwe special editions uit." },
    { "type": "text", "id": "cta_text", "label": "Tekst", "default": "Blijf ons volgen en mis geen enkele feestelijke verrassing!" },
    { "type": "text", "id": "cta_label", "label": "Knoptekst", "default": "Bekijk alle special editions" },
    { "type": "url", "id": "cta_url", "label": "Knop link" },
    { "type": "header", "content": "Decoratie" },
    { "type": "checkbox", "id": "show_decorations", "label": "Decoratieve merkaccenten tonen", "default": true }
  ],
  "blocks": [
    {
      "type": "special",
      "name": "Special editie",
      "limit": 5,
      "settings": [
        { "type": "checkbox", "id": "featured", "label": "Uitgelicht (grote kaart links)", "default": false },
        { "type": "image_picker", "id": "image", "label": "Afbeelding" },
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "cake",
          "options": [
            { "value": "cake", "label": "Taart" },
            { "value": "heart", "label": "Hart" },
            { "value": "tree", "label": "Kerstboom" },
            { "value": "pumpkin", "label": "Pompoen" },
            { "value": "sun", "label": "Zon" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "star", "label": "Ster" },
            { "value": "sparkles", "label": "Sparkles" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Themakleur", "default": "pink",
          "options": [
            { "value": "pink", "label": "Roze" },
            { "value": "green", "label": "Groen" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" },
            { "value": "purple", "label": "Paars" }
          ]
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "Verjaardagsbox" },
        { "type": "textarea", "id": "text", "label": "Tekst (alleen uitgelicht)", "default": "Maak van de verjaardag van jouw hond een feestje om nooit te vergeten." },
        { "type": "text", "id": "badge", "label": "Badge (alleen uitgelicht, bv. Meest gekozen)" },
        { "type": "text", "id": "button_label", "label": "Knoptekst", "default": "Bekijk box" },
        { "type": "url", "id": "button_url", "label": "Knop link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Special Editions",
      "blocks": [
        { "type": "special", "settings": { "featured": true, "icon": "cake", "color": "pink", "title": "Verjaardagsbox", "text": "Maak van de verjaardag van jouw hond een feestje om nooit te vergeten.", "badge": "Meest gekozen", "button_label": "Bekijk verjaardagsbox" } },
        { "type": "special", "settings": { "icon": "heart", "color": "pink", "title": "Valentijnsbox", "button_label": "Bekijk Valentijnsbox" } },
        { "type": "special", "settings": { "icon": "tree", "color": "green", "title": "Kerstbox", "button_label": "Bekijk Kerstbox" } },
        { "type": "special", "settings": { "icon": "pumpkin", "color": "orange", "title": "Halloweenbox", "button_label": "Bekijk Halloweenbox" } },
        { "type": "special", "settings": { "icon": "sun", "color": "yellow", "title": "Zomerbox", "button_label": "Bekijk Zomerbox" } }
      ]
    }
  ]
}
{% endschema %}
