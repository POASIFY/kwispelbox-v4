{%- comment -%}
  sections/reviews.liquid — Kwispelbox KB-v4
  Premium reviewsectie: gecentreerde kop, 3 reviewkaarten, brede trustbar.
  - review : reviewkaart (block, herschikbaar)
  - trust  : trustbar-item (block)
  Mobiel: kaarten als swipebare carousel, trustbar als 2-koloms kaarten.
{%- endcomment -%}

{%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
{%- assign trust_blocks  = section.blocks | where: 'type', 'trust' -%}

<div class="rev full-width">
  <div class="rev__inner">

    <!-- ── Kop ─────────────────────────────────────── -->
    <div class="rev__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="rev__eyebrow">
          <span class="rev__eyebrow-icon" aria-hidden="true">{%- render 'lucide', icon: 'heart' -%}</span>
          {{ section.settings.eyebrow }}
        </span>
      {%- endif -%}

      <div class="rev__title-row">
        {%- if section.settings.show_decorations -%}
          <span class="rev__deco-lines" aria-hidden="true">
            <svg viewBox="0 0 34 28" fill="none" stroke-width="3" stroke-linecap="round"><path d="M4 8h12" stroke="var(--color-green)"/><path d="M2 16h9" stroke="var(--color-pink)"/><path d="M8 23h11" stroke="var(--color-green)"/></svg>
          </span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="rev__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.show_decorations -%}
          <span class="rev__deco-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
        {%- endif -%}
      </div>

      {%- if section.settings.subtitle != blank -%}
        {%- assign sub = section.settings.subtitle -%}
        {%- if section.settings.highlight_word != blank -%}
          {%- capture hl -%}<span class="rev__sub-hl">{{ section.settings.highlight_word }}</span>{%- endcapture -%}
          {%- assign sub = sub | replace: section.settings.highlight_word, hl -%}
        {%- endif -%}
        <p class="rev__subtitle">{{ sub }}</p>
      {%- endif -%}
    </div>

    <!-- ── Reviewkaarten ───────────────────────────── -->
    {%- if review_blocks.size > 0 -%}
      <div class="rev__cards">
        {%- for block in review_blocks -%}
          {%- assign rating = block.settings.rating | default: 5 -%}
          <article class="rev-card rev-card--{{ block.settings.accent }}" {{ block.shopify_attributes }}>

            <div class="rev-card__profile">
              <div class="rev-card__avatar">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 240 }}"
                       srcset="{{ block.settings.image | image_url: width: 160 }} 160w, {{ block.settings.image | image_url: width: 240 }} 240w"
                       sizes="120px" alt="{{ block.settings.image.alt | default: block.settings.dog_name | escape }}"
                       width="120" height="120" loading="lazy" class="rev-card__avatar-img">
                {%- else -%}
                  <div class="rev-card__avatar-img rev-card__avatar-img--placeholder">{%- render 'lucide', icon: 'dog' -%}</div>
                {%- endif -%}
              </div>
              <div class="rev-card__id">
                <span class="rev-card__name">
                  {{ block.settings.dog_name }}
                  <span class="rev-card__name-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
                </span>
                {%- if block.settings.breed != blank -%}<span class="rev-card__breed">{{ block.settings.breed }}</span>{%- endif -%}
                {%- if block.settings.badge != blank -%}
                  <span class="rev-card__badge rev-card__badge--{{ block.settings.badge_color }}">{{ block.settings.badge }}</span>
                {%- endif -%}
              </div>
            </div>

            <div class="rev-card__stars">
              {%- for i in (1..5) -%}
                <svg class="rev-star{% if i <= rating %} is-on{% endif %}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>
              {%- endfor -%}
              <span class="rev-card__rating">{{ rating }}/5</span>
            </div>

            <div class="rev-card__quote">
              <span class="rev-card__qmark" aria-hidden="true">&ldquo;</span>
              {%- if block.settings.review_title != blank -%}<h3 class="rev-card__title">{{ block.settings.review_title }}</h3>{%- endif -%}
              {%- if block.settings.review_text != blank -%}<p class="rev-card__text">{{ block.settings.review_text }}</p>{%- endif -%}
            </div>

            {%- if block.settings.verified_text != blank -%}
              <span class="rev-card__verified">
                <span class="rev-card__verified-icon" aria-hidden="true">{%- render 'lucide', icon: 'check' -%}</span>
                {{ block.settings.verified_text }}
              </span>
            {%- endif -%}

            <span class="rev-card__watermark" aria-hidden="true">&rdquo;</span>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- ── Trustbar ────────────────────────────────── -->
    {%- if trust_blocks.size > 0 -%}
      <div class="rev-trust">
        <ul class="rev-trust__list" role="list">
          {%- for block in trust_blocks -%}
            <li class="rev-trust__item" {{ block.shopify_attributes }}>
              <span class="rev-trust__icon rev-trust__icon--{{ block.settings.color }}" aria-hidden="true">{%- render 'lucide', icon: block.settings.icon -%}</span>
              <div class="rev-trust__text">
                <span class="rev-trust__title">{{ block.settings.title }}</span>
                {%- if block.settings.text != blank -%}<span class="rev-trust__line">{{ block.settings.text }}</span>{%- endif -%}
                {%- if block.settings.show_stars -%}
                  <span class="rev-trust__stars" aria-hidden="true">
                    {%- for i in (1..5) -%}<svg class="rev-star is-on" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>{%- endfor -%}
                  </span>
                {%- endif -%}
                {%- if block.settings.subtext != blank -%}<span class="rev-trust__sub">{{ block.settings.subtext }}</span>{%- endif -%}
              </div>
              {%- if block.settings.show_heart -%}
                <span class="rev-trust__heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}

.rev { background: var(--color-cream); padding: 96px 0 80px; }
.rev__inner { max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* ── Kop ─────────────────────────────────────────────── */
.rev__head { text-align: center; max-width: 640px; margin: 0 auto 52px; }
.rev__eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: var(--font-body); font-size: .78rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: .1em; color: var(--color-pink); margin-bottom: 16px;
}
.rev__eyebrow-icon { display: inline-flex; }
.rev__eyebrow-icon .lucide { width: 15px; height: 15px; }

.rev__title-row { display: inline-flex; align-items: center; justify-content: center; gap: 16px; }
.rev__title { font-family: var(--font-heading); font-size: clamp(2.1rem, 4.6vw, 3.4rem); line-height: 1.04; color: var(--color-ink); margin: 0; }
.rev__deco-lines { display: inline-flex; width: 34px; height: 28px; flex-shrink: 0; }
.rev__deco-lines svg { width: 100%; height: 100%; }
.rev__deco-heart { display: inline-flex; width: 30px; height: 30px; flex-shrink: 0; color: var(--color-pink); opacity: .6; }
.rev__deco-heart svg { width: 100%; height: 100%; }

.rev__subtitle { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.6; color: var(--color-body); margin: 16px auto 0; max-width: 520px; }
.rev__sub-hl { color: var(--color-orange); font-weight: 700; }

/* ── Reviewkaarten ───────────────────────────────────── */
.rev__cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; align-items: stretch; }

.rev-card {
  --ac: var(--color-pink); --ac-soft: #ffe0ee;
  position: relative; overflow: hidden;
  display: flex; flex-direction: column;
  background: #fff; border: 1.5px solid var(--color-line);
  border-radius: 24px; padding: 30px 30px 26px;
  box-shadow: 0 18px 44px rgba(61, 34, 9, .08);
}
.rev-card--pink   { --ac: var(--color-pink);   --ac-soft: #ffe0ee; }
.rev-card--orange { --ac: var(--color-orange); --ac-soft: #fff0e4; }
.rev-card--green  { --ac: var(--color-green);  --ac-soft: #e8f5e2; }
.rev-card--yellow { --ac: #d99100;             --ac-soft: #fffae0; }

/* Profielrij */
.rev-card__profile { position: relative; z-index: 1; display: flex; align-items: center; gap: 16px; }
.rev-card__avatar { flex-shrink: 0; width: 92px; height: 92px; border-radius: 50%; overflow: hidden; box-shadow: 0 6px 16px rgba(61, 34, 9, .14); background: var(--ac-soft); }
.rev-card__avatar-img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rev-card__avatar-img--placeholder { display: flex; align-items: center; justify-content: center; color: var(--ac); }
.rev-card__avatar-img--placeholder .lucide { width: 40px; height: 40px; }
.rev-card__id { display: flex; flex-direction: column; align-items: flex-start; gap: 4px; min-width: 0; }
.rev-card__name { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-heading); font-size: 1.4rem; color: var(--color-ink); line-height: 1; }
.rev-card__name-heart { display: inline-flex; width: 15px; height: 15px; color: var(--color-pink); flex-shrink: 0; }
.rev-card__name-heart svg { width: 100%; height: 100%; }
.rev-card__breed { font-family: var(--font-body); font-size: .85rem; color: var(--color-muted); }
.rev-card__badge { font-family: var(--font-body); font-size: .72rem; font-weight: 800; padding: 4px 12px; border-radius: var(--radius-pill); margin-top: 3px; }
.rev-card__badge--pink   { background: #ffe0ee; color: #c4396a; }
.rev-card__badge--orange { background: #fff0e4; color: #c8721f; }
.rev-card__badge--green  { background: #e8f5e2; color: #4e8230; }
.rev-card__badge--yellow { background: #fffae0; color: #9a7400; }

/* Sterren */
.rev-card__stars { position: relative; z-index: 1; display: flex; align-items: center; gap: 3px; margin: 22px 0; }
.rev-star { width: 19px; height: 19px; color: #e6ddca; flex-shrink: 0; }
.rev-star.is-on { color: #f4a72c; }
.rev-card__rating { font-family: var(--font-body); font-size: .85rem; font-weight: 800; color: var(--color-ink); margin-left: 7px; }

/* Quote */
.rev-card__quote { position: relative; z-index: 1; }
.rev-card__qmark { display: block; font-family: var(--font-heading); font-size: 50px; line-height: .6; color: var(--ac); height: 30px; }
.rev-card__title { font-family: var(--font-heading); font-size: 1.28rem; line-height: 1.2; color: var(--color-ink); margin: 6px 0 8px; }
.rev-card__text { font-family: var(--font-body); font-size: .95rem; line-height: 1.65; color: var(--color-body); margin: 0; }

/* Verificatielabel */
.rev-card__verified {
  position: relative; z-index: 1; margin-top: auto; padding-top: 22px;
  display: inline-flex; align-items: center; gap: 7px;
  font-family: var(--font-body); font-size: .8rem; font-weight: 700; color: var(--color-green);
}
.rev-card__verified-icon { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); }
.rev-card__verified-icon .lucide { width: 13px; height: 13px; }

/* Watermark sluitquote */
.rev-card__watermark {
  position: absolute; right: 14px; bottom: -34px; z-index: 0;
  font-family: var(--font-heading); font-size: 150px; line-height: 1;
  color: var(--ac); opacity: .07; pointer-events: none;
}

/* ── Trustbar ────────────────────────────────────────── */
.rev-trust {
  margin-top: 28px; background: #fff;
  border: 1.5px solid var(--color-line); border-radius: 28px;
  box-shadow: 0 16px 44px rgba(61, 34, 9, .07);
}
.rev-trust__list { list-style: none; margin: 0; padding: 0; display: flex; align-items: stretch; }
.rev-trust__item {
  position: relative; flex: 1; display: flex; align-items: center; gap: 16px;
  padding: 26px 24px; border-left: 1px solid var(--color-line);
}
.rev-trust__item:first-child { border-left: none; }
.rev-trust__icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 58px; height: 58px; border-radius: 50%; background: #e8f5e2; color: var(--color-green); }
.rev-trust__icon .lucide { width: 28px; height: 28px; }
.rev-trust__icon--green  { background: #e8f5e2; color: var(--color-green); }
.rev-trust__icon--pink   { background: #ffe0ee; color: var(--color-pink); }
.rev-trust__icon--orange { background: #fff0e4; color: var(--color-orange); }
.rev-trust__icon--yellow { background: #fffae0; color: #d99100; }
.rev-trust__text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.rev-trust__title { font-family: var(--font-heading); font-size: 1.45rem; color: var(--color-ink); line-height: 1.1; }
.rev-trust__line { font-family: var(--font-body); font-size: .85rem; font-weight: 700; color: var(--color-ink); }
.rev-trust__stars { display: inline-flex; gap: 2px; margin-top: 2px; }
.rev-trust__stars .rev-star { width: 14px; height: 14px; color: #f4a72c; }
.rev-trust__sub { font-family: var(--font-body); font-size: .76rem; color: var(--color-muted); }
.rev-trust__heart { position: absolute; top: 16px; right: 16px; width: 18px; height: 18px; color: var(--color-pink); opacity: .55; }
.rev-trust__heart svg { width: 100%; height: 100%; }

/* ── Tablet ──────────────────────────────────────────── */
@media (max-width: 989px) and (min-width: 700px) {
  .rev__cards { grid-template-columns: repeat(2, 1fr); }
  .rev-trust__list { flex-wrap: wrap; }
  .rev-trust__item { flex: 0 0 50%; }
  .rev-trust__item:nth-child(odd) { border-left: none; }
  .rev-trust__item:nth-child(n+3) { border-top: 1px solid var(--color-line); }
}

/* ── Mobiel: swipebare reviews + gestapelde trust ────── */
@media (max-width: 699px) {
  .rev { padding: 64px 0 56px; }
  .rev__head { margin-bottom: 36px; }
  .rev__deco-lines, .rev__deco-heart { display: none; }

  /* Reviews als swipebare carousel */
  .rev__cards {
    display: flex; flex-wrap: nowrap; overflow-x: auto; gap: 16px;
    margin: 0 calc(-1 * var(--page-margin)); padding: 4px var(--page-margin) 14px;
    scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none;
  }
  .rev__cards::-webkit-scrollbar { display: none; }
  .rev-card { flex: 0 0 86%; scroll-snap-align: center; padding: 26px 24px 24px; }
  .rev-card__avatar { width: 76px; height: 76px; }
  .rev-card__name { font-size: 1.25rem; }

  /* Trustbar → 2-koloms kaarten */
  .rev-trust { background: none; border: none; box-shadow: none; border-radius: 0; margin-top: 28px; }
  .rev-trust__list { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .rev-trust__item {
    border-left: none; background: #fff; border: 1.5px solid var(--color-line);
    border-radius: 20px; box-shadow: 0 10px 26px rgba(61, 34, 9, .06);
    padding: 20px; flex-direction: column; align-items: flex-start; gap: 12px;
  }
}

@media (max-width: 459px) {
  .rev-card { flex-basis: 90%; }
  .rev-trust__list { grid-template-columns: 1fr; }
}

@media (prefers-reduced-motion: reduce) {
  .rev__cards { scroll-behavior: auto; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Klantreviews",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Geliefd door honden én hun baasjes" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Wat onze klanten zeggen" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitel", "default": "Duizenden honden genieten al elke maand van hun Kwispelbox. Lees wat hun baasjes hiervan vinden." },
    { "type": "text", "id": "highlight_word", "label": "Woord in oranje accent", "default": "Kwispelbox" },
    { "type": "checkbox", "id": "show_decorations", "label": "Decoratieve accenten bij titel tonen", "default": true }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Reviewkaart",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Foto hond" },
        { "type": "text", "id": "dog_name", "label": "Naam hond", "default": "Luna" },
        { "type": "text", "id": "breed", "label": "Ras", "default": "Golden Retriever" },
        { "type": "text", "id": "badge", "label": "Box badge", "default": "Happy Box" },
        {
          "type": "select", "id": "badge_color", "label": "Badge kleur", "default": "pink",
          "options": [
            { "value": "pink", "label": "Roze (Happy)" },
            { "value": "orange", "label": "Oranje (Mega)" },
            { "value": "green", "label": "Groen (Mini)" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "range", "id": "rating", "label": "Sterren", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "review_title", "label": "Reviewtitel", "default": "Elke maand weer een feestje!" },
        { "type": "textarea", "id": "review_text", "label": "Reviewtekst", "default": "Luna wordt altijd zó enthousiast als de Kwispelbox binnenkomt. De speeltjes zijn stevig en superleuk, en ze is dol op de knuffels. Echt een aanrader!" },
        { "type": "text", "id": "verified_text", "label": "Verificatietekst", "default": "Geverifieerde aankoop" },
        {
          "type": "select", "id": "accent", "label": "Accentkleur (quote)", "default": "pink",
          "options": [
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "green", "label": "Groen" },
            { "value": "yellow", "label": "Geel" }
          ]
        }
      ]
    },
    {
      "type": "trust",
      "name": "Trustitem",
      "limit": 4,
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "paw",
          "options": [
            { "value": "paw", "label": "Poot" },
            { "value": "heart", "label": "Hart" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "shield-check", "label": "Schild" },
            { "value": "star", "label": "Ster" },
            { "value": "award", "label": "Award" },
            { "value": "truck", "label": "Vrachtwagen" },
            { "value": "sparkles", "label": "Sparkles" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Icoonvlak kleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "title", "label": "Titel / cijfer", "default": "1.200+" },
        { "type": "text", "id": "text", "label": "Beschrijving", "default": "Blije honden in onze community" },
        { "type": "checkbox", "id": "show_stars", "label": "Sterren tonen", "default": false },
        { "type": "text", "id": "subtext", "label": "Extra regel (optioneel)" },
        { "type": "checkbox", "id": "show_heart", "label": "Roze hartje rechts tonen", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Klantreviews",
      "blocks": [
        { "type": "review", "settings": { "dog_name": "Luna", "breed": "Golden Retriever", "badge": "Happy Box", "badge_color": "pink", "rating": 5, "review_title": "Elke maand weer een feestje!", "review_text": "Luna wordt altijd zó enthousiast als de Kwispelbox binnenkomt. De speeltjes zijn stevig en superleuk, en ze is dol op de knuffels. Echt een aanrader!", "verified_text": "Geverifieerde aankoop", "accent": "pink" } },
