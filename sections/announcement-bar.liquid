{% comment %}
  sections/announcement-bar.liquid — Kwispelbox KB-v3
  Desktop: alle berichten tegelijk naast elkaar met scheidingslijn
  Mobiel: CSS marquee scroll
{% endcomment %}

{%- assign message_blocks = section.blocks | where: 'type', 'message' -%}
{%- assign block_count = message_blocks | size -%}

{%- if block_count > 0 -%}
  <div class="announcement-bar" role="region" aria-label="Aankondigingen">

    <!-- Desktop: alle items naast elkaar -->
    <div class="announcement-bar__desktop">
      {%- for block in message_blocks -%}
        <div class="announcement-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <span class="announcement-bar__icon announcement-bar__icon--{{ block.settings.icon_color | default: 'orange' }}" aria-hidden="true">
              {{- block.settings.icon | inline_asset_content -}}
            </span>
          {%- endif -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="announcement-bar__text">{{ block.settings.text }}</a>
          {%- else -%}
            <span class="announcement-bar__text">{{ block.settings.text }}</span>
          {%- endif -%}
          {%- if block.settings.stars != blank -%}
            <span class="announcement-bar__stars" aria-hidden="true">{{ block.settings.stars }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <!-- Mobiel: marquee -->
    <div class="announcement-bar__mobile" aria-hidden="true">
      <div class="announcement-bar__marquee">
        <div class="announcement-bar__marquee-track">
          {%- for i in (1..2) -%}
            {%- for block in message_blocks -%}
              <span class="announcement-bar__marquee-item">
                {%- if block.settings.icon != blank -%}
                  <span class="announcement-bar__icon">
                    {{- block.settings.icon | inline_asset_content -}}
                  </span>
                {%- endif -%}
                {{- block.settings.text -}}
                <span class="announcement-bar__separator" aria-hidden="true">·</span>
              </span>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
{%- endif -%}

{% stylesheet %}
.announcement-bar {
  background-color: var(--color-cream);
  border-bottom: 1px solid var(--color-line);
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--color-ink);
}

/* Desktop: alle items naast elkaar */
.announcement-bar__desktop {
  display: none;
  align-items: stretch;
  justify-content: center;
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 var(--page-margin);
}

@media (min-width: 750px) {
  .announcement-bar__desktop { display: flex; }
  .announcement-bar__mobile  { display: none; }
}

.announcement-bar__item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 24px;
  border-right: 1px solid var(--color-line);
  flex: 1;
  justify-content: center;
  white-space: nowrap;
}

.announcement-bar__item:last-child {
  border-right: none;
}

.announcement-bar__icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  color: var(--color-orange);
}

.announcement-bar__icon svg {
  width: 16px;
  height: 16px;
}

.announcement-bar__icon--green  { color: var(--color-green); }
.announcement-bar__icon--pink   { color: var(--color-pink); }
.announcement-bar__icon--orange { color: var(--color-orange); }
.announcement-bar__icon--yellow { color: var(--color-yellow); }
.announcement-bar__icon--muted  { color: var(--color-muted); }

.announcement-bar__text {
  color: var(--color-ink);
  text-decoration: none;
  font-weight: 700;
}

a.announcement-bar__text:hover {
  text-decoration: underline;
}

.announcement-bar__stars {
  color: var(--color-yellow);
  letter-spacing: 1px;
  font-size: 0.85rem;
}

/* Mobiel: marquee */
.announcement-bar__mobile {
  display: flex;
  width: 100%;
  overflow: hidden;
  padding: 8px 0;
}

.announcement-bar__marquee {
  display: flex;
  width: 100%;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
}

.announcement-bar__marquee-track {
  display: flex;
  align-items: center;
  white-space: nowrap;
  animation: announcement-scroll 24s linear infinite;
  will-change: transform;
}

@media (prefers-reduced-motion: reduce) {
  .announcement-bar__marquee-track { animation: none; }
}

.announcement-bar__marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0 20px;
}

.announcement-bar__separator {
  margin-left: 12px;
  opacity: 0.4;
}

@keyframes announcement-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
{% endstylesheet %}

