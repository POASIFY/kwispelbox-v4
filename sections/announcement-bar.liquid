{%- comment -%}
  sections/announcement-bar.liquid — Kwispelbox KB-v4
  Desktop: alle berichten naast elkaar
  Mobiel: CSS marquee
{%- endcomment -%}

{%- assign msg_blocks = section.blocks | where: 'type', 'message' -%}

{%- if msg_blocks.size > 0 -%}
<div class="ann-bar" role="region" aria-label="Aankondigingen">

  <ul class="ann-bar__list" role="list">
    {%- for block in msg_blocks -%}
      <li class="ann-bar__item" {{ block.shopify_attributes }}>
        {%- if block.settings.icon != blank -%}
          <span class="ann-bar__icon ann-bar__icon--{{ block.settings.icon_color }}" aria-hidden="true">
            {{- block.settings.icon | inline_asset_content -}}
          </span>
        {%- endif -%}
        <span class="ann-bar__text">
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
          {%- else -%}
            {{ block.settings.text }}
          {%- endif -%}
          {%- if block.settings.stars != blank -%}
            <span class="ann-bar__stars" aria-hidden="true">{{ block.settings.stars }}</span>
          {%- endif -%}
        </span>
      </li>
    {%- endfor -%}
  </ul>

  <div class="ann-bar__marquee-wrap" aria-hidden="true">
    <div class="ann-bar__marquee">
      <div class="ann-bar__track">
        {%- for i in (1..2) -%}
          {%- for block in msg_blocks -%}
            <span class="ann-bar__marquee-item">
              {%- if block.settings.icon != blank -%}
                <span class="ann-bar__icon ann-bar__icon--{{ block.settings.icon_color }}" aria-hidden="true">
                  {{- block.settings.icon | inline_asset_content -}}
                </span>
              {%- endif -%}
              {{ block.settings.text }}
              <span aria-hidden="true"> · </span>
            </span>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

</div>
{%- endif -%}

{% stylesheet %}

.ann-bar {
  background: var(--color-cream);
  font-family: var(--font-body);
  font-size: .78rem;
  font-weight: 700;
  color: var(--color-ink);
}

.ann-bar__list {
  display: none;
  list-style: none;
  margin: 0;
  padding: 0 var(--page-margin);
  max-width: var(--page-width);
  margin-inline: auto;
}

.ann-bar__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 16px;
  border-right: 1px solid var(--color-line);
  white-space: nowrap;
}

.ann-bar__item:last-child { border-right: none; }

.ann-bar__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  border-radius: 50%;
}

.ann-bar__icon svg { width: 15px; height: 15px; }

.ann-bar__icon--orange { background: #fff0e4; color: var(--color-orange); }
.ann-bar__icon--green  { background: #e8f5e2; color: var(--color-green); }
.ann-bar__icon--pink   { background: #ffe0ee; color: var(--color-pink); }
.ann-bar__icon--yellow { background: #fffae0; color: #b07d00; }
.ann-bar__icon--muted  { background: var(--color-cream); color: var(--color-muted); }

.ann-bar__text { color: var(--color-ink); }
.ann-bar__text a { color: var(--color-ink); text-decoration: none; }
.ann-bar__text a:hover { text-decoration: underline; }

.ann-bar__stars { color: var(--color-yellow); margin-left: 4px; }

.ann-bar__marquee-wrap {
  display: none;
  overflow: hidden;
  padding: 8px 0;
  mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
}

.ann-bar__marquee { display: flex; width: 100%; overflow: hidden; }

.ann-bar__track {
  display: flex;
  align-items: center;
  white-space: nowrap;
  animation: ann-scroll 28s linear infinite;
}

.ann-bar__marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0 16px;
}

@keyframes ann-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

@media (prefers-reduced-motion: reduce) {
  .ann-bar__track { animation: none; }
}

@media (max-width: 749px) {
  .ann-bar__marquee-wrap { display: flex; }
}

@media (min-width: 750px) {
  .ann-bar__list { display: flex; }
}

{% endstylesheet %}

