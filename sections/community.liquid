{%- comment -%}
  sections/community.liquid — Kwispelbox KB-v4
  "Meer dan 1.200 blije honden" — uitgelichte testimonial (foto + quote),
  fotogrid van honden met naam-pills, en een stats-balk.
{%- endcomment -%}

{%- assign featured     = section.blocks | where: 'type', 'featured' | first -%}
{%- assign photo_blocks = section.blocks | where: 'type', 'photo' -%}
{%- assign stat_blocks  = section.blocks | where: 'type', 'stat' -%}

<div class="com full-width">

  {%- if section.settings.show_decorations -%}
    <div class="com__deco" aria-hidden="true">
      <span class="com__deco com__deco--lines"><svg viewBox="0 0 48 26" fill="none" stroke-width="2.6" stroke-linecap="round"><path d="M5 17C10 7 14 20 19 12" stroke="var(--color-green)"/><path d="M3 9c2-3 5-4 8-3" stroke="var(--color-pink)"/><path d="M9 22c1-3 3-5 6-5" stroke="var(--color-yellow)"/></svg></span>
      <span class="com__deco com__deco--heart"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
      <span class="com__deco com__deco--paw"><svg viewBox="0 0 24 24" fill="var(--color-pink)"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg></span>
      <span class="com__deco com__deco--heart2"><svg viewBox="0 0 24 24" fill="none" stroke="var(--color-pink)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></span>
    </div>
  {%- endif -%}

  <div class="com__inner">

    <div class="com__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="com__eyebrow"><span class="com__eyebrow-icon" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="com__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="com__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="com__main">

      {%- if featured -%}
        <article class="com__testi" {{ featured.shopify_attributes }}>
          <div class="com__testi-media">
            {%- if featured.settings.image != blank -%}
              <img src="{{ featured.settings.image | image_url: width: 800 }}" srcset="{{ featured.settings.image | image_url: width: 500 }} 500w, {{ featured.settings.image | image_url: width: 800 }} 800w" sizes="(max-width:859px) 92vw, 30vw" alt="{{ featured.settings.image.alt | default: featured.settings.dog_name | escape }}" width="600" height="640" loading="lazy" class="com__testi-img">
            {%- else -%}
              <div class="com__testi-img com__testi-img--ph">{%- render 'kb-icon', icon: 'paw' -%}</div>
            {%- endif -%}
            {%- if featured.settings.dog_name != blank -%}
              <span class="com__pill com__pill--lg">{{ featured.settings.dog_name }}<span class="com__pill-heart" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span></span>
            {%- endif -%}
          </div>
          <div class="com__testi-body">
            <span class="com__quote-mark" aria-hidden="true"><svg viewBox="0 0 40 30" fill="currentColor"><path d="M0 17.5C0 9.8 4.6 4 12.2 1l1.6 3.6C9.4 6.6 7 9.6 7 12.6h5.4V30H0V17.5Zm22 0C22 9.8 26.6 4 34.2 1l1.6 3.6C31.4 6.6 29 9.6 29 12.6h5.4V30H22V17.5Z"/></svg></span>
            {%- if featured.settings.quote != blank -%}
              <blockquote class="com__quote">{{ featured.settings.quote }}</blockquote>
            {%- endif -%}
            {%- assign rating = featured.settings.rating | default: 5 -%}
            <span class="com__stars" role="img" aria-label="{{ rating }} van 5 sterren">
              {%- for i in (1..5) -%}<svg class="com__star{% if i <= rating %} is-on{% endif %}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01z"/></svg>{%- endfor -%}
            </span>
            <span class="com__author">
              {%- if featured.settings.owner_name != blank -%}{{ featured.settings.owner_name }}{%- endif -%}
              {%- if featured.settings.owner_name != blank and featured.settings.dog_name != blank %} &amp; {% endif -%}
              {%- if featured.settings.dog_name != blank -%}{{ featured.settings.dog_name }}{%- endif -%}
            </span>
          </div>
        </article>
      {%- endif -%}

      {%- if photo_blocks.size > 0 -%}
        <div class="com__photos">
          {%- for block in photo_blocks -%}
            <figure class="com-photo" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" srcset="{{ block.settings.image | image_url: width: 360 }} 360w, {{ block.settings.image | image_url: width: 600 }} 600w" sizes="(max-width:859px) 46vw, 22vw" alt="{{ block.settings.image.alt | default: block.settings.dog_name | escape }}" width="360" height="270" loading="lazy" class="com-photo__img">
              {%- else -%}
                <div class="com-photo__img com-photo__img--ph">{%- render 'kb-icon', icon: 'paw' -%}</div>
              {%- endif -%}
              {%- if block.settings.dog_name != blank -%}
                <figcaption class="com__pill com__pill--photo"><span class="com__pill-heart" aria-hidden="true">{%- render 'kb-icon', icon: 'heart' -%}</span>{{ block.settings.dog_name }}</figcaption>
              {%- endif -%}
            </figure>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

    {%- if stat_blocks.size > 0 -%}
      <div class="com__stats">
        {%- for block in stat_blocks -%}
          <div class="com__stat com__stat--{{ block.settings.color }}" {{ block.shopify_attributes }}>
            <span class="com__stat-icon" aria-hidden="true">{%- render 'kb-icon', icon: block.settings.icon -%}</span>
            <div class="com__stat-body">
              <span class="com__stat-value">{{ block.settings.value }}</span>
              {%- if block.settings.label != blank -%}<span class="com__stat-label">{{ block.settings.label }}</span>{%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.com { position: relative; background: transparent; padding: var(--section-pad) 0; overflow: hidden; }
.com__inner { position: relative; z-index: 1; max-width: var(--page-width); margin: 0 auto; padding: 0 var(--page-margin); }

/* Decoratie */
.com__deco { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.com__deco span { position: absolute; display: block; }
.com__deco span svg { display: block; width: 100%; height: 100%; }
.com__deco--lines { top: 60px; left: 6%; width: 52px; height: 28px; }
.com__deco--heart { top: 70px; left: 14%; width: 30px; height: 30px; }
.com__deco--paw { top: 12%; right: 6%; width: 30px; height: 30px; opacity: .5; }
.com__deco--heart2 { top: 60px; right: 12%; width: 34px; height: 34px; }

/* Kop */
.com__head { text-align: center; margin: 0 auto 40px; }
.com__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--color-pink); margin-bottom: 12px; }
.com__eyebrow-icon { display: inline-flex; }
.com__eyebrow-icon svg { width: 16px; height: 16px; }
.com__heading { font-family: var(--font-heading); font-size: var(--fs-h2); line-height: 1.05; color: var(--color-ink); margin: 0; }
.com__intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: 1.6; color: var(--color-body); margin: 14px auto 0; max-width: 580px; }

/* Main: testimonial + fotogrid */
.com__main { display: grid; grid-template-columns: 1.5fr 1fr; gap: 22px; align-items: stretch; }

/* Naam-pill */
.com__pill { display: inline-flex; align-items: center; gap: 6px; background: #fff; color: var(--color-ink); font-family: var(--font-heading); font-size: .9rem; padding: 7px 14px; border-radius: var(--radius-pill); box-shadow: 0 5px 14px rgba(61,34,9,.14); position: absolute; z-index: 2; }
.com__pill-heart { display: inline-flex; color: var(--color-pink); }
.com__pill-heart svg { width: 15px; height: 15px; fill: currentColor; stroke: currentColor; }
.com__pill--lg { top: 16px; left: 16px; font-size: 1rem; padding: 8px 16px; }
.com__pill--photo { left: 12px; bottom: 12px; font-size: .82rem; flex-direction: row-reverse; padding: 6px 13px; }

/* Testimonial-kaart */
.com__testi { position: relative; background: #fff; border-radius: 24px; overflow: hidden; display: grid; grid-template-columns: 1fr 1fr; box-shadow: 0 16px 40px rgba(61,34,9,.08); }
.com__testi-media { position: relative; }
.com__testi-img { width: 100%; height: 100%; object-fit: cover; display: block; }
.com__testi-img--ph { display: flex; align-items: center; justify-content: center; min-height: 360px; background: linear-gradient(140deg, #fff, #eef7e8); color: var(--color-green); }
.com__testi-img--ph svg { width: 80px; height: 80px; }
.com__testi-body { display: flex; flex-direction: column; justify-content: center; gap: 18px; padding: 40px 40px; }
.com__quote-mark { color: var(--color-pink); }
.com__quote-mark svg { width: 50px; height: 38px; display: block; }
.com__quote { font-family: var(--font-heading); font-size: clamp(1.2rem, 1.8vw, 1.6rem); line-height: 1.35; color: var(--color-ink); margin: 0; font-weight: 400; }
.com__stars { display: inline-flex; gap: 5px; }
.com__star { width: 24px; height: 24px; color: #e6ddca; }
.com__star.is-on { color: #f4a72c; }
.com__author { font-family: var(--font-body); font-size: 1rem; font-weight: 700; color: var(--color-body); }

/* Fotogrid 2 × 3 */
.com__photos { display: grid; grid-template-columns: 1fr 1fr; grid-auto-rows: 1fr; gap: 14px; }
.com-photo { position: relative; margin: 0; border-radius: 18px; overflow: hidden; aspect-ratio: 4 / 3; box-shadow: 0 10px 26px rgba(61,34,9,.08); }
.com-photo__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 500ms cubic-bezier(.2,.6,.2,1); }
.com-photo:hover .com-photo__img { transform: scale(1.06); }
.com-photo__img--ph { display: flex; align-items: center; justify-content: center; background: linear-gradient(140deg, #fff, #fdeaf2); color: var(--color-pink); }
.com-photo__img--ph svg { width: 40px; height: 40px; }

/* Stats-balk */
.com__stats { margin-top: 26px; background: #fff; border: 1.5px solid var(--color-line); border-radius: 24px; box-shadow: var(--shadow-card); display: grid; grid-template-columns: repeat(4, 1fr); padding: 24px 14px; }
.com__stat { --c: var(--color-green); --c-soft: #eef7e8; display: flex; align-items: center; gap: 16px; padding: 8px 22px; min-width: 0; }
.com__stat + .com__stat { border-left: 1.5px dashed var(--color-line); }
.com__stat--green  { --c: var(--color-green);  --c-soft: #eef7e8; }
.com__stat--pink   { --c: var(--color-pink);   --c-soft: #fdeaf2; }
.com__stat--orange { --c: var(--color-orange); --c-soft: #fdf0e2; }
.com__stat--yellow { --c: #d99100;             --c-soft: #fdf6e0; }
.com__stat-icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 54px; height: 54px; border-radius: 50%; background: var(--c-soft); color: var(--c); }
.com__stat-icon svg { width: 26px; height: 26px; }
.com__stat-body { display: flex; flex-direction: column; line-height: 1.15; min-width: 0; }
.com__stat-value { font-family: var(--font-heading); font-size: 1.55rem; color: var(--color-ink); }
.com__stat-label { font-family: var(--font-body); font-size: .82rem; color: var(--color-muted); margin-top: 2px; }

/* Tablet */
@media (max-width: 1100px) and (min-width: 860px) {
  .com__main { grid-template-columns: 1.3fr 1fr; }
  .com__testi-body { padding: 28px; gap: 14px; }
}

/* Mobiel */
@media (max-width: 859px) {
  .com__head { margin-bottom: 28px; }
  .com__main { grid-template-columns: 1fr; gap: 22px; }
  .com__testi { grid-template-columns: 1fr; }
  .com__testi-media { aspect-ratio: 16 / 11; }
  .com__testi-img--ph { min-height: 0; height: 100%; }
  .com__testi-body { padding: 22px 22px 26px; gap: 14px; }
  .com__quote { font-size: 1.18rem; }

  .com__photos { gap: 12px; }

  .com__stats { grid-template-columns: 1fr 1fr; padding: 16px 6px; }
  .com__stat { flex-direction: column; text-align: center; gap: 9px; padding: 16px 12px; min-width: 0; }
  .com__stat + .com__stat { border-left: none; }
  .com__stat:nth-child(1), .com__stat:nth-child(2) { border-bottom: 1.5px dashed var(--color-line); }
  .com__stat:nth-child(odd) { border-right: 1.5px dashed var(--color-line); }
  .com__stat-icon { width: 46px; height: 46px; }
  .com__stat-icon svg { width: 22px; height: 22px; }
  .com__stat-body { align-items: center; }
  .com__stat-value { font-size: 1.2rem; }
  .com__stat-label { font-size: .76rem; line-height: 1.25; overflow-wrap: anywhere; }
  .com__deco--paw, .com__deco--lines { display: none; }
}

@media (max-width: 459px) {
  .com__photos { gap: 10px; }
  .com__stat-value { font-size: 1.02rem; }
}

@media (prefers-reduced-motion: reduce) {
  .com-photo__img { transition: none; }
  .com-photo:hover .com-photo__img { transform: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Hondencommunity",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Een community vol kwispelende staarten" },
    { "type": "text", "id": "heading", "label": "Kop", "default": "Meer dan 1.200 blije honden." },
    { "type": "textarea", "id": "intro", "label": "Subtekst", "default": "Elke dag maken we honden (en hun baasjes) blij met onze verrassingsboxen." },
    { "type": "checkbox", "id": "show_decorations", "label": "Decoratieve merkaccenten tonen", "default": true }
  ],
  "blocks": [
    {
      "type": "featured",
      "name": "Uitgelichte review",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Hondenfoto" },
        { "type": "text", "id": "dog_name", "label": "Naam hond", "default": "Luna" },
        { "type": "textarea", "id": "quote", "label": "Review quote", "default": "Ze rent iedere keer naar de deur zodra de Kwispelbox komt. Echt haar favoriete moment van de maand!" },
        { "type": "range", "id": "rating", "label": "Sterren", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "owner_name", "label": "Naam baasje", "default": "Sanne" }
      ]
    },
    {
      "type": "photo",
      "name": "Communityfoto",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Hondenfoto" },
        { "type": "text", "id": "dog_name", "label": "Naam hond", "default": "Milo" }
      ]
    },
    {
      "type": "stat",
      "name": "Statistiek",
      "limit": 4,
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "users",
          "options": [
            { "value": "users", "label": "Community" },
            { "value": "camera", "label": "Camera" },
            { "value": "heart", "label": "Hart" },
            { "value": "star", "label": "Ster" },
            { "value": "chat", "label": "Chat" },
            { "value": "gift", "label": "Cadeau" },
            { "value": "paw", "label": "Poot" },
            { "value": "sparkles", "label": "Sparkles" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Accentkleur", "default": "green",
          "options": [
            { "value": "green", "label": "Groen" },
            { "value": "pink", "label": "Roze" },
            { "value": "orange", "label": "Oranje" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "value", "label": "Cijfer / kernwoord", "default": "1.200+" },
        { "type": "text", "id": "label", "label": "Beschrijving", "default": "Blije honden in onze community" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hondencommunity",
      "blocks": [
        { "type": "featured", "settings": { "dog_name": "Luna", "quote": "Ze rent iedere keer naar de deur zodra de Kwispelbox komt. Echt haar favoriete moment van de maand!", "rating": 5, "owner_name": "Sanne" } },
        { "type": "photo", "settings": { "dog_name": "Milo" } },
        { "type": "photo", "settings": { "dog_name": "Pip" } },
        { "type": "photo", "settings": { "dog_name": "Boris" } },
        { "type": "photo", "settings": { "dog_name": "Nala" } },
        { "type": "photo", "settings": { "dog_name": "Max" } },
        { "type": "photo", "settings": { "dog_name": "Charlie" } },
        { "type": "stat", "settings": { "icon": "users", "color": "green", "value": "1.200+", "label": "Blije honden in onze community" } },
        { "type": "stat", "settings": { "icon": "camera", "color": "pink", "value": "Dagelijks", "label": "Nieuwe foto's en verhalen" } },
        { "type": "stat", "settings": { "icon": "heart", "color": "yellow", "value": "Samen", "label": "Eén grote community van hondenliefhebbers" } },
        { "type": "stat", "settings": { "icon": "star", "color": "yellow", "value": "4,9/5", "label": "Gemiddelde waardering uit 350+ reviews" } }
      ]
    }
  ]
}
{% endschema %}
