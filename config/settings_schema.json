      },
      {
        "type": "color",
        "id": "color_brand_green",
        "label": "Groen",
        "default": "#66AA44"
      },
      {
        "type": "color",
        "id": "color_brand_orange",
        "label": "Oranje",
        "default": "#F7A048"
      },
      {
        "type": "color",
        "id": "color_brand_yellow",
        "label": "Geel accent",
        "default": "#FFE071"
      },
      {
        "type": "color",
        "id": "color_ink",
        "label": "Koppen",
        "default": "#3d2209"
      },
      {
        "type": "color",
        "id": "color_body",
        "label": "Bodytekst",
        "default": "#603A15"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Subtekst",
        "default": "#A88259"
      },
      {
        "type": "color",
        "id": "color_cream",
        "label": "Achtergrond creme",
        "default": "#F8EFDD"
      },
      {
        "type": "color",
        "id": "color_line",
        "label": "Lijnkleur",
        "default": "#EDE2C9"
      }
