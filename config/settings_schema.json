[
  {
    "name": "theme_info",
    "theme_name": "Kwispelbox KB-v3",
    "theme_version": "3.0.0",
    "theme_author": "POASIFY",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Indeling",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Paginabreedte",
        "options": [
          {
            "value": "90rem",
            "label": "Smal"
          },
          {
            "value": "110rem",
            "label": "Breed"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Paginamarge",
        "default": 20
      }
    ]
  },
  {
    "name": "Merkkleur",
    "settings": [
      {
        "type": "color",
        "id": "color_brand_pink",
        "label": "Roze accent",
